<%- include('../partials/head', {title: 'Salary Details'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-employee') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title">Salary Details</div>
          <div class="page-subtitle">Payroll breakdown & payslip download</div>
        </div>
      </div>
      <div class="header-actions">
      </div>
    </header>
    <div class="page-body">
      <!-- Current Month Hero -->
      <div class="salary-hero" id="salary-hero" style="display:none;">
        <div style="position:relative;z-index:1;">
          <div class="salary-hero-label">Net Salary</div>
          <div class="salary-hero-amount" id="hero-net">₹0</div>
          <div class="salary-hero-month" id="hero-month">—</div>
          <div style="display:flex;gap:12px;margin-top:16px;flex-wrap:wrap;">
            <div style="background:rgba(255,255,255,0.12);border-radius:10px;padding:10px 16px;">
              <div style="font-size:11px;color:rgba(255,255,255,0.6);">Present / Working</div>
              <div style="font-size:18px;font-weight:800;" id="hero-days">—</div>
            </div>
            <div style="background:rgba(255,255,255,0.12);border-radius:10px;padding:10px 16px;">
              <div style="font-size:11px;color:rgba(255,255,255,0.6);">Actual Hours</div>
              <div style="font-size:18px;font-weight:800;" id="hero-hrs">—</div>
            </div>
            <div style="background:rgba(255,255,255,0.12);border-radius:10px;padding:10px 16px;">
              <div style="font-size:11px;color:rgba(255,255,255,0.6);">Status</div>
              <div style="font-size:18px;font-weight:800;text-transform:uppercase;" id="hero-status">—</div>
            </div>
          </div>
          <div style="display:flex;gap:8px;margin-top:16px;" id="hero-dl-btns">
            <button class="btn" style="background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.25);" onclick="viewCurrent()"><i class="bx bx-show"></i> View Payslip</button>
            <button class="btn" style="background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.25);" onclick="downloadCurrent()"><i class="bx bx-download"></i> Download</button>
          </div>
        </div>
      </div>

      <!-- Salary Breakdown -->
      <div class="salary-breakdown-grid" id="breakdown-grid" style="display:none;">
        <div class="breakdown-card">
          <div class="breakdown-title"><div class="breakdown-title-dot" style="background:#111;"></div> Earnings</div>
          <div class="breakdown-item"><span class="breakdown-item-label">Base Salary</span><span class="breakdown-item-value" id="bd-base">₹0</span></div>
          <div class="breakdown-item"><span class="breakdown-item-label">Allowances</span><span class="breakdown-item-value green" id="bd-allow">+₹0</span></div>
          <div class="breakdown-item"><span class="breakdown-item-label">Overtime Pay</span><span class="breakdown-item-value green" id="bd-otpay">+₹0</span></div>
          <div class="breakdown-total"><span>Gross Earnings</span><span id="bd-gross">₹0</span></div>
        </div>
        <div class="breakdown-card">
          <div class="breakdown-title"><div class="breakdown-title-dot" style="background:#dc2626;"></div> Deductions</div>
          <div class="breakdown-item"><span class="breakdown-item-label">Other Deductions</span><span class="breakdown-item-value red" id="bd-ded">-₹0</span></div>
          <div class="breakdown-item"><span class="breakdown-item-label">Absent Deduction</span><span class="breakdown-item-value red" id="bd-absent">-₹0</span></div>
          <div class="breakdown-total"><span>Total Deductions</span><span id="bd-total-ded" style="color:#dc2626;">₹0</span></div>
        </div>
        <div class="breakdown-card">
          <div class="breakdown-title"><div class="breakdown-title-dot" style="background:#374151;"></div> Attendance</div>
          <div class="breakdown-item"><span class="breakdown-item-label">Working Days</span><span class="breakdown-item-value" id="bd-workdays">0</span></div>
          <div class="breakdown-item"><span class="breakdown-item-label">Present Days</span><span class="breakdown-item-value" id="bd-present">0</span></div>
          <div class="breakdown-item"><span class="breakdown-item-label">Absent Days</span><span class="breakdown-item-value red" id="bd-absentd">0</span></div>
          <div class="breakdown-item"><span class="breakdown-item-label">Overtime Hours</span><span class="breakdown-item-value" id="bd-othrs">0h</span></div>
          <div class="breakdown-item" style="margin-top:8px;"><span class="breakdown-item-label">Attendance Rate</span><span class="breakdown-item-value" id="bd-rate">0%</span></div>
          <div class="progress-bar-wrap mt-2"><div class="progress-bar-fill" id="bd-bar" style="width:0%"></div></div>
        </div>
        <div class="breakdown-card" style="background:linear-gradient(135deg,#111,#333);color:white;border:none;">
          <div class="breakdown-title" style="color:rgba(255,255,255,0.6);"><div class="breakdown-title-dot" style="background:white;"></div> Summary</div>
          <div style="text-align:center;padding:20px 0;">
            <div style="font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:8px;">Take Home Pay</div>
            <div style="font-size:42px;font-weight:900;letter-spacing:-2px;" id="bd-net">₹0</div>
            <div style="font-size:12px;color:rgba(255,255,255,0.5);margin-top:4px;" id="bd-period">—</div>
          </div>
          <div style="border-top:1px solid rgba(255,255,255,0.15);padding-top:12px;margin-top:8px;">
            <div class="breakdown-item" style="border:none;color:rgba(255,255,255,0.7);"><span>Hourly Rate</span><span id="bd-hourly" style="color:white;font-weight:700;">₹0/hr</span></div>
          </div>
        </div>
      </div>

      <!-- Salary History Cards -->
      <div style="margin-bottom:8px;"><div class="card-title" style="padding:0 4px;">Salary History</div><div class="card-subtitle" style="padding:0 4px;">All your payroll records</div></div>
      <div id="salary-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
        <div style="grid-column:1/-1;display:flex;justify-content:center;padding:40px;"><span class="spinner"></span></div>
      </div>
    </div>
  </div>
</div>

<script src="/js/api.js"></script>
<script>
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
let allSalaries = [];
let currentSalary = null;

function fmt(n) { return fmtCurrency(n); }

function showBreakdown(s) {
  currentSalary = s;
  const rate = s.expectedHours > 0 ? Math.min(100, Math.round((s.actualHours / s.expectedHours) * 100)) : 0;
  const hourly = s.expectedHours > 0 ? (s.baseSalary / s.expectedHours).toFixed(2) : 0;

  document.getElementById('salary-hero').style.display = '';
  document.getElementById('breakdown-grid').style.display = '';

  document.getElementById('hero-net').textContent = fmt(s.netSalary);
  document.getElementById('hero-month').textContent = MONTHS[s.month-1] + ' ' + s.year;
  document.getElementById('hero-days').textContent = (s.presentDays||0) + '/' + (s.totalWorkDays||0);
  document.getElementById('hero-hrs').textContent = (s.actualHours||0) + 'h';
  document.getElementById('hero-status').textContent = s.status;
  document.getElementById('hero-dl-btns').style.display = s.status === 'paid' || s.status === 'finalized' ? '' : 'none';

  document.getElementById('bd-base').textContent = fmt(s.baseSalary);
  document.getElementById('bd-allow').textContent = '+' + fmt(s.allowances);
  document.getElementById('bd-otpay').textContent = '+' + fmt(s.overtimePay);
  document.getElementById('bd-gross').textContent = fmt(s.grossSalary);

  document.getElementById('bd-ded').textContent = '-' + fmt(s.deductions);
  document.getElementById('bd-absent').textContent = '-' + fmt(s.absentDeduction);
  document.getElementById('bd-total-ded').textContent = '-' + fmt(s.deductions + (s.absentDeduction||0));

  document.getElementById('bd-workdays').textContent = s.totalWorkDays || 0;
  document.getElementById('bd-present').textContent = s.presentDays || 0;
  document.getElementById('bd-absentd').textContent = s.absentDays || 0;
  document.getElementById('bd-othrs').textContent = (s.overtime||0) + 'h';
  document.getElementById('bd-rate').textContent = rate + '%';
  document.getElementById('bd-bar').style.width = rate + '%';
  document.getElementById('bd-bar').className = 'progress-bar-fill' + (rate >= 90 ? ' green' : rate >= 70 ? '' : ' red');

  document.getElementById('bd-net').textContent = fmt(s.netSalary);
  document.getElementById('bd-period').textContent = MONTHS[s.month-1] + ' ' + s.year;
  document.getElementById('bd-hourly').textContent = '₹' + hourly + '/hr';
}

async function loadSalary() {
  try {
    const salaries = await api('GET','/salary');
    allSalaries = salaries;
    const grid = document.getElementById('salary-grid');

    if (!salaries.length) {
      grid.innerHTML = '<div style="grid-column:1/-1;"><div class="empty-state"><div class="empty-icon"><i class="bx bxs-wallet"></i></div><h3>No salary records yet</h3><p>Your payroll will appear here once processed</p></div></div>';
      return;
    }

    // Show latest
    const now = new Date();
    const latest = salaries.find(s => s.month === now.getMonth()+1 && s.year === now.getFullYear()) || salaries[0];
    if (latest) showBreakdown(latest);

    grid.innerHTML = salaries.map(s => {
      const sc = s.status==='paid'?'#22c55e':s.status==='finalized'?'#3b82f6':'#f59e0b';
      const sb = s.status==='paid'?'#dcfce7':s.status==='finalized'?'#dbeafe':'#fef3c7';
      const canDl = s.status==='paid'||s.status==='finalized';
      return `<div onclick="showBreakdown(allSalaries.find(x=>x.id===${s.id}))" style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;cursor:pointer;display:flex;flex-direction:column;gap:12px;transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.boxShadow=''">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <div style="font-weight:700;font-size:14px;color:var(--text-primary);">${MONTHS[s.month-1]} ${s.year}</div>
          <span style="font-size:11px;font-weight:700;background:${sb};color:${sc};border-radius:20px;padding:3px 10px;text-transform:capitalize;">${s.status}</span>
        </div>
        <div style="text-align:center;background:linear-gradient(135deg,var(--accent),#7c3aed);border-radius:12px;padding:14px;">
          <div style="font-size:10px;color:rgba(255,255,255,0.7);margin-bottom:3px;">Net Salary</div>
          <div style="font-size:26px;font-weight:900;color:white;">${fmt(s.netSalary)}</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
          <div style="background:var(--bg-input);border-radius:8px;padding:8px;">
            <div style="font-size:10px;color:var(--text-muted);">Hours</div>
            <div style="font-size:12px;font-weight:700;">${s.actualHours}/${s.expectedHours}h</div>
          </div>
          <div style="background:var(--bg-input);border-radius:8px;padding:8px;">
            <div style="font-size:10px;color:var(--text-muted);">Days</div>
            <div style="font-size:12px;font-weight:700;">${s.presentDays||0}/${s.totalWorkDays||0}d</div>
          </div>
        </div>
        ${canDl?`<div style="display:flex;gap:6px;" onclick="event.stopPropagation()">
          <button class="btn btn-ghost btn-sm" onclick="downloadPayslip(${s.id},'view')" style="flex:1;justify-content:center;"><i class="bx bx-show"></i> View</button>
          <button class="btn btn-ghost btn-sm" onclick="downloadPayslip(${s.id},'download')" style="flex:1;justify-content:center;"><i class="bx bx-download"></i> Download</button>
        </div>`:''}
      </div>`;
    }).join('');
  } catch(e) { toast(e.message,'error'); }
}

function downloadPayslip(id, mode) { mode = mode || "download";
  const token = getToken();
  window.open('/api/salary/'+id+'/payslip?token='+token+'&mode='+mode, '_blank');
}

function downloadCurrent() {
  if (currentSalary) downloadPayslip(currentSalary.id, 'download');
}

function viewCurrent() {
  if (currentSalary) downloadPayslip(currentSalary.id, 'view');
}

loadSalary();
</script>
</body></html>
