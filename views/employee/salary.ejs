<%- include('../partials/head', {title: 'Salary Details'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-employee') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title">Salary Details</div>
          <div class="page-subtitle">Payroll breakdown & payslip download</div>
        </div>
      </div>
    </header>
    <div class="page-body">

      <!-- Hero -->
      <div class="salary-hero" id="salary-hero" style="display:none;">
        <div style="position:relative;z-index:1;">
          <div class="salary-hero-label">Net Take Home</div>
          <div class="salary-hero-amount" id="hero-net">₹0</div>
          <div class="salary-hero-month" id="hero-month">—</div>
          <div style="display:flex;gap:12px;margin-top:16px;flex-wrap:wrap;">
            <div style="background:rgba(255,255,255,0.12);border-radius:10px;padding:10px 16px;">
              <div style="font-size:11px;color:rgba(255,255,255,0.6);">CTC</div>
              <div style="font-size:18px;font-weight:800;" id="hero-ctc">—</div>
            </div>
            <div style="background:rgba(255,255,255,0.12);border-radius:10px;padding:10px 16px;">
              <div style="font-size:11px;color:rgba(255,255,255,0.6);">Days Worked</div>
              <div style="font-size:18px;font-weight:800;" id="hero-days">—</div>
            </div>
            <div style="background:rgba(255,255,255,0.12);border-radius:10px;padding:10px 16px;">
              <div style="font-size:11px;color:rgba(255,255,255,0.6);">Status</div>
              <div style="font-size:18px;font-weight:800;text-transform:uppercase;" id="hero-status">—</div>
            </div>
          </div>
          <div style="display:flex;gap:8px;margin-top:16px;" id="hero-dl-btns">
            <button class="btn" style="background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.25);" onclick="viewCurrent()"><i class="bx bx-show"></i> View Payslip</button>
            <button class="btn" style="background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.25);" onclick="downloadCurrent()"><i class="bx bx-download"></i> Download</button>
          </div>
        </div>
      </div>

      <!-- Salary Breakdown -->
      <div id="breakdown-grid" style="display:none;">

        <!-- Attendance row -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px;" id="att-row">
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:14px;text-align:center;">
            <div style="font-size:11px;color:var(--text-muted);">Total Days</div>
            <div style="font-size:22px;font-weight:800;" id="bd-caldays">0</div>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:14px;text-align:center;">
            <div style="font-size:11px;color:var(--text-muted);">Leave Taken</div>
            <div style="font-size:22px;font-weight:800;color:#f59e0b;" id="bd-leave">0</div>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:14px;text-align:center;">
            <div style="font-size:11px;color:var(--text-muted);">Days Worked</div>
            <div style="font-size:22px;font-weight:800;color:#22c55e;" id="bd-worked">0</div>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:14px;text-align:center;">
            <div style="font-size:11px;color:var(--text-muted);">Present Days</div>
            <div style="font-size:22px;font-weight:800;" id="bd-present">0</div>
          </div>
        </div>

        <!-- Earnings + Deductions + Net -->
        <div class="salary-breakdown-grid">
          <!-- Earnings -->
          <div class="breakdown-card">
            <div class="breakdown-title"><div class="breakdown-title-dot" style="background:#111;"></div> Earnings</div>
            <div class="breakdown-item"><span class="breakdown-item-label">Basic Salary</span><span class="breakdown-item-value" id="bd-basic">₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">DA (Dearness Allow.)</span><span class="breakdown-item-value green" id="bd-da">+₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">HRA</span><span class="breakdown-item-value green" id="bd-hra">+₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">Conveyance</span><span class="breakdown-item-value green" id="bd-conv">+₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">Medical Expenses</span><span class="breakdown-item-value green" id="bd-med">+₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">Special Allowance</span><span class="breakdown-item-value green" id="bd-special">+₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">Bonus</span><span class="breakdown-item-value green" id="bd-bonus">+₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">Travel Allow. (TA)</span><span class="breakdown-item-value green" id="bd-ta">+₹0</span></div>
            <div class="breakdown-total"><span>Gross Salary</span><span id="bd-gross">₹0</span></div>
          </div>

          <!-- Deductions -->
          <div class="breakdown-card">
            <div class="breakdown-title"><div class="breakdown-title-dot" style="background:#dc2626;"></div> Deductions</div>
            <div class="breakdown-item"><span class="breakdown-item-label">PF Contribution</span><span class="breakdown-item-value red" id="bd-pf">-₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">Profession Tax</span><span class="breakdown-item-value red" id="bd-ptax">-₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">TDS</span><span class="breakdown-item-value red" id="bd-tds">-₹0</span></div>
            <div class="breakdown-item"><span class="breakdown-item-label">Salary Advance</span><span class="breakdown-item-value red" id="bd-advance">-₹0</span></div>
            <div class="breakdown-total" style="color:#dc2626;"><span>Total Deductions</span><span id="bd-total-ded">₹0</span></div>
          </div>

          <!-- Summary -->
          <div class="breakdown-card" style="background:linear-gradient(135deg,#111,#333);color:white;border:none;">
            <div class="breakdown-title" style="color:rgba(255,255,255,0.6);"><div class="breakdown-title-dot" style="background:white;"></div> Summary</div>
            <div style="text-align:center;padding:20px 0;">
              <div style="font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:8px;">Take Home Pay</div>
              <div style="font-size:40px;font-weight:900;letter-spacing:-2px;" id="bd-net">₹0</div>
              <div style="font-size:12px;color:rgba(255,255,255,0.5);margin-top:4px;" id="bd-period">—</div>
            </div>
            <div style="border-top:1px solid rgba(255,255,255,0.15);padding-top:12px;margin-top:8px;">
              <div class="breakdown-item" style="border:none;color:rgba(255,255,255,0.7);">
                <span>CTC</span><span style="color:white;font-weight:700;" id="bd-ctc">₹0</span>
              </div>
              <div class="breakdown-item" style="border:none;color:rgba(255,255,255,0.7);">
                <span>DA Rate</span><span style="color:white;font-weight:700;">10% of prop. CTC</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Salary History -->
      <div style="margin-bottom:8px;"><div class="card-title" style="padding:0 4px;">Salary History</div><div class="card-subtitle" style="padding:0 4px;">All your payroll records</div></div>
      <div id="salary-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
        <div style="grid-column:1/-1;display:flex;justify-content:center;padding:40px;"><span class="spinner"></span></div>
      </div>
    </div>
  </div>
</div>

<script src="/js/api.js"></script>
<script>
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
let allSalaries = [], currentSalary = null;

function fmt(n) { return fmtCurrency(n); }
function fmtPlus(n) { return '+' + fmt(n); }
function fmtMinus(n) { return '-' + fmt(n); }

function showBreakdown(s) {
  currentSalary = s;
  const calDays  = new Date(s.year, s.month, 0).getDate();
  const worked   = Math.max(0, calDays - (s.leaveTaken || 0));

  document.getElementById('salary-hero').style.display  = '';
  document.getElementById('breakdown-grid').style.display = '';

  document.getElementById('hero-net').innerHTML = fmt(s.netSalary);
  document.getElementById('hero-month').textContent  = MONTHS[s.month-1] + ' ' + s.year;
  document.getElementById('hero-ctc').innerHTML = fmt(s.baseSalary);
  document.getElementById('hero-days').textContent   = worked + '/' + calDays + 'd';
  document.getElementById('hero-status').textContent = s.status;
  document.getElementById('hero-dl-btns').style.display = (s.status==='paid'||s.status==='finalized') ? '' : 'none';

  // Attendance
  document.getElementById('bd-caldays').textContent = calDays;
  document.getElementById('bd-leave').textContent   = s.leaveTaken || 0;
  document.getElementById('bd-worked').textContent  = worked;
  document.getElementById('bd-present').textContent = s.presentDays || 0;

  // Earnings
  document.getElementById('bd-basic').innerHTML = fmt(s.basicSalary);
  document.getElementById('bd-da').textContent      = fmtPlus(s.da);
  document.getElementById('bd-hra').textContent     = fmtPlus(s.hra);
  document.getElementById('bd-conv').textContent    = fmtPlus(s.conveyanceWorking);
  document.getElementById('bd-med').textContent     = fmtPlus(s.medicalWorking);
  document.getElementById('bd-special').textContent = fmtPlus(s.specialAllowance);
  document.getElementById('bd-bonus').textContent   = fmtPlus(s.bonus);
  document.getElementById('bd-ta').textContent      = fmtPlus(s.ta);
  document.getElementById('bd-gross').innerHTML = fmt(s.grossSalary);

  // Deductions
  document.getElementById('bd-pf').textContent      = fmtMinus(s.pfContribution);
  document.getElementById('bd-ptax').textContent    = fmtMinus(s.professionTax);
  document.getElementById('bd-tds').textContent     = fmtMinus(s.tds);
  document.getElementById('bd-advance').textContent = fmtMinus(s.salaryAdvance);
  document.getElementById('bd-total-ded').innerHTML = '-' + fmt(s.deductions);

  // Summary
  document.getElementById('bd-net').innerHTML = fmt(s.netSalary);
  document.getElementById('bd-period').textContent = MONTHS[s.month-1] + ' ' + s.year;
  document.getElementById('bd-ctc').innerHTML = fmt(s.baseSalary);
}

async function loadSalary() {
  try {
    const salaries = await api('GET', '/salary');
    allSalaries = salaries;
    const grid = document.getElementById('salary-grid');

    if (!salaries.length) {
      grid.innerHTML = '<div style="grid-column:1/-1;"><div class="empty-state"><div class="empty-icon"><i class="bx bxs-wallet"></i></div><h3>No salary records yet</h3><p>Your payroll will appear here once processed</p></div></div>';
      return;
    }

    const now    = new Date();
    const latest = salaries.find(s => s.month===now.getMonth()+1 && s.year===now.getFullYear()) || salaries[0];
    if (latest) showBreakdown(latest);

    grid.innerHTML = salaries.map(s => {
      const sc    = s.status==='paid'?'#22c55e':s.status==='finalized'?'#3b82f6':'#f59e0b';
      const sb    = s.status==='paid'?'#dcfce7':s.status==='finalized'?'#dbeafe':'#fef3c7';
      const canDl = s.status==='paid' || s.status==='finalized';
      const calDays = new Date(s.year, s.month, 0).getDate();
      const worked  = Math.max(0, calDays - (s.leaveTaken || 0));
      return `<div onclick="showBreakdown(allSalaries.find(x=>x.id===${s.id}))" style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;cursor:pointer;display:flex;flex-direction:column;gap:12px;transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.boxShadow=''">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <div style="font-weight:700;font-size:14px;color:var(--text-primary);">${MONTHS[s.month-1]} ${s.year}</div>
          <span style="font-size:11px;font-weight:700;background:${sb};color:${sc};border-radius:20px;padding:3px 10px;text-transform:capitalize;">${s.status}</span>
        </div>
        <div style="text-align:center;background:linear-gradient(135deg,var(--accent),#7c3aed);border-radius:12px;padding:14px;">
          <div style="font-size:10px;color:rgba(255,255,255,0.7);margin-bottom:3px;">Net Salary</div>
          <div style="font-size:26px;font-weight:900;color:white;">${fmt(s.netSalary)}</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
          <div style="background:var(--bg-input);border-radius:8px;padding:8px;">
            <div style="font-size:10px;color:var(--text-muted);">Gross</div>
            <div style="font-size:12px;font-weight:700;">${fmt(s.grossSalary)}</div>
          </div>
          <div style="background:var(--bg-input);border-radius:8px;padding:8px;">
            <div style="font-size:10px;color:var(--text-muted);">Days</div>
            <div style="font-size:12px;font-weight:700;">${worked}/${calDays}d</div>
          </div>
        </div>
        ${canDl?`<div style="display:flex;gap:6px;" onclick="event.stopPropagation()">
          <button class="btn btn-ghost btn-sm" onclick="dlPayslip(${s.id},'view')" style="flex:1;justify-content:center;"><i class="bx bx-show"></i> View</button>
          <button class="btn btn-ghost btn-sm" onclick="dlPayslip(${s.id},'download')" style="flex:1;justify-content:center;"><i class="bx bx-download"></i> Download</button>
        </div>`:''}
      </div>`;
    }).join('');
  } catch(e) { toast(e.message, 'error'); }
}

function dlPayslip(id, mode) {
  window.open('/api/salary/' + id + '/payslip?token=' + getToken() + '&mode=' + (mode||'download'), '_blank');
}
function downloadCurrent() { if (currentSalary) dlPayslip(currentSalary.id, 'download'); }
function viewCurrent()     { if (currentSalary) dlPayslip(currentSalary.id, 'view'); }

loadSalary();
</script>
</body></html>
