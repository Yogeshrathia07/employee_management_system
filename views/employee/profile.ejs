<%- include('../partials/head', {title: 'Profile'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-employee') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title">My Profile</div>
          <div class="page-subtitle">Your personal information and payroll</div>
        </div>
      </div>
      <div class="header-actions"></div>
    </header>

    <div class="page-body admin-employees-page employee-shared-page">
      <div class="employee-directory-shell">
      <div class="admin-toolbar" style="margin-bottom:20px;justify-content:flex-end;">
        <button class="btn btn-ghost btn-sm" onclick="openModal('pwd-modal')"><i class="bx bx-lock-alt"></i> Change Password</button>
        <button class="btn btn-primary btn-sm" onclick="openModal('edit-modal')"><i class="bx bx-edit"></i> Edit Profile</button>
      </div>

      <!-- ── TOP HERO BANNER ── -->
      <div class="prof-hero">
        <div class="prof-hero-avatar-wrap">
          <div class="prof-hero-avatar" id="profile-avatar">U</div>
          <button class="prof-avatar-upload-btn" onclick="document.getElementById('photo-input').click()" title="Upload photo">
            <i class="bx bx-camera"></i>
          </button>
          <input type="file" id="photo-input" style="display:none;" accept=".jpg,.jpeg,.png,.webp" onchange="uploadPhoto()">
        </div>
        <div class="prof-hero-info">
          <div class="prof-hero-name" id="profile-name">Loading…</div>
          <div class="prof-hero-sub" id="profile-job">—</div>
          <div class="prof-hero-badges">
            <span class="prof-badge-status"><span class="prof-badge-dot"></span>Active</span>
            <span class="prof-badge-code" id="emp-code-badge" style="display:none;"></span>
          </div>
        </div>
        <div class="prof-hero-record">
          <div class="prof-hero-record-head">
            <div>
              <div class="card-title">Employment Details</div>
            </div>
            <span class="badge badge-approved" id="verification-badge">Verified</span>
          </div>
          <div class="prof-hero-record-grid">
            <div>
              <div class="detail-label">Employee Code</div>
              <div class="detail-value" id="detail-empcode">—</div>
            </div>
            <div>
              <div class="detail-label">Department</div>
              <div class="detail-value" id="detail-dept">—</div>
            </div>
          </div>
        </div>
        <div class="prof-hero-actions">
          <button class="btn btn-ghost btn-sm" onclick="resetPhoto()" id="reset-photo-btn" style="display:none;">
            <i class="bx bx-reset"></i> Default Avatar
          </button>
        </div>
      </div>

      <!-- ── TAB NAV ── -->
      <div class="tabs" style="margin-bottom:20px;border-bottom:2px solid var(--border-subtle);">
        <button class="tab-btn active" id="tab-profile" onclick="switchTab('profile')">
          <i class="bx bxs-user-circle" style="margin-right:5px;"></i>Profile
        </button>
        <button class="tab-btn" id="tab-salary" onclick="switchTab('salary')">
          <i class="bx bxs-wallet" style="margin-right:5px;"></i>My Salary
        </button>
      </div>

      <!-- ══════════ PROFILE TAB ══════════ -->
      <div id="panel-profile">

        <div class="prof-stat-grid">
          <div class="prof-stat-box">
            <div class="prof-stat-icon" style="background:#eef0fb;color:#5b6abf;"><i class="bx bxs-envelope"></i></div>
            <div class="prof-stat-label">Email</div>
            <div class="prof-stat-value" id="profile-email">—</div>
          </div>
          <div class="prof-stat-box">
            <div class="prof-stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="bx bxs-phone"></i></div>
            <div class="prof-stat-label">Phone</div>
            <div class="prof-stat-value" id="profile-phone">—</div>
          </div>
          <div class="prof-stat-box">
            <div class="prof-stat-icon" style="background:#dbeafe;color:#2563eb;"><i class="bx bxs-user-circle"></i></div>
            <div class="prof-stat-label">Role</div>
            <div class="prof-stat-value" id="profile-role">—</div>
          </div>
          <div class="prof-stat-box">
            <div class="prof-stat-icon" style="background:#fce7f3;color:#be185d;"><i class="bx bxs-user-detail"></i></div>
            <div class="prof-stat-label">Gender</div>
            <div class="prof-stat-value" id="profile-gender">—</div>
          </div>
        </div>

      </div><!-- end panel-profile -->

      <!-- ══════════ SALARY TAB ══════════ -->
      <div id="panel-salary" style="display:none;">
        <div id="salary-loading" style="text-align:center;padding:40px;"><span class="spinner"></span></div>

        <!-- History Table -->
        <div class="card">
          <div class="card-header">
            <div><div class="card-title">Salary History</div><div class="card-subtitle">All your payroll records</div></div>
          </div>
          <div style="padding:16px 16px 0;">
            <div style="display:flex;gap:10px;flex-wrap:wrap;">
              <select id="salary-filter-month" class="form-control" style="max-width:180px;" onchange="renderSalaryHistory()">
                <option value="">All Months</option>
              </select>
              <select id="salary-filter-year" class="form-control" style="max-width:160px;" onchange="renderSalaryHistory()">
                <option value="">All Years</option>
              </select>
              <select id="salary-filter-status" class="form-control" style="max-width:180px;" onchange="renderSalaryHistory()">
                <option value="">All Status</option>
                <option value="draft">Draft</option>
                <option value="frozen">Frozen</option>
                <option value="finalized">Finalized</option>
                <option value="paid">Paid</option>
              </select>
              <button class="btn btn-ghost" onclick="clearSalaryFilters()">Clear</button>
            </div>
          </div>
          <div style="padding:12px 0 0;">
            <div class="table-wrapper">
              <table>
                <thead><tr><th>Period</th><th>Base</th><th>Gross</th><th>Deductions</th><th>Net Salary</th><th>Hours</th><th>Days</th><th>Status</th><th>Payslip</th></tr></thead>
                <tbody id="salary-tbody"><tr><td colspan="9" style="text-align:center;padding:40px"><span class="spinner"></span></td></tr></tbody>
              </table>
            </div>
          </div>
        </div>
      </div><!-- end salary panel -->

      </div>
    </div><!-- end page-body -->
  </div><!-- end main-content -->
</div><!-- end app-layout -->

<!-- Edit Profile Modal -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal">
    <div class="modal-header"><span class="modal-title">Update Profile</span><button class="modal-close" onclick="closeModal('edit-modal')">×</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Full Name</label><input type="text" id="edit-name" class="form-control"></div>
      <div class="form-group"><label class="form-label">Phone</label><input type="text" id="edit-phone" class="form-control" placeholder="+91 98765 43210"></div>
      <div class="form-group"><label class="form-label">Gender</label><select id="edit-gender" class="form-control"><option value="unspecified">Select gender</option><option value="male">Male</option><option value="female">Female</option></select></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('edit-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveProfile()">Save Changes</button>
    </div>
  </div>
</div>

<!-- Change Password Modal -->
<div class="modal-overlay" id="pwd-modal">
  <div class="modal" style="max-width:440px">
    <div class="modal-header"><span class="modal-title">Change Password</span><button class="modal-close" onclick="closeModal('pwd-modal')">×</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Current Password</label><input type="password" id="pwd-current" class="form-control"></div>
      <div class="form-group"><label class="form-label">New Password</label><input type="password" id="pwd-new" class="form-control" placeholder="Min 8 chars, upper, lower, number, special"></div>
      <div class="form-group"><label class="form-label">Confirm New Password</label><input type="password" id="pwd-confirm" class="form-control"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('pwd-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="changePassword()"><i class="bx bx-lock-alt"></i> Change</button>
    </div>
  </div>
</div>

<style>
/* ── Profile Hero Banner ── */
.prof-hero {
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 24px 28px;
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}
.prof-hero-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.prof-hero-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, #111111, #000000);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 800;
  color: white;
  overflow: hidden;
  border: 3px solid var(--border);
}
.prof-avatar-upload-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 26px;
  height: 26px;
  background: var(--accent);
  border: 2px solid white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: white;
  font-size: 12px;
  transition: var(--transition);
}
.prof-avatar-upload-btn:hover { background: var(--accent-dark); }

.prof-hero-info { flex: 1; min-width: 150px; }
.prof-hero-name { font-size: 22px; font-weight: 800; color: var(--text-primary); letter-spacing: -0.4px; }
.prof-hero-sub  { font-size: 13px; color: var(--text-muted); margin-top: 3px; }
.prof-hero-badges { display: flex; align-items: center; gap: 8px; margin-top: 10px; flex-wrap: wrap; }

.prof-badge-status {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 12px; background: var(--success-light);
  border-radius: 20px; font-size: 11px; font-weight: 700; color: #16a34a;
}
.prof-badge-dot { width: 6px; height: 6px; background: #22c55e; border-radius: 50%; animation: pulse 2s infinite; }
.prof-badge-code {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 12px; background: var(--accent-light);
  border: 1px solid rgba(91,106,191,0.2); border-radius: 20px;
  font-size: 11px; font-weight: 700; color: var(--accent-dark);
}

/* ── Small Square Stat Boxes ── */
.prof-stat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.prof-stat-box {
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow);
  padding: 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: var(--transition);
  min-height: 110px;
  max-width: 100%;
}
.prof-stat-box:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}
.prof-stat-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  flex-shrink: 0;
}
.prof-stat-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.4px;
}
.prof-stat-value {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

@media(max-width:1100px) {
  .prof-stat-grid { grid-template-columns: repeat(4, 1fr); }
}
@media(max-width:768px) {
  .prof-stat-grid { grid-template-columns: repeat(2, 1fr); }
  .prof-stat-box { padding: 13px 14px; min-height: 90px; }
}
@media(max-width:400px) {
  .prof-stat-grid { grid-template-columns: 1fr 1fr; }
}
</style>

<script src="/js/api.js"></script>
<script>
// ─── TAB SWITCHER ────────────────────────────────────────────
function switchTab(tab) {
  document.getElementById('panel-profile').style.display = tab === 'profile' ? '' : 'none';
  document.getElementById('panel-salary').style.display  = tab === 'salary'  ? '' : 'none';
  document.getElementById('tab-profile').classList.toggle('active', tab === 'profile');
  document.getElementById('tab-salary').classList.toggle('active',  tab === 'salary');
  if (tab === 'salary' && !salaryLoaded) loadSalary();
}

window.addEventListener('DOMContentLoaded', function() {
  if (window.location.hash === '#salary') switchTab('salary');
});

// ─── PROFILE ─────────────────────────────────────────────────
async function loadProfile() {
  try {
    var user = await api('GET', '/users/me');
    var avatarEl = document.getElementById('profile-avatar');
    if (user.profilePhoto) {
      avatarEl.innerHTML = '<img src="/api/users/'+user.id+'/photo?t='+Date.now()+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">';
      document.getElementById('reset-photo-btn').style.display = '';
    } else {
      avatarEl.textContent = (user.name || 'U').charAt(0).toUpperCase();
      document.getElementById('reset-photo-btn').style.display = 'none';
    }
    document.getElementById('profile-name').textContent    = user.name;
    document.getElementById('profile-job').textContent     = (user.position ? user.position + ' · ' : '') + (user.department || user.role);
    function sv(id, val) { var e = document.getElementById(id); if(e){ e.textContent = val; e.title = val; } }
    sv('profile-email',    user.email);
    sv('profile-phone',    user.phone || 'Not set');
    sv('profile-dept',     user.department || 'Not assigned');
    sv('profile-position', user.position || '—');
    sv('profile-role',     user.role.charAt(0).toUpperCase() + user.role.slice(1));
    document.getElementById('detail-empcode').textContent  = user.employeeCode || ('#EMP-' + String(user.id).padStart(4,'0'));
    sv('detail-company',   user.company?.name || '—');
    document.getElementById('detail-dept').textContent     = user.department || '—';
    sv('detail-joined',    fmtDate(user.createdAt));

    if (user.employeeCode) {
      var badge = document.getElementById('emp-code-badge');
      badge.textContent = user.employeeCode;
      badge.style.display = 'inline-flex';
    }

    // Verification badge
    var vb = document.getElementById('verification-badge');
    if (user.verificationStatus === 'verified') {
      vb.className = 'badge badge-approved'; vb.textContent = 'Verified';
    } else if (user.verificationStatus === 'docs_submitted') {
      vb.className = 'badge badge-pending'; vb.textContent = 'Under Review';
    } else if (user.verificationStatus === 'pending_docs') {
      vb.className = 'badge badge-inactive'; vb.textContent = 'Docs Pending';
    } else {
      vb.style.display = 'none';
    }

    document.getElementById('edit-name').value  = user.name;
    document.getElementById('edit-phone').value = user.phone || '';
    document.getElementById('edit-gender').value = user.gender || 'unspecified';
  } catch(e) { toast(e.message, 'error'); }
}

async function saveProfile() {
  try {
    await api('PUT', '/users/me/profile', {
      name: document.getElementById('edit-name').value,
      phone: document.getElementById('edit-phone').value,
      gender: document.getElementById('edit-gender').value,
    });
    toast('Profile updated!', 'success');
    closeModal('edit-modal');
    loadProfile();
  } catch(e) { toast(e.message, 'error'); }
}

async function changePassword() {
  var cur = document.getElementById('pwd-current').value;
  var np  = document.getElementById('pwd-new').value;
  var cf  = document.getElementById('pwd-confirm').value;
  if (!cur || !np) return toast('All fields required', 'error');
  if (!/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&#^()_\-+=])[A-Za-z\d@$!%*?&#^()_\-+=]{8,}$/.test(np)) return toast('Password must be at least 8 characters with uppercase, lowercase, number and special character', 'error');
  if (np !== cf) return toast('Passwords do not match', 'error');
  try {
    await api('POST', '/users/change-password', { currentPassword: cur, newPassword: np });
    toast('Password changed!', 'success');
    closeModal('pwd-modal');
    ['pwd-current','pwd-new','pwd-confirm'].forEach(function(id){ document.getElementById(id).value=''; });
  } catch(e) { toast(e.message, 'error'); }
}

async function uploadPhoto() {
  var fi = document.getElementById('photo-input');
  if (!fi.files.length) return;
  var fd = new FormData();
  fd.append('photo', fi.files[0]);
  try {
    var token = getToken();
    var res = await fetch('/api/users/me/photo', { method:'POST', headers:{'Authorization':'Bearer '+token}, body:fd });
    var data = await res.json();
    if (!res.ok) throw new Error(data.message || 'Failed');
    toast('Photo updated!', 'success');
    var u = getUser(); if (u) { u.profilePhoto = data.profilePhoto; localStorage.setItem('ems_user', JSON.stringify(u)); }
    loadProfile();
  } catch(e) { toast(e.message, 'error'); }
}

async function resetPhoto() {
  if (!confirm('Reset to default avatar?')) return;
  try {
    await api('PUT', '/users/me/profile', { profilePhoto: '' });
    var u = getUser(); if (u) { u.profilePhoto = ''; localStorage.setItem('ems_user', JSON.stringify(u)); }
    toast('Photo reset to default', 'success');
    loadProfile();
  } catch(e) { toast(e.message, 'error'); }
}

// ─── SALARY ──────────────────────────────────────────────────
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
let allSalaries = [];
let salaryLoaded = false;

function fmt(n) { return fmtCurrency(n); }

function populateSalaryFilters(salaries) {
  const monthSel = document.getElementById('salary-filter-month');
  const yearSel = document.getElementById('salary-filter-year');
  if (!monthSel || !yearSel) return;

  const selectedMonth = monthSel.value;
  const selectedYear = yearSel.value;
  const years = Array.from(new Set((salaries || []).map(s => String(s.year)))).sort((a, b) => Number(b) - Number(a));

  monthSel.innerHTML = '<option value="">All Months</option>' + MONTHS.map((m, i) => `<option value="${i + 1}">${m}</option>`).join('');
  yearSel.innerHTML = '<option value="">All Years</option>' + years.map(y => `<option value="${y}">${y}</option>`).join('');

  monthSel.value = selectedMonth;
  yearSel.value = selectedYear;
}

function renderSalaryHistory() {
  const tbody = document.getElementById('salary-tbody');
  if (!tbody) return;

  const monthFilter = document.getElementById('salary-filter-month')?.value || '';
  const yearFilter = document.getElementById('salary-filter-year')?.value || '';
  const statusFilter = (document.getElementById('salary-filter-status')?.value || '').toLowerCase();

  const rows = allSalaries.filter(s => {
    if (monthFilter && String(s.month) !== String(monthFilter)) return false;
    if (yearFilter && String(s.year) !== String(yearFilter)) return false;
    if (statusFilter && String(s.status || '').toLowerCase() !== statusFilter) return false;
    return true;
  });

  if (!rows.length) {
    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:32px;color:var(--text-muted);">No salary records found for the selected filters.</td></tr>';
    return;
  }

  tbody.innerHTML = rows.map(s => `<tr>
    <td><strong>${MONTHS[s.month-1]} ${s.year}</strong></td>
    <td>${fmt(s.baseSalary)}</td>
    <td>${fmt(s.grossSalary)}</td>
    <td style="color:var(--danger)">${fmt(s.deductions || 0)}</td>
    <td><strong>${fmt(s.netSalary)}</strong></td>
    <td style="font-size:12px">${s.actualHours||0}/${s.expectedHours||0}h</td>
    <td style="font-size:12px">${s.presentDays||0}/${s.totalWorkDays||0}d</td>
    <td>${statusBadge(s.status)}</td>
    <td>${(s.status==='paid'||s.status==='finalized')?`<button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();downloadPayslip(${s.id},'view')" title="View"><i class="bx bx-show"></i></button><button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();downloadPayslip(${s.id},'download')" title="Download"><i class="bx bx-download"></i></button>`:`<span style="color:var(--text-muted);font-size:11px;">${s.status}</span>`}</td>
  </tr>`).join('');
}

function clearSalaryFilters() {
  const monthSel = document.getElementById('salary-filter-month');
  const yearSel = document.getElementById('salary-filter-year');
  const statusSel = document.getElementById('salary-filter-status');
  if (monthSel) monthSel.value = '';
  if (yearSel) yearSel.value = '';
  if (statusSel) statusSel.value = '';
  renderSalaryHistory();
}

async function loadSalary() {
  salaryLoaded = true;
  try {
    const salaries = await api('GET', '/salary');
    allSalaries = salaries;
    document.getElementById('salary-loading').style.display = 'none';
    const tbody = document.getElementById('salary-tbody');

    if (!salaries.length) {
      tbody.innerHTML = '<tr><td colspan="9"><div class="empty-state"><div class="empty-icon"><i class="bx bxs-wallet"></i></div><h3>No salary records yet</h3><p>Your payroll will appear here once processed</p></div></td></tr>';
      return;
    }

    populateSalaryFilters(salaries);
    renderSalaryHistory();
  } catch(e) { toast(e.message,'error'); }
}

function downloadPayslip(id, mode) {
  window.open('/api/salary/'+id+'/payslip?token='+getToken()+'&mode='+mode, '_blank');
}

loadProfile();
</script>
</body></html>

