<%- include('../partials/head', {title: 'My Tasks'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-employee') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title">My Tasks</div>
          <div class="page-subtitle">Tasks assigned to you by your manager</div>
        </div>
      </div>
      <div class="header-actions"></div>
    </header>
    <div class="page-body admin-employees-page employee-shared-page">
      <div class="employee-directory-shell">

        <!-- Filters -->
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px;">
          <div class="toggle-group mb-0">
            <button class="toggle-btn active" id="f-all"         onclick="filter('all')">All</button>
            <button class="toggle-btn"        id="f-todo"        onclick="filter('todo')">To Do</button>
            <button class="toggle-btn"        id="f-in_progress" onclick="filter('in_progress')">In Progress</button>
            <button class="toggle-btn"        id="f-done"        onclick="filter('done')">Done</button>
          </div>
          <select id="f-priority" class="form-control" style="max-width:160px;" onchange="render()">
            <option value="">All Priorities</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
          <span style="font-size:13px;color:var(--text-muted);" id="task-count"></span>
        </div>

        <!-- Table -->
        <div class="card">
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Task / Project</th>
                  <th>Priority</th>
                  <th>Due Date</th>
                  <th>Status</th>
                  <th>Approval</th>
                  <th>Assigned By</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="tasks-tbody">
                <tr><td colspan="7" style="text-align:center;padding:60px;"><span class="spinner"></span></td></tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- View Task Modal -->
<div class="modal-overlay" id="view-modal">
  <div class="modal" style="max-width:560px">
    <div class="modal-header"><span class="modal-title">Task Details</span><button class="modal-close" onclick="closeModal('view-modal')">×</button></div>
    <div class="modal-body" id="view-body"></div>
    <div class="modal-footer" id="view-footer">
      <button class="btn btn-ghost" onclick="closeModal('view-modal')">Close</button>
    </div>
  </div>
</div>

<!-- Refuse Modal -->
<div class="modal-overlay" id="refuse-modal">
  <div class="modal" style="max-width:460px;">
    <div class="modal-header">
      <span class="modal-title">Refuse Task</span>
      <button class="modal-close" onclick="closeModal('refuse-modal')">×</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="refuse-task-id">
      <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);border-radius:10px;padding:12px 14px;margin-bottom:16px;font-size:13px;color:#ef4444;">
        <i class="bx bx-error" style="margin-right:6px;"></i>
        You are about to refuse this task. Please provide a clear reason.
      </div>
      <div class="form-group mb-0">
        <label class="form-label">Reason for Refusal <span style="color:var(--danger)">*</span></label>
        <textarea id="refuse-reason" class="form-control" rows="3" placeholder="e.g. Outside my skill set, resource conflict, unclear requirements..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('refuse-modal')">Cancel</button>
      <button class="btn btn-danger" onclick="submitRefuse()"><i class="bx bx-x-circle"></i> Refuse Task</button>
    </div>
  </div>
</div>

<script src="/js/api.js"></script>
<script>
let allTasks = [];
let currentFilter = 'all';

const PRIORITY_COLOR = { low:'#22c55e', medium:'#f59e0b', high:'#ef4444' };
const PRIORITY_BG    = { low:'rgba(34,197,94,0.1)', medium:'rgba(245,158,11,0.1)', high:'rgba(239,68,68,0.1)' };
const STATUS_LABEL   = { todo:'To Do', in_progress:'In Progress', done:'Done' };

function filter(f) {
  currentFilter = f;
  ['all','todo','in_progress','done'].forEach(function(x) {
    document.getElementById('f-' + x).classList.toggle('active', x === f);
  });
  render();
}

function render() {
  var priority = document.getElementById('f-priority').value;
  var tasks = allTasks.filter(function(t) {
    if (currentFilter !== 'all' && t.status !== currentFilter) return false;
    if (priority && t.priority !== priority) return false;
    return true;
  });

  var countEl = document.getElementById('task-count');
  if (countEl) countEl.textContent = tasks.length + ' task' + (tasks.length !== 1 ? 's' : '');

  var tbody = document.getElementById('tasks-tbody');
  if (!tasks.length) {
    tbody.innerHTML = '<tr><td colspan="7"><div class="empty-state"><div class="empty-icon"><i class="bx bxs-check-square"></i></div><h3>No tasks found</h3><p>No tasks match the selected filter</p></div></td></tr>';
    return;
  }

  tbody.innerHTML = tasks.map(function(t) {
    var isOverdue = t.dueDate && new Date(t.dueDate) < new Date() && t.status !== 'done';
    var dueStr = t.dueDate ? new Date(t.dueDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '—';

    var approvalCell = '—';
    if (t.approvalStatus === 'pending_approval') {
      approvalCell = '<span style="font-size:11px;font-weight:700;color:#f59e0b;"><i class="bx bxs-time"></i> Awaiting</span>';
    } else if (t.approvalStatus === 'approved') {
      approvalCell = '<span style="font-size:11px;font-weight:700;color:#22c55e;"><i class="bx bxs-check-circle"></i> Approved</span>';
    } else if (t.approvalStatus === 'refused') {
      approvalCell = '<span style="font-size:11px;font-weight:700;color:#ef4444;"><i class="bx bx-x-circle"></i> Refused</span>';
    }

    var statusBadgeClass = t.status === 'done' ? 'success' : t.status === 'in_progress' ? 'warning' : 'ghost';

    return '<tr>' +
      '<td>' +
        '<div style="font-weight:600;font-size:13px;">' + t.title + '</div>' +
        (t.projectName ? '<div style="font-size:11px;color:var(--accent);font-weight:600;margin-top:2px;"><i class="bx bx-folder" style="font-size:10px;"></i> ' + t.projectName + '</div>' : '') +
        (t.description ? '<div style="font-size:11px;color:var(--text-muted);margin-top:1px;">' + t.description.slice(0,60) + (t.description.length>60?'…':'') + '</div>' : '') +
      '</td>' +
      '<td><span style="font-size:12px;font-weight:700;background:' + PRIORITY_BG[t.priority] + ';color:' + PRIORITY_COLOR[t.priority] + ';border-radius:12px;padding:2px 9px;text-transform:capitalize;">' + t.priority + '</span></td>' +
      '<td style="font-size:12px;' + (isOverdue?'color:#ef4444;font-weight:700;':'color:var(--text-muted);') + '">' + dueStr + (isOverdue?' <span style="font-size:10px;">(overdue)</span>':'') + '</td>' +
      '<td><span class="badge badge-' + statusBadgeClass + '">' + STATUS_LABEL[t.status] + '</span></td>' +
      '<td>' + approvalCell + '</td>' +
      '<td style="font-size:12px;color:var(--text-muted);">' + (t.assigner ? t.assigner.name : '—') + '</td>' +
      '<td>' +
        '<div style="display:flex;gap:5px;flex-wrap:wrap;">' +
          '<button class="btn btn-ghost btn-sm" onclick="viewTask(' + t.id + ')" title="View"><i class="bx bx-show"></i></button>' +
          getActionButtons(t) +
        '</div>' +
      '</td>' +
    '</tr>';
  }).join('');
}

function getActionButtons(t) {
  if (t.approvalStatus === 'refused' || t.approvalStatus === 'approved' || t.status === 'done') return '';
  if (t.approvalStatus === 'pending_approval') return '';
  var btns = '';
  if (t.status === 'todo') {
    btns += '<button class="btn btn-ghost btn-sm" onclick="startTask(' + t.id + ')"><i class="bx bx-play"></i></button>';
  }
  if (t.status === 'in_progress') {
    btns += '<button class="btn btn-primary btn-sm" onclick="requestCompletion(' + t.id + ')"><i class="bx bx-check-double"></i></button>';
  }
  btns += '<button class="btn btn-danger btn-sm" onclick="openRefuse(' + t.id + ')" title="Refuse"><i class="bx bx-x"></i></button>';
  return btns;
}

function viewTask(id) {
  var t = allTasks.find(function(x){ return x.id === id; });
  if (!t) return;
  var isOverdue = t.dueDate && new Date(t.dueDate) < new Date() && t.status !== 'done';
  var dueStr = t.dueDate ? new Date(t.dueDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '—';

  var approvalHtml = '';
  if (t.approvalStatus === 'pending_approval') {
    approvalHtml = '<div style="background:#fef3c7;border:1px solid #fde68a;border-radius:10px;padding:10px 14px;font-size:13px;color:#92400e;margin-top:14px;"><i class="bx bxs-time"></i> Completion request sent — awaiting manager approval</div>';
  } else if (t.approvalStatus === 'approved') {
    approvalHtml = '<div style="background:#d1fae5;border:1px solid #a7f3d0;border-radius:10px;padding:10px 14px;font-size:13px;color:#065f46;margin-top:14px;"><i class="bx bxs-check-circle"></i> Manager approved — task completed!</div>';
  } else if (t.approvalStatus === 'refused') {
    approvalHtml = '<div style="background:#fee2e2;border:1px solid #fecaca;border-radius:10px;padding:10px 14px;font-size:13px;color:#991b1b;margin-top:14px;"><i class="bx bx-x-circle"></i> <strong>Refused:</strong> ' + (t.refusalReason || '—') + '</div>';
  }

  document.getElementById('view-body').innerHTML =
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;grid-column:1/-1;">' +
        '<div class="detail-label">Title</div>' +
        '<div style="font-weight:700;font-size:15px;color:var(--text-primary);margin-top:4px;">' + t.title + '</div>' +
        (t.projectName ? '<div style="font-size:12px;color:var(--accent);font-weight:600;margin-top:4px;"><i class="bx bx-folder"></i> ' + t.projectName + '</div>' : '') +
      '</div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Priority</div><div style="font-weight:600;color:' + PRIORITY_COLOR[t.priority] + ';text-transform:capitalize;margin-top:4px;">' + t.priority + '</div></div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Status</div><div style="margin-top:4px;">' + STATUS_LABEL[t.status] + '</div></div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Due Date</div><div style="margin-top:4px;' + (isOverdue?'color:#ef4444;font-weight:700;':'') + '">' + dueStr + (isOverdue?' (overdue)':'') + '</div></div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Assigned By</div><div style="margin-top:4px;">' + (t.assigner ? t.assigner.name : '—') + '</div></div>' +
    '</div>' +
    (t.description ? '<div style="margin-top:14px;background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Description</div><div style="margin-top:4px;font-size:13px;color:var(--text-secondary);">' + t.description + '</div></div>' : '') +
    approvalHtml;

  // Footer action buttons
  var footer = document.getElementById('view-footer');
  var actionHtml = '<button class="btn btn-ghost" onclick="closeModal(\'view-modal\')">Close</button>';
  if (t.approvalStatus !== 'refused' && t.approvalStatus !== 'approved' && t.status !== 'done' && t.approvalStatus !== 'pending_approval') {
    if (t.status === 'todo') {
      actionHtml += '<button class="btn btn-primary" onclick="startTask(' + t.id + ');closeModal(\'view-modal\');"><i class="bx bx-play"></i> Start Task</button>';
    } else if (t.status === 'in_progress') {
      actionHtml += '<button class="btn btn-primary" onclick="requestCompletion(' + t.id + ');closeModal(\'view-modal\');"><i class="bx bx-check-double"></i> Request Completion</button>';
    }
    actionHtml += '<button class="btn btn-danger" onclick="openRefuse(' + t.id + ');closeModal(\'view-modal\');"><i class="bx bx-x"></i> Refuse</button>';
  }
  footer.innerHTML = actionHtml;
  openModal('view-modal');
}

async function startTask(id) {
  try { await api('PATCH', '/tasks/' + id + '/status', { status: 'in_progress' }); toast('Task started!', 'success'); loadTasks(); }
  catch(e) { toast(e.message, 'error'); }
}

async function requestCompletion(id) {
  try { await api('PATCH', '/tasks/' + id + '/request-completion', {}); toast('Completion request sent to manager!', 'success'); loadTasks(); }
  catch(e) { toast(e.message, 'error'); }
}

function openRefuse(id) {
  document.getElementById('refuse-task-id').value = id;
  document.getElementById('refuse-reason').value = '';
  openModal('refuse-modal');
}

async function submitRefuse() {
  var id = document.getElementById('refuse-task-id').value;
  var reason = document.getElementById('refuse-reason').value.trim();
  if (!reason) return toast('Please enter a reason for refusing', 'error');
  try {
    await api('PATCH', '/tasks/' + id + '/refuse', { reason });
    toast('Task refused. Your manager has been notified.', 'info');
    closeModal('refuse-modal');
    loadTasks();
  } catch(e) { toast(e.message, 'error'); }
}

async function loadTasks() {
  try { allTasks = await api('GET', '/tasks'); render(); }
  catch(e) { toast(e.message, 'error'); }
}

loadTasks();
</script>
</body></html>
