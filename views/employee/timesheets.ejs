<%- include('../partials/head', {title: 'My Timesheets'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-employee') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div><div class="page-title">Timesheets</div><div class="page-subtitle">Log and track your work hours</div></div>
      </div>
      <div class="header-actions"></div>
    </header>
    <div class="page-body admin-employees-page employee-shared-page">
      <div class="employee-directory-shell">

      <!-- Stats -->
      <div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
        <div class="stat-card"><div class="stat-icon blue"><i class="bx bxs-time-five"></i></div><div><div class="stat-value" id="total-hours">0h</div><div class="stat-label">Approved Hours</div></div></div>
        <div class="stat-card"><div class="stat-icon green"><i class="bx bxs-check-circle"></i></div><div><div class="stat-value" id="approved-sheets">0</div><div class="stat-label">Approved</div></div></div>
        <div class="stat-card"><div class="stat-icon orange"><i class="bx bxs-hourglass"></i></div><div><div class="stat-value" id="pending-sheets">0</div><div class="stat-label">Pending</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:#fee2e2;color:#ef4444;"><i class="bx bxs-x-circle"></i></div><div><div class="stat-value" id="rejected-sheets">0</div><div class="stat-label">Rejected</div></div></div>
      </div>

      <!-- Toolbar -->
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px;">
        <div class="toggle-group">
          <button class="toggle-btn active" id="tab-week" onclick="setView('week')"><i class="bx bx-calendar-week"></i> Week</button>
          <button class="toggle-btn" id="tab-month" onclick="setView('month')"><i class="bx bx-calendar"></i> Month</button>
          <button class="toggle-btn" id="tab-year" onclick="setView('year')"><i class="bx bx-bar-chart-alt-2"></i> Year</button>
        </div>
        <button class="btn employee-cta-btn" onclick="openNewTs()"><i class="bx bx-plus"></i> New Timesheet</button>
      </div>

      <!-- Navigator -->
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;">
        <button class="btn btn-ghost btn-sm" onclick="navPrev()"><i class="bx bx-chevron-left"></i></button>
        <div style="flex:1;text-align:center;font-weight:600;font-size:14px;color:var(--text-primary);" id="nav-label">—</div>
        <button class="btn btn-ghost btn-sm" onclick="navNext()"><i class="bx bx-chevron-right"></i></button>
        <button class="btn btn-ghost btn-sm" style="font-size:12px;" onclick="navToday()">Today</button>
      </div>

      <!-- View content -->
      <div id="ts-content">
        <div style="display:flex;justify-content:center;padding:40px;"><span class="spinner"></span></div>
      </div>

      </div>
    </div>
  </div>
</div>

<!-- Timesheet Modal -->
<div class="modal-overlay" id="ts-modal">
  <div class="modal employee-timesheet-modal">
    <div class="modal-header">
      <span class="modal-title" id="ts-modal-title">Weekly Timesheet</span>
      <button class="modal-close" onclick="closeModal('ts-modal')">�</button>
    </div>
    <div class="modal-body employee-timesheet-body">
      <div class="timesheet-sheet-topbar">
        <div class="timesheet-sheet-weekbox">
          <div class="timesheet-sheet-meta-label">Timesheet For</div>
          <div class="timesheet-sheet-weeklabel" id="ts-week-label">Week Ending �</div>
        </div>
        <div class="timesheet-sheet-top-actions">
          <button class="btn btn-ghost" type="button" onclick="addTimesheetRow()"><i class="bx bx-plus"></i> Add Entry</button>
        </div>
      </div>

      <div class="ts-status-banner" id="ts-edit-banner">
        <i class="bx bxs-info-circle"></i>
        <span id="ts-edit-banner-text"></span>
      </div>
      <div class="timesheet-sheet-assigned" id="assigned-work-note">Loading assigned work...</div>

      <div class="timesheet-sheet-scroll">
        <table class="timesheet-sheet-table">
          <thead id="ts-sheet-head"></thead>
          <tbody id="ts-sheet-body"></tbody>
          <tfoot id="ts-sheet-foot"></tfoot>
        </table>
      </div>

      <div class="ts-notes-area form-group" style="margin-bottom:0">
        <label class="form-label">Notes</label>
        <textarea id="ts-notes" class="form-control" rows="1" placeholder="Any notes for this week..."></textarea>
      </div>

      <div class="ts-summary">
        <span><strong id="sum-days">0</strong> active days</span>
        <span style="color:var(--border)">|</span>
        <span><strong id="sum-rows">0</strong> row(s)</span>
        <span style="color:var(--border)">|</span>
        <span class="ts-summary-total"><strong id="sum-total">0</strong>h total</span>
      </div>
    </div>
    <div class="modal-footer modal-footer-ts">
      <button class="btn btn-ghost" onclick="closeModal('ts-modal')">Cancel</button>
      <button class="btn btn-primary" id="ts-submit-btn" onclick="submitTimesheet()">Submit Timesheet</button>
    </div>
  </div>
</div>

<style>
.employee-timesheet-modal{width:min(96vw,960px);max-width:min(96vw,960px);height:min(90vh,700px);display:flex;flex-direction:column;border-radius:20px}
.employee-timesheet-body{flex:1;display:flex;flex-direction:column;gap:8px;overflow:hidden;padding:12px 20px 0}
.timesheet-sheet-topbar{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.timesheet-sheet-weekbox{display:flex;flex-direction:column;gap:2px}
.timesheet-sheet-meta-label{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-muted)}
.timesheet-sheet-weeklabel{font-size:16px;font-weight:800;color:var(--text-primary)}
.timesheet-sheet-top-actions{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.timesheet-sheet-assigned{padding:9px 13px;border-radius:10px;background:linear-gradient(135deg,#eef4ff,#f0f4ff);border:1px solid #c7d7f8;font-size:12px;color:#4a6194}
.ts-status-banner{padding:8px 13px;border-radius:10px;font-size:12px;font-weight:600;display:none;align-items:center;gap:8px}
.ts-status-banner.pending{background:#fef3c7;border:1px solid #fde68a;color:#92400e;display:flex}
.ts-status-banner.approved{background:#d1fae5;border:1px solid #a7f3d0;color:#065f46;display:flex}
.ts-status-banner.rejected{background:#fee2e2;border:1px solid #fecaca;color:#991b1b;display:flex}
.timesheet-sheet-scroll{flex:1;overflow:auto;border:1px solid var(--border);border-radius:14px;background:#fff;min-height:140px}
.timesheet-sheet-table{width:100%;min-width:880px;border-collapse:collapse}
.timesheet-sheet-table th,.timesheet-sheet-table td{padding:8px 6px;border-bottom:1px solid #edf0f7;vertical-align:middle}
.timesheet-sheet-table thead th{position:sticky;top:0;background:#f0f4ff;color:#5871a4;font-size:11px;font-weight:700;z-index:2;white-space:nowrap}
.timesheet-sheet-table thead th.ts-day-head{text-align:center;min-width:52px}
.timesheet-sheet-table .sheet-col-project{min-width:200px}
.timesheet-sheet-table .sheet-col-billing{min-width:100px}
.timesheet-sheet-table .sheet-col-desc{min-width:160px}
.timesheet-sheet-table .sheet-col-total{min-width:52px;text-align:center;font-weight:800;color:var(--accent)}
.timesheet-sheet-table .sheet-col-actions{min-width:44px;text-align:center}
.timesheet-sheet-table select,.timesheet-sheet-table input{width:100%;min-height:34px;border-radius:8px;border:1px solid #d4dcee;padding:0 8px;background:#fff;font-family:inherit;font-size:12px;color:var(--text-primary)}
.timesheet-sheet-table select:focus,.timesheet-sheet-table input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 2px rgba(99,102,241,.1)}
.timesheet-sheet-table input[type=number]{text-align:center;padding:0 4px}
.timesheet-sheet-task-meta{display:block;margin-top:3px;font-size:10px;color:var(--text-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:195px}
.timesheet-sheet-total-row td{background:#f5f7ff;font-weight:700;border-bottom:none;font-size:12px}
.timesheet-delete-btn{width:30px;height:30px;border:none;border-radius:8px;background:#fee2e2;color:#ef4444;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;margin:auto}
.timesheet-delete-btn:hover{background:#fecaca}
.ts-summary{display:flex;align-items:center;gap:10px;font-size:12px;color:var(--text-secondary);padding:7px 12px;background:var(--bg-input);border-radius:10px;flex-wrap:wrap;flex-shrink:0}
.ts-summary-total{margin-left:auto;font-weight:700;font-size:13px;color:var(--text-primary)}
.ts-notes-area{flex-shrink:0}
.ts-notes-area .form-label{font-size:11px;margin-bottom:3px}
.ts-notes-area .form-control{font-size:12px;resize:none;min-height:unset}
.modal-footer-ts{padding:10px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px;flex-shrink:0}
@media (max-width:768px){
  .employee-timesheet-modal{width:100vw;max-width:100vw;max-height:100vh;border-radius:0}
  .timesheet-sheet-weeklabel{font-size:14px}
}
</style>

<script src="/js/api.js"></script>
<script>
var DAYNAMES      = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
var MONTHS_SHORT  = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
var MONTHS_FULL   = ['January','February','March','April','May','June','July','August','September','October','November','December'];

var allTimesheets = [];
var currentView   = 'week';
var navDate       = new Date();
var selectedDates = new Set();
var activeWeek    = 'current';
var editingTsId   = null;
var assignedTasks = [];
var timesheetRows = [];
var tsRowSeed = 1;

/* ── helpers ────────────────────────────────────────────── */
function getMondayOf(date) {
  var d = new Date(date); d.setHours(0,0,0,0);
  var day = d.getDay();
  d.setDate(d.getDate() - day + (day === 0 ? -6 : 1));
  return d;
}
function addDays(d, n) { var r = new Date(d); r.setDate(r.getDate() + n); return r; }
function fmtISO(d) {
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}
function fmtRange(a, b) {
  var da = new Date(a), db = new Date(b);
  if (da.getMonth() === db.getMonth() && da.getFullYear() === db.getFullYear())
    return da.getDate() + '–' + db.getDate() + ' ' + MONTHS_SHORT[da.getMonth()] + ' ' + da.getFullYear();
  return da.getDate() + ' ' + MONTHS_SHORT[da.getMonth()] + ' – ' + db.getDate() + ' ' + MONTHS_SHORT[db.getMonth()] + ' ' + db.getFullYear();
}
function fmtFull(d) {
  var x = new Date(d);
  return x.toLocaleDateString('en-US', {day:'2-digit', month:'short', year:'numeric'});
}
function dayIndex(d) { var x = new Date(d).getDay(); return x === 0 ? 6 : x - 1; }
function statusStyle(s) {
  return s==='approved' ? {c:'#22c55e',b:'#dcfce7'} : s==='rejected' ? {c:'#ef4444',b:'#fee2e2'} : {c:'#f59e0b',b:'#fef3c7'};
}

/* ── view switching ─────────────────────────────────────── */
function setView(v) {
  currentView = v;
  ['week','month','year'].forEach(function(x) {
    document.getElementById('tab-' + x).classList.toggle('active', x === v);
  });
  renderView();
}
function navPrev() {
  if (currentView === 'week')       navDate = addDays(getMondayOf(navDate), -7);
  else if (currentView === 'month') navDate = new Date(navDate.getFullYear(), navDate.getMonth() - 1, 1);
  else                              navDate = new Date(navDate.getFullYear() - 1, 0, 1);
  renderView();
}
function navNext() {
  if (currentView === 'week')       navDate = addDays(getMondayOf(navDate), 7);
  else if (currentView === 'month') navDate = new Date(navDate.getFullYear(), navDate.getMonth() + 1, 1);
  else                              navDate = new Date(navDate.getFullYear() + 1, 0, 1);
  renderView();
}
function navToday() { navDate = new Date(); renderView(); }
function renderView() {
  if (currentView === 'week') renderWeekView();
  else if (currentView === 'month') renderMonthView();
  else renderYearView();
}

/* ── WEEK VIEW ──────────────────────────────────────────── */
function renderWeekView() {
  var monday = getMondayOf(navDate);
  var sunday = addDays(monday, 6);
  document.getElementById('nav-label').textContent = 'Week of ' + fmtRange(monday, sunday);

  // Build date→{hours, entries[], ts} map — aggregate multiple entries on same day
  var dayMap = {};
  allTimesheets.forEach(function(ts) {
    (ts.entries || []).forEach(function(e) {
      if (!dayMap[e.date]) { dayMap[e.date] = { hours: 0, entries: [], ts: ts }; }
      dayMap[e.date].hours += Number(e.hours || 0);
      dayMap[e.date].entries.push(e);
      dayMap[e.date].ts = ts;
    });
  });

  var todayISO = fmtISO(new Date());
  var totalH = 0;
  var rows = '';

  for (var i = 0; i < 7; i++) {
    var d = addDays(monday, i);
    var iso = fmtISO(d);
    var hit = dayMap[iso];
    var isToday = iso === todayISO;
    var isWeekend = i >= 5;
    var st = hit ? statusStyle(hit.ts.status) : null;

    rows += '<tr style="border-bottom:1px solid var(--border);' +
      (isToday ? 'background:rgba(99,102,241,0.05);' : isWeekend ? 'opacity:0.55;' : '') + '">' +
      '<td style="padding:11px 14px;white-space:nowrap;">' +
        '<div style="display:flex;align-items:center;gap:8px;">' +
          '<span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:8px;font-size:11px;font-weight:700;' +
            (isToday ? 'background:var(--accent);color:white;' : 'background:var(--bg-input);color:var(--text-muted);') + '">' +
            DAYNAMES[i].charAt(0) +
          '</span>' +
          '<div>' +
            '<div style="font-weight:' + (isToday?'700':'500') + ';font-size:13px;color:var(--text-primary);">' + DAYNAMES[i] + '</div>' +
            '<div style="font-size:11px;color:var(--text-muted);">' + d.getDate() + ' ' + MONTHS_SHORT[d.getMonth()] + '</div>' +
          '</div>' +
        '</div>' +
      '</td>' +
      '<td style="padding:11px 14px;text-align:center;">' +
        (hit ? '<span style="font-size:15px;font-weight:800;color:var(--accent);">' + hit.hours.toFixed(1) + '<span style="font-size:11px;font-weight:400;">h</span></span>'
             : '<span style="color:var(--border);font-size:18px;">—</span>') +
        (hit && hit.entries.length > 1 ? '<div style="font-size:10px;color:var(--text-muted);">' + hit.entries.length + ' entries</div>' : '') +
      '</td>' +
      '<td style="padding:11px 14px;">' +
        (hit ? hit.entries.map(function(e){ return e.workType; }).filter(function(v,i,a){return v&&a.indexOf(v)===i;}).map(function(wt){ return '<span style="font-size:11px;background:var(--bg-input);border-radius:6px;padding:2px 7px;text-transform:capitalize;color:var(--text-secondary);margin-right:3px;">' + wt + '</span>'; }).join('') : '') +
      '</td>' +
      '<td style="padding:11px 14px;font-size:12px;color:var(--text-secondary);max-width:150px;">' +
        (hit ? hit.entries.map(function(e){ return e.project || ''; }).filter(function(v,i,a){return v&&a.indexOf(v)===i;}).join(', ') : '') +
      '</td>' +
      '<td style="padding:11px 14px;font-size:12px;color:var(--text-muted);max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' +
        (hit ? hit.entries.map(function(e){ return e.description || ''; }).filter(Boolean).join(' / ') : '') +
      '</td>' +
      '<td style="padding:11px 14px;">' +
        (hit ? '<span style="font-size:11px;font-weight:600;background:' + st.b + ';color:' + st.c + ';border-radius:12px;padding:2px 9px;text-transform:capitalize;">' + hit.ts.status + '</span>' : '') +
      '</td>' +
      '<td style="padding:11px 10px;text-align:right;">' +
        (hit && (hit.ts.status==='pending'||hit.ts.status==='rejected') ?
          '<button class="btn btn-ghost btn-sm" onclick="openEditTs(' + hit.ts.id + ')"><i class="bx bx-edit"></i></button>' : '') +
      '</td>' +
    '</tr>';
    if (hit) totalH += (hit.hours || 0);
  }

  var hasWeekEntries = Object.keys(dayMap).some(function(k) {
    var dd = new Date(k); return dd >= monday && dd <= sunday;
  });

  var html = '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">' +
    '<table style="width:100%;border-collapse:collapse;">' +
    '<thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">' +
      '<th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;">Day</th>' +
      '<th style="padding:10px 14px;text-align:center;font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;">Hours</th>' +
      '<th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;">Type</th>' +
      '<th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;">Project</th>' +
      '<th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;">Task</th>' +
      '<th style="padding:10px 14px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;">Status</th>' +
      '<th></th>' +
    '</tr></thead>' +
    '<tbody>' + rows + '</tbody>' +
    '<tfoot><tr style="background:var(--bg-input);border-top:2px solid var(--border);">' +
      '<td style="padding:10px 14px;font-weight:700;font-size:13px;color:var(--text-primary);">Weekly Total</td>' +
      '<td style="padding:10px 14px;text-align:center;font-size:18px;font-weight:800;color:var(--accent);">' + totalH + '<span style="font-size:12px;font-weight:400;">h</span></td>' +
      '<td colspan="5"></td>' +
    '</tr></tfoot>' +
    '</table>' +
    '</div>';

  if (!hasWeekEntries) {
    html += '<div style="margin-top:14px;text-align:center;padding:20px 24px;background:var(--bg-input);border-radius:var(--radius);border:1px dashed var(--border);">' +
      '<div style="font-size:13px;color:var(--text-muted);margin-bottom:10px;">No timesheet entries for this week</div>' +
      '<button class="btn btn-primary btn-sm" onclick="openNewTs()"><i class="bx bx-plus"></i> Log This Week</button>' +
      '</div>';
  }

  document.getElementById('ts-content').innerHTML = html;
}

/* ── MONTH VIEW ─────────────────────────────────────────── */
function renderMonthView() {
  var yr = navDate.getFullYear(), mo = navDate.getMonth();
  document.getElementById('nav-label').textContent = MONTHS_FULL[mo] + ' ' + yr;

  var sheets = allTimesheets.filter(function(ts) {
    var d = new Date(ts.weekStart);
    return d.getFullYear() === yr && d.getMonth() === mo;
  }).sort(function(a,b){ return new Date(a.weekStart)-new Date(b.weekStart); });

  if (!sheets.length) {
    document.getElementById('ts-content').innerHTML =
      '<div style="text-align:center;padding:48px 24px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);">' +
      '<i class="bx bxs-calendar-x" style="font-size:48px;color:var(--text-muted);margin-bottom:12px;display:block;"></i>' +
      '<div style="color:var(--text-muted);font-size:14px;margin-bottom:16px;">No timesheets for ' + MONTHS_FULL[mo] + ' ' + yr + '</div>' +
      '<button class="btn btn-primary" onclick="openNewTs()"><i class="bx bx-plus"></i> Add Timesheet</button>' +
      '</div>';
    return;
  }

  var totalH    = sheets.reduce(function(s,t){ return s+(t.totalHours||0); },0);
  var approvedH = sheets.filter(function(t){return t.status==='approved';}).reduce(function(s,t){ return s+(t.totalHours||0); },0);

  var html = '<div style="background:linear-gradient(135deg,var(--accent),#7c3aed);border-radius:var(--radius);padding:18px 22px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:18px;">' +
    '<div style="color:white;"><div style="font-size:28px;font-weight:800;line-height:1;">' + totalH + 'h</div><div style="font-size:12px;opacity:.75;margin-top:2px;">Total logged</div></div>' +
    '<div style="color:white;"><div style="font-size:28px;font-weight:800;line-height:1;">' + approvedH + 'h</div><div style="font-size:12px;opacity:.75;margin-top:2px;">Approved</div></div>' +
    '<div style="color:white;"><div style="font-size:28px;font-weight:800;line-height:1;">' + sheets.length + '</div><div style="font-size:12px;opacity:.75;margin-top:2px;">Timesheets</div></div>' +
    '</div>';

  html += '<div style="display:flex;flex-direction:column;gap:12px;">';
  sheets.forEach(function(ts) {
    var st      = statusStyle(ts.status);
    var entries = ts.entries || [];
    var canEdit = ts.status === 'pending' || ts.status === 'rejected';

    html += '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;">' +
      '<div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:14px;">' +
        '<div>' +
          '<div style="font-weight:600;font-size:14px;color:var(--text-primary);margin-bottom:3px;"><i class="bx bx-calendar" style="color:var(--accent);margin-right:6px;"></i>' + fmtRange(ts.weekStart, ts.weekEnd) + '</div>' +
          '<div style="font-size:11px;color:var(--text-muted);">Submitted ' + fmtFull(ts.createdAt) + '</div>' +
        '</div>' +
        '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">' +
          '<span style="font-size:11px;font-weight:700;background:' + st.b + ';color:' + st.c + ';border-radius:20px;padding:3px 11px;text-transform:capitalize;">' + ts.status + '</span>' +
          (canEdit ? '<button class="btn btn-ghost btn-sm" onclick="openEditTs(' + ts.id + ')"><i class="bx bx-edit"></i> Edit</button>' : '') +
          (ts.status==='pending' ? '<button class="btn btn-danger btn-sm" onclick="deleteTs(' + ts.id + ')" title="Delete"><i class="bx bx-trash"></i></button>' : '') +
        '</div>' +
      '</div>' +
      '<div style="display:flex;gap:12px;margin-bottom:' + (entries.length?'12':'0') + 'px;">' +
        '<div style="background:var(--bg-input);border-radius:10px;padding:8px 18px;text-align:center;">' +
          '<div style="font-size:20px;font-weight:800;color:var(--accent);">' + ts.totalHours + 'h</div>' +
          '<div style="font-size:11px;color:var(--text-muted);">Total Hours</div>' +
        '</div>' +
        '<div style="background:var(--bg-input);border-radius:10px;padding:8px 18px;text-align:center;">' +
          '<div style="font-size:20px;font-weight:800;color:var(--text-primary);">' + entries.length + '</div>' +
          '<div style="font-size:11px;color:var(--text-muted);">Days Logged</div>' +
        '</div>' +
      '</div>' +
      (entries.length ? '<div style="display:flex;flex-wrap:wrap;gap:6px;">' +
        entries.map(function(e) {
          var ed = new Date(e.date);
          return '<div style="background:var(--bg-input);border-radius:8px;padding:4px 10px;font-size:11px;color:var(--text-secondary);">' +
            '<strong>' + DAYNAMES[dayIndex(ed)] + ' ' + ed.getDate() + '</strong>' +
            ' · ' + e.hours + 'h' +
            (e.workType ? ' · <span style="text-transform:capitalize;">' + e.workType + '</span>' : '') +
            (e.project ? ' · ' + e.project : '') +
          '</div>';
        }).join('') +
      '</div>' : '') +
      (ts.approver ? '<div style="margin-top:10px;font-size:12px;color:var(--text-muted);"><i class="bx bx-check-circle" style="color:#22c55e;margin-right:4px;"></i>Approved by <strong>' + ts.approver.name + '</strong></div>' : '') +
      (ts.rejectionReason ? '<div style="margin-top:10px;font-size:12px;color:#ef4444;background:#fee2e2;border-radius:8px;padding:8px 12px;"><i class="bx bx-x-circle" style="margin-right:4px;"></i>' + ts.rejectionReason + '</div>' : '') +
    '</div>';
  });
  html += '</div>';
  document.getElementById('ts-content').innerHTML = html;
}

/* ── YEAR VIEW ──────────────────────────────────────────── */
function renderYearView() {
  var yr = navDate.getFullYear();
  document.getElementById('nav-label').textContent = yr.toString();

  var yearSheets = allTimesheets.filter(function(ts) {
    return new Date(ts.weekStart).getFullYear() === yr;
  });
  var totalYearH = yearSheets.reduce(function(s,t){ return s+(t.totalHours||0); },0);

  var monthData = MONTHS_FULL.map(function(name, mi) {
    var ms = yearSheets.filter(function(ts){ return new Date(ts.weekStart).getMonth() === mi; });
    return {
      name: name, short: MONTHS_SHORT[mi], mi: mi,
      sheets: ms,
      hours: ms.reduce(function(s,t){ return s+(t.totalHours||0); },0),
      approvedH: ms.filter(function(t){return t.status==='approved';}).reduce(function(s,t){return s+(t.totalHours||0);},0),
      pending: ms.filter(function(t){return t.status==='pending';}).length,
      rejected: ms.filter(function(t){return t.status==='rejected';}).length
    };
  });
  var maxH = Math.max.apply(null, monthData.map(function(m){ return m.hours; })) || 1;

  var html = '<div style="background:linear-gradient(135deg,var(--accent),#7c3aed);border-radius:var(--radius);padding:18px 22px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:20px;">' +
    '<div style="color:white;"><div style="font-size:28px;font-weight:800;line-height:1;">' + totalYearH + 'h</div><div style="font-size:12px;opacity:.75;margin-top:2px;">Total in ' + yr + '</div></div>' +
    '<div style="color:white;"><div style="font-size:28px;font-weight:800;line-height:1;">' + yearSheets.filter(function(t){return t.status==='approved';}).length + '</div><div style="font-size:12px;opacity:.75;margin-top:2px;">Approved sheets</div></div>' +
    '<div style="color:white;"><div style="font-size:28px;font-weight:800;line-height:1;">' + yearSheets.length + '</div><div style="font-size:12px;opacity:.75;margin-top:2px;">Total sheets</div></div>' +
    '</div>';

  var now = new Date();
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;">';
  monthData.forEach(function(m) {
    var isCurrMonth = m.mi === now.getMonth() && yr === now.getFullYear();
    var barW = Math.round((m.hours / maxH) * 100);

    html += '<div style="background:var(--bg-card);border:1px solid ' + (isCurrMonth?'var(--accent)':'var(--border)') + ';border-radius:var(--radius);padding:14px 16px;cursor:pointer;transition:box-shadow .2s;" ' +
      'onclick="navDate=new Date(' + yr + ',' + m.mi + ',1);setView(\'month\')" ' +
      'onmouseover="this.style.boxShadow=\'var(--shadow-lg)\'" onmouseout="this.style.boxShadow=\'\'">' +
      '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">' +
        '<div style="font-weight:600;font-size:14px;color:' + (isCurrMonth?'var(--accent)':'var(--text-primary)') + ';">' + m.name + '</div>' +
        (m.pending ? '<span style="font-size:10px;background:#fef3c7;color:#b45309;border-radius:10px;padding:1px 7px;font-weight:700;">' + m.pending + ' pending</span>' : '') +
        (m.rejected && !m.pending ? '<span style="font-size:10px;background:#fee2e2;color:#ef4444;border-radius:10px;padding:1px 7px;font-weight:700;">' + m.rejected + ' rejected</span>' : '') +
      '</div>' +
      '<div style="font-size:24px;font-weight:800;color:' + (m.hours?'var(--text-primary)':'var(--text-muted)') + ';line-height:1;margin-bottom:8px;">' +
        m.hours + '<span style="font-size:14px;font-weight:400;color:var(--text-muted);">h</span>' +
      '</div>' +
      '<div style="height:5px;background:var(--bg-input);border-radius:5px;overflow:hidden;margin-bottom:8px;">' +
        '<div style="width:' + barW + '%;height:100%;background:var(--accent);border-radius:5px;"></div>' +
      '</div>' +
      '<div style="font-size:11px;color:var(--text-muted);">' +
        (m.sheets.length
          ? m.sheets.length + ' sheet' + (m.sheets.length>1?'s':'') + (m.approvedH ? ' · ' + m.approvedH + 'h approved' : '')
          : 'No entries') +
      '</div>' +
    '</div>';
  });
  html += '</div>';
  document.getElementById('ts-content').innerHTML = html;
}

/* ── stats ──────────────────────────────────────────────── */
function updateStats() {
  var approved = allTimesheets.filter(function(t){return t.status==='approved';});
  var pending  = allTimesheets.filter(function(t){return t.status==='pending';});
  var rejected = allTimesheets.filter(function(t){return t.status==='rejected';});
  document.getElementById('total-hours').textContent    = approved.reduce(function(s,t){return s+t.totalHours;},0).toFixed(1) + 'h';
  document.getElementById('approved-sheets').textContent = approved.length;
  document.getElementById('pending-sheets').textContent  = pending.length;
  document.getElementById('rejected-sheets').textContent = rejected.length;
}

async function loadTimesheets() {
  try {
    allTimesheets = await api('GET', '/timesheets');
    updateStats();
    renderView();
  } catch(e) { toast(e.message, 'error'); }
}

/* ── day picker ─────────────────────────────────────────── */
function getWeekDates(which) {
  var today = new Date(); today.setHours(0,0,0,0);
  var monday = getMondayOf(today);
  if (which === 'previous') monday = addDays(monday, -7);
  return Array.from({length:7}, function(_,i){ return addDays(monday, i); });
}

function setWeek(which) {
  activeWeek = which;
  selectedDates.clear();
  buildDayPicker(); updateSummary();
}

function buildDayPicker() {
  var dates = getWeekDates(activeWeek);
  // Allow all 7 days of the selected week (including future days of current week)
  document.getElementById('day-picker').innerHTML = dates.map(function(d, i) {
    var iso = fmtISO(d);
    var isSelected = selectedDates.has(iso);
    return '<button type="button" class="day-chip' + (isSelected?' selected':'') + '" data-date="' + iso + '" onclick="toggleDay(this)">' +
      '<span class="day-chip-name">' + DAYNAMES[i] + '</span>' +
      '<span class="day-chip-date">' + d.getDate() + ' ' + MONTHS_SHORT[d.getMonth()] + '</span>' +
    '</button>';
  }).join('');
}

function toggleDay(btn) {
  var date = btn.dataset.date;
  if (selectedDates.has(date)) { selectedDates.delete(date); btn.classList.remove('selected'); }
  else { selectedDates.add(date); btn.classList.add('selected'); }
  updateSummary();
}
function updateSummary() {
  var hrs = parseFloat(document.getElementById('ts-hours').value) || 0;
  document.getElementById('sum-days').textContent  = selectedDates.size;
  document.getElementById('sum-hrs').textContent   = hrs;
  document.getElementById('sum-total').textContent = (selectedDates.size * hrs).toFixed(1);
}

/* ── modal open/edit ────────────────────────────────────── */
function openNewTs() {
  editingTsId = null;
  document.getElementById('ts-modal-title').textContent = 'Log Work Hours';
  document.getElementById('ts-submit-btn').textContent  = 'Submit Timesheet';
  selectedDates.clear(); activeWeek = 'current';
  document.getElementById('ts-hours').value    = 8;
  document.getElementById('ts-worktype').value = 'work';
  document.getElementById('ts-project').value  = '';
  document.getElementById('ts-desc').value     = '';
  document.getElementById('ts-notes').value    = '';
  buildDayPicker(); updateSummary(); openModal('ts-modal');
}

function openEditTs(id) {
  var t = allTimesheets.find(function(x){ return x.id === id; });
  if (!t) return;
  editingTsId = id;
  document.getElementById('ts-modal-title').textContent = 'Edit Timesheet (will reset to pending)';
  document.getElementById('ts-submit-btn').textContent  = 'Update & Resubmit';
  selectedDates.clear();
  var entries = t.entries || [];
  if (entries.length) {
    var thisMon  = getMondayOf(new Date());
    var entryMon = getMondayOf(new Date(entries[0].date));
    activeWeek = entryMon.getTime() === thisMon.getTime() ? 'current' : 'previous';
    entries.forEach(function(e){ selectedDates.add(e.date); });
    document.getElementById('ts-hours').value    = entries[0].hours    || 8;
    document.getElementById('ts-worktype').value = entries[0].workType || 'work';
    document.getElementById('ts-project').value  = entries[0].project  || '';
    document.getElementById('ts-desc').value     = entries[0].description || '';
  }
  document.getElementById('ts-notes').value = t.notes || '';
  buildDayPicker(); updateSummary(); openModal('ts-modal');
}

/* ── submit / delete ────────────────────────────────────── */
async function submitTimesheet() {
  if (!selectedDates.size) return toast('Select at least one day', 'error');
  var hrs = parseFloat(document.getElementById('ts-hours').value) || 0;
  if (hrs <= 0) return toast('Enter valid hours', 'error');
  var sorted  = [...selectedDates].sort();
  var entries = sorted.map(function(d) {
    return { date: d, hours: hrs, workType: document.getElementById('ts-worktype').value,
             project: document.getElementById('ts-project').value, description: document.getElementById('ts-desc').value };
  });
  var notes = document.getElementById('ts-notes').value;
  try {
    if (editingTsId) {
      await api('PUT', '/timesheets/' + editingTsId, { entries: entries, notes: notes });
      toast('Timesheet updated & resubmitted!', 'success');
    } else {
      await api('POST', '/timesheets', { weekStart: sorted[0], weekEnd: sorted[sorted.length-1], entries: entries, notes: notes });
      toast('Timesheet submitted!', 'success');
    }
    closeModal('ts-modal');
    loadTimesheets();
  } catch(e) { toast(e.message, 'error'); }
}

async function deleteTs(id) {
  if (!confirm('Delete this timesheet?')) return;
  try { await api('DELETE', '/timesheets/' + id); toast('Deleted', 'success'); loadTimesheets(); }
  catch(e) { toast(e.message, 'error'); }
}

function getSheetWeekDates() {
  return getWeekDates(activeWeek);
}

function getAssignedTaskLabel(task) {
  if (!task) return 'General Work';
  var due = task.dueDate ? (' � Due ' + fmtFull(task.dueDate)) : '';
  return task.title + due;
}

function getAssignedTaskNote(task) {
  if (!task) return 'No assigned work selected. You can still log general work.';
  return (task.description || 'Assigned by ' + ((task.assigner && task.assigner.name) || 'manager'));
}

async function loadAssignedTasks() {
  try {
    assignedTasks = await api('GET', '/tasks');
  } catch(e) {
    assignedTasks = [];
  }
  assignedTasks = (assignedTasks || []).filter(function(t) { return t.approvalStatus !== 'refused'; });
  updateAssignedWorkNote();
}

function updateAssignedWorkNote() {
  var note = document.getElementById('assigned-work-note');
  if (!note) return;
  if (!assignedTasks.length) {
    note.innerHTML = '<strong>No assigned work found.</strong> You can still add a timesheet using the general work option.';
    return;
  }
  note.innerHTML = '<strong>' + assignedTasks.length + ' assigned work item(s)</strong> are available in the project list. Choose one to auto-link your timesheet entry, or use <strong>No assigned work</strong> when needed.';
}

function createDefaultRow() {
  var firstTask = assignedTasks[0] || null;
  return {
    rowId: tsRowSeed++,
    projectId: firstTask ? String(firstTask.id) : '__manual__',
    taskId: firstTask ? String(firstTask.id) : '__manual__',
    billingType: 'Billable',
    description: firstTask ? (firstTask.description || firstTask.title) : '',
    hours: [0,0,0,0,0,0,0]
  };
}

function findAssignedTask(id) {
  return assignedTasks.find(function(t) { return String(t.id) === String(id); }) || null;
}

function getRowById(rowId) {
  return timesheetRows.find(function(r) { return r.rowId === rowId; }) || null;
}

function ensureSheetRows() {
  if (!timesheetRows.length) timesheetRows.push(createDefaultRow());
}

function setWeek(which) {
  activeWeek = which;
  renderTimesheetSheet();
}

function renderTimesheetSheet() {
  ensureSheetRows();
  updateAssignedWorkNote();
  var dates = getSheetWeekDates();
  var weekEnd = dates[6];
  document.getElementById('ts-week-label').textContent = 'Week Ending ' + fmtFull(weekEnd);

  document.getElementById('ts-sheet-head').innerHTML = '<tr>' +
    '<th class="sheet-col-project">Project / Work</th>' +
    '<th class="sheet-col-billing">Billing</th>' +
    '<th class="sheet-col-desc">Description</th>' +
    dates.map(function(d, idx){ return '<th class="ts-day-head">' + DAYNAMES[idx] + '<br><span style="font-weight:500;color:#8ca0c6;font-size:10px;">' + String(d.getDate()).padStart(2,'0') + '/' + String(d.getMonth()+1).padStart(2,'0') + '</span></th>'; }).join('') +
    '<th class="sheet-col-total">Hrs</th>' +
    '<th class="sheet-col-actions"></th>' +
  '</tr>';

  var body = document.getElementById('ts-sheet-body');
  body.innerHTML = timesheetRows.map(function(row) {
    var task = findAssignedTask(row.taskId);
    var taskOptions = assignedTasks.length
      ? assignedTasks.map(function(t) {
          return '<option value="' + t.id + '" ' + (String(row.taskId) === String(t.id) ? 'selected' : '') + '>' + escHtml(t.title) + '</option>';
        }).join('')
      : '';
    var taskNote = task ? (task.projectName ? task.projectName + ' · ' : '') + (task.description || task.title) : 'General work';
    return '<tr>' +
      '<td class="sheet-col-project">' +
        '<select onchange="changeProject(' + row.rowId + ', this.value)">' +
          '<option value="__manual__" ' + (row.projectId === '__manual__' ? 'selected' : '') + '>No assigned work</option>' +
          assignedTasks.map(function(t) {
            var lbl = t.projectName ? escHtml(t.projectName) + ' — ' + escHtml(t.title) : escHtml(t.title);
            return '<option value="' + t.id + '" ' + (String(row.projectId) === String(t.id) ? 'selected' : '') + '>' + lbl + '</option>';
          }).join('') +
        '</select>' +
        '<span class="timesheet-sheet-task-meta">' + escHtml(taskNote) + '</span>' +
      '</td>' +
      '<td class="sheet-col-billing">' +
        '<select onchange="changeBilling(' + row.rowId + ', this.value)">' +
          '<option ' + (row.billingType === 'Billable' ? 'selected' : '') + '>Billable</option>' +
          '<option ' + (row.billingType === 'Non-Billable' ? 'selected' : '') + '>Non-Billable</option>' +
          '<option ' + (row.billingType === 'Internal' ? 'selected' : '') + '>Internal</option>' +
        '</select>' +
      '</td>' +
      '<td class="sheet-col-desc"><input type="text" value="' + escAttr(row.description || '') + '" placeholder="Describe work done" oninput="changeDescription(' + row.rowId + ', this.value)"></td>' +
      row.hours.map(function(val, idx) {
        return '<td><input type="number" min="0" max="24" step="0.5" value="' + (val || 0) + '" oninput="changeDayHours(' + row.rowId + ',' + idx + ', this.value)"></td>';
      }).join('') +
      '<td class="sheet-col-total" id="row-total-' + row.rowId + '">' + getRowHoursTotal(row).toFixed(1) + '</td>' +
      '<td class="sheet-col-actions"><button type="button" class="timesheet-delete-btn" onclick="removeTimesheetRow(' + row.rowId + ')"><i class="bx bx-trash"></i></button></td>' +
    '</tr>';
  }).join('');

  var dayTotals = [0,0,0,0,0,0,0];
  var weekTotal = 0;
  timesheetRows.forEach(function(row) {
    row.hours.forEach(function(v, idx) { dayTotals[idx] += Number(v || 0); });
    weekTotal += getRowHoursTotal(row);
  });
  document.getElementById('ts-sheet-foot').innerHTML = '<tr class="timesheet-sheet-total-row">' +
    '<td colspan="3">Weekly Totals</td>' +
    dayTotals.map(function(v){ return '<td style="text-align:center;">' + v.toFixed(1) + '</td>'; }).join('') +
    '<td class="sheet-col-total">' + weekTotal.toFixed(1) + '</td>' +
    '<td></td>' +
  '</tr>';

  updateSummary();
}

function getRowHoursTotal(row) {
  return (row.hours || []).reduce(function(sum, v) { return sum + (Number(v) || 0); }, 0);
}

function addTimesheetRow() {
  timesheetRows.push(createDefaultRow());
  renderTimesheetSheet();
}

function removeTimesheetRow(rowId) {
  timesheetRows = timesheetRows.filter(function(r) { return r.rowId !== rowId; });
  if (!timesheetRows.length) timesheetRows = [createDefaultRow()];
  renderTimesheetSheet();
}

function changeProject(rowId, value) {
  var row = getRowById(rowId);
  if (!row) return;
  row.projectId = value;
  if (value !== '__manual__') {
    row.taskId = value;
    var task = findAssignedTask(value);
    if (task && !row.description) row.description = task.description || task.title;
  }
  renderTimesheetSheet();
}

function changeTask(rowId, value) {
  var row = getRowById(rowId);
  if (!row) return;
  row.taskId = value;
  if (value !== '__manual__') {
    row.projectId = value;
    var task = findAssignedTask(value);
    if (task && !row.description) row.description = task.description || task.title;
  }
  renderTimesheetSheet();
}

function changeBilling(rowId, value) {
  var row = getRowById(rowId);
  if (!row) return;
  row.billingType = value;
}

function changeDescription(rowId, value) {
  var row = getRowById(rowId);
  if (!row) return;
  row.description = value;
}

function changeDayHours(rowId, dayIndex, value) {
  var row = getRowById(rowId);
  if (!row) return;
  var num = Math.max(0, Math.min(24, Number(value || 0)));
  row.hours[dayIndex] = num;
  var totalEl = document.getElementById('row-total-' + rowId);
  if (totalEl) totalEl.textContent = getRowHoursTotal(row).toFixed(1);
  updateSummary();
}

function updateSummary() {
  var dates = getSheetWeekDates();
  var activeDays = 0;
  for (var i = 0; i < 7; i++) {
    var total = timesheetRows.reduce(function(sum, row) { return sum + (Number(row.hours[i]) || 0); }, 0);
    if (total > 0) activeDays++;
  }
  var totalHours = timesheetRows.reduce(function(sum, row) { return sum + getRowHoursTotal(row); }, 0);
  document.getElementById('sum-days').textContent = activeDays;
  document.getElementById('sum-rows').textContent = timesheetRows.length;
  document.getElementById('sum-total').textContent = totalHours.toFixed(1);
}

function escHtml(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function escAttr(str) {
  return escHtml(str).replace(/"/g,'&quot;');
}

function openNewTs() {
  // If a timesheet already exists for the current week, open it for editing
  var monday = getMondayOf(new Date());
  var sunday = addDays(monday, 6);
  var monISO = fmtISO(monday), sunISO = fmtISO(sunday);
  var existing = allTimesheets.find(function(ts) { return ts.weekEnd >= monISO && ts.weekStart <= sunISO; });
  if (existing) {
    if (existing.status === 'approved') {
      toast('This week\'s timesheet is already approved — it cannot be modified.', 'info'); return;
    }
    toast('You already have a timesheet for this week — editing it.', 'info');
    openEditTs(existing.id); return;
  }
  editingTsId = null;
  var banner = document.getElementById('ts-edit-banner');
  banner.className = 'ts-status-banner'; banner.style.display = 'none';
  document.getElementById('ts-modal-title').textContent = 'Weekly Timesheet';
  document.getElementById('ts-submit-btn').textContent  = 'Submit Timesheet';
  activeWeek = 'current';
  timesheetRows = [createDefaultRow()];
  document.getElementById('ts-notes').value = '';
  renderTimesheetSheet();
  openModal('ts-modal');
}

function openEditTs(id) {
  var t = allTimesheets.find(function(x){ return x.id === id; });
  if (!t) return;
  editingTsId = id;
  document.getElementById('ts-modal-title').textContent = 'Edit Timesheet';
  document.getElementById('ts-submit-btn').textContent  = 'Update & Resubmit';
  var banner = document.getElementById('ts-edit-banner');
  var statusLabels = { pending: 'Currently pending approval — you can update and resubmit', approved: 'This timesheet was approved — editing will reset it to pending', rejected: 'Rejected — fix and resubmit' };
  banner.className = 'ts-status-banner ' + (t.status || 'pending');
  document.getElementById('ts-edit-banner-text').textContent = statusLabels[t.status] || ('Status: ' + t.status);
  banner.style.display = '';

  var entries = t.entries || [];
  if (entries.length) {
    var thisMon  = getMondayOf(new Date());
    var entryMon = getMondayOf(new Date(entries[0].date));
    activeWeek = entryMon.getTime() === thisMon.getTime() ? 'current' : 'previous';
  } else {
    activeWeek = 'current';
  }
  var grouped = {};
  entries.forEach(function(e) {
    var key = [e.taskId || '', e.project || '', e.description || '', e.billingType || 'Billable'].join('||');
    if (!grouped[key]) {
      grouped[key] = {
        rowId: tsRowSeed++,
        projectId: e.taskId ? String(e.taskId) : '__manual__',
        taskId: e.taskId ? String(e.taskId) : '__manual__',
        billingType: e.billingType || 'Billable',
        description: e.description || '',
        hours: [0,0,0,0,0,0,0]
      };
    }
    grouped[key].hours[dayIndex(e.date)] = Number(e.hours || 0);
  });
  timesheetRows = Object.keys(grouped).map(function(k) { return grouped[k]; });
  if (!timesheetRows.length) timesheetRows = [createDefaultRow()];
  document.getElementById('ts-notes').value = t.notes || '';
  renderTimesheetSheet();
  openModal('ts-modal');
}

async function submitTimesheet() {
  var dates = getSheetWeekDates();
  var entries = [];
  timesheetRows.forEach(function(row) {
    var linkedTask = findAssignedTask(row.taskId);
    var projectName = linkedTask ? linkedTask.title : 'General Work';
    for (var i = 0; i < 7; i++) {
      var hrs = Number(row.hours[i] || 0);
      if (hrs <= 0) continue;
      entries.push({
        date: fmtISO(dates[i]),
        hours: hrs,
        workType: 'work',
        billingType: row.billingType,
        taskId: linkedTask ? linkedTask.id : null,
        project: projectName,
        description: row.description || (linkedTask ? (linkedTask.description || linkedTask.title) : 'General work')
      });
    }
  });

  if (!entries.length) return toast('Enter hours for at least one day', 'error');

  var sortedDates = entries.map(function(e){ return e.date; }).sort();
  var notes = document.getElementById('ts-notes').value;
  try {
    if (editingTsId) {
      await api('PUT', '/timesheets/' + editingTsId, { entries: entries, notes: notes });
      toast('Timesheet updated and resubmitted!', 'success');
    } else {
      await api('POST', '/timesheets', { weekStart: sortedDates[0], weekEnd: sortedDates[sortedDates.length - 1], entries: entries, notes: notes });
      toast('Timesheet submitted!', 'success');
    }
    closeModal('ts-modal');
    loadTimesheets();
  } catch(e) { toast(e.message, 'error'); }
}

loadAssignedTasks();
loadTimesheets();
</script>
</body></html>



