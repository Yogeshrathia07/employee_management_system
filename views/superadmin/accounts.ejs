══════════════════════════════════════════════════════════ */
var editingQuoId = null;

function renderQuotations() {
  var q = (document.getElementById('quo-search').value||'').toLowerCase();
  var st = document.getElementById('quo-status').value;
  api('GET', '/quotations').then(function(data) {
    var filtered = (data||[]).filter(function(r) {
      return (!q || (r.clientName||'').toLowerCase().includes(q) || (r.quotationNumber||'').toLowerCase().includes(q))
          && (!st || r.status === st);
    });
    document.getElementById('quo-body').innerHTML = filtered.length ? filtered.map(function(r) {
      var convBadge = r.status === 'Converted'
