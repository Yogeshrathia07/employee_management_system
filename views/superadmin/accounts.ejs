var editingQuoId = null;

function openQuoModal(id) {
  editingQuoId = id || null;
  document.getElementById('doc-type').value = 'quo';
  document.getElementById('doc-modal-title').textContent = id ? 'Edit Quotation' : 'New Quotation';
  document.getElementById('doc-party-label').textContent = 'Client Name';
  document.getElementById('doc-date2-label').textContent = 'Valid Till';
  document.getElementById('doc-status').innerHTML = '<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>';
  document.getElementById('doc-items').innerHTML = '';
  if (id) {
    api('GET', '/quotations/'+id).then(function(r) {
      document.getElementById('doc-id').value    = r.quotationNumber || '';
      document.getElementById('doc-party').value = r.clientName || '';
      document.getElementById('doc-date').value  = r.date || '';
      document.getElementById('doc-date2').value = r.validTill || '';
      document.getElementById('doc-status').value= r.status || 'Draft';
      document.getElementById('doc-notes').value = r.notes || '';
      (r.items||[]).forEach(function(it){ addLineItemRow(document.getElementById('doc-items'), it); });
      updateDocTotal();
    }).catch(function(e){ toast(e.message,'error'); });
  } else {
    document.getElementById('doc-id').value    = '';
    document.getElementById('doc-party').value = '';
    document.getElementById('doc-date').value  = today();
    document.getElementById('doc-date2').value = '';
    document.getElementById('doc-status').value= 'Draft';
    document.getElementById('doc-notes').value = '';
    addLineItemRow(document.getElementById('doc-items'), null);
    updateDocTotal();
  }
  openModal('doc-modal');
}

async function saveDoc() {
  var type = document.getElementById('doc-type').value;
  if (type !== 'quo') return;
  var items = getDocItems(document.getElementById('doc-items'));
  var total = items.reduce(function(s,it){return s+(it.qty||0)*(it.rate||0);},0);
  var clientName = document.getElementById('doc-party').value;
  if (!clientName) return toast('Client name required','error');
  var data = {
    clientName: clientName,
    date:       document.getElementById('doc-date').value,
    validTill:  document.getElementById('doc-date2').value,
    status:     document.getElementById('doc-status').value,
    notes:      document.getElementById('doc-notes').value,
    items:      items,
    totalAmount:total,
    subtotal:   total,
  };
  try {
    if (editingQuoId) await api('PUT', '/quotations/'+editingQuoId, data);
    else await api('POST', '/quotations', data);
    closeModal('doc-modal');
    renderQuotations();
    toast('Quotation saved!','success');
  } catch(e){ toast(e.message||'Error','error'); }
}

async function deleteQuo(id) {
  if(!confirm('Delete this quotation?')) return;
  try { await api('DELETE', '/quotations/'+id); renderQuotations(); toast('Deleted','success'); }
  catch(e){ toast(e.message,'error'); }
}

