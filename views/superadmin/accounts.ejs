/* ── Invoice number settings (FY + company code) ───────── */
function initInvSettings() {
  var sel = document.getElementById('inv-fy-sel');
  if (!sel || sel.options.length > 0) { updateInvNumPreview(); return; }
  var now = new Date(), yr = now.getFullYear(), mo = now.getMonth() + 1;
  var startYear = mo >= 4 ? yr : yr - 1;
  var firstYear = 2018;
  var lastYear = startYear + 5;
  var html = '';
  for (var i = firstYear; i <= lastYear; i++) {
    var fy = String(i).slice(-2) + '-' + String(i+1).slice(-2);
    var selected = (i === startYear) ? ' selected' : '';
    html += '<option value="' + fy + '"' + selected + '>' + i + '-' + (i+1) + '</option>';
  }
  sel.innerHTML = html;
  // Restore saved values
  var savedCode = localStorage.getItem('inv_company_code') || '';
  var savedFY   = localStorage.getItem('inv_fy') || '';
  if (savedCode) document.getElementById('inv-company-code').value = savedCode.toUpperCase();
  if (savedFY && sel.querySelector('option[value="'+savedFY+'"]')) sel.value = savedFY;
  updateInvNumPreview();
}

/* ── India GST States ───────────────────────────────────── */
var INDIA_STATES = [
  {name:'Andaman & Nicobar Islands',               code:'35'},
  {name:'Andhra Pradesh',                           code:'37'},
  {name:'Arunachal Pradesh',                        code:'12'},
  {name:'Assam',                                    code:'18'},
