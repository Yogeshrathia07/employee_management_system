};

savePO = function() {
  var projectEl = document.getElementById('po-project');
  var vendorName = document.getElementById('po-vendor').value || '';
  var poId = document.getElementById('po-id').value;
  rememberCustomer(vendorName);
  rememberProject(projectEl ? projectEl.value : '');
  return Promise.resolve(_savePO()).then(function() {
    var arr = load('po');
    var idx = arr.findIndex(function(item){ return item.id === poId; });
    if (idx >= 0 && projectEl) arr[idx].project = projectEl.value || '';
    save('po', arr);
    refreshAccountsDataLists();
    refreshAccountCounts();
  });
};

