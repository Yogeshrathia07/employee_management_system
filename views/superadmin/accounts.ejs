  {name:'Dadra & Nagar Haveli and Daman & Diu',    code:'26'},
  {name:'Delhi',                                    code:'07'},
  {name:'Goa',                                      code:'30'},
  {name:'Gujarat',                                  code:'24'},
  {name:'Haryana',                                  code:'06'},
  {name:'Himachal Pradesh',                         code:'02'},
  {name:'Jammu & Kashmir',                          code:'01'},
  {name:'Jharkhand',                                code:'20'},
  {name:'Karnataka',                                code:'29'},
  {name:'Kerala',                                   code:'32'},
  {name:'Ladakh',                                   code:'38'},
  {name:'Lakshadweep',                              code:'31'},
  {name:'Madhya Pradesh',                           code:'23'},
  {name:'Maharashtra',                              code:'27'},
  {name:'Manipur',                                  code:'14'},
  {name:'Meghalaya',                                code:'17'},
  {name:'Mizoram',                                  code:'15'},
  {name:'Nagaland',                                 code:'13'},
  {name:'Odisha',                                   code:'21'},
  {name:'Other Territory',                          code:'97'},
  {name:'Puducherry',                               code:'34'},
  {name:'Punjab',                                   code:'03'},
  {name:'Rajasthan',                                code:'08'},
  {name:'Sikkim',                                   code:'11'},
  {name:'Tamil Nadu',                               code:'33'},
  {name:'Telangana',                                code:'36'},
  {name:'Tripura',                                  code:'16'},
  {name:'Uttar Pradesh',                            code:'09'},
  {name:'Uttarakhand',                              code:'05'},
  {name:'West Bengal',                              code:'19'},
];

function syncStateCode(selectEl, codeInputId) {
  var opt = selectEl.options[selectEl.selectedIndex];
  var el  = document.getElementById(codeInputId);
  if (!el) return;
  var code = (opt && opt.dataset.code) ? opt.dataset.code : '';
  if (!code && selectEl.value) {
    var normalized = normalizeAccountStateName(selectEl.value, el.value);
    var match = INDIA_STATES.find(function(s) { return s.name.toLowerCase() === normalized.toLowerCase(); });
    code = match ? match.code : '';
    if (opt && code) opt.dataset.code = code;
  }
  el.value = code;
}

var ACCOUNT_STATE_FIELDS = {
  'gst-s-state': 'gst-s-code',
  'gst-c-state': 'gst-c-code',
  'pro-s-state': 'pro-s-code',
  'pro-c-state': 'pro-c-code',
  'ven-state': 'ven-statecode',
  'clt-state': 'clt-statecode'
};

function normalizeAccountStateName(value, stateCode) {
  value = String(value || '').trim();
  stateCode = String(stateCode || '').trim();
  if (!value && stateCode) {
    var byCodeOnly = INDIA_STATES.find(function(s) { return s.code === stateCode.padStart(2, '0'); });
    return byCodeOnly ? byCodeOnly.name : '';
  }
  if (!value) return '';
  var cleaned = value.replace(/\s*\(\d{2}\)\s*$/, '').trim();
  var direct = INDIA_STATES.find(function(s) {
    return s.name.toLowerCase() === cleaned.toLowerCase();
  });
  if (direct) return direct.name;
  var codeMatch = value.match(/\((\d{2})\)$/) || value.match(/^(\d{2})$/);
  if (codeMatch) {
    var byCode = INDIA_STATES.find(function(s) { return s.code === codeMatch[1]; });
    if (byCode) return byCode.name;
  }
  if (stateCode) {
    var byExplicitCode = INDIA_STATES.find(function(s) { return s.code === stateCode.padStart(2, '0'); });
    if (byExplicitCode) return byExplicitCode.name;
  }
  return cleaned || value;
}

function accountStateCodeFromGstin(gstin) {
  var m = String(gstin || '').trim().match(/^(\d{2})/);
  if (!m) return '';
  return INDIA_STATES.some(function(s) { return s.code === m[1]; }) ? m[1] : '';
}

function setAccountStateValue(selectId, codeInputId, state, stateCode) {
  var sel = document.getElementById(selectId);
  if (!sel) return;
  stateCode = String(stateCode || '').trim();
  if (stateCode.length === 1) stateCode = '0' + stateCode;
  var normalized = normalizeAccountStateName(state, stateCode);
  var matched = normalized ? INDIA_STATES.find(function(s) {
    return s.name.toLowerCase() === normalized.toLowerCase();
  }) : null;
  if (matched) {
    normalized = matched.name;
    stateCode = stateCode || matched.code;
  }
  if (normalized) {
    sel.value = normalized;
    if (sel.value !== normalized) {
      var legacyOpt = document.createElement('option');
      legacyOpt.value = normalized;
      legacyOpt.textContent = normalized + (stateCode ? ' (' + stateCode + ')' : '');
      if (stateCode) legacyOpt.dataset.code = stateCode;
      sel.appendChild(legacyOpt);
      sel.value = normalized;
    }
    var selectedOpt = sel.options[sel.selectedIndex];
    if (selectedOpt && stateCode && !selectedOpt.dataset.code) selectedOpt.dataset.code = stateCode;
  } else {
    sel.value = '';
  }
  var codeEl = document.getElementById(codeInputId);
  if (codeEl) {
    codeEl.value = stateCode || '';
    if (!codeEl.value) syncStateCode(sel, codeInputId);
  }
}

// Convert "Feb-26" → "2026-02" for <input type="month">
function monthToInput(val) {
  if (!val) return '';
  var MONTHS = {jan:'01',feb:'02',mar:'03',apr:'04',may:'05',jun:'06',
                jul:'07',aug:'08',sep:'09',oct:'10',nov:'11',dec:'12'};
  var m = val.match(/^([A-Za-z]{3})-(\d{2})$/);
  if (!m) return '';
  var mm = MONTHS[m[1].toLowerCase()];
  if (!mm) return '';
  var yy = parseInt(m[2], 10);
  var yyyy = yy < 50 ? 2000 + yy : 1900 + yy;
  return yyyy + '-' + mm;
}

// Convert "2026-02" → "Feb-26" for storage
function monthFromInput(val) {
  if (!val) return '';
  var m = val.match(/^(\d{4})-(\d{2})$/);
  if (!m) return val;
  var NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return NAMES[parseInt(m[2], 10) - 1] + '-' + m[1].slice(2);
}

function accountPreviewCode(prefix) {
  return prefix + '-' + Math.random().toString(36).slice(2, 8).toUpperCase();
}

function accountDateParts(val) {
  if (!val) return { year:'', month:'' };
  var d = new Date(val);
  if (isNaN(d)) {
    var m = String(val).match(/^(\d{4})-(\d{2})/);
    return m ? { year:m[1], month:m[2] } : { year:'', month:'' };
  }
  return { year:String(d.getFullYear()), month:('0' + (d.getMonth() + 1)).slice(-2) };
}

function populateAccountDateFilters(prefix, rows, dateKey) {
  var yearEl = document.getElementById(prefix + '-year');
  var monthEl = document.getElementById(prefix + '-month');
  if (!yearEl || !monthEl) return;
  var selectedYear = yearEl.value;
  var selectedMonth = monthEl.value;
  var currentYear = String(new Date().getFullYear());
  var years = Array.from(new Set((rows || []).map(function(r) {
    return accountDateParts(r[dateKey]).year;
  }).filter(Boolean)));
  if (years.indexOf(currentYear) === -1) years.push(currentYear);
  if (selectedYear && years.indexOf(selectedYear) === -1) years.push(selectedYear);
  years.sort(function(a, b) { return Number(b) - Number(a); });
  yearEl.innerHTML = '<option value="">All Years</option>' + years.map(function(y) {
    return '<option value="' + y + '">' + y + '</option>';
  }).join('');
  yearEl.value = selectedYear || '';

  var monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  monthEl.innerHTML = '<option value="">All Months</option>' + monthNames.map(function(name, idx) {
    var value = ('0' + (idx + 1)).slice(-2);
    return '<option value="' + value + '">' + name + '</option>';
  }).join('');
  monthEl.value = selectedMonth || '';
}

function matchesAccountDateFilter(row, dateKey, year, month) {
  if (!year && !month) return true;
  var parts = accountDateParts(row[dateKey]);
  return (!year || parts.year === year) && (!month || parts.month === month);
}

function populateStateSelects() {
  Object.keys(ACCOUNT_STATE_FIELDS).forEach(function(id) {
    var sel = document.getElementById(id);
    if (!sel || sel.tagName !== 'SELECT') return;
    var prev = sel.value;
    var codeId = ACCOUNT_STATE_FIELDS[id];
    var prevCode = document.getElementById(codeId) ? document.getElementById(codeId).value : '';
    sel.innerHTML = '<option value="">— Select State —</option>';
    INDIA_STATES.forEach(function(s) {
      var o = document.createElement('option');
      o.value = s.name;
      o.dataset.code = s.code;
      o.textContent  = s.name + ' (' + s.code + ')';
      sel.appendChild(o);
    });
    if (prev || prevCode) setAccountStateValue(id, codeId, prev, prevCode);
  });
}

function syncAllAccountStateCodes() {
  Object.keys(ACCOUNT_STATE_FIELDS).forEach(function(id) {
    var sel = document.getElementById(id);
    if (sel) syncStateCode(sel, ACCOUNT_STATE_FIELDS[id]);
  });
}

