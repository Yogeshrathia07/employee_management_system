/* Shared account document preview / print / PDF-save helper.
   These override the older simple print helpers above so every Accounts module
   gets the same compact invoice-style document format. */
var currentAccountDoc = { title:'Document', html:'' };

function accEsc(v) {
  if (v === null || v === undefined) return '';
  return String(v).replace(/[&<>"']/g, function(ch) {
    return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch];
  });
}
function accMoney(v) {
  return 'Rs. ' + Number(v || 0).toLocaleString('en-IN', { minimumFractionDigits:2, maximumFractionDigits:2 });
}
function accDate(v) {
  return v ? fmtD(v) : '';
}
function accDocMeta(kind) {
  var map = {
    inv:{path:'/invoices/', pdfPath:'/invoices/', filePrefix:'Invoice', title:'TAX INVOICE', number:'invoiceNumber', party:'customerName', partyLabel:'Bill To'},
    pro:{path:'/proformas-db/', pdfPath:'/proformas-db/', filePrefix:'Proforma', title:'PROFORMA INVOICE', number:'proformaNumber', party:'customerName', partyLabel:'Bill To'},
    quo:{path:'/quotations/', pdfPath:'/quotations/', filePrefix:'Quotation', title:'QUOTATION', number:'quotationNumber', party:'clientName', partyLabel:'Quote To'},
    po:{path:'/purchase-orders/', pdfPath:'/purchase-orders/', filePrefix:'PO', title:'PURCHASE ORDER', number:'poNumber', party:'vendorName', partyLabel:'Vendor'},
    clt:{path:'/clients/', title:'CLIENT PROFILE', number:'clientCode', party:'name', partyLabel:'Client'},
    ven:{path:'/vendors/', title:'VENDOR PROFILE', number:'vendorCode', party:'name', partyLabel:'Vendor'},
    cwo:{path:'/work-orders/', pdfPath:'/work-orders/', filePrefix:'CWO', title:'CLIENT WORK ORDER', number:'woNumber', party:'partyName', partyLabel:'Client'},
    vwo:{path:'/work-orders/', pdfPath:'/work-orders/', filePrefix:'VWO', title:'VENDOR WORK ORDER', number:'woNumber', party:'partyName', partyLabel:'Vendor'},
    prj:{path:'/project-accounts/', pdfPath:'/project-accounts/', filePrefix:'Project', title:'PROJECT ACCOUNT', number:'projectCode', party:'clientName', partyLabel:'Client'}
  };
  return map[kind] || map.pro;
}
function accNormalizeItems(rec) {
  return (rec.items || []).map(function(it) {
    var qty = Number(it.quantity || it.qty || 0);
    var rate = Number(it.unitPrice || it.rate || 0);
    var amount = Number(it.itemTotal || it.total || it.amount || (qty * rate));
    return {
      code: it.itemCode || it.code || '',
      name: it.name || it.description || it.itemName || '',
      hsn: it.hsnCode || it.hsn || '',
      qty: qty,
      unit: it.unit || '',
      rate: rate,
      taxRate: Number(it.taxRate || 0),
      amount: amount
    };
  });
}
function accDetailRows(rows) {
  return rows.filter(function(r) {
    return r[1] !== null && r[1] !== undefined && r[1] !== '';
  }).map(function(r) {
    return '<tr><th style="width:30%;padding:6px 8px;border:1px solid #111;text-align:left;background:#f5f5f5;">' + accEsc(r[0]) + '</th><td style="padding:6px 8px;border:1px solid #111;">' + accEsc(r[1]) + '</td></tr>';
  }).join('');
}
function accProfileView(title, rec, rows) {
  var code = rec.clientCode || rec.vendorCode || '';
  var status = rec.status || 'Active';
  var fields = rows.filter(function(r) {
    return r[1] !== null && r[1] !== undefined && r[1] !== '';
  }).map(function(r) {
    return '<div class="acc-profile-field"><div class="acc-profile-label">' + accEsc(r[0]) + '</div><div class="acc-profile-value">' + accEsc(r[1]) + '</div></div>';
  }).join('');
  return {
    title: title + (code ? ' - ' + code : ''),
    html: '<div class="acc-profile-view">' +
      '<div class="acc-profile-hero">' +
        '<div><div class="acc-profile-title">' + accEsc(rec.name || title) + '</div><div class="acc-profile-subtitle">' + accEsc(code || title) + '</div></div>' +
        '<span class="acc-profile-status">' + accEsc(status) + '</span>' +
      '</div>' +
      '<div class="acc-profile-grid">' + fields + '</div>' +
    '</div>',
    profileOnly: true
  };
}
