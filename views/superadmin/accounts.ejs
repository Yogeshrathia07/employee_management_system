          <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #e5e7eb;"><span style="color:#6b7280;">Total Amount</span><span id="gst-sum-sub" style="font-weight:600;color:#111;">₹0.00</span></div>
          <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #e5e7eb;" id="gst-sum-sgst-row"><span style="color:#6b7280;" id="gst-sum-sgst-label">SGST (9%)</span><span id="gst-sum-sgst" style="font-weight:600;color:#111;">₹0.00</span></div>
          <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #e5e7eb;" id="gst-sum-cgst-row"><span style="color:#6b7280;" id="gst-sum-cgst-label">CGST (9%)</span><span id="gst-sum-cgst" style="font-weight:600;color:#111;">₹0.00</span></div>
          <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #e5e7eb;" id="gst-sum-igst-row" style="display:none;"><span style="color:#6b7280;" id="gst-sum-igst-label">IGST (18%)</span><span id="gst-sum-igst" style="font-weight:600;color:#111;">₹0.00</span></div>
          <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #e5e7eb;"><span style="color:#6b7280;">Round Off</span><span id="gst-sum-round" style="font-weight:600;color:#111;">₹0.00</span></div>
          <div style="display:flex;justify-content:space-between;padding:10px 0;grid-column:1/-1;border-top:2px solid #111;margin-top:4px;"><span style="font-size:14px;font-weight:700;color:#111;">Amount After Tax</span><span id="gst-sum-total" style="font-size:16px;font-weight:800;color:#111;">₹0.00</span></div>
        </div>
        <div id="gst-sum-tax-hint" style="font-size:11px;color:#9ca3af;margin-top:6px;"></div>
      </div>

      <!-- Bank Details -->
      <div class="gst-section" style="border-top:1px solid var(--border);">
        <div class="gst-section-title" style="color:#111827;"><i class="bx bxs-bank"></i> Bank Details <span style="font-size:11px;font-weight:400;color:#888;">(for payment &amp; PDF)</span></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Bank Name</label>
            <input type="text" id="gst-bank-name" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="e.g. State Bank of India">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Account Holder Name</label>
            <input type="text" id="gst-bank-acname" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="Name on bank account">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-top:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Account Number</label>
            <input type="text" id="gst-bank-ac" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="Bank account number">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">IFSC Code</label>
            <input type="text" id="gst-bank-ifsc" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;text-transform:uppercase;" placeholder="SBIN0001234">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Branch</label>
            <input type="text" id="gst-bank-branch" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="Branch name">
          </div>
        </div>
      </div>

      <!-- Notes / Terms & Conditions -->
      <div class="gst-section" style="border-top:1px solid var(--border);">
        <div class="gst-section-title"><i class="bx bxs-notepad"></i> Notes / Terms &amp; Conditions</div>
        <textarea id="gst-notes" rows="4" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;resize:vertical;box-sizing:border-box;" placeholder="Payment terms, etc."></textarea>
      </div>
    </div>

    <!-- Footer -->
    <div class="modal-footer acc-form-modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('gst-inv-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveGSTInvoice()"><i class="bx bxs-receipt"></i> Save Invoice</button>
    </div>
  </div>
</div>

