/* ── Render Invoice List ────────────────────────────────── */
function renderInvoices() {
  var q  = (document.getElementById('inv-search').value || '').trim();
  var st = document.getElementById('inv-status').value;
  var tp = document.getElementById('inv-type').value;
  var yr = document.getElementById('inv-year') ? document.getElementById('inv-year').value : '';
  var mo = document.getElementById('inv-month') ? document.getElementById('inv-month').value : '';
  var params = new URLSearchParams();
  if (q)  params.set('q', q);
  if (st) params.set('status', st);
  if (tp) params.set('type', tp);

  api('GET', '/invoices?' + params.toString())
    .then(function(data) {
      var tbody = document.getElementById('inv-body');
      data = data || [];
      populateAccountDateFilters('inv', data, 'invoiceDate');
      yr = document.getElementById('inv-year') ? document.getElementById('inv-year').value : yr;
      mo = document.getElementById('inv-month') ? document.getElementById('inv-month').value : mo;
      data = data.filter(function(r) { return matchesAccountDateFilter(r, 'invoiceDate', yr, mo); });
      if (!data.length) { tbody.innerHTML = emptyRow(7); setTabCount('tab-count-inv', 0); return; }

      tbody.innerHTML = data.map(function(r) {
        var typeLabel = r.invoiceType === 'B2C' ? 'Tax Invoice (B2C)' : 'Tax Invoice';
        var typeColor = r.invoiceType === 'B2C' ? '#7c3aed' : '#1d4ed8';
        var typeBg    = r.invoiceType === 'B2C' ? '#ede9fe' : '#dbeafe';

        var _isSuperAdmin = (getUser() || {}).role === 'superadmin';
        var invItems = [
          {icon:'bxl-whatsapp',  label:'Share on WhatsApp', fn:'shareWhatsApp(\''+r.invoiceNumber+'\','+r.totalAmount+')'},
          {icon:'bx-show',       label:'View PDF',          fn:'viewAccountDoc(\'inv\','+r.id+')'},
          {icon:'bx-download',   label:'Download PDF',      fn:'downloadAccountDoc(\'inv\','+r.id+')'},
          {icon:'bx-printer',    label:'Print',             fn:'printAccountDoc(\'inv\','+r.id+')'},
        ];
        if (r.paymentStatus !== 'Paid') invItems.push({icon:'bx-check-circle', label:'Mark as Paid', fn:'openMarkPaid('+r.id+',\''+r.invoiceNumber+'\')'});
        invItems.push({icon:'bx-edit-alt', label:'Edit', fn:'openGSTModal('+r.id+')'});
        if (_isSuperAdmin) invItems.push({icon:'bx-trash', label:'Delete', fn:'deleteInvoice('+r.id+',\''+r.invoiceNumber+'\')', danger:true});
        var actionBtns = accMenuBtn(invItems);

        return '<tr class="inv-row">' +
'<td class="acc-td" style="font-weight:700;color:var(--accent);font-size:12px;white-space:nowrap;">' + (r.invoiceNumber||'') + '</td>' +
          '<td class="acc-td"><span style="font-size:11px;font-weight:700;background:'+typeBg+';color:'+typeColor+';border-radius:6px;padding:3px 9px;">'+typeLabel+'</span></td>' +
          '<td class="acc-td"><div style="font-weight:600;font-size:13px;">' + (r.customerName||'') + '</div>' +
            (r.customerGstin ? '<div style="font-size:10px;color:var(--text-muted);margin-top:1px;">'+r.customerGstin+'</div>' : '') + '</td>' +
          '<td class="acc-td" style="white-space:nowrap;font-size:12px;">' + fmtD(r.invoiceDate) + '</td>' +
          '<td class="acc-td" style="font-weight:700;white-space:nowrap;">₹' + Number(r.totalAmount||0).toLocaleString('en-IN', {minimumFractionDigits:2}) + '</td>' +
          '<td class="acc-td">' + badge(r.status) + '</td>' +
          '<td class="acc-td" style="white-space:nowrap;">' + actionBtns + '</td>' +
        '</tr>';
      }).join('');

      setTabCount('tab-count-inv', data.length);
    })
    .catch(function(err) {
      document.getElementById('inv-body').innerHTML =
        '<tr><td colspan="7" style="padding:40px;text-align:center;">' +
          '<div style="color:#ef4444;font-weight:600;margin-bottom:6px;"><i class="bx bx-error-circle"></i> Failed to load invoices</div>' +
          '<div style="font-size:12px;color:var(--text-muted);">Please restart the server so the Invoices table is created, then refresh.</div>' +
        '</td></tr>';
    });
}

/* ── Print Invoice ──────────────────────────────────────── */
function printInvoice(id) {
  var token = getToken();
  fetch('/api/invoices/' + id + '/pdf', { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r) { return r.blob(); })
    .then(function(blob) {
      var url = URL.createObjectURL(blob);
      var win = window.open(url);
      if (win) {
        win.addEventListener('load', function() { win.print(); });
      } else {
        toast('Allow popups to use Print', 'error');
      }
    })
    .catch(function() { toast('Print failed', 'error'); });
}

/* ── Preview Invoice ────────────────────────────────────── */
function previewInvoice(id) {
  api('GET', '/invoices/' + id).then(function(inv) {
    var useIGST = inv.sellerStateCode && inv.customerStateCode && inv.sellerStateCode !== inv.customerStateCode;
    var items   = inv.items || [];
    var fmt = function(n) { return '₹' + Number(n||0).toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2}); };

    var statusColor = {Draft:'#64748b',Sent:'#3b82f6',Paid:'#22c55e',Overdue:'#ef4444',Cancelled:'#94a3b8'}[inv.status] || '#64748b';

    var TD = 'padding:7px 10px;font-size:12px;border-bottom:1px solid #f1f5f9;vertical-align:top;';
    var itemRows = items.map(function(it, i) {
      var dataRow =
        '<tr>' +
          '<td style="' + TD + 'color:#64748b;text-align:center;">' + (i+1) + '</td>' +
          '<td style="' + TD + '">' + (it.itemCode && it.itemCode !== 'N/A' ? it.itemCode : '—') + '</td>' +
          '<td style="' + TD + '">' + (it.hsnCode || '—') + '</td>' +
          '<td style="' + TD + 'text-align:center;">' + (it.unit || '—') + '</td>' +
          '<td style="' + TD + 'text-align:right;">' + fmt(it.unitPrice) + '</td>' +
          '<td style="' + TD + 'text-align:center;">' + (it.quantity||0) + '</td>' +
          (useIGST
            ? '<td style="' + TD + 'text-align:center;color:#7c3aed;">' + (it.taxRate||0) + '%</td>' +
              '<td style="' + TD + 'text-align:right;color:#7c3aed;">' + fmt(it.igst) + '</td>'
            : '<td style="' + TD + 'text-align:center;color:#0891b2;">' + ((it.taxRate||0)/2) + '%</td>' +
              '<td style="' + TD + 'text-align:right;color:#0891b2;">' + fmt(it.cgst) + '</td>' +
              '<td style="' + TD + 'text-align:center;color:#0891b2;">' + ((it.taxRate||0)/2) + '%</td>' +
              '<td style="' + TD + 'text-align:right;color:#0891b2;">' + fmt(it.sgst) + '</td>') +
          '<td style="' + TD + 'text-align:right;font-weight:700;">' + fmt(it.itemTotal) + '</td>' +
        '</tr>';
      var descRow = it.name
        ? '<tr><td colspan="' + (useIGST ? 9 : 11) + '" style="padding:4px 10px 8px 10px;font-size:12px;color:#475569;background:#f8fafc;border-bottom:1px solid #e2e8f0;">' + it.name + '</td></tr>'
        : '';
      return dataRow + descRow;
    }).join('');

    var html =
      '<div style="padding:24px;font-family:\'DM Sans\',sans-serif;">' +

      /* ── Top bar: invoice number + status badge ── */
      '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">' +
        '<div>' +
          '<div style="font-size:11px;font-weight:600;text-transform:uppercase;color:#94a3b8;letter-spacing:.5px;margin-bottom:3px;">' + (inv.invoiceType==='B2B'?'B2B Tax Invoice':'B2C Invoice') + '</div>' +
          '<div style="font-size:20px;font-weight:800;color:var(--text-primary);">' + (inv.invoiceNumber||'—') + '</div>' +
          '<div style="font-size:12px;color:#64748b;margin-top:3px;">Date: ' + fmtD(inv.invoiceDate) + (inv.dueDate ? ' &nbsp;|&nbsp; Due: ' + fmtD(inv.dueDate) : '') + '</div>' +
        '</div>' +
        '<div style="text-align:right;">' +
          '<span style="background:' + statusColor + '22;color:' + statusColor + ';font-size:12px;font-weight:700;padding:5px 14px;border-radius:20px;border:1px solid ' + statusColor + '44;">' + (inv.status||'Draft') + '</span>' +
          '<div style="font-size:12px;color:#64748b;margin-top:6px;">' + (inv.placeOfSupply ? 'Supply: '+inv.placeOfSupply : '') + '</div>' +
        '</div>' +
      '</div>' +

      /* ── Seller + Customer cards ── */
      '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">' +
        '<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:14px;">' +
          '<div style="font-size:10px;font-weight:700;text-transform:uppercase;color:#94a3b8;letter-spacing:.5px;margin-bottom:8px;"><i class="bx bxs-buildings" style="font-size:12px;"></i> From (Seller)</div>' +
          '<div style="font-size:14px;font-weight:700;color:var(--text-primary);">' + (inv.sellerName||'—') + '</div>' +
          (inv.sellerGstin ? '<div style="font-size:11px;color:#64748b;margin-top:3px;">GSTIN: ' + inv.sellerGstin + (inv.sellerPan ? ' &nbsp;|&nbsp; PAN: '+inv.sellerPan : '') + '</div>' : '') +
          (inv.sellerAddress ? '<div style="font-size:11px;color:#64748b;margin-top:3px;">' + inv.sellerAddress + '</div>' : '') +
          (inv.sellerState ? '<div style="font-size:11px;color:#64748b;">' + inv.sellerState + (inv.sellerStateCode ? ' (' + inv.sellerStateCode + ')' : '') + '</div>' : '') +
          ((inv.sellerPhone||inv.sellerEmail) ? '<div style="font-size:11px;color:#64748b;margin-top:3px;">' + [inv.sellerPhone, inv.sellerEmail].filter(Boolean).join(' | ') + '</div>' : '') +
        '</div>' +
        '<div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:10px;padding:14px;">' +
          '<div style="font-size:10px;font-weight:700;text-transform:uppercase;color:#0891b2;letter-spacing:.5px;margin-bottom:8px;"><i class="bx bxs-user-detail" style="font-size:12px;"></i> Bill To (Customer)</div>' +
          '<div style="font-size:14px;font-weight:700;color:var(--text-primary);">' + (inv.customerName||'—') + '</div>' +
          (inv.customerGstin ? '<div style="font-size:11px;color:#64748b;margin-top:3px;">GSTIN: ' + inv.customerGstin + (inv.customerPan ? ' &nbsp;|&nbsp; PAN: '+inv.customerPan : '') + '</div>' : '') +
          (inv.customerAddress ? '<div style="font-size:11px;color:#64748b;margin-top:3px;">' + inv.customerAddress + '</div>' : '') +
          (inv.customerState ? '<div style="font-size:11px;color:#64748b;">' + inv.customerState + (inv.customerStateCode ? ' (' + inv.customerStateCode + ')' : '') + '</div>' : '') +
          (inv.customerEmail ? '<div style="font-size:11px;color:#64748b;margin-top:3px;">' + inv.customerEmail + '</div>' : '') +
        '</div>' +
      '</div>' +

      /* ── Work / Bill period (if present) ── */
      ((inv.workOrder || inv.projectName || inv.billMonth)
        ? '<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:12px 14px;margin-bottom:16px;display:flex;gap:24px;flex-wrap:wrap;">' +
            (inv.billMonth ? '<div><div style="font-size:10px;color:#92400e;font-weight:600;text-transform:uppercase;">Bill Month</div><div style="font-size:12px;font-weight:700;">' + inv.billMonth + '</div></div>' : '') +
            ((inv.billPeriodFrom && inv.billPeriodTo) ? '<div><div style="font-size:10px;color:#92400e;font-weight:600;text-transform:uppercase;">Bill Period</div><div style="font-size:12px;font-weight:700;">' + fmtD(inv.billPeriodFrom) + ' – ' + fmtD(inv.billPeriodTo) + '</div></div>' : '') +
            (inv.workOrder ? '<div><div style="font-size:10px;color:#92400e;font-weight:600;text-transform:uppercase;">Work Order</div><div style="font-size:12px;font-weight:700;">' + inv.workOrder + '</div></div>' : '') +
            (inv.projectName ? '<div><div style="font-size:10px;color:#92400e;font-weight:600;text-transform:uppercase;">Project</div><div style="font-size:12px;font-weight:700;">' + inv.projectName + '</div></div>' : '') +
          '</div>'
        : '') +

      /* ── Items table ── */
      '<div style="border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;margin-bottom:16px;">' +
        '<div style="background:#f8fafc;padding:10px 12px;font-size:11px;font-weight:700;text-transform:uppercase;color:#64748b;letter-spacing:.5px;border-bottom:1px solid #e2e8f0;"><i class="bx bxs-package" style="font-size:13px;color:var(--accent);"></i> Item Details</div>' +
        '<table style="width:100%;border-collapse:collapse;">' +
          '<thead><tr style="background:#f1f5f9;border-bottom:2px solid #e2e8f0;">' +
            '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#64748b;text-align:center;">#</th>' +
            '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#64748b;">Item Code</th>' +
            '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#64748b;">HSN/SAC</th>' +
            '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#64748b;text-align:center;">Unit</th>' +
            '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#64748b;text-align:right;">Rate</th>' +
            '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#64748b;text-align:center;">Qty</th>' +
            (useIGST
              ? '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#7c3aed;text-align:center;">IGST%</th>' +
                '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#7c3aed;text-align:right;">IGST</th>'
              : '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#0891b2;text-align:center;">CGST%</th>' +
                '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#0891b2;text-align:right;">CGST</th>' +
                '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#0891b2;text-align:center;">SGST%</th>' +
                '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#0891b2;text-align:right;">SGST</th>') +
            '<th style="padding:8px 10px;font-size:11px;font-weight:700;color:#64748b;text-align:right;">Amount</th>' +
          '</tr></thead>' +
          '<tbody>' + itemRows + '</tbody>' +
        '</table>' +
      '</div>' +

      /* ── Totals + Bank side by side ── */
      '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">' +
        /* Bank details */
        '<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:14px;">' +
          '<div style="font-size:10px;font-weight:700;text-transform:uppercase;color:#94a3b8;letter-spacing:.5px;margin-bottom:8px;"><i class="bx bxs-bank" style="font-size:12px;"></i> Bank Details</div>' +
          (inv.bankName    ? '<div style="font-size:12px;margin-bottom:4px;"><span style="color:#64748b;">Bank:</span> <strong>' + inv.bankName + '</strong></div>' : '') +
          (inv.bankAcName  ? '<div style="font-size:12px;margin-bottom:4px;"><span style="color:#64748b;">A/c Name:</span> ' + inv.bankAcName + '</div>' : '') +
          (inv.bankAccount ? '<div style="font-size:12px;margin-bottom:4px;"><span style="color:#64748b;">A/c No.:</span> ' + inv.bankAccount + '</div>' : '') +
          (inv.bankIfsc    ? '<div style="font-size:12px;margin-bottom:4px;"><span style="color:#64748b;">IFSC:</span> ' + inv.bankIfsc + (inv.bankBranch ? ' &nbsp;|&nbsp; ' + inv.bankBranch : '') + '</div>' : '') +
          (!inv.bankName && !inv.bankAccount ? '<div style="font-size:12px;color:#94a3b8;">Not provided</div>' : '') +
        '</div>' +
        /* Tax summary */
        '<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">' +
          '<div style="padding:8px 14px;background:var(--bg-card);border-bottom:1px solid #e2e8f0;">' +
            '<div style="display:flex;justify-content:space-between;font-size:12px;padding:4px 0;"><span style="color:#64748b;">Subtotal</span><span style="font-weight:600;">' + fmt(inv.subtotal) + '</span></div>' +
            (useIGST
              ? '<div style="display:flex;justify-content:space-between;font-size:12px;padding:4px 0;"><span style="color:#7c3aed;">IGST</span><span style="font-weight:600;color:#7c3aed;">' + fmt(inv.totalIgst) + '</span></div>'
              : '<div style="display:flex;justify-content:space-between;font-size:12px;padding:4px 0;"><span style="color:#0891b2;">CGST</span><span style="font-weight:600;color:#0891b2;">' + fmt(inv.totalCgst) + '</span></div>' +
                '<div style="display:flex;justify-content:space-between;font-size:12px;padding:4px 0;"><span style="color:#0891b2;">SGST</span><span style="font-weight:600;color:#0891b2;">' + fmt(inv.totalSgst) + '</span></div>') +
            (parseFloat(inv.roundOff) ? '<div style="display:flex;justify-content:space-between;font-size:12px;padding:4px 0;"><span style="color:#64748b;">Round Off</span><span>' + fmt(inv.roundOff) + '</span></div>' : '') +
          '</div>' +
          '<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 14px;background:#f3f4f6;border-top:1px solid #b8c0cc;">' +
            '<span style="font-size:13px;font-weight:700;color:#111827;">Total Amount</span>' +
            '<span style="font-size:18px;font-weight:800;color:#111827;">' + fmt(inv.totalAmount) + '</span>' +
          '</div>' +
        '</div>' +
      '</div>' +

      /* ── Notes / Terms ── */
      ((inv.notes || inv.termsConditions)
        ? '<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:12px 14px;margin-bottom:12px;">' +
            (inv.notes ? '<div style="margin-bottom:6px;"><span style="font-size:11px;font-weight:700;text-transform:uppercase;color:#64748b;">Notes</span><div style="font-size:12px;color:#334155;margin-top:3px;">' + inv.notes + '</div></div>' : '') +
            (inv.termsConditions ? '<div><span style="font-size:11px;font-weight:700;text-transform:uppercase;color:#64748b;">Terms & Conditions</span><div style="font-size:12px;color:#334155;margin-top:3px;">' + inv.termsConditions + '</div></div>' : '') +
          '</div>'
        : '') +

      '<div style="text-align:center;font-size:11px;color:#94a3b8;padding:8px 0;">Computer-generated invoice preview</div>' +
      '</div>';

    document.getElementById('inv-preview-body').innerHTML = html;
    document.getElementById('btn-preview-pdf').onclick = function() {
      downloadInvPDF(id);
    };
    document.getElementById('btn-preview-edit').onclick = function() {
      closeModal('inv-preview-modal');
      openGSTModal(id);
    };
    openModal('inv-preview-modal');
  }).catch(function() { toast('Failed to load invoice', 'error'); });
}

/* ── Mark as Paid ───────────────────────────────────────── */
function openMarkPaid(id, num) {
  document.getElementById('mark-paid-id').value  = id;
  document.getElementById('mark-paid-num').value = num;
  openModal('mark-paid-modal');
}
function confirmMarkPaid() {
  var id   = document.getElementById('mark-paid-id').value;
  var mode = document.getElementById('mark-paid-mode').value;
  api('PATCH', '/invoices/' + id + '/pay', { paymentMode: mode })
    .then(function() { closeModal('mark-paid-modal'); renderInvoices(); refreshAccountCounts(); toast('Marked as Paid!', 'success'); })
    .catch(function() { toast('Failed to mark paid', 'error'); });
}

/* ── Delete Invoice ─────────────────────────────────────── */
function deleteInvoice(id, num) {
  if (!confirm('Delete invoice ' + num + '? This cannot be undone.')) return;
  api('DELETE', '/invoices/' + id)
    .then(function() { renderInvoices(); refreshAccountCounts(); toast('Invoice deleted', 'success'); })
    .catch(function() { toast('Delete failed', 'error'); });
}

/* ── Invoice Reports ────────────────────────────────────── */
function renderInvReports() {
  api('GET', '/invoices').then(function(data) {
    if (!data) data = [];
    // Stat cards
    var total = data.reduce(function(s,r){return s+Number(r.totalAmount||0);},0);
    var paid  = data.filter(function(r){return r.status==='Paid';});
    var unpaid= data.filter(function(r){return r.status==='Overdue'||r.paymentStatus==='Unpaid';});
    var draft = data.filter(function(r){return r.status==='Draft';});
    var statsEl = document.getElementById('inv-report-stats');
    function statCard(label, val, color, bg) {
      return '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;">' +
        '<div style="display:flex;align-items:center;gap:12px;">' +
          '<div style="width:40px;height:40px;border-radius:10px;background:'+bg+';display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;color:'+color+';">₹</div>' +
          '<div><div style="font-size:18px;font-weight:800;color:var(--text-primary);">'+val+'</div><div style="font-size:11px;color:var(--text-muted);">'+label+'</div></div>' +
        '</div></div>';
    }
    statsEl.innerHTML =
      statCard('Total Invoiced', '₹'+total.toLocaleString('en-IN',{minimumFractionDigits:2}), '#1d4ed8', '#dbeafe') +
      statCard('Paid Revenue', '₹'+paid.reduce(function(s,r){return s+Number(r.totalAmount||0);},0).toLocaleString('en-IN',{minimumFractionDigits:2}), '#16a34a', '#dcfce7') +
      statCard('Pending / Overdue', unpaid.length + ' invoice'+(unpaid.length!==1?'s':''), '#dc2626', '#fee2e2') +
      statCard('Drafts', draft.length + ' invoice'+(draft.length!==1?'s':''), '#7c3aed', '#ede9fe');

    // Status breakdown
    var statMap = {};
    data.forEach(function(r){ statMap[r.status]=(statMap[r.status]||0)+1; });
    var statusEl = document.getElementById('inv-report-status');
    var maxV = Math.max.apply(null, Object.values(statMap).concat([1]));
    statusEl.innerHTML = Object.keys(statMap).map(function(k) {
      var sc = STATUS_COLORS[k]||{c:'#64748b',b:'#f1f5f9'};
      var pct = Math.round((statMap[k]/maxV)*100);
      return '<div style="margin-bottom:12px;">'+
        '<div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;"><span style="font-weight:600;">'+k+'</span><span style="color:var(--text-muted);">'+statMap[k]+'</span></div>'+
        '<div style="background:var(--bg-input);border-radius:4px;height:8px;"><div style="width:'+pct+'%;height:100%;background:'+sc.c+';border-radius:4px;transition:width .4s;"></div></div>'+
      '</div>';
    }).join('') || '<div style="color:var(--text-muted);font-size:13px;text-align:center;padding:24px;">No data yet</div>';

    // Top customers
    var custMap = {};
    data.forEach(function(r){ custMap[r.customerName||'Unknown']=(custMap[r.customerName||'Unknown']||0)+Number(r.totalAmount||0); });
    var sorted = Object.entries(custMap).sort(function(a,b){return b[1]-a[1];}).slice(0,5);
    var custEl = document.getElementById('inv-report-customers');
    var maxC = sorted.length ? sorted[0][1] : 1;
    custEl.innerHTML = sorted.map(function(entry) {
      var pct = Math.round((entry[1]/maxC)*100);
      return '<div style="margin-bottom:14px;">'+
        '<div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;"><span style="font-weight:600;">'+entry[0]+'</span><span style="color:var(--text-muted);">₹'+Number(entry[1]).toLocaleString('en-IN',{minimumFractionDigits:2})+'</span></div>'+
        '<div style="background:var(--bg-input);border-radius:4px;height:8px;"><div style="width:'+pct+'%;height:100%;background:#22c55e;border-radius:4px;transition:width .4s;"></div></div>'+
      '</div>';
    }).join('') || '<div style="color:var(--text-muted);font-size:13px;text-align:center;padding:24px;">No data yet</div>';
  }).catch(function(){});
}

/* ── WhatsApp Share ─────────────────────────────────────── */
function shareWhatsApp(num, amount) {
  var msg = 'Dear Customer,\n\nPlease find your invoice details below:\n\n' +
            'Invoice No: ' + num + '\nAmount: ₹' + Number(amount||0).toLocaleString('en-IN', {minimumFractionDigits:2}) + '\n\n' +
            'Kindly make the payment at the earliest. Thank you for your business!\n\n' +
            'Regards';
  window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
}

/* ── Shared PDF open/download helper ───────────────────── */
function openPDF(apiPath, download, filename) {
  var token = getToken();
  fetch('/api' + apiPath, { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r) { if (!r.ok) throw new Error('PDF failed'); return r.blob(); })
    .then(function(blob) {
      var url = URL.createObjectURL(blob);
      if (download) {
        var a = document.createElement('a');
        a.href = url; a.download = filename || 'document.pdf'; a.click();
      } else {
        window.open(url, '_blank');
      }
      setTimeout(function() { URL.revokeObjectURL(url); }, 15000);
    })
    .catch(function() { toast('PDF generation failed', 'error'); });
}
function viewInvPDF(id)      { openPDF('/invoices/'       + id + '/pdf?view=1', false); }
function downloadInvPDF(id)  { openPDF('/invoices/'       + id + '/pdf',        true,  'Invoice-'+id+'.pdf'); }
function viewProPDF(id)      { openPDF('/proformas-db/'   + id + '/pdf?view=1', false); }
function downloadProPDF(id)  { openPDF('/proformas-db/'   + id + '/pdf',        true,  'Proforma-'+id+'.pdf'); }
function viewPOPDF(id)       { openPDF('/purchase-orders/'+ id + '/pdf?view=1', false); }
function downloadPOPDF(id)   { openPDF('/purchase-orders/'+ id + '/pdf',        true,  'PO-'+id+'.pdf'); }
function viewWOPDF(id)       { openPDF('/work-orders/'    + id + '/pdf?view=1', false); }
function downloadWOPDF(id)   { openPDF('/work-orders/'    + id + '/pdf',        true,  'WO-'+id+'.pdf'); }

/* ── Open Proforma PDF in new tab (DB-backed) ───────────── */
function openProformaPDF(id) {
  api('GET', '/proformas-db/' + id).then(function(rec) {
    var token = getToken();
    fetch('/api/proformas/pdf', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify(rec)
    }).then(function(r) { return r.blob(); }).then(function(blob) {
      window.open(URL.createObjectURL(blob), '_blank');
    }).catch(function() { toast('PDF generation failed', 'error'); });
  }).catch(function(e) { toast(e.message || 'Error', 'error'); });
}

/* ── Print Proforma (DB-backed) ─────────────────────────── */
function printProformaById(id) {
  api('GET', '/proformas-db/' + id).then(function(rec) {
    var token = getToken();
    fetch('/api/proformas/pdf', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify(rec)
    }).then(function(r) { return r.blob(); }).then(function(blob) {
      var url = URL.createObjectURL(blob);
      var win = window.open(url);
      if (win) { win.addEventListener('load', function() { win.print(); }); }
      else { toast('Allow popups to use Print', 'error'); }
    }).catch(function() { toast('Print failed', 'error'); });
  }).catch(function(e) { toast(e.message || 'Error', 'error'); });
}

/* ══════════════════════════════════════════════════════════
   LEGACY doc modal (Proforma / Quotations)  ← unchanged
══════════════════════════════════════════════════════════ */
var editingDocId = null, editingDocType = null;
function addLineItemRow(container, item) {
  item = item || {name:'',qty:1,rate:0};
  var div = document.createElement('div');
  div.className = 'line-item-row';
  div.innerHTML = '<input type="text" class="form-control item-name" placeholder="Item description" value="'+escape(item.name||'')+'">'+
    '<input type="number" class="form-control item-qty" placeholder="Qty" value="'+(item.qty||1)+'" min="1" oninput="updateDocTotal()">'+
    '<input type="number" class="form-control item-rate" placeholder="Rate" value="'+(item.rate||0)+'" min="0" oninput="updateDocTotal()">'+
    '<div class="item-total">'+(item.qty&&item.rate?fmtAmt(item.qty*item.rate):'₹0')+'</div>'+
    '<button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove();updateDocTotal()"><i class="bx bx-x"></i></button>';
  div.querySelector('.item-rate').addEventListener('input', function(){ div.querySelector('.item-total').textContent=fmtAmt((parseFloat(div.querySelector('.item-qty').value)||0)*(parseFloat(div.querySelector('.item-rate').value)||0)); });
  div.querySelector('.item-qty').addEventListener('input', function(){ div.querySelector('.item-total').textContent=fmtAmt((parseFloat(div.querySelector('.item-qty').value)||0)*(parseFloat(div.querySelector('.item-rate').value)||0)); });
  container.appendChild(div);
}
function addLineItem() { addLineItemRow(document.getElementById('doc-items'), null); updateDocTotal(); }
function calcDocItems(container) {
  var rows = container.querySelectorAll('.line-item-row'); var total = 0;
  rows.forEach(function(row){ total += (parseFloat(row.querySelector('.item-qty').value)||0) * (parseFloat(row.querySelector('.item-rate').value)||0); });
  return total;
}
function updateDocTotal() {
  var t = calcDocItems(document.getElementById('doc-items'));
  document.getElementById('doc-total-display').textContent = fmtAmt(t);
}
function getDocItems(container) {
  return Array.from(container.querySelectorAll('.line-item-row')).map(function(row){
    return {name:unescape(row.querySelector('.item-name').value), qty:parseFloat(row.querySelector('.item-qty').value)||1, rate:parseFloat(row.querySelector('.item-rate').value)||0};
  });
}
function openDocModal(type) {
  editingDocType = type; editingDocId = null;
  var titles = {pro:'New Proforma Invoice', quo:'New Quotation'};
  document.getElementById('doc-type').value = type;
  document.getElementById('doc-modal-title').textContent = titles[type];
  document.getElementById('doc-party-label').textContent = 'Client Name';
  document.getElementById('doc-date2-label').textContent = 'Valid Till';
  document.getElementById('doc-items').innerHTML = '';
  document.getElementById('doc-status').innerHTML = '<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>';
  document.getElementById('doc-id').value    = genId(type==='pro'?'PRO':'QUO');
  document.getElementById('doc-party').value = '';
  document.getElementById('doc-date').value  = today();
  document.getElementById('doc-date2').value = '';
  document.getElementById('doc-status').value = 'Draft';
  document.getElementById('doc-notes').value = '';
  addLineItemRow(document.getElementById('doc-items'), null);
  updateDocTotal(); openModal('doc-modal');
}
function openDocEditModal(type, id) {
  editingDocType = type; editingDocId = id;
  var rec = load(type).find(function(x){return x.id===id;});
  if (!rec) return;
  var titles = {inv:'Edit Invoice', pro:'Edit Proforma Invoice', quo:'Edit Quotation'};
  document.getElementById('doc-type').value = type;
  document.getElementById('doc-modal-title').textContent = titles[type];
  document.getElementById('doc-party-label').textContent = 'Client Name';
  document.getElementById('doc-date2-label').textContent = type==='inv' ? 'Due Date' : 'Valid Till';
  document.getElementById('doc-items').innerHTML = '';
  var statMap = {inv:'<option>Draft</option><option>Sent</option><option>Paid</option><option>Overdue</option>', pro:'<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>', quo:'<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>'};
  document.getElementById('doc-status').innerHTML = statMap[type];
  document.getElementById('doc-id').value    = rec.id;
  document.getElementById('doc-party').value = rec.client;
  document.getElementById('doc-date').value  = rec.date;
  document.getElementById('doc-date2').value = rec.dueDate||rec.validTill||'';
  document.getElementById('doc-status').value = rec.status;
  document.getElementById('doc-notes').value = rec.notes||'';
  (rec.items||[]).forEach(function(it){ addLineItemRow(document.getElementById('doc-items'), it); });
  updateDocTotal(); openModal('doc-modal');
}
function saveDoc() {
  var type = document.getElementById('doc-type').value;
  var items = getDocItems(document.getElementById('doc-items'));
  var total = items.reduce(function(s,it){return s+it.qty*it.rate;},0);
  var d2Key = type==='inv' ? 'dueDate' : 'validTill';
  var rec = { id: document.getElementById('doc-id').value, client: document.getElementById('doc-party').value,
    date: document.getElementById('doc-date').value, status: document.getElementById('doc-status').value,
    notes: document.getElementById('doc-notes').value, items: items, amount: total };
  rec[d2Key] = document.getElementById('doc-date2').value;
  var arr = load(type);
  if (editingDocId) { var i=arr.findIndex(function(x){return x.id===editingDocId;}); if(i>=0)arr[i]=rec; }
  else arr.unshift(rec);
  save(type, arr);
  closeModal('doc-modal');
  if(type==='pro') renderProforma(); else if(type==='quo') renderQuotations();
  refreshAccountCounts();
  toast('Saved!','success');
}
function renderProforma() {
  var q  = (document.getElementById('pro-search').value || '').toLowerCase();
  var st = document.getElementById('pro-status').value;
  var data = load('pro').filter(function(r) {
    return (!q || (r.customerName||r.client||'').toLowerCase().includes(q) || (r.id||'').toLowerCase().includes(q))
        && (!st || r.status === st);
  });
  document.getElementById('pro-body').innerHTML = data.length ? data.map(function(r) {
    var proActBtns =
      '<div style="display:flex;gap:2px;justify-content:center;">' +
        '<button class="inv-act-btn" title="Preview"      onclick="previewProforma(\''+r.id+'\')"><i class="bx bx-show"></i></button>' +
        '<button class="inv-act-btn" title="Print"        onclick="printProforma(\''+r.id+'\')"><i class="bx bx-printer"></i></button>' +
        '<button class="inv-act-btn" title="Download PDF" onclick="downloadProformaPDF(\''+r.id+'\')"><i class="bx bx-download"></i></button>' +
        '<button class="inv-act-btn" title="Convert to Invoice" onclick="convertToInvoiceFromId(\''+r.id+'\')"><i class="bx bxs-receipt"></i></button>' +
        '<button class="inv-act-btn" title="Edit"         onclick="openProformaModal(\''+r.id+'\')"><i class="bx bx-edit-alt"></i></button>' +
        '<button class="inv-act-btn inv-act-del" title="Delete" onclick="deleteProforma(\''+r.id+'\')"><i class="bx bx-trash"></i></button>' +
      '</div>';
    return '<tr class="inv-row">' +
      '<td class="acc-td" style="font-weight:700;color:var(--accent);">' + (r.id||'—') + '</td>' +
      '<td class="acc-td">' + (r.customerName||r.client||'—') + '</td>' +
      '<td class="acc-td">' + fmtD(r.date) + '</td>' +
      '<td class="acc-td">' + fmtD(r.validityDate||r.validTill) + '</td>' +
      '<td class="acc-td" style="font-weight:600;">' + fmtAmt(r.totalAmount||r.amount||0) + '</td>' +
      '<td class="acc-td">' + badge(r.status) + '</td>' +
      '<td class="acc-td">' + proActBtns + '</td>' +
      '</tr>';
  }).join('') : emptyRow(7);
}

/* ── Proforma number generator ──────────────────────────── */
function nextProformaNumber() {
  var year = new Date().getFullYear();
  var key  = 'pro_seq_' + year;
  var seq  = parseInt(localStorage.getItem(key) || '0') + 1;
  localStorage.setItem(key, seq);
  return 'PRO-' + year + '-' + String(seq).padStart(4, '0');
}

/* ── Fill customer fields from vendor dropdown ──────────── */
function fillProFromVendor(jsonStr) {
  if (!jsonStr) return;
  try {
    var v = JSON.parse(jsonStr);
    document.getElementById('pro-c-name').value  = v.name    || '';
    document.getElementById('pro-c-gstin').value = v.gst     || '';
    document.getElementById('pro-c-addr').value  = v.address || '';
    setAccountStateValue('pro-c-state', 'pro-c-code', v.state, v.stateCode || accountStateCodeFromGstin(v.gst || v.gstin));
    recalcProforma();
  } catch(e) {}
}

/* ── Populate company (seller) dropdown for proforma ────── */
function populateProCompanyDropdown(selectedName, autoFill) {
  var sel = document.getElementById('pro-company-sel');
  if (!sel) return;
  autoFill = autoFill !== false;
  api('GET', '/companies').then(function(companies) {
    sel.innerHTML = '<option value="">— Select a company —</option>';
    companies.forEach(function(c) {
      if (c.status === 'inactive') return;
      var opt = document.createElement('option');
      opt.value = JSON.stringify(c);
      opt.textContent = c.name + (c.gstNo ? '  |  ' + c.gstNo : '');
      if (selectedName && c.name === selectedName) opt.selected = true;
      sel.appendChild(opt);
    });
    // Auto-select first company if none selected
    if (!selectedName && autoFill && sel.options.length > 1) {
      sel.selectedIndex = 1;
      fillProFromCompany(sel.value);
    } else if (selectedName && autoFill) {
      var match = companies.find(function(c) { return c.name === selectedName; });
      if (match) fillProFromCompany(JSON.stringify(match));
    }
  }).catch(function() {});
}

function fillProFromCompany(jsonStr) {
  if (!jsonStr) return;
  var c;
  try { c = JSON.parse(jsonStr); } catch(e) { return; }
  document.getElementById('pro-s-name').value   = c.name       || '';
  document.getElementById('pro-s-gstin').value  = (c.gstNo     || '').toUpperCase();
  document.getElementById('pro-s-addr').value   = c.address    || '';
  setAccountStateValue('pro-s-state', 'pro-s-code', c.state, c.stateCode || accountStateCodeFromGstin(c.gstNo));
  document.getElementById('pro-s-pan').value    = (c.panNo     || '').toUpperCase();
  document.getElementById('pro-s-phone').value  = c.phone      || '';
  document.getElementById('pro-s-email').value  = c.email      || '';
  document.getElementById('pro-bank-name').value   = c.bankName    || '';
  document.getElementById('pro-bank-acname').value = c.bankAcName  || '';
  document.getElementById('pro-bank-ac').value     = c.bankAccount || '';
  document.getElementById('pro-bank-ifsc').value   = (c.bankIfsc   || '').toUpperCase();
  document.getElementById('pro-bank-branch').value = c.bankBranch  || '';
  recalcProforma();
}

/* ── Populate vendor dropdown for proforma ──────────────── */
function populateProVendorDropdown() {
  var sel = document.getElementById('pro-vendor-sel');
  var vendors = load('ven').filter(function(v) { return v.status === 'Active'; });
  sel.innerHTML = '<option value="">— Type manually or pick a vendor —</option>' +
    vendors.map(function(v) {
      return '<option value=\'' + JSON.stringify(v).replace(/'/g,"&#39;") + '\'>' + v.name + (v.gst ? ' ('+v.gst+')' : '') + '</option>';
    }).join('');
}

