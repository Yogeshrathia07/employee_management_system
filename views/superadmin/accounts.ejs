<style>
.acc-tab {
  flex:1;min-width:fit-content;padding:8px 14px;border:none;background:transparent;border-radius:9px;
  font-size:12px;font-weight:600;color:var(--text-muted);cursor:pointer;transition:all .15s;white-space:nowrap;
}
.acc-tab.active { background:var(--bg-card);color:var(--accent);box-shadow:var(--shadow); }
.acc-tab:hover:not(.active) { color:var(--text-primary); }
.acc-subtab {
  padding:6px 16px;border:none;background:transparent;border-radius:7px;
  font-size:12px;font-weight:600;color:var(--text-muted);cursor:pointer;transition:all .15s;
}
.acc-subtab.active { background:var(--bg-card);color:var(--accent);box-shadow:var(--shadow); }
.acc-th { padding:10px 14px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;white-space:nowrap; }
.acc-td { padding:11px 14px;font-size:13px;color:var(--text-primary);border-bottom:1px solid var(--border); }
.acc-empty { grid-column:1/-1;padding:48px;text-align:center;color:var(--text-muted);font-size:14px; }
.line-item-row { display:flex;gap:8px;align-items:center; }
.line-item-row input { flex:1; }
.line-item-row .item-qty { width:70px;flex:none; }
.line-item-row .item-rate { width:100px;flex:none; }
.line-item-row .item-total { width:90px;flex:none;background:var(--bg-input);border:1px solid var(--border);border-radius:8px;padding:8px 10px;font-size:12px;color:var(--text-muted);text-align:right; }
</style>

<script src="/js/api.js"></script>
<script>
/* ── storage helpers ──────────────────────────────────── */
var STORE = {
  inv: 'acc_invoices', pro: 'acc_proforma', quo: 'acc_quotations',
  po: 'acc_po', ven: 'acc_vendors', cwo: 'acc_cwo', vwo: 'acc_vwo', prj: 'acc_projects'
};
function load(key) { try { return JSON.parse(localStorage.getItem(STORE[key]||key)||'[]'); } catch(e){ return []; } }
function save(key, arr) { localStorage.setItem(STORE[key]||key, JSON.stringify(arr)); }
function genId(prefix) { return prefix + '-' + Math.random().toString(36).substr(2,6).toUpperCase(); }
function today() { return new Date().toISOString().slice(0,10); }
function fmtAmt(n) { return '₹' + Number(n||0).toLocaleString('en-IN'); }
function fmtD(s) { if(!s) return '—'; var d=new Date(s); return d.getDate()+' '+['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()]+' '+d.getFullYear(); }

var STATUS_COLORS = {
  Draft:{c:'#64748b',b:'#f1f5f9'}, Sent:{c:'#3b82f6',b:'#dbeafe'},
  Paid:{c:'#22c55e',b:'#dcfce7'}, Accepted:{c:'#22c55e',b:'#dcfce7'},
  Active:{c:'#22c55e',b:'#dcfce7'}, Completed:{c:'#8b5cf6',b:'#ede9fe'},
  Overdue:{c:'#ef4444',b:'#fee2e2'}, Rejected:{c:'#ef4444',b:'#fee2e2'},
  Cancelled:{c:'#ef4444',b:'#fee2e2'}, Received:{c:'#22c55e',b:'#dcfce7'},
  Proposed:{c:'#f59e0b',b:'#fef3c7'}, Planning:{c:'#f59e0b',b:'#fef3c7'},
  'On Hold':{c:'#f59e0b',b:'#fef3c7'}
};
function badge(s) {
  var sc = STATUS_COLORS[s]||{c:'#64748b',b:'#f1f5f9'};
  return '<span style="font-size:11px;font-weight:700;background:'+sc.b+';color:'+sc.c+';border-radius:20px;padding:2px 10px;">'+s+'</span>';
}
function emptyRow(cols) {
  return '<tr><td colspan="'+cols+'" style="padding:48px;text-align:center;color:var(--text-muted);">No records found</td></tr>';
}
function actBtns(editFn, delFn) {
  return '<div style="display:flex;gap:4px;">'+
    '<button class="btn btn-ghost btn-sm" onclick="'+editFn+'"><i class="bx bx-edit"></i></button>'+
    '<button class="btn btn-danger btn-sm" onclick="'+delFn+'"><i class="bx bx-trash"></i></button>'+
  '</div>';
}

/* ── tab navigation ───────────────────────────────────── */
var activeModule = 'home';
function showModule(key) {
  document.querySelectorAll('.acc-module').forEach(function(el){ el.style.display='none'; });
  document.querySelectorAll('.acc-tab').forEach(function(el){ el.classList.remove('active'); });
  document.getElementById('mod-'+key).style.display='';
  document.getElementById('tab-'+key).classList.add('active');
  activeModule = key;
  if(key==='home') updateDashStats();
  else if(key==='inv') renderInvoices();
  else if(key==='pro') renderProforma();
  else if(key==='quo') renderQuotations();
  else if(key==='po') renderPO();
  else if(key==='ven') renderVendors();
  else if(key==='cwo') renderCWO();
  else if(key==='vwo') renderVWO();
  else if(key==='prj') renderProjects();
}
function showSubTab(key) {
  document.getElementById('sub-invoices').style.display = key==='invoices'?'':'none';
  document.getElementById('sub-calc').style.display = key==='calc'?'':'none';
  document.getElementById('stab-invoices').classList.toggle('active', key==='invoices');
  document.getElementById('stab-calc').classList.toggle('active', key==='calc');
}
function updateDashStats() {
  document.getElementById('dash-inv').textContent = load('inv').length;
  document.getElementById('dash-ven').textContent = load('ven').length;
  document.getElementById('dash-cwo').textContent = load('cwo').length;
  document.getElementById('dash-prj').textContent = load('prj').length;
}

/* ── INVOICES ─────────────────────────────────────────── */
var editingDocId = null, editingDocType = null;
function calcDocItems(container) {
  var rows = container.querySelectorAll('.line-item-row');
  var total = 0;
  rows.forEach(function(row){ total += (parseFloat(row.querySelector('.item-qty').value)||0) * (parseFloat(row.querySelector('.item-rate').value)||0); });
  return total;
}
function updateDocTotal() {
  var t = calcDocItems(document.getElementById('doc-items'));
  document.getElementById('doc-total-display').textContent = fmtAmt(t);
}
function addLineItemRow(container, item) {
  item = item || {name:'',qty:1,rate:0};
  var div = document.createElement('div');
  div.className = 'line-item-row';
  div.innerHTML = '<input type="text" class="form-control item-name" placeholder="Item description" value="'+escape(item.name||'')+'">'+
    '<input type="number" class="form-control item-qty" placeholder="Qty" value="'+(item.qty||1)+'" min="1" oninput="updateDocTotal()">'+
    '<input type="number" class="form-control item-rate" placeholder="Rate" value="'+(item.rate||0)+'" min="0" oninput="updateDocTotal()">'+
    '<div class="item-total">'+(item.qty&&item.rate?fmtAmt(item.qty*item.rate):'₹0')+'</div>'+
    '<button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove();updateDocTotal()"><i class="bx bx-x"></i></button>';
  div.querySelector('.item-rate').addEventListener('input', function(){ div.querySelector('.item-total').textContent=fmtAmt((parseFloat(div.querySelector('.item-qty').value)||0)*(parseFloat(div.querySelector('.item-rate').value)||0)); });
  div.querySelector('.item-qty').addEventListener('input', function(){ div.querySelector('.item-total').textContent=fmtAmt((parseFloat(div.querySelector('.item-qty').value)||0)*(parseFloat(div.querySelector('.item-rate').value)||0)); });
  container.appendChild(div);
}
function addLineItem() { addLineItemRow(document.getElementById('doc-items'), null); updateDocTotal(); }
function getDocItems(container) {
  return Array.from(container.querySelectorAll('.line-item-row')).map(function(row){
    return {name:unescape(row.querySelector('.item-name').value), qty:parseFloat(row.querySelector('.item-qty').value)||1, rate:parseFloat(row.querySelector('.item-rate').value)||0};
  });
}
function openInvModal(id) {
  editingDocType = 'inv'; editingDocId = id||null;
  document.getElementById('doc-type').value = 'inv';
  document.getElementById('doc-modal-title').textContent = id ? 'Edit Invoice' : 'New Invoice';
  document.getElementById('doc-party-label').textContent = 'Client Name';
  document.getElementById('doc-date2-label').textContent = 'Due Date';
  document.getElementById('doc-items').innerHTML = '';
  var statuses = '<option>Draft</option><option>Sent</option><option>Paid</option><option>Overdue</option>';
  document.getElementById('doc-status').innerHTML = statuses;
  if (id) {
    var rec = load('inv').find(function(x){return x.id===id;});
    if (!rec) return;
    document.getElementById('doc-id').value    = rec.id;
    document.getElementById('doc-party').value = rec.client;
    document.getElementById('doc-date').value  = rec.date;
    document.getElementById('doc-date2').value = rec.dueDate;
    document.getElementById('doc-status').value = rec.status;
    document.getElementById('doc-notes').value = rec.notes||'';
    (rec.items||[]).forEach(function(it){ addLineItemRow(document.getElementById('doc-items'), it); });
  } else {
    document.getElementById('doc-id').value    = genId('INV');
    document.getElementById('doc-party').value = '';
    document.getElementById('doc-date').value  = today();
    document.getElementById('doc-date2').value = '';
    document.getElementById('doc-status').value = 'Draft';
    document.getElementById('doc-notes').value = '';
    addLineItemRow(document.getElementById('doc-items'), null);
  }
  updateDocTotal(); openModal('doc-modal');
}
function openDocModal(type) {
  editingDocType = type; editingDocId = null;
  var titles = {pro:'New Proforma Invoice', quo:'New Quotation'};
  document.getElementById('doc-type').value = type;
  document.getElementById('doc-modal-title').textContent = titles[type];
  document.getElementById('doc-party-label').textContent = 'Client Name';
  document.getElementById('doc-date2-label').textContent = 'Valid Till';
  document.getElementById('doc-items').innerHTML = '';
  document.getElementById('doc-status').innerHTML = '<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>';
  document.getElementById('doc-id').value    = genId(type==='pro'?'PRO':'QUO');
  document.getElementById('doc-party').value = '';
  document.getElementById('doc-date').value  = today();
  document.getElementById('doc-date2').value = '';
  document.getElementById('doc-status').value = 'Draft';
  document.getElementById('doc-notes').value = '';
  addLineItemRow(document.getElementById('doc-items'), null);
  updateDocTotal(); openModal('doc-modal');
}
function openDocEditModal(type, id) {
  editingDocType = type; editingDocId = id;
  var rec = load(type).find(function(x){return x.id===id;});
  if (!rec) return;
  var titles = {inv:'Edit Invoice', pro:'Edit Proforma Invoice', quo:'Edit Quotation'};
  document.getElementById('doc-type').value = type;
  document.getElementById('doc-modal-title').textContent = titles[type];
  document.getElementById('doc-party-label').textContent = 'Client Name';
  document.getElementById('doc-date2-label').textContent = type==='inv' ? 'Due Date' : 'Valid Till';
  document.getElementById('doc-items').innerHTML = '';
  var statMap = {inv:'<option>Draft</option><option>Sent</option><option>Paid</option><option>Overdue</option>', pro:'<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>', quo:'<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>'};
  document.getElementById('doc-status').innerHTML = statMap[type];
  document.getElementById('doc-id').value    = rec.id;
  document.getElementById('doc-party').value = rec.client;
  document.getElementById('doc-date').value  = rec.date;
  document.getElementById('doc-date2').value = rec.dueDate||rec.validTill||'';
  document.getElementById('doc-status').value = rec.status;
  document.getElementById('doc-notes').value = rec.notes||'';
  (rec.items||[]).forEach(function(it){ addLineItemRow(document.getElementById('doc-items'), it); });
  updateDocTotal(); openModal('doc-modal');
}
function saveDoc() {
  var type = document.getElementById('doc-type').value;
  var items = getDocItems(document.getElementById('doc-items'));
  var total = items.reduce(function(s,it){return s+it.qty*it.rate;},0);
  var d2Key = type==='inv' ? 'dueDate' : 'validTill';
  var rec = { id: document.getElementById('doc-id').value, client: document.getElementById('doc-party').value,
    date: document.getElementById('doc-date').value, status: document.getElementById('doc-status').value,
    notes: document.getElementById('doc-notes').value, items: items, amount: total };
  rec[d2Key] = document.getElementById('doc-date2').value;
  var arr = load(type);
  if (editingDocId) { var i=arr.findIndex(function(x){return x.id===editingDocId;}); if(i>=0)arr[i]=rec; }
  else arr.unshift(rec);
  save(type, arr);
  closeModal('doc-modal');
  if(type==='inv') renderInvoices(); else if(type==='pro') renderProforma(); else renderQuotations();
  toast('Saved!','success');
}
function renderInvoices() {
  var q=(document.getElementById('inv-search').value||'').toLowerCase();
  var st=document.getElementById('inv-status').value;
  var data=load('inv').filter(function(r){ return (!q||(r.client||'').toLowerCase().includes(q)||(r.id||'').toLowerCase().includes(q))&&(!st||r.status===st); });
  document.getElementById('inv-body').innerHTML = data.length ? data.map(function(r){
    return '<tr>'+
      '<td class="acc-td" style="font-weight:600;">'+r.id+'</td>'+
      '<td class="acc-td">'+r.client+'</td>'+
      '<td class="acc-td">'+fmtD(r.date)+'</td>'+
      '<td class="acc-td">'+fmtD(r.dueDate)+'</td>'+
      '<td class="acc-td" style="font-weight:600;">'+fmtAmt(r.amount)+'</td>'+
      '<td class="acc-td">'+badge(r.status)+'</td>'+
