/* ── PURCHASE ORDERS ──────────────────────────────────── */
var editingPOId = null;
function addPOItemRow(container, item) {
  item = item||{name:'',qty:1,rate:0};
  var div = document.createElement('div'); div.className='line-item-row';
  div.innerHTML='<input type="text" class="form-control item-name" placeholder="Item description" value="'+escape(item.name||'')+'">'+
    '<input type="number" class="form-control item-qty" placeholder="Qty" value="'+(item.qty||1)+'" min="1" oninput="updatePOTotal()">'+
    '<input type="number" class="form-control item-rate" placeholder="Rate" value="'+(item.rate||0)+'" min="0" oninput="updatePOTotal()">'+
    '<div class="item-total">'+fmtAmt((item.qty||1)*(item.rate||0))+'</div>'+
    '<button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove();updatePOTotal()"><i class="bx bx-x"></i></button>';
  div.querySelector('.item-rate').addEventListener('input',function(){div.querySelector('.item-total').textContent=fmtAmt((parseFloat(div.querySelector('.item-qty').value)||0)*(parseFloat(div.querySelector('.item-rate').value)||0));});
  div.querySelector('.item-qty').addEventListener('input',function(){div.querySelector('.item-total').textContent=fmtAmt((parseFloat(div.querySelector('.item-qty').value)||0)*(parseFloat(div.querySelector('.item-rate').value)||0));});
  container.appendChild(div);
}
function addPOItem() { addPOItemRow(document.getElementById('po-items'),null); updatePOTotal(); }
function updatePOTotal() {
  var rows=document.getElementById('po-items').querySelectorAll('.line-item-row');
  var total=0; rows.forEach(function(r){total+=(parseFloat(r.querySelector('.item-qty').value)||0)*(parseFloat(r.querySelector('.item-rate').value)||0);});
  document.getElementById('po-total-display').textContent=fmtAmt(total);
}
function openPOModal(id) {
  editingPOId=id||null;
  document.getElementById('po-modal-title').textContent=id?'Edit Purchase Order':'New Purchase Order';
  document.getElementById('po-items').innerHTML='';
  if(id){
    var rec=load('po').find(function(x){return x.id===id;}); if(!rec)return;
    document.getElementById('po-id').value=rec.id; document.getElementById('po-vendor').value=rec.vendor;
    document.getElementById('po-date').value=rec.date; document.getElementById('po-delivery').value=rec.deliveryDate||'';
    document.getElementById('po-status-sel').value=rec.status; document.getElementById('po-notes').value=rec.notes||'';
    (rec.items||[]).forEach(function(it){addPOItemRow(document.getElementById('po-items'),it);});
  } else {
    document.getElementById('po-id').value=genId('PO'); document.getElementById('po-vendor').value='';
    document.getElementById('po-date').value=today(); document.getElementById('po-delivery').value='';
    document.getElementById('po-status-sel').value='Draft'; document.getElementById('po-notes').value='';
    addPOItemRow(document.getElementById('po-items'),null);
  }
  updatePOTotal(); openModal('po-modal');
}
function savePO() {
  var items=getDocItems(document.getElementById('po-items'));
  var rec={id:document.getElementById('po-id').value, vendor:document.getElementById('po-vendor').value,
    date:document.getElementById('po-date').value, deliveryDate:document.getElementById('po-delivery').value,
    status:document.getElementById('po-status-sel').value, notes:document.getElementById('po-notes').value,
    items:items, amount:items.reduce(function(s,it){return s+it.qty*it.rate;},0)};
  var arr=load('po');
  if(editingPOId){var i=arr.findIndex(function(x){return x.id===editingPOId;});if(i>=0)arr[i]=rec;}else arr.unshift(rec);
  save('po',arr); closeModal('po-modal'); renderPO(); toast('Saved!','success');
}
