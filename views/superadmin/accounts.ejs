var editingWOId = null, editingWOType = null;

function openWOModal(type, id) {
  editingWOType = type; editingWOId = id || null;
  var isCWO = type === 'cwo';
  document.getElementById('wo-type').value = type;
  document.getElementById('wo-modal-title').textContent = isCWO
    ? (id ? 'Edit Client Work Order' : 'New Client Work Order')
    : (id ? 'Edit Vendor Work Order' : 'New Vendor Work Order');
  document.getElementById('wo-party-label').textContent = isCWO ? 'Client' : 'Vendor';
  var clientSel   = document.getElementById('wo-client-sel');
  var vendorSelect= document.getElementById('wo-vendor');
  if (isCWO) {
    clientSel.style.display   = '';
    vendorSelect.style.display= 'none';
  } else {
    clientSel.style.display   = 'none';
    vendorSelect.style.display= '';
  }
  if (id) {
    api('GET', '/work-orders/'+id).then(function(r) {
      document.getElementById('wo-id').value = r.woNumber || '';
      if (isCWO) {
        populateClientDropdown('wo-client-sel', r.clientId, '— Select client —');
      } else {
        populateVendorDropdownAPI('wo-vendor', r.vendorId, '— Select vendor —');
      }
      populateProjectDropdown('wo-project-sel', r.projectAccountId, '— Select project —');
      document.getElementById('wo-project-id').value = r.projectAccountId || '';
      document.getElementById('wo-start').value      = r.startDate || '';
      document.getElementById('wo-end').value        = r.endDate || '';
      document.getElementById('wo-scope').value      = r.scope || '';
      document.getElementById('wo-amount').value     = r.totalAmount || 0;
      document.getElementById('wo-status-sel').value = r.status || 'Draft';
    }).catch(function(e){ toast(e.message,'error'); });
  } else {
    document.getElementById('wo-id').value       = accountPreviewCode(isCWO ? 'CWO' : 'VWO');
    document.getElementById('wo-project-id').value = '';
    populateProjectDropdown('wo-project-sel', null, '— Select project —');
    document.getElementById('wo-start').value    = today();
    document.getElementById('wo-end').value     = '';
    document.getElementById('wo-scope').value   = '';
    document.getElementById('wo-amount').value  = 0;
    document.getElementById('wo-status-sel').value = 'Draft';
    if (isCWO) populateClientDropdown('wo-client-sel', null, '— Select client —');
    else        populateVendorDropdownAPI('wo-vendor', null, '— Select vendor —');
  }
  openModal('wo-modal');
}

