/* ── Recalculate totals using global SGST/CGST rates ───── */
function toggleTaxExempt() {
  var exempt   = document.getElementById('gst-tax-exempt').checked;
  var fields   = document.getElementById('gst-tax-rate-fields');
  var notice   = document.getElementById('gst-exempt-notice');
  var sumSgst  = document.getElementById('gst-sum-sgst-row');
  var sumCgst  = document.getElementById('gst-sum-cgst-row');
  var sumIgst  = document.getElementById('gst-sum-igst-row');
  if (fields)  fields.style.display  = exempt ? 'none' : 'grid';
  if (notice)  notice.style.display  = exempt ? 'block' : 'none';
  if (sumSgst) sumSgst.style.display = exempt ? 'none' : '';
  if (sumCgst) sumCgst.style.display = exempt ? 'none' : '';
  if (sumIgst) sumIgst.style.display = 'none';
  recalcGST();
}

function recalcGST() {
  var exempt = document.getElementById('gst-tax-exempt') && document.getElementById('gst-tax-exempt').checked;
  var sgstRate = exempt ? 0 : (parseFloat(document.getElementById('gst-sgst-rate') && document.getElementById('gst-sgst-rate').value) || 0);
  var cgstRate = exempt ? 0 : (parseFloat(document.getElementById('gst-cgst-rate') && document.getElementById('gst-cgst-rate').value) || 0);
  var sellerCode   = (document.getElementById('gst-s-code')   && document.getElementById('gst-s-code').value   || '').trim();
  var customerCode = (document.getElementById('gst-c-code')   && document.getElementById('gst-c-code').value   || '').trim();
  var useIGST = !exempt && sellerCode && customerCode && sellerCode !== customerCode;
  var totalTaxRate = sgstRate + cgstRate;
  var igstRate = totalTaxRate; // same total rate, applied as single IGST for inter-state

  var subtotal = 0;
  var cards = document.getElementById('gst-items-body').querySelectorAll('[id^="gst-row-"]');
  cards.forEach(function(card) {
    var qty     = parseFloat(card.querySelector('.gi-qty').value)   || 0;
    var price   = parseFloat(card.querySelector('.gi-price').value) || 0;
    var taxable = qty * price;
    var gstAmt  = taxable * totalTaxRate / 100;
    subtotal   += taxable;
    var taxableEl = card.querySelector('[id^="gi-taxable-"]');
    if (taxableEl) taxableEl.textContent = taxable.toFixed(2);
    var amtEl = card.querySelector('[id^="gi-amt-"]');
    if (amtEl) amtEl.textContent = (taxable + gstAmt).toFixed(2);
  });

  var totalSgst = useIGST ? 0 : subtotal * sgstRate / 100;
  var totalCgst = useIGST ? 0 : subtotal * cgstRate / 100;
  var totalIgst = useIGST ? subtotal * igstRate / 100 : 0;
  var gross     = subtotal + totalSgst + totalCgst + totalIgst;
  var roundOff  = parseFloat((Math.round(gross) - gross).toFixed(2));
  var total     = gross + roundOff;

  // Update summary panel
  function fmt(n) { return '₹' + n.toFixed(2); }
  var subEl = document.getElementById('gst-sum-sub');
  if (subEl) subEl.textContent = fmt(subtotal);
  var roundEl = document.getElementById('gst-sum-round');
  if (roundEl) roundEl.textContent = fmt(roundOff);
  var totalEl = document.getElementById('gst-sum-total');
  if (totalEl) totalEl.textContent = fmt(total);

  var sgstRow  = document.getElementById('gst-sum-sgst-row');
  var cgstRow  = document.getElementById('gst-sum-cgst-row');
  var igstRow  = document.getElementById('gst-sum-igst-row');
  var hintEl   = document.getElementById('gst-sum-tax-hint');

  if (useIGST) {
    if (sgstRow) sgstRow.style.display = 'none';
    if (cgstRow) cgstRow.style.display = 'none';
    if (igstRow) { igstRow.style.display = 'flex'; }
    var igstLbl = document.getElementById('gst-sum-igst-label');
    var igstVal = document.getElementById('gst-sum-igst');
    if (igstLbl) igstLbl.textContent = 'IGST (' + igstRate + '%)';
    if (igstVal) igstVal.textContent = fmt(totalIgst);
    if (hintEl)  hintEl.textContent  = 'Inter-state supply (seller state ' + sellerCode + ' \u2260 buyer state ' + customerCode + '): IGST applied.';
  } else {
    if (sgstRow) sgstRow.style.display = 'flex';
    if (cgstRow) cgstRow.style.display = 'flex';
    if (igstRow) igstRow.style.display = 'none';
    var sgstLbl = document.getElementById('gst-sum-sgst-label');
    var cgstLbl = document.getElementById('gst-sum-cgst-label');
    var sgstVal = document.getElementById('gst-sum-sgst');
    var cgstVal = document.getElementById('gst-sum-cgst');
    if (sgstLbl) sgstLbl.textContent = 'SGST (' + sgstRate + '%)';
    if (cgstLbl) cgstLbl.textContent = 'CGST (' + cgstRate + '%)';
    if (sgstVal) sgstVal.textContent = fmt(totalSgst);
    if (cgstVal) cgstVal.textContent = fmt(totalCgst);
    if (hintEl)  hintEl.textContent  = sellerCode && customerCode ? 'Intra-state supply (same state): CGST + SGST applied.' : '';
  }
}

/* ── Collect Items from Cards ───────────────────────────── */
function collectGSTItems() {
  var exempt = document.getElementById('gst-tax-exempt') && document.getElementById('gst-tax-exempt').checked;
  var sgstRate = exempt ? 0 : (parseFloat(document.getElementById('gst-sgst-rate').value) || 0);
  var cgstRate = exempt ? 0 : (parseFloat(document.getElementById('gst-cgst-rate').value) || 0);
  var totalTaxRate = sgstRate + cgstRate;
  var sellerCode   = (document.getElementById('gst-s-code').value   || '').trim();
  var customerCode = (document.getElementById('gst-c-code').value   || '').trim();
  var useIGST = !exempt && sellerCode && customerCode && sellerCode !== customerCode;

  var cards = document.getElementById('gst-items-body').querySelectorAll('[id^="gst-row-"]');
  var items = [];
  cards.forEach(function(card) {
    var qty   = parseFloat(card.querySelector('.gi-qty').value)   || 0;
    var price = parseFloat(card.querySelector('.gi-price').value) || 0;
    var taxable = qty * price;
    var gstAmt  = taxable * totalTaxRate / 100;
    var cgstAmt = useIGST ? 0 : taxable * cgstRate / 100;
    var sgstAmt = useIGST ? 0 : taxable * sgstRate / 100;
    var igstAmt = useIGST ? gstAmt : 0;
    items.push({
      itemCode: card.querySelector('.gi-code').value,
      name:     card.querySelector('.gi-name').value,
      hsnCode:  card.querySelector('.gi-hsn').value,
      quantity: qty,
      unit:     card.querySelector('.gi-unit').value,
      unitPrice: price,
      discount: 0,
      taxRate:  totalTaxRate,
      taxableAmount: parseFloat(taxable.toFixed(2)),
      cgst:     parseFloat(cgstAmt.toFixed(2)),
      sgst:     parseFloat(sgstAmt.toFixed(2)),
      igst:     parseFloat(igstAmt.toFixed(2)),
      itemTotal: parseFloat((taxable + gstAmt).toFixed(2)),
    });
  });
  return items;
}

/* ── Save Invoice (API) ─────────────────────────────────── */
function saveGSTInvoice() {
  syncAllAccountStateCodes();
  if (!document.getElementById('gst-c-name').value.trim()) return toast('Customer name is required','error');
  if (!document.getElementById('gst-date').value)          return toast('Invoice date is required','error');

  var sgstRate = parseFloat(document.getElementById('gst-sgst-rate').value) || 0;
  var cgstRate = parseFloat(document.getElementById('gst-cgst-rate').value) || 0;

  var items = collectGSTItems();
  var subtotal = 0, totalCgst = 0, totalSgst = 0, totalIgst = 0;
  items.forEach(function(it) {
    subtotal  += it.taxableAmount;
    totalCgst += it.cgst;
    totalSgst += it.sgst;
    totalIgst += it.igst;
  });
  var gross      = subtotal + totalCgst + totalSgst + totalIgst;
  var roundOff   = parseFloat((Math.round(gross) - gross).toFixed(2));
  var totalAmount= parseFloat((gross + roundOff).toFixed(2));

  var payload = {
    documentType:      document.getElementById('gst-doc-type').value,
    invoiceType:       'B2B',
    invoiceDate:       document.getElementById('gst-date').value,
    dueDate:           document.getElementById('gst-due').value    || null,
    billMonth:         monthFromInput(document.getElementById('gst-bill-month').value),
    billPeriodFrom:    document.getElementById('gst-bill-from').value || null,
    billPeriodTo:      document.getElementById('gst-bill-to').value   || null,
    isRABill:          document.getElementById('gst-ra-bill').checked,
    sellerName:        document.getElementById('gst-s-name').value,
    sellerGstin:       document.getElementById('gst-s-gstin').value.toUpperCase(),
    sellerAddress:     document.getElementById('gst-s-addr').value,
    sellerState:       document.getElementById('gst-s-state').value,
    sellerStateCode:   document.getElementById('gst-s-code').value,
    sellerPan:         document.getElementById('gst-s-pan').value.toUpperCase(),
    sellerPhone:       document.getElementById('gst-s-phone').value,
    sellerEmail:       document.getElementById('gst-s-email').value,
    customerName:      document.getElementById('gst-c-name').value,
    customerEmail:     document.getElementById('gst-c-email').value,
    customerAddress:   document.getElementById('gst-c-addr').value,
    customerGstin:     document.getElementById('gst-c-gstin').value.toUpperCase(),
    customerPan:       document.getElementById('gst-c-pan').value.toUpperCase(),
    customerState:     document.getElementById('gst-c-state').value,
    customerStateCode: document.getElementById('gst-c-code').value,
    workOrder:         document.getElementById('gst-work-order').value,
    projectName:       document.getElementById('gst-project').value,
    workDetails:       document.getElementById('gst-work-details').value,
    items:             items,
    subtotal:          parseFloat(subtotal.toFixed(2)),
    totalCgst:         parseFloat(totalCgst.toFixed(2)),
    totalSgst:         parseFloat(totalSgst.toFixed(2)),
    totalIgst:         parseFloat(totalIgst.toFixed(2)),
    totalTax:          parseFloat((totalCgst + totalSgst + totalIgst).toFixed(2)),
    roundOff:          roundOff,
    totalAmount:       totalAmount,
    sgstRate:          sgstRate,
    cgstRate:          cgstRate,
    taxExempt:         !!(document.getElementById('gst-tax-exempt') && document.getElementById('gst-tax-exempt').checked),
    showTaxInPdf:      !!(document.getElementById('gst-show-tax-pdf') && document.getElementById('gst-show-tax-pdf').checked),
    status:            document.getElementById('gst-status').value,
    bankName:          document.getElementById('gst-bank-name').value,
    bankAcName:        document.getElementById('gst-bank-acname').value,
    bankAccount:       document.getElementById('gst-bank-ac').value,
    bankIfsc:          document.getElementById('gst-bank-ifsc').value.toUpperCase(),
    bankBranch:        document.getElementById('gst-bank-branch').value,
    notes:             document.getElementById('gst-notes').value,
    financialYear:     (document.getElementById('inv-fy-sel') && document.getElementById('inv-fy-sel').value) || localStorage.getItem('inv_fy') || '',
    companyCode:       (document.getElementById('inv-company-code') && document.getElementById('inv-company-code').value.trim().toUpperCase()) || localStorage.getItem('inv_company_code') || '',
  };

  var method = gstEditingId ? 'PUT' : 'POST';
  var path   = gstEditingId ? '/invoices/' + gstEditingId : '/invoices';

  return api(method, path, payload)
    .then(function(inv) {
      closeModal('gst-inv-modal');
      renderInvoices();
      refreshAccountCounts();
      toast((gstEditingId ? 'Invoice updated' : 'Invoice #' + inv.invoiceNumber + ' created') + '!', 'success');
    })
    .catch(function(e) { toast('Error: ' + (e.message || 'Save failed'), 'error'); });
}

