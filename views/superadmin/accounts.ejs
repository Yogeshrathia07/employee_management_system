            (inv.notes ? '<div style="margin-bottom:6px;"><span style="font-size:11px;font-weight:700;text-transform:uppercase;color:#64748b;">Notes</span><div style="font-size:12px;color:#334155;margin-top:3px;">' + inv.notes + '</div></div>' : '') +
