      document.getElementById('pro-s-email').value         = rec.sellerEmail || '';
      document.getElementById('pro-s-pan').value           = rec.sellerPan || '';
      var proCustomer = setAccountCustomerFields('pro', rec);
      if (proCustomer.name) rememberCustomer(proCustomer);
      populateProVendorDropdown(proCustomer.name);
      document.getElementById('pro-bill-month').value      = monthToInput(rec.billMonth || '');
      document.getElementById('pro-bill-from').value       = rec.billPeriodFrom || '';
      document.getElementById('pro-bill-to').value         = rec.billPeriodTo || '';
      document.getElementById('pro-work-order').value      = rec.workOrder || '';
      document.getElementById('pro-project').value         = rec.projectName || '';
      document.getElementById('pro-work-details').value    = rec.workDetails || '';
      document.getElementById('pro-bank-name').value       = rec.bankName || '';
      document.getElementById('pro-bank-acname').value     = rec.bankAcName || '';
      document.getElementById('pro-bank-ac').value         = rec.bankAccount || '';
      document.getElementById('pro-bank-ifsc').value       = rec.bankIfsc || '';
      document.getElementById('pro-bank-branch').value     = rec.bankBranch || '';
      document.getElementById('pro-pay-terms').value       = rec.paymentTerms || '';
      document.getElementById('pro-pay-terms-custom').value= rec.paymentTermsCustom || '';
      document.getElementById('pro-delivery').value        = rec.deliveryTimeline || '';
      document.getElementById('pro-warranty').value        = rec.warranty || '';
      document.getElementById('pro-notes').value           = rec.notes || '';
      document.getElementById('pro-terms').value           = rec.termsConditions || '';
      document.getElementById('pro-show-tax-pdf').checked  = rec.showTaxInPdf !== false;
      (rec.items || []).forEach(function(it) { addProformaItem(it); });
      recalcProforma();
    }).catch(function(e) { toast(e.message || 'Error loading proforma', 'error'); });
  } else {
    populateProCompanyDropdown(); // auto-select first company for new proforma
