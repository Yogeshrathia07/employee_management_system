function onRepSectionChange() {
  var sec = document.getElementById('rep-section').value;
  var cfg = REP_CONFIG[sec];
  // Update status options
  var stSel = document.getElementById('rep-status');
  stSel.innerHTML = '<option value="">All Status</option>';
  (cfg.statuses||[]).forEach(function(s){
    var o = document.createElement('option'); o.value = s; o.textContent = s; stSel.appendChild(o);
  });
  // Show/hide date filters
  var showDate = !!cfg.dateField;
  document.getElementById('rep-date-from-wrap').style.display = showDate ? '' : 'none';
  document.getElementById('rep-date-to-wrap').style.display   = showDate ? '' : 'none';
  repData = []; repFiltered = [];
  renderReport();
}

function renderReport() {
  var sec   = document.getElementById('rep-section').value;
  var cfg   = REP_CONFIG[sec];
  var tbody = document.getElementById('rep-body');
  var thead = document.getElementById('rep-thead');
  tbody.innerHTML = '<tr><td colspan="20" style="text-align:center;padding:32px;color:var(--text-muted);">Loading...</td></tr>';

  api('GET', cfg.endpoint).then(function(data) {
    repData = data || [];
    var q     = (document.getElementById('rep-search').value||'').toLowerCase();
    var st    = document.getElementById('rep-status').value;
    var dfrom = document.getElementById('rep-date-from').value;
    var dto   = document.getElementById('rep-date-to').value;

    repFiltered = repData.filter(function(r) {
      if (st && r.status !== st) return false;
      if (q) {
        var num  = String(r[cfg.numField]  ||'').toLowerCase();
        var name = String(r[cfg.nameField] ||'').toLowerCase();
        if (!num.includes(q) && !name.includes(q)) return false;
      }
      if (cfg.dateField && dfrom && (r[cfg.dateField]||'') < dfrom) return false;
      if (cfg.dateField && dto   && (r[cfg.dateField]||'') > dto)   return false;
      return true;
    });

    // Header
    thead.innerHTML = '<tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">' +
      cfg.columns.map(function(c){ return '<th class="acc-th">' + c.h + '</th>'; }).join('') + '</tr>';

    // Rows
    if (!repFiltered.length) {
      tbody.innerHTML = '<tr><td colspan="' + cfg.columns.length + '" style="text-align:center;padding:40px;color:var(--text-muted);">No records match the filters</td></tr>';
    } else {
      tbody.innerHTML = repFiltered.map(function(r) {
        return '<tr class="inv-row">' + cfg.columns.map(function(c) {
          var val = c.v(r);
          var disp = (typeof val === 'number') ? fmtAmt(val) : (val || '—');
          return '<td class="acc-td" style="font-size:12px;white-space:nowrap;">' + disp + '</td>';
        }).join('') + '</tr>';
      }).join('');
    }

    // Summary
    var summaryEl = document.getElementById('rep-summary');
    var cards = [{ label:'Total Records', val: repFiltered.length, money: false }];
    if (cfg.amountField) {
      var total = repFiltered.reduce(function(s,r){ return s + parseFloat(r[cfg.amountField]||0); }, 0);
      cards.push({ label:'Total Amount', val: total, money: true });
    }
    // Status breakdown
    var byStatus = {};
    repFiltered.forEach(function(r){ var s=r.status||'—'; byStatus[s]=(byStatus[s]||0)+1; });
    Object.keys(byStatus).forEach(function(s){ cards.push({ label:s, val:byStatus[s], money:false }); });
    summaryEl.innerHTML = cards.map(function(c){
      return '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:12px 18px;min-width:110px;">' +
        '<div style="font-size:18px;font-weight:800;color:var(--text-primary);">' + (c.money ? fmtAmt(c.val) : c.val) + '</div>' +
        '<div style="font-size:11px;color:var(--text-muted);margin-top:2px;">' + c.label + '</div>' +
        '</div>';
    }).join('');

  }).catch(function(e) {
    tbody.innerHTML = '<tr><td colspan="20" style="text-align:center;padding:32px;color:var(--danger);">' + (e.message||'Error loading data') + '</td></tr>';
    document.getElementById('rep-summary').innerHTML = '';
  });
}

function clearRepFilters() {
  document.getElementById('rep-date-from').value = '';
  document.getElementById('rep-date-to').value   = '';
  document.getElementById('rep-status').value    = '';
  document.getElementById('rep-search').value    = '';
