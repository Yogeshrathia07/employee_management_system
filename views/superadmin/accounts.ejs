<style>
.acc-tab {
  flex:1;min-width:fit-content;padding:8px 14px;border:none;background:transparent;border-radius:9px;
  font-size:12px;font-weight:600;color:var(--text-muted);cursor:pointer;transition:all .15s;white-space:nowrap;
}
.acc-tab.active { background:var(--bg-card);color:var(--accent);box-shadow:var(--shadow); }
.acc-tab:hover:not(.active) { color:var(--text-primary); }
.acc-tab-badge { display:inline-flex;align-items:center;justify-content:center;min-width:16px;height:16px;padding:0 4px;border-radius:99px;background:var(--accent);color:#fff;font-size:10px;font-weight:700;line-height:1;margin-left:3px;vertical-align:middle; }
.acc-tab-badge:empty { display:none; }
.acc-subtab {
  padding:6px 16px;border:none;background:transparent;border-radius:7px;
  font-size:12px;font-weight:600;color:var(--text-muted);cursor:pointer;transition:all .15s;
}
.acc-subtab.active { background:var(--bg-card);color:var(--accent);box-shadow:var(--shadow); }
.acc-th { padding:10px 14px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;white-space:nowrap; }
.acc-td { padding:11px 14px;font-size:13px;color:var(--text-primary);border-bottom:1px solid var(--border); }
.acc-empty { grid-column:1/-1;padding:48px;text-align:center;color:var(--text-muted);font-size:14px; }
.acc-inline-settings {
  display:flex;
  flex-wrap:wrap;
  align-items:center;
  gap:10px 16px;
  padding:12px 16px;
  background:var(--bg-input);
  border:1px solid var(--border);
  border-radius:12px;
  margin-bottom:14px;
}
.acc-inline-title {
  display:flex;
  align-items:center;
  gap:8px;
  font-size:13px;
  font-weight:700;
  color:var(--text-muted);
  white-space:nowrap;
}
.acc-inline-title i {
  color:var(--accent);
  font-size:15px;
}
.acc-inline-field {
  display:flex;
  align-items:center;
  gap:8px;
  flex-shrink:0;
}
.acc-inline-label {
  font-size:12px;
  color:var(--text-muted);
  white-space:nowrap;
}
.acc-inline-input {
  min-width:0;
  height:40px !important;
  min-height:40px;
  padding:0 14px !important;
  font-size:13px !important;
  line-height:1.2;
}
.acc-inline-preview {
  display:flex;
  align-items:center;
  justify-content:flex-start;
  gap:8px;
  font-size:12px;
  color:var(--text-muted);
  min-height:40px;
}
.acc-inline-code {
  display:inline-flex;
  align-items:center;
  min-height:32px;
  padding:4px 10px;
  border-radius:8px;
  background:var(--bg-card);
  border:1px solid var(--border);
  font-size:12px;
  font-weight:700;
  color:var(--accent);
  white-space:nowrap;
}
.line-item-row {
  display:grid;
  grid-template-columns:minmax(220px, 2.2fr) minmax(90px, .8fr) minmax(120px, 1fr) minmax(120px, 1fr) auto;
  gap:10px;
  align-items:end;
  padding:12px;
  border:1px solid var(--border);
  border-radius:12px;
  background:var(--bg-card);
}
.line-item-field {
  display:flex;
  flex-direction:column;
  gap:6px;
  min-width:0;
}
.line-item-label {
  font-size:11px;
  font-weight:700;
  color:var(--text-muted);
  letter-spacing:.04em;
  text-transform:uppercase;
}
.line-item-row input { width:100%; min-width:0; }
.line-item-row .item-total {
