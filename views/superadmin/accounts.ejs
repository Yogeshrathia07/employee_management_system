          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Status</label>
            <select id="gst-status" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;outline:none;">
