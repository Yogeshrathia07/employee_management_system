<!-- ══════════════════════ PROFORMA INVOICE MODAL ══════════════════════════════ -->
<div class="modal-overlay" id="pro-inv-modal">
  <div class="modal acc-form-modal-shell acc-form-modal-wide" style="max-width:99vw;width:99vw;margin:0 auto;border-radius:14px;">
    <div class="modal-header">
      <span class="modal-title" id="pro-inv-title"><i class="bx bxs-file-doc" style="color:var(--accent)"></i> New Proforma Invoice</span>
      <button class="modal-close" onclick="closeModal('pro-inv-modal')">×</button>
    </div>
    <div class="modal-body acc-form-modal-body" style="padding:0;">
      <input type="hidden" id="pro-edit-id">

      <!-- ── Proforma Info ─────────────────────────────────────────────────── -->
      <div class="gst-section">
        <div class="gst-section-title"><i class="bx bxs-file-doc"></i> Proforma Information</div>
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;">
          <div class="form-group"><label class="form-label">Proforma #</label><input type="text" id="pro-number" class="form-control" readonly style="background:var(--bg-input);font-weight:600;" placeholder="Auto-generated"></div>
          <div class="form-group"><label class="form-label">Date <span style="color:#ef4444">*</span></label><input type="date" id="pro-date" class="form-control"></div>
          <div class="form-group"><label class="form-label">Validity Date <span style="color:#ef4444">*</span></label><input type="date" id="pro-validity" class="form-control"></div>
          <div class="form-group"><label class="form-label">Place of Supply</label><input type="text" id="pro-supply" class="form-control" placeholder="e.g. Maharashtra"></div>
          <div class="form-group"><label class="form-label">Status</label>
            <select id="pro-status-field" class="form-control">
              <option value="Draft">Draft</option><option value="Sent">Sent</option>
              <option value="Accepted">Accepted</option><option value="Rejected">Rejected</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ── Seller + Customer ─────────────────────────────────────────────── -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--border);">
        <div class="gst-section" style="border-right:1px solid var(--border);">
          <div class="gst-section-title" style="color:#1d4ed8;"><i class="bx bxs-buildings"></i> Company / Seller Details</div>
          <div class="form-group"><label class="form-label">Company Name <span style="color:#ef4444">*</span></label><input type="text" id="pro-s-name" class="form-control" placeholder="Your company name"></div>
          <div class="form-group"><label class="form-label">GSTIN</label><input type="text" id="pro-s-gstin" class="form-control" placeholder="22AAAAA0000A1Z5" maxlength="15" style="text-transform:uppercase"></div>
          <div class="form-group"><label class="form-label">Address</label><textarea id="pro-s-addr" class="form-control" rows="2" placeholder="Full address"></textarea></div>
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:8px;">
            <div class="form-group"><label class="form-label">State</label><input type="text" id="pro-s-state" class="form-control" placeholder="e.g. Maharashtra"></div>
            <div class="form-group"><label class="form-label">State Code</label><input type="text" id="pro-s-code" class="form-control" placeholder="27" maxlength="2"></div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
