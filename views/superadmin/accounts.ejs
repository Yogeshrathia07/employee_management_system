    var barColor=pct>90?'#ef4444':pct>70?'#f59e0b':'#22c55e';
    return '<tr><td class="acc-td" style="font-weight:600;">'+r.id+'</td>'+
      '<td class="acc-td"><div style="font-weight:600;">'+r.name+'</div><div style="height:4px;background:var(--bg-input);border-radius:4px;margin-top:4px;width:100px;"><div style="width:'+pct+'%;height:100%;background:'+barColor+';border-radius:4px;"></div></div></td>'+
      '<td class="acc-td">'+r.client+'</td>'+
      '<td class="acc-td" style="font-weight:600;">'+fmtAmt(r.budget)+'</td>'+
      '<td class="acc-td">'+fmtAmt(r.spent)+'</td>'+
      '<td class="acc-td" style="font-weight:600;color:'+(rem<0?'#ef4444':'var(--text-primary)')+';">'+fmtAmt(rem)+'</td>'+
      '<td class="acc-td">'+badge(r.status)+'</td>'+
      '<td class="acc-td">'+actBtns('openPrjModal(\''+r.id+'\')','delRecord(\'prj\',\''+r.id+'\')')+'</td></tr>';
  }).join(''):emptyRow(8);
}

/* ── delete (localStorage modules only) ──────────────────── */
async function delRecord(key, id) {
  if(!confirm('Delete this record?')) return;
  var arr=load(key);
  var rec=arr.find(function(x){return x.id===id;});
  if(!rec) return toast('Record not found','error');
  var typeMap={
    pro:'proforma',
    quo:'quotation',
    po:'purchase_order',
    ven:'vendor',
    cwo:'client_work_order',
    vwo:'vendor_work_order',
    prj:'project_account'
  };
  try {
    await api('POST', '/recycle-bin/custom', {
      itemType:typeMap[key],
      itemId:rec.id,
      itemData:rec,
      itemTitle:rec.id + (rec.name ? (' - ' + rec.name) : rec.vendor ? (' - ' + rec.vendor) : rec.party ? (' - ' + rec.party) : rec.client ? (' - ' + rec.client) : '')
    });
  } catch (e) {
    return toast(e.message || 'Could not move to recycle bin', 'error');
  }
  save(key,arr.filter(function(x){return x.id!==id;}));
  var renders={pro:renderProforma,quo:renderQuotations,po:renderPO,ven:renderVendors,cwo:renderCWO,vwo:renderVWO,prj:renderProjects};
  if(renders[key]) renders[key]();
  toast('Deleted (moved to recycle bin)','success');
}

/* ── calculators ──────────────────────────────────────── */
function calcGST() {
  var amt=parseFloat(document.getElementById('gst-amount').value)||0;
  var rate=parseFloat(document.getElementById('gst-rate').value)||18;
  var mode=(document.getElementById('gst-mode')||{}).value||'exclusive';
  var baseAmt=mode==='inclusive' && rate>0 ? (amt/(1+(rate/100))) : amt;
  var gstAmt=mode==='inclusive' ? (amt-baseAmt) : (amt*rate/100);
  document.getElementById('gst-cgst').textContent=fmtAmt(gstAmt/2);
  document.getElementById('gst-sgst').textContent=fmtAmt(gstAmt/2);
  document.getElementById('gst-igst').textContent=fmtAmt(gstAmt);
  document.getElementById('gst-total').textContent=fmtAmt(mode==='inclusive'?amt:(amt+gstAmt));
}
function calcDiscount() {
  var orig=parseFloat(document.getElementById('disc-orig').value)||0;
  var pct=parseFloat(document.getElementById('disc-pct').value)||0;
  var disc=orig*pct/100;
  document.getElementById('disc-amt').textContent=fmtAmt(disc);
  document.getElementById('disc-pay').textContent=fmtAmt(orig-disc);
}
function calcTDS() {
  var gross=parseFloat(document.getElementById('tds-gross').value)||0;
  var rate=parseFloat(document.getElementById('tds-rate').value)||10;
  var mode=(document.getElementById('tds-mode')||{}).value||'exclusive';
  var baseAmt=mode==='inclusive' && rate>0 ? (gross/(1+(rate/100))) : gross;
  var ded=mode==='inclusive' ? (gross-baseAmt) : (gross*rate/100);
  document.getElementById('tds-ded').textContent=fmtAmt(ded);
  document.getElementById('tds-net').textContent=fmtAmt(mode==='inclusive'?baseAmt:(gross-ded));
}

/* ── init ─────────────────────────────────────────────── */
/* overrides for easier data entry */
function htmlEscape(str) {
  return String(str == null ? '' : str)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#39;');
}
function populatePOVendorDropdown(selectedName) {
  var sel=document.getElementById('po-vendor');
  if(!sel) return;
  var vendors=load('ven').filter(function(v){ return (v.status||'Active')!=='Inactive'; });
  sel.innerHTML='';
  var placeholder=document.createElement('option');
  placeholder.value='';
  placeholder.textContent='Select vendor';
  sel.appendChild(placeholder);
  vendors.forEach(function(v){
    var opt=document.createElement('option');
    opt.value=v.name||'';
    opt.textContent=(v.name||'Unnamed Vendor')+(v.id?' ('+v.id+')':'')+(v.gst?' | GST: '+v.gst:'');
    sel.appendChild(opt);
  });
  if(selectedName){
    var exists=Array.from(sel.options).some(function(opt){ return opt.value===selectedName; });
    if(!exists){
      var opt=document.createElement('option');
      opt.value=selectedName;
      opt.textContent=selectedName;
      sel.appendChild(opt);
    }
    sel.value=selectedName;
  }
}
function populateVendorWODropdown(selectedName) {
  var sel=document.getElementById('wo-vendor');
  if(!sel) return;
  var vendors=load('ven').filter(function(v){ return (v.status||'Active')!=='Inactive'; });
  sel.innerHTML='';
  var placeholder=document.createElement('option');
  placeholder.value='';
  placeholder.textContent='Select vendor';
  sel.appendChild(placeholder);
  vendors.forEach(function(v){
    var opt=document.createElement('option');
    opt.value=v.name||'';
    opt.textContent=(v.name||'Unnamed Vendor')+(v.id?' ('+v.id+')':'')+(v.gst?' | GST: '+v.gst:'');
    sel.appendChild(opt);
  });
  if(selectedName){
    var exists=Array.from(sel.options).some(function(opt){ return opt.value===selectedName; });
    if(!exists){
      var opt=document.createElement('option');
      opt.value=selectedName;
      opt.textContent=selectedName;
      sel.appendChild(opt);
    }
    sel.value=selectedName;
  }
}
function buildLineItemRow(item, totalUpdater) {
  item=item||{name:'',qty:1,rate:0};
  var total=((parseFloat(item.qty)||0)*(parseFloat(item.rate)||0));
  return '<div class="line-item-field">'+
      '<label class="line-item-label">Description</label>'+
      '<input type="text" class="form-control item-name" placeholder="Item description" value="'+htmlEscape(item.name||'')+'">'+
    '</div>'+
    '<div class="line-item-field">'+
      '<label class="line-item-label">Qty</label>'+
      '<input type="number" class="form-control item-qty" placeholder="Qty" value="'+(item.qty||1)+'" min="1" oninput="'+totalUpdater+'()">'+
    '</div>'+
    '<div class="line-item-field">'+
      '<label class="line-item-label">Rate</label>'+
      '<input type="number" class="form-control item-rate" placeholder="Rate" value="'+(item.rate||0)+'" min="0" oninput="'+totalUpdater+'()">'+
    '</div>'+
    '<div class="line-item-field">'+
      '<label class="line-item-label">Total</label>'+
      '<div class="item-total">'+fmtAmt(total)+'</div>'+
    '</div>'+
    '<div class="line-item-actions">'+
      '<button type="button" class="btn btn-danger btn-sm line-item-remove" onclick="this.closest(\'.line-item-row\').remove();'+totalUpdater+'()"><i class="bx bx-x"></i></button>'+
    '</div>';
}
function wireLineItemTotal(row) {
  function recalc() {
    var qty=parseFloat(row.querySelector('.item-qty').value)||0;
    var rate=parseFloat(row.querySelector('.item-rate').value)||0;
    row.querySelector('.item-total').textContent=fmtAmt(qty*rate);
  }
  var qtyEl=row.querySelector('.item-qty');
  var rateEl=row.querySelector('.item-rate');
  if(qtyEl) qtyEl.addEventListener('input', recalc);
  if(rateEl) rateEl.addEventListener('input', recalc);
  recalc();
}
function addLineItemRow(container, item) {
  var div=document.createElement('div');
  div.className='line-item-row';
  div.innerHTML=buildLineItemRow(item,'updateDocTotal');
  container.appendChild(div);
  wireLineItemTotal(div);
}
function addPOItemRow(container, item) {
  var div=document.createElement('div');
  div.className='line-item-row';
  div.innerHTML=buildLineItemRow(item,'updatePOTotal');
  container.appendChild(div);
  wireLineItemTotal(div);
}
function openPOModal(id) {
  editingPOId=id||null;
  document.getElementById('po-modal-title').textContent=id?'Edit Purchase Order':'New Purchase Order';
  document.getElementById('po-items').innerHTML='';
  populatePOVendorDropdown();
  if(id){
    var rec=load('po').find(function(x){return x.id===id;}); if(!rec)return;
    document.getElementById('po-id').value=rec.id;
    populatePOVendorDropdown(rec.vendor||'');
    document.getElementById('po-date').value=rec.date;
    document.getElementById('po-delivery').value=rec.deliveryDate||'';
    document.getElementById('po-status-sel').value=rec.status;
    document.getElementById('po-notes').value=rec.notes||'';
    (rec.items||[]).forEach(function(it){addPOItemRow(document.getElementById('po-items'),it);});
  } else {
    document.getElementById('po-id').value=genId('PO');
    document.getElementById('po-vendor').value='';
    document.getElementById('po-date').value=today();
    document.getElementById('po-delivery').value='';
    document.getElementById('po-status-sel').value='Draft';
    document.getElementById('po-notes').value='';
    addPOItemRow(document.getElementById('po-items'),null);
  }
  updatePOTotal();
  openModal('po-modal');
}
function savePO() {
  var items=getDocItems(document.getElementById('po-items'));
  var vendorName=document.getElementById('po-vendor').value||'';
  if(!vendorName) return toast('Select a vendor','error');
  if(!items.length) return toast('Add at least one item','error');
  var rec={id:document.getElementById('po-id').value, vendor:vendorName,
    date:document.getElementById('po-date').value, deliveryDate:document.getElementById('po-delivery').value,
    status:document.getElementById('po-status-sel').value, notes:document.getElementById('po-notes').value,
    items:items, amount:items.reduce(function(s,it){return s+it.qty*it.rate;},0)};
  var arr=load('po');
  if(editingPOId){var i=arr.findIndex(function(x){return x.id===editingPOId;});if(i>=0)arr[i]=rec;}else arr.unshift(rec);
  save('po',arr); closeModal('po-modal'); renderPO(); toast('Saved!','success');
}
function openWOModal(type, id) {
  editingWOType=type; editingWOId=id||null;
  var labels={cwo:{title:id?'Edit Client Work Order':'New Client Work Order', party:'Client Name'},
               vwo:{title:id?'Edit Vendor Work Order':'New Vendor Work Order', party:'Vendor'}};
  document.getElementById('wo-type').value=type;
  document.getElementById('wo-modal-title').textContent=labels[type].title;
  document.getElementById('wo-party-label').textContent=labels[type].party;
  var partyInput=document.getElementById('wo-party');
  var vendorSelect=document.getElementById('wo-vendor');
  if(type==='vwo'){
    partyInput.style.display='none';
    vendorSelect.style.display='';
    populateVendorWODropdown();
  } else {
    partyInput.style.display='';
    vendorSelect.style.display='none';
    vendorSelect.value='';
  }
  if(id){
    var rec=load(type).find(function(x){return x.id===id;}); if(!rec)return;
    document.getElementById('wo-id').value=rec.id;
    partyInput.value=rec.party||'';
    if(type==='vwo') populateVendorWODropdown(rec.party||'');
    document.getElementById('wo-project').value=rec.project||'';
    document.getElementById('wo-start').value=rec.startDate||'';
    document.getElementById('wo-end').value=rec.endDate||'';
    document.getElementById('wo-scope').value=rec.scope||'';
    document.getElementById('wo-amount').value=rec.amount||0;
    document.getElementById('wo-status-sel').value=rec.status||'Draft';
  } else {
    ['wo-party','wo-project','wo-scope'].forEach(function(i){document.getElementById(i).value='';});
    if(type==='vwo') populateVendorWODropdown();
    document.getElementById('wo-id').value=genId(type==='cwo'?'CWO':'VWO');
    document.getElementById('wo-start').value=today();
    document.getElementById('wo-end').value='';
    document.getElementById('wo-amount').value=0;
    document.getElementById('wo-status-sel').value='Draft';
  }
  openModal('wo-modal');
}
function saveWO() {
  var type=document.getElementById('wo-type').value;
  var partyName=type==='vwo' ? (document.getElementById('wo-vendor').value||'') : document.getElementById('wo-party').value;
  var rec={id:document.getElementById('wo-id').value, party:partyName,
    project:document.getElementById('wo-project').value, startDate:document.getElementById('wo-start').value,
    endDate:document.getElementById('wo-end').value, scope:document.getElementById('wo-scope').value,
    amount:parseFloat(document.getElementById('wo-amount').value)||0, status:document.getElementById('wo-status-sel').value};
  if(!rec.party) return toast(type==='vwo'?'Select a vendor':'Name required','error');
  var arr=load(type);
  if(editingWOId){var i=arr.findIndex(function(x){return x.id===editingWOId;});if(i>=0)arr[i]=rec;}else arr.unshift(rec);
  save(type,arr); closeModal('wo-modal');
  if(type==='cwo') renderCWO(); else renderVWO(); toast('Saved!','success');
}
document.addEventListener('DOMContentLoaded', function(){
  populatePOVendorDropdown();
  populateVendorWODropdown();
});
updateDashStats();
</script>
