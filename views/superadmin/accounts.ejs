<%- include('../partials/head', {title: 'Accounts'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-superadmin') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title"><i class="bx bxs-credit-card" style="color:var(--accent)"></i> Accounts</div>
          <div class="page-subtitle">Financial management - invoices, orders, vendors and projects</div>
        </div>
      </div>
      <div class="header-actions"></div>
    </header>

    <div class="page-body admin-employees-page">
      <div class="employee-directory-shell">

        <!-- Module Tabs -->
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:24px;background:var(--bg-input);border-radius:12px;padding:4px;">
          <button class="acc-tab active" id="tab-home"    onclick="showModule('home')"><i class="bx bxs-home"></i> Dashboard</button>
          <button class="acc-tab" id="tab-inv"     onclick="showModule('inv')"><i class="bx bxs-receipt"></i> Invoices</button>
          <button class="acc-tab" id="tab-pro"     onclick="showModule('pro')"><i class="bx bxs-file-doc"></i> Proforma</button>
          <button class="acc-tab" id="tab-quo"     onclick="showModule('quo')"><i class="bx bxs-notepad"></i> Quotations</button>
          <button class="acc-tab" id="tab-po"      onclick="showModule('po')"><i class="bx bxs-truck"></i> Purchase Orders</button>
          <button class="acc-tab" id="tab-ven"     onclick="showModule('ven')"><i class="bx bxs-user-badge"></i> Vendors</button>
          <button class="acc-tab" id="tab-cwo"     onclick="showModule('cwo')"><i class="bx bxs-briefcase"></i> Client W/O</button>
          <button class="acc-tab" id="tab-vwo"     onclick="showModule('vwo')"><i class="bx bxs-wrench"></i> Vendor W/O</button>
          <button class="acc-tab" id="tab-prj"     onclick="showModule('prj')"><i class="bx bxs-bar-chart-alt-2"></i> Project Accounts</button>
        </div>

        <!-- ═══════════════════════════════════════════════════ DASHBOARD -->
        <div id="mod-home" class="acc-module">
          <div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
            <div class="stat-card"><div class="stat-icon blue"><i class="bx bxs-receipt"></i></div><div><div class="stat-value" id="dash-inv">0</div><div class="stat-label">Invoices</div></div></div>
            <div class="stat-card"><div class="stat-icon green"><i class="bx bxs-user-badge"></i></div><div><div class="stat-value" id="dash-ven">0</div><div class="stat-label">Vendors</div></div></div>
            <div class="stat-card"><div class="stat-icon orange"><i class="bx bxs-briefcase"></i></div><div><div class="stat-value" id="dash-cwo">0</div><div class="stat-label">Client W/O</div></div></div>
            <div class="stat-card"><div class="stat-icon" style="background:#f3e8ff;color:#7c3aed;"><i class="bx bxs-bar-chart-alt-2"></i></div><div><div class="stat-value" id="dash-prj">0</div><div class="stat-label">Projects</div></div></div>
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;">
            <% var modules = [
              {key:'inv', icon:'bxs-receipt',       color:'#3b82f6', bg:'#dbeafe', title:'Invoices',            desc:'Manage client invoices and billing'},
              {key:'pro', icon:'bxs-file-doc',       color:'#8b5cf6', bg:'#ede9fe', title:'Proforma Invoices',   desc:'Generate preliminary invoices for clients'},
              {key:'quo', icon:'bxs-notepad',        color:'#0ea5e9', bg:'#e0f2fe', title:'Quotations',          desc:'Create and send quotes to potential clients'},
              {key:'po',  icon:'bxs-truck',          color:'#f59e0b', bg:'#fef3c7', title:'Purchase Orders',     desc:'Manage vendor purchase orders'},
              {key:'ven', icon:'bxs-user-badge',     color:'#22c55e', bg:'#dcfce7', title:'Vendor Registration', desc:'Register and manage vendor information'},
              {key:'cwo', icon:'bxs-briefcase',      color:'#ef4444', bg:'#fee2e2', title:'Client Work Orders',  desc:'Track work orders for clients'},
              {key:'vwo', icon:'bxs-wrench',         color:'#f97316', bg:'#ffedd5', title:'Vendor Work Orders',  desc:'Assign and track vendor work orders'},
              {key:'prj', icon:'bxs-bar-chart-alt-2',color:'#7c3aed', bg:'#f3e8ff', title:'Project Accounts',   desc:'Budget and track project financials'}
            ]; %>
            <% modules.forEach(function(m) { %>
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;display:flex;flex-direction:column;gap:12px;transition:box-shadow .2s;cursor:pointer;" onclick="showModule('<%= m.key %>')" onmouseover="this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.boxShadow=''">
              <div style="width:44px;height:44px;border-radius:12px;background:<%= m.bg %>;display:flex;align-items:center;justify-content:center;">
                <i class="bx <%= m.icon %>" style="font-size:22px;color:<%= m.color %>;"></i>
              </div>
              <div>
                <div style="font-weight:700;font-size:14px;color:var(--text-primary);margin-bottom:4px;"><%= m.title %></div>
                <div style="font-size:12px;color:var(--text-muted);"><%= m.desc %></div>
              </div>
              <button class="btn btn-ghost btn-sm" style="margin-top:auto;justify-content:flex-start;" onclick="event.stopPropagation();showModule('<%= m.key %>')">Go to <%= m.title %> <i class="bx bx-chevron-right"></i></button>
            </div>
            <% }); %>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ INVOICES -->
        <div id="mod-inv" class="acc-module" style="display:none;">
          <!-- Module Title -->
          <div style="margin-bottom:20px;">
            <div style="font-size:17px;font-weight:800;color:var(--text-primary);margin-bottom:4px;"><i class="bx bxs-receipt" style="color:var(--accent);margin-right:6px;"></i>Invoice Management & Tools</div>
            <div style="font-size:12px;color:var(--text-muted);">Create, view, and manage client invoices. Includes helpful calculators and export options.</div>
          </div>

          <!-- Sub-tabs -->
          <div style="display:flex;gap:4px;background:var(--bg-input);border-radius:10px;padding:3px;width:fit-content;margin-bottom:20px;">
            <button class="acc-subtab active" id="stab-invoices" onclick="showSubTab('invoices')"><i class="bx bx-list-ul"></i> Invoices</button>
            <button class="acc-subtab" id="stab-calc" onclick="showSubTab('calc')"><i class="bx bx-calculator"></i> Calculators</button>
          </div>

          <!-- ── Invoices sub-tab ── -->
          <div id="sub-invoices">
            <!-- Invoice number settings -->
            <div class="acc-inline-settings">
              <div class="acc-inline-title"><i class="bx bx-cog"></i> Invoice Number Format</div>
              <div class="acc-inline-field">
                <label class="acc-inline-label" for="inv-company-code">Company Code</label>
                <input type="text" id="inv-company-code" class="form-control acc-inline-input" placeholder="e.g. DHPE" maxlength="8" oninput="updateInvNumPreview()">
              </div>
              <div class="acc-inline-field">
                <label class="acc-inline-label" for="inv-fy-sel">Financial Year</label>
                <select id="inv-fy-sel" class="form-control acc-inline-input" onchange="updateInvNumPreview()"></select>
              </div>
              <div class="acc-inline-preview">Preview: <code id="inv-num-preview" class="acc-inline-code">INV-001/DHPE/26-27/XXXXXX</code></div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-muted);cursor:pointer;">
                <input type="checkbox" id="inv-show-deleted" onchange="renderInvoices()" style="accent-color:var(--accent);width:15px;height:15px;">
                Show Deleted
              </label>
              <div style="margin-left:auto;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                <div class="search-bar" style="width:200px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="inv-search" placeholder="Search ref, customer..." oninput="renderInvoices()"></div>
                <select id="inv-status" class="form-control" style="width:120px" onchange="renderInvoices()">
                  <option value="">All Status</option><option>Draft</option><option>Sent</option><option>Paid</option><option>Overdue</option><option>Cancelled</option>
                </select>
                <select id="inv-type" class="form-control" style="width:120px" onchange="renderInvoices()">
                  <option value="">All Types</option><option value="B2B">Tax Invoice</option><option value="B2C">B2C Invoice</option>
                </select>
                <button class="btn btn-primary" onclick="openGSTModal()" style="font-weight:700;gap:6px;">
                  <i class="bx bx-plus-circle"></i> Create Invoice
                </button>
              </div>
            </div>
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
              <table style="width:100%;border-collapse:collapse;" id="inv-table">
                <thead><tr style="background:var(--bg-input);border-bottom:2px solid var(--border);">
                  <th class="acc-th">Ref #</th>
                  <th class="acc-th">Type</th>
                  <th class="acc-th">Customer</th>
                  <th class="acc-th">Date</th>
                  <th class="acc-th">Total (₹)</th>
                  <th class="acc-th">Status</th>
                  <th class="acc-th" style="text-align:center;">Actions</th>
                </tr></thead>
                <tbody id="inv-body"></tbody>
              </table>
            </div>
          </div>

          <!-- ── Reports sub-tab ── -->
          <!-- Calculator subtab -->
          <div id="sub-calc" style="display:none;">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;">
              <!-- GST Calc -->
              <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;">
                <div style="font-weight:700;font-size:14px;margin-bottom:16px;"><i class="bx bx-calculator" style="color:var(--accent)"></i> GST Calculator</div>
                <div class="form-group"><label class="form-label">Amount</label><input type="number" id="gst-amount" class="form-control" placeholder="Enter amount" oninput="calcGST()" onwheel="this.blur()"></div>
                <div class="form-group"><label class="form-label">GST Rate %</label>
                  <input type="number" id="gst-rate" class="form-control" placeholder="Enter GST rate" value="18" min="0" step="0.01" inputmode="decimal" oninput="calcGST()" onwheel="this.blur()">
                </div>
                <div class="form-group"><label class="form-label">GST Type</label>
                  <select id="gst-mode" class="form-control" onchange="calcGST()">
                    <option value="exclusive" selected>Exclusive</option>
                    <option value="inclusive">Inclusive</option>
                  </select>
                </div>
                <div style="background:var(--bg-input);border-radius:10px;padding:14px;margin-top:8px;">
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">CGST</span><span id="gst-cgst" style="font-weight:600;">₹0</span></div>
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">SGST</span><span id="gst-sgst" style="font-weight:600;">₹0</span></div>
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">IGST</span><span id="gst-igst" style="font-weight:600;">₹0</span></div>
                  <div style="border-top:1px solid var(--border);margin:8px 0;"></div>
                  <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:700;"><span>Total</span><span id="gst-total" style="color:var(--accent);">₹0</span></div>
                </div>
              </div>
              <!-- Discount Calc -->
              <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;">
                <div style="font-weight:700;font-size:14px;margin-bottom:16px;"><i class="bx bx-purchase-tag" style="color:var(--accent)"></i> Discount Calculator</div>
                <div class="form-group"><label class="form-label">Original Price</label><input type="number" id="disc-orig" class="form-control" placeholder="Original price" oninput="calcDiscount()"></div>
                <div class="form-group"><label class="form-label">Discount %</label><input type="number" id="disc-pct" class="form-control" placeholder="e.g. 10" min="0" max="100" oninput="calcDiscount()"></div>
                <div style="background:var(--bg-input);border-radius:10px;padding:14px;margin-top:8px;">
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">Discount Amount</span><span id="disc-amt" style="font-weight:600;">₹0</span></div>
                  <div style="border-top:1px solid var(--border);margin:8px 0;"></div>
                  <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:700;"><span>Payable Amount</span><span id="disc-pay" style="color:var(--accent);">₹0</span></div>
                </div>
              </div>
              <!-- TDS Calc -->
              <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;">
                <div style="font-weight:700;font-size:14px;margin-bottom:16px;"><i class="bx bx-trending-down" style="color:var(--accent)"></i> TDS Calculator</div>
                <div class="form-group"><label class="form-label">Amount</label><input type="number" id="tds-gross" class="form-control" placeholder="Enter amount" oninput="calcTDS()" onwheel="this.blur()"></div>
                <div class="form-group"><label class="form-label">TDS Rate %</label>
                  <input type="number" id="tds-rate" class="form-control" placeholder="Enter TDS rate" value="10" min="0" step="0.01" inputmode="decimal" oninput="calcTDS()" onwheel="this.blur()">
                </div>
                <div class="form-group"><label class="form-label">TDS Type</label>
                  <select id="tds-mode" class="form-control" onchange="calcTDS()">
                    <option value="exclusive" selected>Exclusive</option>
                    <option value="inclusive">Inclusive</option>
                  </select>
                </div>
                <div style="background:var(--bg-input);border-radius:10px;padding:14px;margin-top:8px;">
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">TDS Deduction</span><span id="tds-ded" style="font-weight:600;">₹0</span></div>
                  <div style="border-top:1px solid var(--border);margin:8px 0;"></div>
                  <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:700;"><span>Net Receivable</span><span id="tds-net" style="color:var(--accent);">₹0</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ PROFORMA -->
        <div id="mod-pro" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="pro-search" placeholder="Search proforma..." oninput="renderProforma()"></div>
            <select id="pro-status" class="form-control" style="width:140px" onchange="renderProforma()">
              <option value="">All Status</option><option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openProformaModal()"><i class="bx bx-plus"></i> New Proforma</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Proforma #</th><th class="acc-th">Customer</th><th class="acc-th">Date</th><th class="acc-th">Valid Till</th><th class="acc-th">Total (₹)</th><th class="acc-th">Status</th><th class="acc-th" style="text-align:center;">Actions</th>
              </tr></thead>
              <tbody id="pro-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ QUOTATIONS -->
        <div id="mod-quo" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="quo-search" placeholder="Search quotation..." oninput="renderQuotations()"></div>
            <select id="quo-status" class="form-control" style="width:140px" onchange="renderQuotations()">
              <option value="">All Status</option><option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openDocModal('quo')"><i class="bx bx-plus"></i> New Quotation</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Quotation #</th><th class="acc-th">Client</th><th class="acc-th">Date</th><th class="acc-th">Valid Till</th><th class="acc-th">Amount</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="quo-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ══════════════════════════════════════════ PURCHASE ORDERS -->
        <div id="mod-po" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="po-search" placeholder="Search PO..." oninput="renderPO()"></div>
            <select id="po-status" class="form-control" style="width:140px" onchange="renderPO()">
              <option value="">All Status</option><option>Draft</option><option>Sent</option><option>Received</option><option>Cancelled</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openPOModal()"><i class="bx bx-plus"></i> New PO</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">PO #</th><th class="acc-th">Vendor</th><th class="acc-th">Date</th><th class="acc-th">Delivery Date</th><th class="acc-th">Amount</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="po-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ═══════════════════════════════════════ VENDOR REGISTRATION -->
        <div id="mod-ven" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="ven-search" placeholder="Search vendor..." oninput="renderVendors()"></div>
            <select id="ven-status" class="form-control" style="width:140px" onchange="renderVendors()">
              <option value="">All Status</option><option>Active</option><option>Inactive</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openVenModal()"><i class="bx bx-plus"></i> Register Vendor</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Vendor #</th><th class="acc-th">Name</th><th class="acc-th">Contact</th><th class="acc-th">Email</th><th class="acc-th">Category</th><th class="acc-th">GST</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="ven-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ══════════════════════════════════════ CLIENT WORK ORDERS -->
        <div id="mod-cwo" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="cwo-search" placeholder="Search CWO..." oninput="renderCWO()"></div>
            <select id="cwo-status" class="form-control" style="width:140px" onchange="renderCWO()">
              <option value="">All Status</option><option>Draft</option><option>Proposed</option><option>Active</option><option>Completed</option><option>Cancelled</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openWOModal('cwo')"><i class="bx bx-plus"></i> Create CWO</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">CWO #</th><th class="acc-th">Client</th><th class="acc-th">Project</th><th class="acc-th">Start Date</th><th class="acc-th">End Date</th><th class="acc-th">Amount</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="cwo-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ═══════════════════════════════════════ VENDOR WORK ORDERS -->
        <div id="mod-vwo" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="vwo-search" placeholder="Search VWO..." oninput="renderVWO()"></div>
            <select id="vwo-status" class="form-control" style="width:140px" onchange="renderVWO()">
              <option value="">All Status</option><option>Draft</option><option>Proposed</option><option>Active</option><option>Completed</option><option>Cancelled</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openWOModal('vwo')"><i class="bx bx-plus"></i> Create VWO</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">VWO #</th><th class="acc-th">Vendor</th><th class="acc-th">Project</th><th class="acc-th">Start Date</th><th class="acc-th">End Date</th><th class="acc-th">Amount</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="vwo-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ════════════════════════════════════════ PROJECT ACCOUNTS -->
        <div id="mod-prj" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="prj-search" placeholder="Search project..." oninput="renderProjects()"></div>
            <select id="prj-status" class="form-control" style="width:140px" onchange="renderProjects()">
              <option value="">All Status</option><option>Planning</option><option>Active</option><option>Completed</option><option>On Hold</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openPrjModal()"><i class="bx bx-plus"></i> New Project</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Project #</th><th class="acc-th">Name</th><th class="acc-th">Client</th><th class="acc-th">Budget</th><th class="acc-th">Spent</th><th class="acc-th">Remaining</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="prj-body"></tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════ MODALS -->

<!-- ════════════════════════════ GST INVOICE MODAL ════════════════════════════ -->
<div class="modal-overlay" id="gst-inv-modal" style="align-items:flex-start;padding:10px 0;">
  <div class="modal gst-invoice-modal-shell" style="max-width:99vw;width:99vw;margin:0 auto;border-radius:14px;">
    <div class="modal-header" style="position:sticky;top:0;z-index:10;background:var(--bg-card);border-radius:14px 14px 0 0;">
      <span class="modal-title" id="gst-inv-title"><i class="bx bxs-receipt" style="color:var(--accent)"></i> New GST Invoice</span>
      <button class="modal-close" onclick="closeModal('gst-inv-modal')" style="font-size:22px;">×</button>
    </div>
    <div class="modal-body gst-invoice-modal-body" style="padding:0;overflow-y:auto;overflow-x:hidden;">
      <input type="hidden" id="gst-inv-id">

      <!-- ── Section: Invoice Info ──────────────────────────────────────── -->
      <div class="gst-section">
        <div class="gst-section-title"><i class="bx bxs-file-doc"></i> Invoice Information</div>
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;">
          <div class="form-group">
            <label class="form-label">Invoice #</label>
            <input type="text" id="gst-number" class="form-control" readonly style="background:var(--bg-input);font-weight:600;" placeholder="Auto-generated">
          </div>
          <div class="form-group">
            <label class="form-label">Invoice Type</label>
            <select id="gst-type" class="form-control">
              <option value="B2B">B2B</option>
              <option value="B2C">B2C</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Invoice Date <span style="color:#ef4444">*</span></label>
            <input type="date" id="gst-date" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Due Date</label>
            <input type="date" id="gst-due" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Place of Supply</label>
            <input type="text" id="gst-supply" class="form-control" placeholder="e.g. Maharashtra">
          </div>
        </div>
      </div>

      <!-- ── Section: Seller & Buyer ────────────────────────────────────── -->
      <div class="gst-collapse-panel">
        <div class="gst-panel-hdr" onclick="toggleGSTPanel(this)"><i class="bx bxs-buildings"></i> Seller & Customer Details <i class="bx bx-chevron-up gst-chevron"></i></div>
        <div class="gst-panel-body" style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--border);">
        <!-- Seller -->
        <div class="gst-section" style="border-right:1px solid var(--border);">
          <div class="gst-section-title" style="color:#1d4ed8;"><i class="bx bxs-buildings"></i> Company / Seller Details</div>
          <div class="form-group"><label class="form-label">Company Name <span style="color:#ef4444">*</span></label><input type="text" id="gst-s-name" class="form-control" placeholder="Your company name"></div>
          <div class="form-group"><label class="form-label">GSTIN</label><input type="text" id="gst-s-gstin" class="form-control" placeholder="22AAAAA0000A1Z5" maxlength="15" style="text-transform:uppercase"></div>
          <div class="form-group"><label class="form-label">Address</label><textarea id="gst-s-addr" class="form-control" rows="2" placeholder="Full address"></textarea></div>
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:8px;">
            <div class="form-group"><label class="form-label">State</label><input type="text" id="gst-s-state" class="form-control" placeholder="e.g. Maharashtra"></div>
            <div class="form-group"><label class="form-label">State Code</label><input type="text" id="gst-s-code" class="form-control" placeholder="27" maxlength="2"></div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div class="form-group"><label class="form-label">Phone</label><input type="text" id="gst-s-phone" class="form-control" placeholder="Contact number"></div>
            <div class="form-group"><label class="form-label">Email</label><input type="email" id="gst-s-email" class="form-control" placeholder="company@email.com"></div>
          </div>
          <div class="form-group"><label class="form-label">PAN</label><input type="text" id="gst-s-pan" class="form-control" placeholder="ABCDE1234F" maxlength="10" style="text-transform:uppercase"></div>
        </div>
        <!-- Buyer -->
        <div class="gst-section">
          <div class="gst-section-title" style="color:#0891b2;"><i class="bx bxs-user-detail"></i> Customer / Buyer Details</div>
          <!-- Vendor quick-select -->
          <div class="form-group">
            <label class="form-label"><i class="bx bxs-user-badge" style="color:#0891b2;font-size:13px;"></i> Select from Vendor List <span style="color:var(--text-muted);font-weight:400;font-size:11px;">(auto-fills fields below)</span></label>
            <select id="gst-vendor-sel" class="form-control" onchange="fillFromVendor(this.value)" style="border-color:#0891b2;">
              <option value="">— Type manually or pick a vendor —</option>
            </select>
          </div>
          <div style="border-top:1px dashed var(--border);margin:4px 0 12px 0;"></div>
          <div class="form-group"><label class="form-label">Customer Name <span style="color:#ef4444">*</span></label><input type="text" id="gst-c-name" class="form-control" placeholder="Customer / company name"></div>
          <div class="form-group"><label class="form-label">GSTIN <span style="color:var(--text-muted);font-weight:400;font-size:11px;">(optional for B2C)</span></label><input type="text" id="gst-c-gstin" class="form-control" placeholder="Customer GSTIN" maxlength="15" style="text-transform:uppercase"></div>
          <div class="form-group"><label class="form-label">Address</label><textarea id="gst-c-addr" class="form-control" rows="2" placeholder="Customer address"></textarea></div>
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:8px;">
            <div class="form-group"><label class="form-label">State</label><input type="text" id="gst-c-state" class="form-control" placeholder="e.g. Karnataka" oninput="recalcGST()"></div>
            <div class="form-group"><label class="form-label">State Code</label><input type="text" id="gst-c-code" class="form-control" placeholder="29" maxlength="2" oninput="recalcGST()"></div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div class="form-group"><label class="form-label">PAN</label><input type="text" id="gst-c-pan" class="form-control" placeholder="ABCDE1234F" maxlength="10" style="text-transform:uppercase"></div>
            <div class="form-group"><label class="form-label">Email</label><input type="email" id="gst-c-email" class="form-control" placeholder="customer@email.com"></div>
          </div>
          <div style="background:var(--bg-input);border-radius:8px;padding:10px;font-size:12px;color:var(--text-muted);margin-top:4px;">
            <i class="bx bx-info-circle"></i>
            <span id="gst-tax-hint">CGST + SGST applied (same state). Change state code to switch.</span>
          </div>
        </div>
        </div><!-- /gst-panel-body -->
      </div><!-- /gst-collapse-panel -->

      <!-- ── Section: Bill Details + Bank Details ─────────────────────── -->
      <div class="gst-collapse-panel">
        <div class="gst-panel-hdr" onclick="toggleGSTPanel(this)"><i class="bx bxs-calendar"></i> Bill Details & Bank Account <i class="bx bx-chevron-up gst-chevron"></i></div>
        <div class="gst-panel-body" style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--border);">
        <!-- Bill Details -->
        <div class="gst-section" style="border-right:1px solid var(--border);">
          <div class="gst-section-title" style="color:#0891b2;"><i class="bx bxs-calendar"></i> Bill Details <span style="font-size:11px;font-weight:400;color:var(--text-muted);">(optional)</span></div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
            <div class="form-group"><label class="form-label">Bill Month</label><input type="text" id="gst-bill-month" class="form-control" placeholder="e.g. Feb-26"></div>
            <div class="form-group"><label class="form-label">Period From</label><input type="date" id="gst-bill-from" class="form-control"></div>
            <div class="form-group"><label class="form-label">Period To</label><input type="date" id="gst-bill-to" class="form-control"></div>
          </div>
          <div class="form-group"><label class="form-label">Work Order Ref</label><input type="text" id="gst-work-order" class="form-control" placeholder="WO number / reference"></div>
          <div class="form-group"><label class="form-label">Project Name</label><input type="text" id="gst-project" class="form-control" placeholder="Project name"></div>
          <div class="form-group"><label class="form-label">Work Details</label><textarea id="gst-work-details" class="form-control" rows="2" placeholder="Brief description of work done"></textarea></div>
        </div>
        <!-- Bank Details -->
        <div class="gst-section">
          <div class="gst-section-title" style="color:#1d4ed8;"><i class="bx bxs-bank"></i> Bank Details <span style="font-size:11px;font-weight:400;color:var(--text-muted);">(for payment)</span></div>
          <div class="form-group"><label class="form-label">Bank Name</label><input type="text" id="gst-bank-name" class="form-control" placeholder="e.g. State Bank of India"></div>
          <div class="form-group"><label class="form-label">Account Holder Name</label><input type="text" id="gst-bank-acname" class="form-control" placeholder="Name on bank account"></div>
          <div class="form-group"><label class="form-label">Account Number</label><input type="text" id="gst-bank-ac" class="form-control" placeholder="Bank account number"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div class="form-group"><label class="form-label">IFSC Code</label><input type="text" id="gst-bank-ifsc" class="form-control" placeholder="SBIN0001234" style="text-transform:uppercase"></div>
            <div class="form-group"><label class="form-label">Branch</label><input type="text" id="gst-bank-branch" class="form-control" placeholder="Branch name"></div>
          </div>
        </div>
        </div><!-- /gst-panel-body -->
      </div><!-- /gst-collapse-panel -->

      <!-- ── Section: Items ──────────────────────────────────────────────── -->
      <div class="gst-collapse-panel">
        <div class="gst-panel-hdr" onclick="toggleGSTPanel(this)"><i class="bx bxs-package"></i> Product / Service Items <i class="bx bx-chevron-up gst-chevron"></i></div>
        <div class="gst-panel-body">
        <div class="gst-section" style="border-top:1px solid var(--border);">
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;table-layout:fixed;" id="gst-items-table">
            <colgroup>
              <col style="width:36px"><col style="width:7%"><col><col style="width:8%"><col style="width:6%"><col style="width:6%"><col style="width:10%"><col style="width:7%"><col style="width:8%"><col style="width:10%"><col style="width:36px">
            </colgroup>
            <thead>
              <tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">#</th>
                <th class="acc-th">Code</th>
                <th class="acc-th">Item Name / Description</th>
                <th class="acc-th">HSN/SAC</th>
                <th class="acc-th">Qty</th>
                <th class="acc-th">Unit</th>
                <th class="acc-th">Unit Price (₹)</th>
                <th class="acc-th">Disc %</th>
                <th class="acc-th">Tax %</th>
                <th class="acc-th">Amount (₹)</th>
                <th class="acc-th"></th>
              </tr>
            </thead>
            <tbody id="gst-items-body"></tbody>
          </table>
        </div>
        <button type="button" class="btn btn-ghost btn-sm" style="margin-top:10px;" onclick="addGSTItem()">
          <i class="bx bx-plus"></i> Add Item
        </button>
        </div><!-- /gst-section -->
        </div><!-- /gst-panel-body -->
      </div><!-- /gst-collapse-panel -->

      <!-- ── Section: Tax Summary + Payment ─────────────────────────────── -->
      <div class="gst-collapse-panel">
        <div class="gst-panel-hdr" onclick="toggleGSTPanel(this)"><i class="bx bx-calculator"></i> Tax Summary & Payment <i class="bx bx-chevron-up gst-chevron"></i></div>
        <div class="gst-panel-body" style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--border);">
        <!-- Tax Summary -->
        <div class="gst-section" style="border-right:1px solid var(--border);">
          <div class="gst-section-title"><i class="bx bx-calculator"></i> Tax Calculation</div>
          <div class="gst-summary-table">
            <div class="gst-sum-row"><span>Subtotal (Taxable Value)</span><span id="gst-sub">₹0.00</span></div>
            <div class="gst-sum-row" id="gst-row-cgst"><span>CGST</span><span id="gst-cgst-val">₹0.00</span></div>
            <div class="gst-sum-row" id="gst-row-sgst"><span>SGST</span><span id="gst-sgst-val">₹0.00</span></div>
            <div class="gst-sum-row" id="gst-row-igst"><span>IGST</span><span id="gst-igst-val">₹0.00</span></div>
            <div class="gst-sum-row"><span>Total Tax</span><span id="gst-tax-total">₹0.00</span></div>
            <div class="gst-sum-row" style="border-top:1px solid var(--border);padding-top:8px;">
              <span>Round Off</span>
              <span id="gst-roundoff">₹0.00</span>
            </div>
            <div class="gst-sum-row gst-total-row">
              <span>TOTAL AMOUNT</span>
              <span id="gst-total-amt" style="font-size:18px;color:var(--accent);">₹0.00</span>
            </div>
          </div>
        </div>
        <!-- Payment -->
        <div class="gst-section">
          <div class="gst-section-title"><i class="bx bxs-wallet"></i> Payment & Status</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group">
              <label class="form-label">Payment Status</label>
              <select id="gst-pay-status" class="form-control">
                <option value="Unpaid">Unpaid</option>
                <option value="Paid">Paid</option>
                <option value="Partial">Partial</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Payment Mode</label>
              <select id="gst-pay-mode" class="form-control">
                <option value="">Select mode</option>
                <option value="Cash">Cash</option>
                <option value="UPI">UPI</option>
                <option value="Bank Transfer">Bank Transfer</option>
                <option value="Cheque">Cheque</option>
                <option value="Card">Card</option>
                <option value="NEFT">NEFT</option>
                <option value="RTGS">RTGS</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Invoice Status</label>
            <select id="gst-status" class="form-control">
              <option value="Draft">Draft</option>
              <option value="Sent">Sent</option>
              <option value="Paid">Paid</option>
              <option value="Overdue">Overdue</option>
              <option value="Cancelled">Cancelled</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Notes</label>
            <textarea id="gst-notes" class="form-control" rows="2" placeholder="Any additional notes for this invoice..."></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">Terms & Conditions</label>
            <textarea id="gst-terms" class="form-control" rows="2" placeholder="e.g. Payment due within 30 days..."></textarea>
          </div>
        </div>
        </div><!-- /gst-panel-body -->
      </div><!-- /gst-collapse-panel -->
    </div>

    <div class="modal-footer gst-invoice-modal-footer" style="flex-wrap:wrap;gap:8px;">
      <button class="btn btn-ghost" onclick="closeModal('gst-inv-modal')">Cancel</button>
      <div style="margin-left:auto;display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn btn-secondary" onclick="saveGSTInvoice('Draft')"><i class="bx bx-save"></i> Save as Draft</button>
        <button class="btn btn-primary" onclick="saveGSTInvoice()"><i class="bx bxs-receipt"></i> Generate Invoice</button>
      </div>
    </div>
  </div>
</div>

