/* ── PDF blob fetch helper ──────────────────────────────── */
function _proformaPDFBlob(proId, cb) {
  var rec = load('pro').find(function(r) { return r.id === proId; });
  if (!rec) return toast('Proforma not found', 'error');
  var token = getToken();
  fetch('/api/proformas/pdf', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify(rec)
  }).then(function(r) { return r.blob(); }).then(cb).catch(function() { toast('PDF generation failed', 'error'); });
}

function downloadProformaPDF(proId) {
  _proformaPDFBlob(proId, function(blob) {
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a'); a.href = url; a.download = 'Proforma-' + proId + '.pdf'; a.click(); URL.revokeObjectURL(url);
  });
}

function printProforma(proId) {
  _proformaPDFBlob(proId, function(blob) {
    var url = URL.createObjectURL(blob);
    var win = window.open(url);
    if (win) { win.addEventListener('load', function() { win.print(); }); }
    else { toast('Allow popups to use Print', 'error'); }
  });
}

/* ── Delete proforma ────────────────────────────────────── */
function deleteProforma(proId) {
  if (!confirm('Delete proforma ' + proId + '?')) return;
  save('pro', load('pro').filter(function(r) { return r.id !== proId; }));
  renderProforma();
  toast('Proforma deleted', 'success');
}

/* ── Convert proforma → Invoice (from table row) ────────── */
function convertToInvoiceFromId(proId) {
  var rec = load('pro').find(function(r) { return r.id === proId; });
  if (!rec) return toast('Proforma not found', 'error');
  _applyProformaToInvoiceModal(rec);
}

/* ── Convert proforma → Invoice (from inside modal) ─────── */
function convertToInvoice() {
  if (!proEditingId) return toast('Save the proforma first', 'error');
  var rec = load('pro').find(function(r) { return r.id === proEditingId; });
  if (!rec) return toast('Proforma not found', 'error');
  closeModal('pro-inv-modal');
  _applyProformaToInvoiceModal(rec);
}

function _applyProformaToInvoiceModal(rec) {
  showModule('inv');
  setTimeout(function() {
    openGSTModal(null);  // open blank invoice
    setTimeout(function() {
      // Fill seller
      document.getElementById('gst-s-name').value  = rec.sellerName  || '';
      document.getElementById('gst-s-gstin').value = rec.sellerGstin || '';
      document.getElementById('gst-s-addr').value  = rec.sellerAddress || '';
      document.getElementById('gst-s-state').value = rec.sellerState || '';
      document.getElementById('gst-s-code').value  = rec.sellerStateCode || '';
      document.getElementById('gst-s-phone').value = rec.sellerPhone || '';
      document.getElementById('gst-s-email').value = rec.sellerEmail || '';
      document.getElementById('gst-s-pan').value   = rec.sellerPan   || '';
      // Fill customer
      document.getElementById('gst-c-name').value  = rec.customerName  || '';
      document.getElementById('gst-c-gstin').value = rec.customerGstin || '';
      document.getElementById('gst-c-addr').value  = rec.customerAddress || '';
      document.getElementById('gst-c-state').value = rec.customerState || '';
      document.getElementById('gst-c-code').value  = rec.customerStateCode || '';
      document.getElementById('gst-c-pan').value   = rec.customerPan  || '';
      document.getElementById('gst-c-email').value = rec.customerEmail || '';
      // Fill other fields
      document.getElementById('gst-supply').value       = rec.placeOfSupply || '';
      document.getElementById('gst-bill-month').value   = rec.billMonth || '';
      document.getElementById('gst-bill-from').value    = rec.billPeriodFrom || '';
      document.getElementById('gst-bill-to').value      = rec.billPeriodTo || '';
      document.getElementById('gst-work-order').value   = rec.workOrder || '';
      document.getElementById('gst-project').value      = rec.projectName || '';
      document.getElementById('gst-work-details').value = rec.workDetails || '';
      document.getElementById('gst-bank-name').value    = rec.bankName || '';
      document.getElementById('gst-bank-acname').value  = rec.bankAcName || '';
      document.getElementById('gst-bank-ac').value      = rec.bankAccount || '';
      document.getElementById('gst-bank-ifsc').value    = rec.bankIfsc || '';
      document.getElementById('gst-bank-branch').value  = rec.bankBranch || '';
      document.getElementById('gst-notes').value        = rec.notes || '';
      document.getElementById('gst-terms').value        = rec.termsConditions || '';
      // Fill items
      document.getElementById('gst-items-body').innerHTML = '';
      gstItemCount = 0;
      (rec.items || []).forEach(function(it) { addGSTItem(it); });
      recalcGST();
      toast('Proforma data copied to Invoice. Review and save.', 'success');
    }, 300);
  }, 200);
}

