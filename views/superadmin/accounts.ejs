/* ══════════════════════════════════════════════════════════
   DROPDOWN POPULATORS (API-backed)
══════════════════════════════════════════════════════════ */
function populateClientDropdown(selId, selectedId, placeholder) {
  var sel = document.getElementById(selId);
  if (!sel) return Promise.resolve();
  return api('GET', '/clients?status=Active').then(function(clients) {
    sel.innerHTML = '<option value="">' + (placeholder||'— Select client —') + '</option>';
    (clients||[]).forEach(function(c) {
      var opt = document.createElement('option');
      opt.value = c.id;
      opt.dataset.name       = c.name;
      opt.dataset.gstin      = c.gstin || '';
      opt.dataset.pan        = c.pan || '';
      opt.dataset.email      = c.email || '';
      opt.dataset.address    = c.billingAddress || '';
      opt.dataset.state      = c.state || '';
      opt.dataset.stateCode  = c.stateCode || '';
      opt.textContent = c.name + (c.clientCode ? ' (' + c.clientCode + ')' : '');
      if (selectedId && c.id == selectedId) opt.selected = true;
      sel.appendChild(opt);
    });
  }).catch(function(){});
}

function populateProjectDropdown(selId, selectedId, placeholder) {
  var sel = document.getElementById(selId);
  if (!sel) return Promise.resolve();
  return api('GET', '/project-accounts').then(function(projects) {
    sel.innerHTML = '<option value="">' + (placeholder || '— Select project —') + '</option>';
    (projects || []).forEach(function(p) {
      var opt = document.createElement('option');
      opt.value = p.id;
      opt.dataset.name = p.name;
      opt.textContent  = p.name + (p.projectCode ? ' (' + p.projectCode + ')' : '');
      if (selectedId && p.id == selectedId) opt.selected = true;
      sel.appendChild(opt);
    });
  }).catch(function(){});
}

function populateVendorDropdownAPI(selId, selectedId, placeholder) {
  var sel = document.getElementById(selId);
  if (!sel) return Promise.resolve();
  return api('GET', '/vendors?status=Active').then(function(vendors) {
    sel.innerHTML = '<option value="">' + (placeholder||'— Select vendor —') + '</option>';
    (vendors||[]).forEach(function(v) {
      var opt = document.createElement('option');
      opt.value = v.id;
      opt.dataset.name       = v.name;
      opt.dataset.gstin      = v.gstin || '';
      opt.dataset.pan        = v.pan || '';
      opt.dataset.email      = v.email || '';
      opt.dataset.address    = v.address || '';
      opt.dataset.state      = v.state || '';
      opt.dataset.stateCode  = v.stateCode || '';
      opt.dataset.bankName   = v.bankName || '';
      opt.dataset.bankAcName = v.bankAcName || '';
      opt.dataset.bankAccount= v.bankAccount || '';
      opt.dataset.bankIfsc   = v.bankIfsc || '';
      opt.dataset.bankBranch = v.bankBranch || '';
      opt.textContent = v.name + (v.vendorCode ? ' (' + v.vendorCode + ')' : '') + (v.gstin ? ' | ' + v.gstin : '');
      if (selectedId && v.id == selectedId) opt.selected = true;
      sel.appendChild(opt);
    });
  }).catch(function(){});
}

/* ══════════════════════════════════════════════════════════
