          (customerAddress ? '<div style="font-size:11px;color:#475569;margin-top:5px;">' + accEsc(customerAddress) + '</div>' : '') +
          (customerState ? '<div style="font-size:11px;color:#475569;margin-top:3px;">' + accEsc(customerState) + (customerStateCode ? ' (' + accEsc(customerStateCode) + ')' : '') + '</div>' : '') +
          (customerEmail ? '<div style="font-size:11px;color:#475569;margin-top:5px;">' + accEsc(customerEmail) + '</div>' : '') +
        '</div>' +
      '</div>'
    : '';

  var html =
    '<div class="acc-doc-page">' +
      headerHtml +
      '<div class="acc-doc-content">' +
        billCardsBlock +
        (billCardsBlock ? '' : (customerAddress ? '<div style="border:1px solid #b8c0cc;background:#fff;padding:7px 10px;margin-bottom:8px;"><b style="color:#111827;">Address:</b> ' + accEsc(customerAddress) + '</div>' : '')) +
        (rec.workOrder || rec.projectName || rec.billMonth ? '<div style="border:1px solid #b8c0cc;background:#fff;padding:7px 10px;margin-bottom:8px;display:flex;gap:14px;flex-wrap:wrap;">' + (rec.workOrder ? '<span><b>Work Order:</b> ' + accEsc(rec.workOrder) + '</span>' : '') + (rec.projectName ? '<span><b>Project:</b> ' + accEsc(rec.projectName) + '</span>' : '') + (rec.billMonth ? '<span><b>Bill Month:</b> ' + accEsc(rec.billMonth) + '</span>' : '') + '</div>' : '') +
        itemsBlock +
        (items.length ? '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;"><div style="border:1px solid #b8c0cc;background:#fff;padding:8px 10px;"><div style="font-weight:900;color:#111827;margin-bottom:3px;">Amount in Words</div><div>Rupees ' + accMoney(total).replace('Rs. ', '') + ' only</div></div><div style="border:1px solid #b8c0cc;background:#fff;padding:8px 10px;"><div style="display:grid;grid-template-columns:1fr max-content;gap:12px;padding-bottom:5px;"><span style="color:#4b5563;">Total Amount</span><b style="white-space:nowrap;text-align:right;">' + accMoney(subtotal) + '</b></div>' + (showTax && totalTax ? '<div style="display:grid;grid-template-columns:1fr max-content;gap:12px;padding-bottom:5px;"><span style="color:#4b5563;">Total Tax</span><b style="white-space:nowrap;text-align:right;">' + accMoney(totalTax) + '</b></div>' : '') + '<div style="display:grid;grid-template-columns:1fr max-content;gap:12px;border-top:1px solid #b8c0cc;margin-top:3px;padding-top:6px;font-size:13px;"><span style="font-weight:900;color:#111827;">Amount After Tax</span><b style="font-size:14px;white-space:nowrap;text-align:right;">' + accMoney(total) + '</b></div></div></div>' : '') +
        bankBlock +
        (rec.notes || rec.termsConditions || rec.scope || rec.description ? '<div style="border:1px solid #b8c0cc;background:#fff;padding:8px 10px;margin-top:8px;"><div style="font-weight:900;color:#111827;margin-bottom:4px;">Notes / Terms</div>' + accEsc(rec.notes || rec.termsConditions || rec.scope || rec.description) + '</div>' : '') +
        '<div style="display:flex;justify-content:flex-end;margin-top:18px;padding-bottom:10px;"><div style="text-align:center;width:190px;border-top:1px solid #111827;padding-top:6px;color:#111827;font-size:11px;">Authorized Signatory</div></div>' +
      '</div>' +
      '<div class="acc-doc-footer acc-doc-fixed-footer"><b>Note:</b> This document is the property of DHPE and is confidential. It must not be disclosed, shared, or transmitted to any person or firm not authorized by us. No part of this document may be copied, reproduced, or used in whole or in part without our prior written consent.</div>' +
    '</div>';
  return { title:title + (number ? ' - ' + number : ''), number:number, html:html };
}
function accPrintFrame(title, html, autoPrint) {
  var page =
    '<!DOCTYPE html><html><head><title>' + accEsc(title) + '</title>' +
    '<style>@page{size:A4;margin:0;}*{box-sizing:border-box}html,body{margin:0!important;padding:0!important;background:#fff;color:#111;font-family:Arial,sans-serif}.acc-doc-page{box-shadow:none!important;width:210mm!important;min-height:297mm!important;max-width:none!important;margin:0!important;padding:0!important;border:1px solid #9ca3af!important;page-break-after:auto;break-after:auto;display:block}.acc-doc-content{display:block;padding:8px 10px 0}.acc-doc-footer{border-top:1px solid #b8c0cc;padding:5px 10px 6px;margin-top:10px;font-size:9.5px;line-height:1.25;color:#475569;background:#fff;break-inside:avoid;page-break-inside:avoid}td,th{vertical-align:top}table{page-break-inside:auto;border-collapse:collapse}tr{page-break-inside:auto;break-inside:auto}thead{display:table-header-group}tfoot{display:table-footer-group}.no-print{display:none!important}@media print{html,body{margin:0!important;padding:0!important;print-color-adjust:exact;-webkit-print-color-adjust:exact}.acc-doc-page{width:210mm!important;min-height:297mm!important}}</style>' +
    '</head><body>' + html + (autoPrint ? '<script>window.onload=function(){window.focus();window.print();};<\/script>' : '') + '</body></html>';
  var w = window.open('', '_blank', 'width=980,height=720');
  if (!w) return toast('Allow popups to open PDF/print preview', 'error');
  w.document.open();
  w.document.write(page);
  w.document.close();
}
function accountPdfUrl(kind, id, view) {
  var meta = accDocMeta(kind);
  return meta.pdfPath ? meta.pdfPath + id + '/pdf' + (view ? '?view=1' : '') : '';
}
function accountPdfFilename(kind, id, doc) {
  var meta = accDocMeta(kind);
  var labels = {
    inv:'Invoice',
    pro:'Proforma-Invoice',
    quo:'Quotation',
    po:'Purchase-Order',
    cwo:'Client-Work-Order',
    vwo:'Vendor-Work-Order',
    prj:'Project-Account'
  };
  var number = doc && doc.number ? doc.number : '';
  if (!number && doc && doc.title) {
    var parts = String(doc.title).split(/\s+-\s+/);
    number = parts.length > 1 ? parts[parts.length - 1] : '';
  }
  var base = [labels[kind] || meta.filePrefix || meta.title || 'Document', number || id]
    .filter(Boolean)
    .join('-')
    .replace(/[^a-z0-9_.-]+/gi, '-')
    .replace(/-+/g, '-')
    .replace(/^-+|-+$/g, '');
  return (base || 'document') + '.pdf';
}
function loadAccountDoc(kind, id) {
  var meta = accDocMeta(kind);
  return api('GET', meta.path + id).then(function(rec) {
    var doc = accBuildDocument(kind, rec || {});
    doc.kind = kind;
    doc.id = id;
    doc.pdfUrl = accountPdfUrl(kind, id, false);
    doc.pdfViewUrl = accountPdfUrl(kind, id, true);
    return doc;
  });
}
function viewAccountDoc(kind, id) {
  loadAccountDoc(kind, id).then(function(doc) {
    currentAccountDoc = doc;
    document.getElementById('acc-doc-preview-title').innerHTML = '<i class="bx bx-file"></i> ' + accEsc(doc.title);
    document.getElementById('acc-doc-preview-body').innerHTML = doc.html;
    var pdfControls = !doc.profileOnly;
    var printBtn = document.getElementById('acc-doc-print-btn');
    var downloadBtn = document.getElementById('acc-doc-download-btn');
    if (printBtn) printBtn.style.display = pdfControls ? '' : 'none';
    if (downloadBtn) downloadBtn.style.display = pdfControls ? '' : 'none';
    openModal('acc-doc-preview-modal');
  }).catch(function(e) { toast(e.message || 'Unable to open document', 'error'); });
}
function printAccountDoc(kind, id) {
  loadAccountDoc(kind, id).then(function(doc) {
    accPrintFrame(doc.title, doc.html, true);
  }).catch(function(e) { toast(e.message || 'Unable to print document', 'error'); });
}
function downloadAccountDoc(kind, id) {
  loadAccountDoc(kind, id).then(function(doc) {
    if (doc.pdfUrl) return openPDF(doc.pdfUrl, true, accountPdfFilename(kind, id, doc));
    accPrintFrame(doc.title, doc.html, true);
  }).catch(function(e) { toast(e.message || 'Unable to download document', 'error'); });
}
function printCurrentAccountDoc() {
  if (!currentAccountDoc.html) return;
  accPrintFrame(currentAccountDoc.title, currentAccountDoc.html, true);
}
function downloadCurrentAccountDoc() {
  if (!currentAccountDoc.html) return;
  if (currentAccountDoc.pdfUrl) return openPDF(currentAccountDoc.pdfUrl, true, accountPdfFilename(currentAccountDoc.kind, currentAccountDoc.id, currentAccountDoc));
  accPrintFrame(currentAccountDoc.title, currentAccountDoc.html, true);
}
function printPO(id)  { printAccountDoc('po', id); }
function printVen(id) { printAccountDoc('ven', id); }
function printClt(id) { printAccountDoc('clt', id); }
function printWO(id)  { printAccountDoc('cwo', id); }
function printPrj(id) { printAccountDoc('prj', id); }
</script>
<div id="acc-action-menu" style="display:none;position:fixed;z-index:9999;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;box-shadow:0 8px 28px rgba(0,0,0,0.18);min-width:200px;overflow:hidden;padding:4px 0;"></div>
</body></html>
