function buildLineItemRow(item, totalUpdater) {
  item=item||{name:'',qty:1,rate:0};
  var total=((parseFloat(item.qty)||0)*(parseFloat(item.rate)||0));
  return '<div class="line-item-field">'+
      '<label class="line-item-label">Description</label>'+
      '<input type="text" class="form-control item-name" placeholder="Item description" value="'+htmlEscape(item.name||'')+'">'+
    '</div>'+
    '<div class="line-item-field">'+
      '<label class="line-item-label">Qty</label>'+
      '<input type="number" class="form-control item-qty" placeholder="Qty" value="'+(item.qty||1)+'" min="1" oninput="'+totalUpdater+'()">'+
    '</div>'+
    '<div class="line-item-field">'+
      '<label class="line-item-label">Rate</label>'+
      '<input type="number" class="form-control item-rate" placeholder="Rate" value="'+(item.rate||0)+'" min="0" oninput="'+totalUpdater+'()">'+
    '</div>'+
    '<div class="line-item-field">'+
      '<label class="line-item-label">Total</label>'+
      '<div class="item-total">'+fmtAmt(total)+'</div>'+
    '</div>'+
    '<div class="line-item-actions">'+
      '<button type="button" class="btn btn-danger btn-sm line-item-remove" onclick="this.closest(\'.line-item-row\').remove();'+totalUpdater+'()"><i class="bx bx-x"></i></button>'+
    '</div>';
}
function wireLineItemTotal(row) {
  function recalc() {
    var qty=parseFloat(row.querySelector('.item-qty').value)||0;
    var rate=parseFloat(row.querySelector('.item-rate').value)||0;
    row.querySelector('.item-total').textContent=fmtAmt(qty*rate);
  }
  var qtyEl=row.querySelector('.item-qty');
  var rateEl=row.querySelector('.item-rate');
  if(qtyEl) qtyEl.addEventListener('input', recalc);
  if(rateEl) rateEl.addEventListener('input', recalc);
  recalc();
}
function addLineItemRow(container, item) {
  var div=document.createElement('div');
  div.className='line-item-row';
  div.innerHTML=buildLineItemRow(item,'updateDocTotal');
  container.appendChild(div);
  wireLineItemTotal(div);
}
