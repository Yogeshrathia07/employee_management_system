/* ── calculators ──────────────────────────────────────── */
function calcGST() {
  var amt=parseFloat(document.getElementById('gst-amount').value)||0;
  var rate=parseFloat(document.getElementById('gst-rate').value)||18;
  var mode=(document.getElementById('gst-mode')||{}).value||'exclusive';
  var split=(document.getElementById('gst-split')||{}).value||'cgst_sgst';
  var baseAmt=mode==='inclusive' && rate>0 ? (amt/(1+(rate/100))) : amt;
  var gstAmt=mode==='inclusive' ? (amt-baseAmt) : (amt*rate/100);
  var cgstRow=document.getElementById('gst-row-cgst');
  var sgstRow=document.getElementById('gst-row-sgst');
  var igstRow=document.getElementById('gst-row-igst');
  if (cgstRow) cgstRow.style.display = split === 'igst' ? 'none' : 'flex';
  if (sgstRow) sgstRow.style.display = split === 'igst' ? 'none' : 'flex';
  if (igstRow) igstRow.style.display = split === 'cgst_sgst' ? 'none' : 'flex';
  document.getElementById('gst-cgst').textContent=fmtAmt(split === 'igst' ? 0 : gstAmt/2);
  document.getElementById('gst-sgst').textContent=fmtAmt(split === 'igst' ? 0 : gstAmt/2);
  document.getElementById('gst-igst').textContent=fmtAmt(split === 'cgst_sgst' ? 0 : gstAmt);
  document.getElementById('gst-total').textContent=fmtAmt(mode==='inclusive'?amt:(amt+gstAmt));
}
function calcDiscount() {
  var orig=parseFloat(document.getElementById('disc-orig').value)||0;
  var pct=parseFloat(document.getElementById('disc-pct').value)||0;
  var disc=orig*pct/100;
  document.getElementById('disc-amt').textContent=fmtAmt(disc);
  document.getElementById('disc-pay').textContent=fmtAmt(orig-disc);
}
function calcTDS() {
  var gross=parseFloat(document.getElementById('tds-gross').value)||0;
  var rate=parseFloat(document.getElementById('tds-rate').value)||10;
  var mode=(document.getElementById('tds-mode')||{}).value||'exclusive';
  var baseAmt=mode==='inclusive' && rate>0 ? (gross/(1+(rate/100))) : gross;
  var ded=mode==='inclusive' ? (gross-baseAmt) : (gross*rate/100);
  document.getElementById('tds-ded').textContent=fmtAmt(ded);
  document.getElementById('tds-net').textContent=fmtAmt(mode==='inclusive'?baseAmt:(gross-ded));
}

