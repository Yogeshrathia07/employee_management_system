<script src="/js/api.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script>
/* ── storage helpers ──────────────────────────────────── */
var STORE = {
  inv: 'acc_invoices', pro: 'acc_proforma', quo: 'acc_quotations',
  po: 'acc_po', ven: 'acc_vendors', cwo: 'acc_cwo', vwo: 'acc_vwo', prj: 'acc_projects'
};
function load(key) { try { return JSON.parse(localStorage.getItem(STORE[key]||key)||'[]'); } catch(e){ return []; } }
function save(key, arr) { localStorage.setItem(STORE[key]||key, JSON.stringify(arr)); }
function genId(prefix) { return prefix + '-' + Math.random().toString(36).substr(2,6).toUpperCase(); }
function today() { return new Date().toISOString().slice(0,10); }
function fmtAmt(n) { return '₹ ' + Number(n||0).toLocaleString('en-IN'); }
function fmtD(s) { if(!s) return '-'; var d=new Date(s); return d.getDate()+' '+['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()]+' '+d.getFullYear(); }
var ACCOUNTS_REGISTRY_KEYS = {
  customers: 'acc_customer_registry',
  projects: 'acc_project_registry',
  workOrders: 'acc_workorder_registry'
};
function cleanAccountText(value) {
  var text = String(value == null ? '' : value).replace(/\+/g, ' ').trim();
  for (var i = 0; i < 3 && /%[0-9A-Fa-f]{2}/.test(text); i++) {
    try {
      var decoded = decodeURIComponent(text);
      if (decoded === text) break;
      text = decoded;
    } catch(e) {
      break;
    }
  }
  return text.trim();
}
function uniqueStrings(list) {
  return Array.from(new Set((list || []).map(function(v){ return cleanAccountText(v); }).filter(Boolean)));
}
function getKnownCustomers() {
  var vendors = load('ven').map(function(v){
    return {
      name: cleanAccountText(v.name || ''),
      email: v.email || '',
      gst: v.gst || '',
      pan: v.pan || '',
      address: v.address || '',
      state: v.state || '',
      stateCode: v.stateCode || '',
      source: 'vendor'
    };
  });
  var docs = []
    .concat(load('quo').map(function(r){ return { name:cleanAccountText(r.client || ''), source:'quotation' }; }))
    .concat(load('pro').map(function(r){ return {
      name:cleanAccountText(r.customerName || r.client || ''),
      email:r.customerEmail || '',
      gst:r.customerGstin || '',
      pan:r.customerPan || '',
      address:r.customerAddress || '',
      state:r.customerState || '',
      stateCode:r.customerStateCode || '',
      source:'proforma'
    }; }))
    .concat(load('cwo').map(function(r){ return { name:cleanAccountText(r.party || ''), source:'cwo' }; }))
    .concat(load('prj').map(function(r){ return { name:cleanAccountText(r.client || ''), source:'project' }; }));
  var registry = load(ACCOUNTS_REGISTRY_KEYS.customers);
  var merged = vendors.concat(docs).concat(Array.isArray(registry) ? registry : []);
  var byName = {};
  merged.forEach(function(item) {
    var cleanName = cleanAccountText((item && item.name) || '');
    var key = cleanName.toLowerCase();
    if (!key) return;
    byName[key] = Object.assign({}, byName[key] || {}, item, { name: cleanName });
  });
  return Object.keys(byName).sort().map(function(key){ return byName[key]; });
}
function getKnownProjects() {
  return uniqueStrings(
    load('prj').map(function(r){ return r.name; })
      .concat(load('cwo').map(function(r){ return r.project; }))
      .concat(load('vwo').map(function(r){ return r.project; }))
      .concat(load('po').map(function(r){ return r.project; }))
      .concat(load('pro').map(function(r){ return r.projectName || r.project; }))
      .concat(load(ACCOUNTS_REGISTRY_KEYS.projects))
  ).sort();
}
function getKnownWorkOrders() {
  return uniqueStrings(
    load('cwo').map(function(r){ return r.id; })
      .concat(load('po').map(function(r){ return r.workOrder; }))
      .concat(load('pro').map(function(r){ return r.workOrder; }))
      .concat(load(ACCOUNTS_REGISTRY_KEYS.workOrders))
  ).sort();
}
function rememberCustomer(customer) {
  if (!customer) return;
  var payload = typeof customer === 'string' ? { name: customer } : Object.assign({}, customer);
  payload.name = cleanAccountText(payload.name);
  if (!payload.name || !String(payload.name).trim()) return;
  var arr = load(ACCOUNTS_REGISTRY_KEYS.customers);
  if (!Array.isArray(arr)) arr = [];
  var key = cleanAccountText(payload.name).toLowerCase();
  var idx = arr.findIndex(function(item){ return cleanAccountText((item && item.name) || '').toLowerCase() === key; });
  var merged = Object.assign({}, idx >= 0 ? arr[idx] : {}, payload, { name: cleanAccountText(payload.name) });
  if (idx >= 0) arr[idx] = merged;
  else arr.unshift(merged);
  save(ACCOUNTS_REGISTRY_KEYS.customers, arr);
}
function normalizeAccountCustomer(source) {
  source = source || {};
  var gst = source.gst || source.gstin || source.customerGstin || source.customerGSTIN || source.clientGstin || source.clientGSTIN || '';
  return {
    name: cleanAccountText(source.name || source.customerName || source.clientName || source.client || source.partyName || source.party || ''),
    email: source.email || source.customerEmail || source.clientEmail || '',
    gst: String(gst || '').toUpperCase(),
    pan: String(source.pan || source.customerPan || source.clientPan || '').toUpperCase(),
    address: source.address || source.customerAddress || source.clientAddress || source.billingAddress || '',
    state: source.state || source.customerState || source.clientState || '',
    stateCode: source.stateCode || source.customerStateCode || source.clientStateCode || accountStateCodeFromGstin(gst)
  };
}
function setAccountCustomerFields(prefix, source) {
  var customer = normalizeAccountCustomer(source);
  var nameEl = document.getElementById(prefix + '-c-name');
  var emailEl = document.getElementById(prefix + '-c-email');
  var gstEl = document.getElementById(prefix + '-c-gstin');
  var panEl = document.getElementById(prefix + '-c-pan');
  var addrEl = document.getElementById(prefix + '-c-addr');
  if (nameEl) nameEl.value = customer.name || '';
  if (emailEl) emailEl.value = customer.email || '';
  if (gstEl) gstEl.value = customer.gst || '';
  if (panEl) panEl.value = customer.pan || '';
  if (addrEl) addrEl.value = customer.address || '';
  setAccountStateValue(prefix + '-c-state', prefix + '-c-code', customer.state, customer.stateCode || accountStateCodeFromGstin(customer.gst));
  return customer;
}
function rememberProject(projectName) {
  var name = String(projectName || '').trim();
  if (!name) return;
  var arr = load(ACCOUNTS_REGISTRY_KEYS.projects);
  if (!Array.isArray(arr)) arr = [];
  if (!arr.some(function(item){ return String(item || '').trim().toLowerCase() === name.toLowerCase(); })) {
    arr.unshift(name);
    save(ACCOUNTS_REGISTRY_KEYS.projects, arr);
  }
}
function rememberWorkOrder(woRef) {
  var ref = String(woRef || '').trim();
  if (!ref) return;
  var arr = load(ACCOUNTS_REGISTRY_KEYS.workOrders);
  if (!Array.isArray(arr)) arr = [];
  if (!arr.some(function(item){ return String(item || '').trim().toLowerCase() === ref.toLowerCase(); })) {
    arr.unshift(ref);
    save(ACCOUNTS_REGISTRY_KEYS.workOrders, arr);
  }
}
function renderDataList(id, values) {
  var list = document.getElementById(id);
  if (!list) return;
  list.innerHTML = (values || []).map(function(value){
    return '<option value="' + htmlEscape(cleanAccountText(value || '')) + '"></option>';
  }).join('');
}
function syncCustomerSources(customers) {
  (customers || []).forEach(function(c) { rememberCustomer(c); });
  renderDataList('acc-customer-list', getKnownCustomers().map(function(c){ return c.name; }));
  populateVendorDropdown();
  populateProVendorDropdown();
}
function refreshAccountsDataLists() {
  renderDataList('acc-customer-list', getKnownCustomers().map(function(c){ return c.name; }));
  Promise.all([
    api('GET', '/clients').catch(function(){ return []; }),
    api('GET', '/vendors').catch(function(){ return []; }),
    api('GET', '/invoices').catch(function(){ return []; }),
    api('GET', '/proformas-db').catch(function(){ return []; })
  ]).then(function(all) {
    var clients = (all[0] || []).map(function(c) {
      return { name:c.name, email:c.email, gst:c.gstin, pan:c.pan, address:c.billingAddress, state:c.state, stateCode:c.stateCode, source:'client' };
    });
    var vendors = (all[1] || []).map(function(v) {
      return { name:v.name, email:v.email, gst:v.gstin, pan:v.pan, address:v.address, state:v.state, stateCode:v.stateCode, source:'vendor' };
    });
    var invoices = (all[2] || []).map(function(r) {
      return { name:r.customerName, email:r.customerEmail, gst:r.customerGstin, pan:r.customerPan, address:r.customerAddress, state:r.customerState, stateCode:r.customerStateCode, source:'invoice' };
    });
    var proformas = (all[3] || []).map(function(r) {
      return { name:r.customerName, email:r.customerEmail, gst:r.customerGstin, pan:r.customerPan, address:r.customerAddress, state:r.customerState, stateCode:r.customerStateCode, source:'proforma' };
    });
    syncCustomerSources(clients.concat(vendors, invoices, proformas));
  });
  // Projects datalist from API (used in Invoice/Proforma/PO project text fields)
  api('GET', '/project-accounts').then(function(projects) {
    renderDataList('acc-project-list', (projects||[]).map(function(p){ return p.name; }));
  }).catch(function(){
    renderDataList('acc-project-list', getKnownProjects());
  });
  // WO datalist from API (used in Invoice/Proforma WO reference fields)
  api('GET', '/work-orders').then(function(wos) {
    renderDataList('acc-work-order-list', (wos||[]).map(function(w){ return w.woNumber; }));
  }).catch(function(){
    renderDataList('acc-work-order-list', getKnownWorkOrders());
