/* ── shared floating action menu ─────────────────────────── */
var _accMenuReg = {};
var _accMenuSeq = 0;

function accMenuBtn(items) {
  var id = ++_accMenuSeq;
  _accMenuReg[id] = items;
  return '<button class="acc-menu-trigger" onclick="openAccMenu(event,'+id+')"><i class="bx bx-dots-vertical-rounded"></i></button>';
}

function openAccMenu(event, id) {
  event.stopPropagation();
  var items = _accMenuReg[id];
  if (!items) return;
  var menu = document.getElementById('acc-action-menu');
  var lastIdx = items.length - 1;
  menu.innerHTML = items.map(function(item, i) {
    var divider = (item.danger && i > 0) ? '<div style="height:1px;background:var(--border);margin:3px 0;"></div>' : '';
    return divider + '<div class="acc-menu-item'+(item.danger?' acc-menu-danger':'')+'" onclick="closeAccMenu();'+item.fn+'">'+
      '<i class="bx '+item.icon+'" style="width:18px;text-align:center;"></i><span>'+item.label+'</span></div>';
  }).join('');
  var btn = event.currentTarget;
  var rect = btn.getBoundingClientRect();
  var dangerCount = items.filter(function(x){return x.danger;}).length;
  var menuW = 200, menuH = items.length * 37 + dangerCount * 7 + 10;
  var left = rect.right - menuW;
  if (left < 4) left = rect.left;
  var top = rect.bottom + 4;
  if (top + menuH > window.innerHeight - 8) top = rect.top - menuH - 4;
  menu.style.left = left + 'px';
  menu.style.top = top + 'px';
  menu.style.display = 'block';
}
function closeAccMenu() {
  var m = document.getElementById('acc-action-menu');
  if (m) m.style.display = 'none';
}
document.addEventListener('click', function(e) {
  if (!e.target.closest('#acc-action-menu') && !e.target.closest('.acc-menu-trigger')) closeAccMenu();
});
document.addEventListener('scroll', closeAccMenu, true);

function actBtns(editFn, delFn) {
  return accMenuBtn([
    {icon:'bx-edit-alt', label:'Edit',   fn:editFn},
    {icon:'bx-trash',    label:'Delete', fn:delFn, danger:true}
  ]);
}

