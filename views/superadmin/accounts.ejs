<%- include('../partials/head', {title: 'Accounts'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-superadmin') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title"><i class="bx bxs-credit-card" style="color:var(--accent)"></i> Accounts</div>
          <div class="page-subtitle">Financial management - invoices, orders, vendors and projects</div>
        </div>
      </div>
      <div class="header-actions"></div>
    </header>

    <div class="page-body admin-employees-page">
      <div class="employee-directory-shell">

        <!-- Module Tabs -->
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:24px;background:var(--bg-input);border-radius:12px;padding:4px;">
          <button class="acc-tab active" id="tab-home"    onclick="showModule('home')"><i class="bx bxs-home"></i> Dashboard</button>
          <button class="acc-tab" id="tab-inv"     onclick="showModule('inv')"><i class="bx bxs-receipt"></i> Invoices <span id="tab-count-inv" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-pro"     onclick="showModule('pro')"><i class="bx bxs-file-doc"></i> Proforma <span id="tab-count-pro" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-quo"     onclick="showModule('quo')"><i class="bx bxs-notepad"></i> Quotations <span id="tab-count-quo" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-po"      onclick="showModule('po')"><i class="bx bxs-truck"></i> Purchase Orders <span id="tab-count-po" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-clt"     onclick="showModule('clt')"><i class="bx bxs-contact"></i> Clients <span id="tab-count-clt" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-ven"     onclick="showModule('ven')"><i class="bx bxs-user-badge"></i> Vendors <span id="tab-count-ven" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-cwo"     onclick="showModule('cwo')"><i class="bx bxs-briefcase"></i> Client W/O <span id="tab-count-cwo" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-vwo"     onclick="showModule('vwo')"><i class="bx bxs-wrench"></i> Vendor W/O <span id="tab-count-vwo" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-prj"     onclick="showModule('prj')"><i class="bx bxs-bar-chart-alt-2"></i> Projects <span id="tab-count-prj" class="acc-tab-badge"></span></button>
          <button class="acc-tab" id="tab-rep"     onclick="showModule('rep')"><i class="bx bxs-report"></i> Reports</button>
        </div>

        <!-- ═══════════════════════════════════════════════════ DASHBOARD -->
        <div id="mod-home" class="acc-module">
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;">
            <% var modules = [
              {key:'inv', icon:'bxs-receipt',         title:'Invoices',            desc:'Manage client invoices and billing'},
              {key:'pro', icon:'bxs-file-doc',         title:'Proforma Invoices',   desc:'Generate preliminary invoices for clients'},
              {key:'quo', icon:'bxs-notepad',          title:'Quotations',          desc:'Create and send quotes to potential clients'},
              {key:'po',  icon:'bxs-truck',            title:'Purchase Orders',     desc:'Manage vendor purchase orders'},
              {key:'clt', icon:'bxs-contact',          title:'Clients',             desc:'Register and manage client / customer information'},
              {key:'ven', icon:'bxs-user-badge',       title:'Vendor Registration', desc:'Register and manage vendor information'},
              {key:'cwo', icon:'bxs-briefcase',        title:'Client Work Orders',  desc:'Track work orders for clients'},
              {key:'vwo', icon:'bxs-wrench',           title:'Vendor Work Orders',  desc:'Assign and track vendor work orders'},
              {key:'prj', icon:'bxs-bar-chart-alt-2',  title:'Projects',           desc:'Plan and track projects'},
              {key:'rep', icon:'bxs-report',           title:'Reports & Export',   desc:'Filter account sections and export reports'}
            ]; %>
            <% modules.forEach(function(m) { %>
            <div style="background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:20px;display:flex;flex-direction:column;gap:12px;cursor:pointer;transition:box-shadow .2s,border-color .2s;" onclick="showModule('<%= m.key %>')" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.08)';this.style.borderColor='#d1d5db'" onmouseout="this.style.boxShadow='';this.style.borderColor='#e5e7eb'">
              <div style="width:44px;height:44px;border-radius:12px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;">
                <i class="bx <%= m.icon %>" style="font-size:22px;color:#374151;"></i>
              </div>
              <div>
                <div style="font-weight:700;font-size:14px;color:#111;margin-bottom:4px;"><%= m.title %></div>
                <div style="font-size:12px;color:#9ca3af;"><%= m.desc %></div>
              </div>
              <button style="margin-top:auto;display:inline-flex;align-items:center;gap:4px;border:1px solid #e5e7eb;border-radius:8px;padding:7px 12px;font-size:12px;font-weight:500;color:#374151;background:#fff;cursor:pointer;" onclick="event.stopPropagation();showModule('<%= m.key %>')">Go to <%= m.title %> <i class="bx bx-chevron-right"></i></button>
            </div>
            <% }); %>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ INVOICES -->
        <div id="mod-inv" class="acc-module" style="display:none;">
          <!-- Module Title -->
          <div style="margin-bottom:20px;">
            <div style="font-size:17px;font-weight:800;color:var(--text-primary);margin-bottom:4px;"><i class="bx bxs-receipt" style="color:var(--accent);margin-right:6px;"></i>Invoice Management & Tools</div>
            <div style="font-size:12px;color:var(--text-muted);">Create, view, and manage client invoices. Includes helpful calculators and export options.</div>
          </div>

          <!-- Sub-tabs -->
          <div style="display:flex;gap:4px;background:var(--bg-input);border-radius:10px;padding:3px;width:fit-content;margin-bottom:20px;">
            <button class="acc-subtab active" id="stab-invoices" onclick="showSubTab('invoices')"><i class="bx bx-list-ul"></i> Invoices</button>
            <button class="acc-subtab" id="stab-calc" onclick="showSubTab('calc')"><i class="bx bx-calculator"></i> Calculators</button>
          </div>

          <!-- ── Invoices sub-tab ── -->
          <div id="sub-invoices">
            <!-- Invoice number settings -->
            <div class="acc-inline-settings">
              <div class="acc-inline-title"><i class="bx bx-cog"></i> Invoice Number Format</div>
              <div class="acc-inline-field">
                <label class="acc-inline-label" for="inv-company-code">Company Code</label>
                <input type="text" id="inv-company-code" class="form-control acc-inline-input" placeholder="e.g. DHPE" maxlength="8" oninput="updateInvNumPreview()">
              </div>
              <div class="acc-inline-field">
                <label class="acc-inline-label" for="inv-fy-sel">Financial Year</label>
                <select id="inv-fy-sel" class="form-control acc-inline-input" onchange="updateInvNumPreview()"></select>
              </div>
              <div class="acc-inline-preview">Preview: <code id="inv-num-preview" class="acc-inline-code">001/DHPE/26-27/XXXXXX</code></div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
              <div style="margin-left:auto;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                <div class="search-bar" style="width:200px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="inv-search" placeholder="Search ref, customer..." oninput="renderInvoices()"></div>
                <select id="inv-status" class="form-control" style="width:120px" onchange="renderInvoices()">
                  <option value="">All Status</option><option>Draft</option><option>Sent</option><option>Paid</option><option>Overdue</option><option>Cancelled</option>
                </select>
                <select id="inv-type" class="form-control" style="width:120px" onchange="renderInvoices()">
                  <option value="">All Types</option><option value="B2B">Tax Invoice</option><option value="B2C">B2C Invoice</option>
                </select>
                <select id="inv-year" class="form-control" style="width:120px" onchange="renderInvoices()">
                  <option value="">All Years</option>
                </select>
                <select id="inv-month" class="form-control" style="width:130px" onchange="renderInvoices()">
                  <option value="">All Months</option>
                </select>
                <button class="btn btn-primary" onclick="openGSTModal()" style="font-weight:700;gap:6px;">
                  <i class="bx bx-plus-circle"></i> Create Invoice
                </button>
              </div>
            </div>
            <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
              <table style="width:100%;border-collapse:collapse;" id="inv-table">
                <thead><tr style="background:var(--bg-input);border-bottom:2px solid var(--border);">
                  <th class="acc-th">Ref #</th>
                  <th class="acc-th">Type</th>
                  <th class="acc-th">Customer</th>
                  <th class="acc-th">Date</th>
                  <th class="acc-th">Total (₹)</th>
                  <th class="acc-th">Status</th>
                  <th class="acc-th" style="text-align:center;">Actions</th>
                </tr></thead>
                <tbody id="inv-body"></tbody>
              </table>
            </div>
          </div>

          <!-- ── Reports sub-tab ── -->
          <!-- Calculator subtab -->
          <div id="sub-calc" style="display:none;">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;">
              <!-- GST Calc -->
              <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;">
                <div style="font-weight:700;font-size:14px;margin-bottom:16px;"><i class="bx bx-calculator" style="color:var(--accent)"></i> GST Calculator</div>
                <div class="form-group"><label class="form-label">Amount</label><input type="number" id="gst-amount" class="form-control" placeholder="Enter amount" oninput="calcGST()" onwheel="this.blur()"></div>
                <div class="form-group"><label class="form-label">GST Rate %</label>
                  <input type="number" id="gst-rate" class="form-control" placeholder="Enter GST rate" value="18" min="0" step="0.01" inputmode="decimal" oninput="calcGST()" onwheel="this.blur()">
                </div>
                <div class="form-group"><label class="form-label">GST Type</label>
                  <select id="gst-mode" class="form-control" onchange="calcGST()">
                    <option value="exclusive" selected>Exclusive</option>
                    <option value="inclusive">Inclusive</option>
                  </select>
                </div>
                <div class="form-group"><label class="form-label">GST Split</label>
                  <select id="gst-split" class="form-control" onchange="calcGST()">
                    <option value="cgst_sgst" selected>CGST + SGST</option>
                    <option value="igst">IGST</option>
                    <option value="all">Show All</option>
                  </select>
                </div>
                <div style="background:var(--bg-input);border-radius:10px;padding:14px;margin-top:8px;">
                  <div id="gst-row-cgst" style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">CGST</span><span id="gst-cgst" style="font-weight:600;">₹0</span></div>
                  <div id="gst-row-sgst" style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">SGST</span><span id="gst-sgst" style="font-weight:600;">₹0</span></div>
                  <div id="gst-row-igst" style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">IGST</span><span id="gst-igst" style="font-weight:600;">₹0</span></div>
                  <div style="border-top:1px solid var(--border);margin:8px 0;"></div>
                  <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:700;"><span>Total</span><span id="gst-total" style="color:var(--accent);">₹0</span></div>
                </div>
              </div>
              <!-- Discount Calc -->
              <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;">
                <div style="font-weight:700;font-size:14px;margin-bottom:16px;"><i class="bx bx-purchase-tag" style="color:var(--accent)"></i> Discount Calculator</div>
                <div class="form-group"><label class="form-label">Original Price</label><input type="number" id="disc-orig" class="form-control" placeholder="Original price" oninput="calcDiscount()"></div>
                <div class="form-group"><label class="form-label">Discount %</label><input type="number" id="disc-pct" class="form-control" placeholder="e.g. 10" min="0" max="100" oninput="calcDiscount()"></div>
                <div style="background:var(--bg-input);border-radius:10px;padding:14px;margin-top:8px;">
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">Discount Amount</span><span id="disc-amt" style="font-weight:600;">₹0</span></div>
                  <div style="border-top:1px solid var(--border);margin:8px 0;"></div>
                  <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:700;"><span>Payable Amount</span><span id="disc-pay" style="color:var(--accent);">₹0</span></div>
                </div>
              </div>
              <!-- TDS Calc -->
              <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;">
                <div style="font-weight:700;font-size:14px;margin-bottom:16px;"><i class="bx bx-trending-down" style="color:var(--accent)"></i> TDS Calculator</div>
                <div class="form-group"><label class="form-label">Amount</label><input type="number" id="tds-gross" class="form-control" placeholder="Enter amount" oninput="calcTDS()" onwheel="this.blur()"></div>
                <div class="form-group"><label class="form-label">TDS Rate %</label>
                  <input type="number" id="tds-rate" class="form-control" placeholder="Enter TDS rate" value="10" min="0" step="0.01" inputmode="decimal" oninput="calcTDS()" onwheel="this.blur()">
                </div>
                <div class="form-group"><label class="form-label">TDS Type</label>
                  <select id="tds-mode" class="form-control" onchange="calcTDS()">
                    <option value="exclusive" selected>Exclusive</option>
                    <option value="inclusive">Inclusive</option>
                  </select>
                </div>
                <div style="background:var(--bg-input);border-radius:10px;padding:14px;margin-top:8px;">
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px;"><span style="color:var(--text-muted);">TDS Deduction</span><span id="tds-ded" style="font-weight:600;">₹0</span></div>
                  <div style="border-top:1px solid var(--border);margin:8px 0;"></div>
                  <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:700;"><span>Net Receivable</span><span id="tds-net" style="color:var(--accent);">₹0</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ PROFORMA -->
        <div id="mod-pro" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="pro-search" placeholder="Search proforma..." oninput="renderProforma()"></div>
            <select id="pro-status" class="form-control" style="width:140px" onchange="renderProforma()">
              <option value="">All Status</option><option>Draft</option><option>Sent</option><option>Confirmed</option><option>Rejected</option><option>Converted</option>
            </select>
            <select id="pro-year" class="form-control" style="width:120px" onchange="renderProforma()">
              <option value="">All Years</option>
            </select>
            <select id="pro-month" class="form-control" style="width:130px" onchange="renderProforma()">
              <option value="">All Months</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openProformaModal()"><i class="bx bx-plus"></i> New Proforma</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Proforma #</th><th class="acc-th">Customer</th><th class="acc-th">Date</th><th class="acc-th">Valid Till</th><th class="acc-th">Total (₹)</th><th class="acc-th">Status</th><th class="acc-th" style="text-align:center;">Actions</th>
              </tr></thead>
              <tbody id="pro-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ QUOTATIONS -->
        <div id="mod-quo" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="quo-search" placeholder="Search quotation..." oninput="renderQuotations()"></div>
            <select id="quo-status" class="form-control" style="width:140px" onchange="renderQuotations()">
              <option value="">All Status</option><option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openDocModal('quo')"><i class="bx bx-plus"></i> New Quotation</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Quotation #</th><th class="acc-th">Client</th><th class="acc-th">Date</th><th class="acc-th">Valid Till</th><th class="acc-th">Amount</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="quo-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ══════════════════════════════════════════ PURCHASE ORDERS -->
        <div id="mod-po" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="po-search" placeholder="Search PO..." oninput="renderPO()"></div>
            <select id="po-status" class="form-control" style="width:140px" onchange="renderPO()">
              <option value="">All Status</option><option>Draft</option><option>Sent</option><option>Received</option><option>Cancelled</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openPOModal()"><i class="bx bx-plus"></i> New PO</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">PO #</th><th class="acc-th">Vendor</th><th class="acc-th">Date</th><th class="acc-th">Delivery Date</th><th class="acc-th">Amount</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="po-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ═════════════════════════════════════════════════ CLIENTS -->
        <div id="mod-clt" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="clt-search" placeholder="Search client..." oninput="renderClients()"></div>
            <select id="clt-status" class="form-control" style="width:140px" onchange="renderClients()">
              <option value="">All Status</option><option>Active</option><option>Inactive</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openCltModal()"><i class="bx bx-plus"></i> Register Client</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Client #</th><th class="acc-th">Name</th><th class="acc-th">Contact</th><th class="acc-th">Email</th><th class="acc-th">GST</th><th class="acc-th">State</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="clt-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ═══════════════════════════════════════ VENDOR REGISTRATION -->
        <div id="mod-ven" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="ven-search" placeholder="Search vendor..." oninput="renderVendors()"></div>
            <select id="ven-status" class="form-control" style="width:140px" onchange="renderVendors()">
              <option value="">All Status</option><option>Active</option><option>Inactive</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openVenModal()"><i class="bx bx-plus"></i> Register Vendor</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Vendor #</th><th class="acc-th">Name</th><th class="acc-th">Contact</th><th class="acc-th">Email</th><th class="acc-th">Category</th><th class="acc-th">GST</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="ven-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ══════════════════════════════════════ CLIENT WORK ORDERS -->
        <div id="mod-cwo" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="cwo-search" placeholder="Search CWO..." oninput="renderCWO()"></div>
            <select id="cwo-status" class="form-control" style="width:140px" onchange="renderCWO()">
              <option value="">All Status</option><option>Draft</option><option>Proposed</option><option>Active</option><option>Completed</option><option>Cancelled</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openWOModal('cwo')"><i class="bx bx-plus"></i> Create CWO</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">CWO #</th><th class="acc-th">Client</th><th class="acc-th">Project</th><th class="acc-th">Start Date</th><th class="acc-th">End Date</th><th class="acc-th">Amount</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="cwo-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ═══════════════════════════════════════ VENDOR WORK ORDERS -->
        <div id="mod-vwo" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="vwo-search" placeholder="Search VWO..." oninput="renderVWO()"></div>
            <select id="vwo-status" class="form-control" style="width:140px" onchange="renderVWO()">
              <option value="">All Status</option><option>Draft</option><option>Proposed</option><option>Active</option><option>Completed</option><option>Cancelled</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openWOModal('vwo')"><i class="bx bx-plus"></i> Create VWO</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">VWO #</th><th class="acc-th">Vendor</th><th class="acc-th">Project</th><th class="acc-th">Start Date</th><th class="acc-th">End Date</th><th class="acc-th">Amount</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="vwo-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ════════════════════════════════════════ PROJECT ACCOUNTS -->
        <div id="mod-prj" class="acc-module" style="display:none;">
          <div class="admin-toolbar" style="margin-bottom:16px;">
            <div class="search-bar" style="width:220px;"><span class="search-icon"><i class="bx bx-search"></i></span><input type="text" id="prj-search" placeholder="Search project..." oninput="renderProjects()"></div>
            <select id="prj-status" class="form-control" style="width:140px" onchange="renderProjects()">
              <option value="">All Status</option><option>Planning</option><option>Active</option><option>Completed</option><option>On Hold</option>
            </select>
            <button class="btn btn-primary" style="margin-left:auto;" onclick="openPrjModal()"><i class="bx bx-plus"></i> New Project</button>
          </div>
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">
                <th class="acc-th">Project #</th><th class="acc-th">Name</th><th class="acc-th">Client</th><th class="acc-th">Budget</th><th class="acc-th">Spent</th><th class="acc-th">Remaining</th><th class="acc-th">Status</th><th class="acc-th"></th>
              </tr></thead>
              <tbody id="prj-body"></tbody>
            </table>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ REPORTS -->
        <div id="mod-rep" class="acc-module" style="display:none;">
          <!-- Header -->
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
            <div>
              <div style="font-size:17px;font-weight:800;color:var(--text-primary);margin-bottom:4px;">
                <i class="bx bxs-report" style="color:#111111;margin-right:6px;"></i>Reports &amp; Export
              </div>
              <div style="font-size:12px;color:var(--text-muted);">Filter any section and export to Excel</div>
            </div>
            <button class="btn btn-primary" onclick="exportReportExcel()" style="background:#111111;display:flex;align-items:center;gap:6px;">
              <i class="bx bx-export"></i> Export to Excel
            </button>
          </div>

          <!-- Filters Card -->
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;margin-bottom:20px;">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;align-items:end;">
              <div>
                <label style="font-size:11px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Section</label>
                <select id="rep-section" class="form-control" onchange="onRepSectionChange()">
                  <option value="inv">Invoices</option>
                  <option value="pro">Proforma</option>
                  <option value="quo">Quotations</option>
                  <option value="po">Purchase Orders</option>
                  <option value="clt">Clients</option>
                  <option value="ven">Vendors</option>
                  <option value="cwo">Client Work Orders</option>
                  <option value="vwo">Vendor Work Orders</option>
                  <option value="prj">Projects</option>
                </select>
              </div>
              <div id="rep-date-from-wrap">
                <label style="font-size:11px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Date From</label>
                <input type="date" id="rep-date-from" class="form-control" onchange="renderReport()">
              </div>
              <div id="rep-date-to-wrap">
                <label style="font-size:11px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Date To</label>
                <input type="date" id="rep-date-to" class="form-control" onchange="renderReport()">
              </div>
              <div>
                <label style="font-size:11px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Status</label>
                <select id="rep-status" class="form-control" onchange="renderReport()">
                  <option value="">All Status</option>
                </select>
              </div>
              <div>
                <label style="font-size:11px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Search</label>
                <input type="text" id="rep-search" class="form-control" placeholder="Name / number..." oninput="renderReport()">
              </div>
              <div style="display:flex;gap:8px;">
                <button class="btn" style="flex:1;font-size:12px;padding:8px 10px;" onclick="clearRepFilters()">
                  <i class="bx bx-reset"></i> Clear
                </button>
                <button class="btn btn-primary" style="flex:1;font-size:12px;padding:8px 10px;background:#111111;" onclick="renderReport()">
                  <i class="bx bx-filter-alt"></i> Apply
                </button>
              </div>
            </div>
          </div>

          <!-- Summary Cards -->
          <div id="rep-summary" style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;"></div>

          <!-- Table -->
          <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
            <div class="table-wrapper" style="overflow-x:auto;">
              <table style="width:100%;border-collapse:collapse;">
                <thead id="rep-thead"></thead>
                <tbody id="rep-body">
                  <tr><td style="text-align:center;padding:40px;color:var(--text-muted);">Select a section and click Apply</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════ MODALS -->

<!-- ════════════════════════════ GST INVOICE MODAL ════════════════════════════ -->
<div class="modal-overlay" id="gst-inv-modal">
  <div class="modal acc-form-modal-shell acc-form-modal-wide" style="max-width:99vw;width:99vw;margin:0 auto;border-radius:14px;">
    <div class="modal-header">
      <span class="modal-title" id="gst-inv-title"><i class="bx bxs-receipt" style="color:var(--accent)"></i> Create New Invoice</span>
      <button class="modal-close" onclick="closeModal('gst-inv-modal')">×</button>
    </div>

    <!-- Body -->
    <div class="modal-body acc-form-modal-body" style="padding:0;">
      <input type="hidden" id="gst-inv-id">

      <!-- Document Details -->
      <div class="gst-section">
        <div class="gst-section-title"><i class="bx bxs-file-doc"></i> Invoice Information</div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Document Type</label>
            <select id="gst-doc-type" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;outline:none;">
              <option value="Tax Invoice">Tax Invoice</option>
              <option value="Proforma Invoice">Proforma Invoice</option>
              <option value="Quotation">Quotation</option>
              <option value="Credit Note">Credit Note</option>
              <option value="Debit Note">Debit Note</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Reference Number</label>
            <input type="text" id="gst-number" readonly style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#888;background:#f9fafb;font-weight:600;box-sizing:border-box;" placeholder="Auto-generated">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Invoice Date</label>
            <input type="date" id="gst-date" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-top:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Bill For Month</label>
            <input type="month" id="gst-bill-month" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Bill Period Start</label>
            <input type="date" id="gst-bill-from" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Bill Period End</label>
            <input type="date" id="gst-bill-to" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;">
          </div>
        </div>
        <div style="margin-top:16px;">
          <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#111;cursor:pointer;font-weight:500;">
            <input type="checkbox" id="gst-ra-bill" style="width:16px;height:16px;cursor:pointer;">
            This is an R.A. Bill
          </label>
        </div>
      </div>

      <!-- Company + Customer -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--border);">
      <div class="gst-section" style="border-right:1px solid var(--border);">
        <div class="gst-section-title" style="color:#111827;"><i class="bx bxs-buildings"></i> Company / Seller Details</div>
        <div style="margin-bottom:14px;">
          <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Quick-fill from Company List <span style="font-weight:400;font-size:11px;color:#888;">(auto-fills fields below)</span></label>
          <select id="gst-company-sel" onchange="fillFromCompany(this.value)" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;outline:none;">
            <option value="">— Type manually or select a company —</option>
          </select>
        </div>
        <div style="border-top:1px dashed var(--border);margin:0 0 14px 0;"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Company Name</label>
            <input type="text" id="gst-s-name" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="Your company name">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">GSTIN</label>
            <input type="text" id="gst-s-gstin" maxlength="15" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;text-transform:uppercase;" placeholder="22AAAAA0000A1Z5">
          </div>
        </div>
        <div style="margin-top:14px;">
          <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Address</label>
          <textarea id="gst-s-addr" rows="2" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;resize:vertical;box-sizing:border-box;" placeholder="Company address"></textarea>
        </div>
        <div style="display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:14px;margin-top:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">State</label>
            <select id="gst-s-state" onchange="syncStateCode(this,'gst-s-code');recalcGST();" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;cursor:pointer;"></select>
            <input type="hidden" id="gst-s-code">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">PAN</label>
            <input type="text" id="gst-s-pan" maxlength="10" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;text-transform:uppercase;" placeholder="ABCDE1234F">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Phone</label>
            <input type="text" id="gst-s-phone" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="Contact number">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Email</label>
            <input type="email" id="gst-s-email" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="company@email.com">
          </div>
        </div>
      </div>

      <div class="gst-section">
        <div class="gst-section-title" style="color:#0891b2;"><i class="bx bxs-user-detail"></i> Customer / Buyer Details</div>
        <div style="margin-bottom:14px;">
          <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Quick-fill from Existing Customer List <span style="font-weight:400;font-size:11px;color:#888;">(auto-fills fields below)</span></label>
          <select id="gst-vendor-sel" onchange="fillFromVendor(this.value)" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;outline:none;">
            <option value="">-- Type manually or select a customer --</option>
          </select>
        </div>
        <div style="border-top:1px dashed var(--border);margin:4px 0 14px 0;"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Customer Name</label>
            <input type="text" id="gst-c-name" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="Customer / company name">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Customer Email</label>
            <input type="email" id="gst-c-email" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="customer@email.com">
          </div>
        </div>
        <div style="margin-top:14px;">
          <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Customer Address</label>
          <textarea id="gst-c-addr" rows="3" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;resize:vertical;box-sizing:border-box;" placeholder="Customer address"></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 2fr;gap:14px;margin-top:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Customer GSTIN</label>
            <input type="text" id="gst-c-gstin" maxlength="15" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;text-transform:uppercase;" placeholder="Customer GSTIN">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Customer PAN</label>
            <input type="text" id="gst-c-pan" maxlength="10" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;text-transform:uppercase;" placeholder="ABCDE1234F">
          </div>
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Customer State</label>
            <select id="gst-c-state" onchange="syncStateCode(this,'gst-c-code');recalcGST();" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;cursor:pointer;"></select>
            <input type="hidden" id="gst-c-code">
          </div>
        </div>
      </div>
      </div>

      <!-- Work & Project Details -->
      <div class="gst-section" style="border-top:1px solid var(--border);">
        <div class="gst-section-title" style="color:#0891b2;"><i class="bx bxs-calendar"></i> Bill &amp; Work Details <span style="font-size:11px;font-weight:400;color:var(--text-muted);">(optional)</span></div>
        <div style="display:grid;grid-template-columns:240px 1fr 1fr;gap:14px;margin-bottom:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Due Date</label>
            <input type="date" id="gst-due" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;">
          </div>
        </div>
        <div style="margin-bottom:14px;">
          <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Work Order</label>
          <input type="text" id="gst-work-order" list="acc-work-order-list" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="Work order number / reference">
        </div>
        <div style="margin-bottom:14px;">
          <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Project Name</label>
          <input type="text" id="gst-project" list="acc-project-list" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;" placeholder="Project name">
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">Work Details / Scope</label>
          <textarea id="gst-work-details" rows="3" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;resize:vertical;box-sizing:border-box;" placeholder="Brief description of work done"></textarea>
        </div>
      </div>

      <!-- Items -->
      <div class="gst-section" style="border-top:1px solid var(--border);">
        <div class="gst-section-title"><i class="bx bxs-package"></i> Product / Service Items</div>
        <div id="gst-items-body"></div>
        <button type="button" onclick="addGSTItem()" style="margin-top:8px;display:inline-flex;align-items:center;gap:6px;border:1px solid #d1d5db;border-radius:8px;padding:8px 16px;font-size:13px;font-weight:500;color:#111;background:#fff;cursor:pointer;">
          <i class="bx bx-plus-circle"></i> Add Item
        </button>
      </div>

      <!-- Tax & Status -->
      <div class="gst-section" style="border-top:1px solid var(--border);">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:16px;flex-wrap:wrap;">
          <div style="font-size:13px;font-weight:600;color:#111;">Tax &amp; Status</div>
          <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:#075985;background:#e0f2fe;border:1px solid #38bdf8;border-radius:8px;padding:6px 14px;">
              <input type="checkbox" id="gst-show-tax-pdf" checked style="width:16px;height:16px;accent-color:#0284c7;cursor:pointer;">
              Show Tax in PDF
            </label>
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:#374151;background:#fef3c7;border:1px solid #f59e0b;border-radius:8px;padding:6px 14px;">
              <input type="checkbox" id="gst-tax-exempt" onchange="toggleTaxExempt()" style="width:16px;height:16px;accent-color:#f59e0b;cursor:pointer;">
              Tax Exempt (No GST)
            </label>
          </div>
        </div>
        <div id="gst-tax-rate-fields" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:#111;margin-bottom:6px;">SGST Rate (%)</label>
            <input type="number" id="gst-sgst-rate" value="9" min="0" step="0.01" oninput="recalcGST()" onwheel="this.blur()" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:9px 12px;font-size:13px;color:#111;background:#fff;box-sizing:border-box;">
          </div>
          <div>
