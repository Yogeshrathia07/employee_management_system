function renderProjects() {
  var q=(document.getElementById('prj-search').value||'').toLowerCase();
  var st=document.getElementById('prj-status').value;
  var data=load('prj').filter(function(r){return(!q||(r.name||'').toLowerCase().includes(q)||(r.id||'').toLowerCase().includes(q)||(r.client||'').toLowerCase().includes(q))&&(!st||r.status===st);});
  document.getElementById('prj-body').innerHTML=data.length?data.map(function(r){
    var rem=r.budget-r.spent; var pct=r.budget?Math.round((r.spent/r.budget)*100):0;
    var barColor=pct>90?'#ef4444':pct>70?'#f59e0b':'#22c55e';
    return '<tr><td class="acc-td" style="font-weight:600;">'+r.id+'</td>'+
      '<td class="acc-td"><div style="font-weight:600;">'+r.name+'</div><div style="height:4px;background:var(--bg-input);border-radius:4px;margin-top:4px;width:100px;"><div style="width:'+pct+'%;height:100%;background:'+barColor+';border-radius:4px;"></div></div></td>'+
      '<td class="acc-td">'+r.client+'</td>'+
      '<td class="acc-td" style="font-weight:600;">'+fmtAmt(r.budget)+'</td>'+
      '<td class="acc-td">'+fmtAmt(r.spent)+'</td>'+
      '<td class="acc-td" style="font-weight:600;color:'+(rem<0?'#ef4444':'var(--text-primary)')+';">'+fmtAmt(rem)+'</td>'+
      '<td class="acc-td">'+badge(r.status)+'</td>'+
      '<td class="acc-td">'+actBtns('openPrjModal(\''+r.id+'\')','delRecord(\'prj\',\''+r.id+'\')')+'</td></tr>';
  }).join(''):emptyRow(8);
}

/* ── delete ───────────────────────────────────────────── */
function delRecord(key, id) {
  if(!confirm('Delete this record?')) return;
  var arr=load(key).filter(function(x){return x.id!==id;});
  save(key,arr);
  var renders={inv:renderInvoices,pro:renderProforma,quo:renderQuotations,po:renderPO,ven:renderVendors,cwo:renderCWO,vwo:renderVWO,prj:renderProjects};
  if(renders[key]) renders[key]();
  toast('Deleted','success');
}

/* ── calculators ──────────────────────────────────────── */
function calcGST() {
  var amt=parseFloat(document.getElementById('gst-amount').value)||0;
  var rate=parseFloat(document.getElementById('gst-rate').value)||18;
  var gstAmt=amt*rate/100;
  document.getElementById('gst-cgst').textContent=fmtAmt(gstAmt/2);
  document.getElementById('gst-sgst').textContent=fmtAmt(gstAmt/2);
  document.getElementById('gst-igst').textContent=fmtAmt(gstAmt);
  document.getElementById('gst-total').textContent=fmtAmt(amt+gstAmt);
}
function calcDiscount() {
  var orig=parseFloat(document.getElementById('disc-orig').value)||0;
  var pct=parseFloat(document.getElementById('disc-pct').value)||0;
  var disc=orig*pct/100;
  document.getElementById('disc-amt').textContent=fmtAmt(disc);
  document.getElementById('disc-pay').textContent=fmtAmt(orig-disc);
}
function calcTDS() {
  var gross=parseFloat(document.getElementById('tds-gross').value)||0;
  var rate=parseFloat(document.getElementById('tds-rate').value)||10;
  var ded=gross*rate/100;
  document.getElementById('tds-ded').textContent=fmtAmt(ded);
  document.getElementById('tds-net').textContent=fmtAmt(gross-ded);
}

