<script src="/js/api.js"></script>
<script>
/* ── storage helpers ──────────────────────────────────── */
var STORE = {
  inv: 'acc_invoices', pro: 'acc_proforma', quo: 'acc_quotations',
  po: 'acc_po', ven: 'acc_vendors', cwo: 'acc_cwo', vwo: 'acc_vwo', prj: 'acc_projects'
};
function load(key) { try { return JSON.parse(localStorage.getItem(STORE[key]||key)||'[]'); } catch(e){ return []; } }
function save(key, arr) { localStorage.setItem(STORE[key]||key, JSON.stringify(arr)); }
function genId(prefix) { return prefix + '-' + Math.random().toString(36).substr(2,6).toUpperCase(); }
function today() { return new Date().toISOString().slice(0,10); }
function fmtAmt(n) { return 'Rs. ' + Number(n||0).toLocaleString('en-IN'); }
function fmtD(s) { if(!s) return '-'; var d=new Date(s); return d.getDate()+' '+['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()]+' '+d.getFullYear(); }

var STATUS_COLORS = {
  Draft:{c:'#64748b',b:'#f1f5f9'}, Sent:{c:'#3b82f6',b:'#dbeafe'},
  Paid:{c:'#22c55e',b:'#dcfce7'}, Accepted:{c:'#22c55e',b:'#dcfce7'},
  Active:{c:'#22c55e',b:'#dcfce7'}, Completed:{c:'#8b5cf6',b:'#ede9fe'},
  Overdue:{c:'#ef4444',b:'#fee2e2'}, Rejected:{c:'#ef4444',b:'#fee2e2'},
  Cancelled:{c:'#ef4444',b:'#fee2e2'}, Received:{c:'#22c55e',b:'#dcfce7'},
  Proposed:{c:'#f59e0b',b:'#fef3c7'}, Planning:{c:'#f59e0b',b:'#fef3c7'},
  'On Hold':{c:'#f59e0b',b:'#fef3c7'}
};
function badge(s) {
  var sc = STATUS_COLORS[s]||{c:'#64748b',b:'#f1f5f9'};
  return '<span style="font-size:11px;font-weight:700;background:'+sc.b+';color:'+sc.c+';border-radius:20px;padding:2px 10px;">'+s+'</span>';
}
function emptyRow(cols) {
  return '<tr><td colspan="'+cols+'" style="padding:48px;text-align:center;color:var(--text-muted);">No records found</td></tr>';
}
function actBtns(editFn, delFn) {
  return '<div style="display:flex;gap:4px;">'+
    '<button class="btn btn-ghost btn-sm" onclick="'+editFn+'"><i class="bx bx-edit"></i></button>'+
    '<button class="btn btn-danger btn-sm" onclick="'+delFn+'"><i class="bx bx-trash"></i></button>'+
  '</div>';
}

/* ── tab navigation ───────────────────────────────────── */
var activeModule = 'home';
function showModule(key) {
  document.querySelectorAll('.acc-module').forEach(function(el){ el.style.display='none'; });
  document.querySelectorAll('.acc-tab').forEach(function(el){ el.classList.remove('active'); });
  document.getElementById('mod-'+key).style.display='';
  document.getElementById('tab-'+key).classList.add('active');
  activeModule = key;
  if(key==='home') updateDashStats();
  else if(key==='inv') { initInvSettings(); renderInvoices(); }
  else if(key==='pro') renderProforma();
  else if(key==='quo') renderQuotations();
  else if(key==='po') renderPO();
  else if(key==='ven') renderVendors();
  else if(key==='cwo') renderCWO();
  else if(key==='vwo') renderVWO();
  else if(key==='prj') renderProjects();
}
function showSubTab(key) {
  ['invoices','calc'].forEach(function(k) {
    var el = document.getElementById('sub-' + k);
    if (el) el.style.display = k===key ? '' : 'none';
    var btn = document.getElementById('stab-' + k);
    if (btn) btn.classList.toggle('active', k===key);
  });
}
function updateDashStats() {
  // Invoices from API
  api('GET', '/invoices').then(function(data) {
    document.getElementById('dash-inv').textContent = (data||[]).length;
  }).catch(function() {});
  // Others from localStorage
  document.getElementById('dash-ven').textContent = load('ven').length;
  document.getElementById('dash-cwo').textContent = load('cwo').length;
  document.getElementById('dash-prj').textContent = load('prj').length;
}

/* ══════════════════════════════════════════════════════════
   GST INVOICE MODULE  (API-backed)
══════════════════════════════════════════════════════════ */
var gstEditingId = null;
var gstItemCount = 0;

/* ── Populate vendor dropdown from localStorage vendors ─── */
function populateVendorDropdown(selectedName) {
  var sel = document.getElementById('gst-vendor-sel');
  var vendors = load('ven');
  sel.innerHTML = '<option value="">— Type manually or pick a vendor —</option>';
  vendors.forEach(function(v) {
    if (v.status === 'Inactive') return;
    var opt = document.createElement('option');
    opt.value = JSON.stringify(v);
    opt.textContent = v.name + (v.gst ? '  |  GST: ' + v.gst : '');
    if (selectedName && v.name === selectedName) opt.selected = true;
    sel.appendChild(opt);
  });
}

function populatePOVendorDropdown(selectedName) {
  var sel = document.getElementById('po-vendor');
  if (!sel) return;
  var vendors = load('ven').filter(function(v) { return v.status !== 'Inactive'; });
  sel.innerHTML = '<option value="">Select vendor</option>' + vendors.map(function(v) {
    var label = v.name + (v.gst ? ' | GST: ' + v.gst : '');
    return '<option value="' + escape(v.name || '') + '">' + escape(label) + '</option>';
  }).join('');
  if (selectedName) {
    var safeSelectedName = escape(selectedName);
    if (!Array.from(sel.options).some(function(opt) { return opt.value === safeSelectedName; })) {
      var opt = document.createElement('option');
      opt.value = safeSelectedName;
      opt.textContent = selectedName;
      sel.appendChild(opt);
    }
    sel.value = safeSelectedName;
  }
}

/* ── Auto-fill customer fields from selected vendor ─────── */
function fillFromVendor(jsonStr) {
  if (!jsonStr) return;
  var v;
  try { v = JSON.parse(jsonStr); } catch(e) { return; }
  document.getElementById('gst-c-name').value  = v.name    || '';
  document.getElementById('gst-c-gstin').value = (v.gst    || '').toUpperCase();
  document.getElementById('gst-c-addr').value  = v.address || '';
  // Parse state / state code from vendor address or name
  document.getElementById('gst-c-state').value = v.state   || '';
  document.getElementById('gst-c-code').value  = v.stateCode || '';
  recalcGST();
}

/* ── Open GST Invoice Modal ─────────────────────────────── */
function openGSTModal(invId) {
  gstEditingId = invId || null;
  gstItemCount = 0;
  document.getElementById('gst-items-body').innerHTML = '';
  document.getElementById('gst-inv-title').innerHTML = invId
    ? '<i class="bx bxs-edit" style="color:var(--accent)"></i> Edit Invoice'
    : '<i class="bx bxs-receipt" style="color:var(--accent)"></i> New GST Invoice';

  populateVendorDropdown();
  if (invId) {
    api('GET', '/invoices/' + invId).then(function(inv) {
      document.getElementById('gst-number').value     = inv.invoiceNumber;
      document.getElementById('gst-type').value       = inv.invoiceType || 'B2B';
      document.getElementById('gst-date').value       = inv.invoiceDate || '';
      document.getElementById('gst-due').value        = inv.dueDate     || '';
      document.getElementById('gst-supply').value     = inv.placeOfSupply || '';
      document.getElementById('gst-s-name').value     = inv.sellerName  || '';
      document.getElementById('gst-s-gstin').value    = inv.sellerGstin || '';
      document.getElementById('gst-s-addr').value     = inv.sellerAddress || '';
      document.getElementById('gst-s-state').value    = inv.sellerState || '';
      document.getElementById('gst-s-code').value     = inv.sellerStateCode || '';
      document.getElementById('gst-s-phone').value    = inv.sellerPhone || '';
      document.getElementById('gst-s-email').value    = inv.sellerEmail || '';
      document.getElementById('gst-s-pan').value      = inv.sellerPan   || '';
      document.getElementById('gst-c-name').value     = inv.customerName || '';
      document.getElementById('gst-c-gstin').value    = inv.customerGstin || '';
      document.getElementById('gst-c-addr').value     = inv.customerAddress || '';
      document.getElementById('gst-c-state').value    = inv.customerState || '';
      document.getElementById('gst-c-code').value     = inv.customerStateCode || '';
      document.getElementById('gst-c-pan').value      = inv.customerPan  || '';
      document.getElementById('gst-c-email').value    = inv.customerEmail || '';
      document.getElementById('gst-bill-month').value = inv.billMonth    || '';
      document.getElementById('gst-bill-from').value  = inv.billPeriodFrom || '';
      document.getElementById('gst-bill-to').value    = inv.billPeriodTo   || '';
      document.getElementById('gst-work-order').value = inv.workOrder    || '';
      document.getElementById('gst-project').value    = inv.projectName  || '';
      document.getElementById('gst-work-details').value = inv.workDetails || '';
      document.getElementById('gst-bank-name').value  = inv.bankName     || '';
      document.getElementById('gst-bank-acname').value= inv.bankAcName   || '';
      document.getElementById('gst-bank-ac').value    = inv.bankAccount  || '';
      document.getElementById('gst-bank-ifsc').value  = inv.bankIfsc     || '';
      document.getElementById('gst-bank-branch').value= inv.bankBranch   || '';
      document.getElementById('gst-pay-status').value = inv.paymentStatus || 'Unpaid';
      document.getElementById('gst-pay-mode').value   = inv.paymentMode || '';
      document.getElementById('gst-status').value     = inv.status || 'Draft';
      document.getElementById('gst-notes').value      = inv.notes || '';
      document.getElementById('gst-terms').value      = inv.termsConditions || '';
      (inv.items || []).forEach(function(it) { addGSTItem(it); });
      recalcGST();
      openModal('gst-inv-modal');
    }).catch(function(e) { toast('Failed to load invoice', 'error'); });
  } else {
    document.getElementById('gst-number').value     = 'Auto-generated';
    document.getElementById('gst-type').value       = 'B2B';
    document.getElementById('gst-date').value       = today();
    document.getElementById('gst-due').value        = '';
    document.getElementById('gst-supply').value     = '';
    document.getElementById('gst-s-name').value     = '';
    document.getElementById('gst-s-gstin').value    = '';
    document.getElementById('gst-s-addr').value     = '';
    document.getElementById('gst-s-state').value    = '';
    document.getElementById('gst-s-code').value     = '';
    document.getElementById('gst-s-phone').value    = '';
    document.getElementById('gst-s-email').value    = '';
    document.getElementById('gst-s-pan').value      = '';
    document.getElementById('gst-vendor-sel').value = '';
    document.getElementById('gst-c-name').value     = '';
    document.getElementById('gst-c-gstin').value    = '';
    document.getElementById('gst-c-addr').value     = '';
    document.getElementById('gst-c-state').value    = '';
    document.getElementById('gst-c-code').value     = '';
    document.getElementById('gst-c-pan').value      = '';
    document.getElementById('gst-c-email').value    = '';
    document.getElementById('gst-bill-month').value = '';
    document.getElementById('gst-bill-from').value  = '';
    document.getElementById('gst-bill-to').value    = '';
    document.getElementById('gst-work-order').value = '';
    document.getElementById('gst-project').value    = '';
    document.getElementById('gst-work-details').value = '';
    document.getElementById('gst-bank-name').value  = '';
    document.getElementById('gst-bank-acname').value= '';
    document.getElementById('gst-bank-ac').value    = '';
    document.getElementById('gst-bank-ifsc').value  = '';
    document.getElementById('gst-bank-branch').value= '';
    document.getElementById('gst-pay-status').value = 'Unpaid';
    document.getElementById('gst-pay-mode').value   = '';
    document.getElementById('gst-status').value     = 'Draft';
    document.getElementById('gst-notes').value      = '';
    document.getElementById('gst-terms').value      = '';
    addGSTItem();
    recalcGST();
    openModal('gst-inv-modal');
  }
}

/* ── Add GST Line Item Row ──────────────────────────────── */
function addGSTItem(it) {
  gstItemCount++;
  var idx = gstItemCount;
  it = it || { itemCode:'', name:'', hsnCode:'', quantity:1, unit:'', unitPrice:0, discount:0, taxRate:18 };
  var row = document.createElement('tr');
  row.id = 'gst-row-' + idx;
  row.innerHTML =
    '<td class="gst-item-num">' + idx + '</td>' +
    '<td><input type="text"   class="gi-code"  value="' + (it.itemCode||'') + '" placeholder="Code"></td>' +
    '<td><input type="text"   class="gi-name"  value="' + (it.name||'')     + '" placeholder="Item description" oninput="recalcGST()"></td>' +
    '<td><input type="text"   class="gi-hsn"   value="' + (it.hsnCode||'')  + '" placeholder="HSN/SAC"></td>' +
    '<td><input type="number" class="gi-qty"   value="' + (it.quantity||1)  + '" min="0" step="0.01" oninput="recalcGST()"></td>' +
    '<td><input type="text"   class="gi-unit"  value="' + (it.unit||'')     + '" placeholder="Nos/Kg/Hr"></td>' +
    '<td><input type="number" class="gi-price" value="' + (it.unitPrice||0) + '" min="0" step="0.01" oninput="recalcGST()"></td>' +
    '<td><input type="number" class="gi-disc"  value="' + (it.discount||0)  + '" min="0" max="100" step="0.01" oninput="recalcGST()"></td>' +
    '<td><select class="gi-tax" onchange="recalcGST()">' +
      ['0','5','12','18','28'].map(function(r){ return '<option value="'+r+'"'+(String(it.taxRate)===r?' selected':'')+'>'+(r==='0'?'Exempt':r+'%')+'</option>'; }).join('') +
    '</select></td>' +
    '<td style="text-align:right;font-weight:600;font-size:13px;white-space:nowrap;" id="gi-amt-' + idx + '">₹0.00</td>' +
    '<td><button type="button" class="btn btn-danger btn-sm" style="padding:3px 7px;" onclick="removeGSTItem(\'gst-row-'+idx+'\')"><i class="bx bx-x"></i></button></td>';
  document.getElementById('gst-items-body').appendChild(row);
  recalcGST();
}

function removeGSTItem(rowId) {
  var el = document.getElementById(rowId);
  if (el) el.remove();
  recalcGST();
}

/* ── Recalculate GST Totals ─────────────────────────────── */
function recalcGST() {
  var selCode = (document.getElementById('gst-s-code').value || '').trim();
  var cusCode = (document.getElementById('gst-c-code').value || '').trim();
  var useIGST = selCode && cusCode && selCode !== cusCode;

  document.getElementById('gst-tax-hint').textContent = useIGST
    ? 'IGST applied (inter-state: different state codes).'
    : 'CGST + SGST applied (intra-state: same or unset state codes).';
  document.getElementById('gst-row-cgst').style.display = useIGST ? 'none' : '';
  document.getElementById('gst-row-sgst').style.display = useIGST ? 'none' : '';
  document.getElementById('gst-row-igst').style.display = useIGST ? '' : 'none';

  var rows = document.getElementById('gst-items-body').querySelectorAll('tr');
  var subtotal = 0, totalCgst = 0, totalSgst = 0, totalIgst = 0;

  rows.forEach(function(row, i) {
    var qty   = parseFloat(row.querySelector('.gi-qty').value)   || 0;
    var price = parseFloat(row.querySelector('.gi-price').value) || 0;
    var disc  = parseFloat(row.querySelector('.gi-disc').value)  || 0;
    var tax   = parseFloat(row.querySelector('.gi-tax').value)   || 0;
    var taxable = qty * price * (1 - disc / 100);
    var gstAmt  = taxable * tax / 100;
    subtotal += taxable;
    if (useIGST) { totalIgst += gstAmt; }
    else          { totalCgst += gstAmt / 2; totalSgst += gstAmt / 2; }
    var amtEl = row.querySelector('[id^="gi-amt-"]');
    if (amtEl) amtEl.textContent = fmtAmt(taxable + gstAmt);
  });

  var grossTotal  = subtotal + totalCgst + totalSgst + totalIgst;
  var roundOff    = Math.round(grossTotal) - grossTotal;
  var totalAmount = grossTotal + roundOff;

  document.getElementById('gst-sub').textContent       = fmtAmt(subtotal);
  document.getElementById('gst-cgst-val').textContent  = fmtAmt(totalCgst);
  document.getElementById('gst-sgst-val').textContent  = fmtAmt(totalSgst);
  document.getElementById('gst-igst-val').textContent  = fmtAmt(totalIgst);
  document.getElementById('gst-tax-total').textContent = fmtAmt(totalCgst + totalSgst + totalIgst);
  document.getElementById('gst-roundoff').textContent  = fmtAmt(roundOff);
  document.getElementById('gst-total-amt').textContent = fmtAmt(totalAmount);
}

/* ── Collect Items from Table ───────────────────────────── */
function collectGSTItems() {
  var rows = document.getElementById('gst-items-body').querySelectorAll('tr');
  var items = [];
  rows.forEach(function(row) {
    var qty   = parseFloat(row.querySelector('.gi-qty').value)   || 0;
    var price = parseFloat(row.querySelector('.gi-price').value) || 0;
    var disc  = parseFloat(row.querySelector('.gi-disc').value)  || 0;
    var tax   = parseFloat(row.querySelector('.gi-tax').value)   || 0;
    var taxable = qty * price * (1 - disc / 100);
    var gstAmt  = taxable * tax / 100;
    items.push({
      itemCode: row.querySelector('.gi-code').value,
      name:    row.querySelector('.gi-name').value,
      hsnCode: row.querySelector('.gi-hsn').value,
      quantity: qty,
      unit:    row.querySelector('.gi-unit').value,
      unitPrice: price,
      discount: disc,
      taxRate:  tax,
      taxableAmount: parseFloat(taxable.toFixed(2)),
      cgst:  parseFloat((gstAmt/2).toFixed(2)),
      sgst:  parseFloat((gstAmt/2).toFixed(2)),
      igst:  parseFloat(gstAmt.toFixed(2)),
      itemTotal: parseFloat((taxable+gstAmt).toFixed(2)),
    });
  });
  return items;
}

/* ── Save GST Invoice (API) ─────────────────────────────── */
function saveGSTInvoice(forceStatus) {
  var selCode = (document.getElementById('gst-s-code').value || '').trim();
  var cusCode = (document.getElementById('gst-c-code').value || '').trim();
  var useIGST = selCode && cusCode && selCode !== cusCode;

  if (!document.getElementById('gst-c-name').value.trim()) return toast('Customer name is required','error');
  if (!document.getElementById('gst-date').value)          return toast('Invoice date is required','error');

  var items      = collectGSTItems();
  var subtotal   = 0, totalCgst = 0, totalSgst = 0, totalIgst = 0;
  items.forEach(function(it) {
    subtotal += it.taxableAmount;
    if (useIGST) totalIgst += it.igst; else { totalCgst += it.cgst; totalSgst += it.sgst; }
  });
  var gross      = subtotal + totalCgst + totalSgst + totalIgst;
  var roundOff   = parseFloat((Math.round(gross) - gross).toFixed(2));
  var totalAmount= parseFloat((gross + roundOff).toFixed(2));

  var payload = {
    invoiceType:       document.getElementById('gst-type').value,
    invoiceDate:       document.getElementById('gst-date').value,
    dueDate:           document.getElementById('gst-due').value   || null,
    placeOfSupply:     document.getElementById('gst-supply').value,
    sellerName:        document.getElementById('gst-s-name').value,
    sellerGstin:       document.getElementById('gst-s-gstin').value.toUpperCase(),
    sellerAddress:     document.getElementById('gst-s-addr').value,
    sellerState:       document.getElementById('gst-s-state').value,
    sellerStateCode:   document.getElementById('gst-s-code').value,
    sellerPhone:       document.getElementById('gst-s-phone').value,
    sellerEmail:       document.getElementById('gst-s-email').value,
    sellerPan:         document.getElementById('gst-s-pan').value.toUpperCase(),
    customerName:      document.getElementById('gst-c-name').value,
    customerGstin:     document.getElementById('gst-c-gstin').value.toUpperCase(),
    customerAddress:   document.getElementById('gst-c-addr').value,
    customerState:     document.getElementById('gst-c-state').value,
    customerStateCode: document.getElementById('gst-c-code').value,
    customerPan:       document.getElementById('gst-c-pan').value.toUpperCase(),
    customerEmail:     document.getElementById('gst-c-email').value,
    billMonth:         document.getElementById('gst-bill-month').value,
    billPeriodFrom:    document.getElementById('gst-bill-from').value   || null,
    billPeriodTo:      document.getElementById('gst-bill-to').value     || null,
    workOrder:         document.getElementById('gst-work-order').value,
    projectName:       document.getElementById('gst-project').value,
    workDetails:       document.getElementById('gst-work-details').value,
    bankName:          document.getElementById('gst-bank-name').value,
    bankAcName:        document.getElementById('gst-bank-acname').value,
    bankAccount:       document.getElementById('gst-bank-ac').value,
    bankIfsc:          document.getElementById('gst-bank-ifsc').value.toUpperCase(),
    bankBranch:        document.getElementById('gst-bank-branch').value,
    items:             items,
    subtotal:          parseFloat(subtotal.toFixed(2)),
    totalCgst:         parseFloat(totalCgst.toFixed(2)),
    totalSgst:         parseFloat(totalSgst.toFixed(2)),
    totalIgst:         parseFloat(totalIgst.toFixed(2)),
    totalTax:          parseFloat((totalCgst+totalSgst+totalIgst).toFixed(2)),
    roundOff:          roundOff,
    totalAmount:       totalAmount,
    paymentStatus:     document.getElementById('gst-pay-status').value,
    paymentMode:       document.getElementById('gst-pay-mode').value,
    status:            forceStatus || document.getElementById('gst-status').value,
    notes:             document.getElementById('gst-notes').value,
    termsConditions:   document.getElementById('gst-terms').value,
    financialYear:     (document.getElementById('inv-fy-sel') && document.getElementById('inv-fy-sel').value) || localStorage.getItem('inv_fy') || '',
    companyCode:       (document.getElementById('inv-company-code') && document.getElementById('inv-company-code').value.trim().toUpperCase()) || localStorage.getItem('inv_company_code') || '',
  };

  var method = gstEditingId ? 'PUT' : 'POST';
  var path   = gstEditingId ? '/invoices/' + gstEditingId : '/invoices';

  api(method, path, payload)
    .then(function(inv) {
      closeModal('gst-inv-modal');
      renderInvoices();
      toast((gstEditingId ? 'Invoice updated' : 'Invoice #' + inv.invoiceNumber + ' created') + '!', 'success');
    })
    .catch(function(e) { toast('Error: ' + (e.message || 'Save failed'), 'error'); });
}

/* ── Collapsible panel toggle ───────────────────────────── */
function toggleGSTPanel(hdr) {
  hdr.closest('.gst-collapse-panel').classList.toggle('collapsed');
}

/* ── Invoice number settings (FY + company code) ───────── */
function initInvSettings() {
  var sel = document.getElementById('inv-fy-sel');
  if (!sel || sel.options.length > 0) { updateInvNumPreview(); return; }
  var now = new Date(), yr = now.getFullYear(), mo = now.getMonth() + 1;
  var startYear = mo >= 4 ? yr : yr - 1;
  var firstYear = 2018;
  var lastYear = startYear + 5;
  var html = '';
  for (var i = firstYear; i <= lastYear; i++) {
    var fy = String(i).slice(-2) + '-' + String(i+1).slice(-2);
    var selected = (i === startYear) ? ' selected' : '';
    html += '<option value="' + fy + '"' + selected + '>' + i + '-' + (i+1) + '</option>';
  }
  sel.innerHTML = html;
  // Restore saved values
  var savedCode = localStorage.getItem('inv_company_code') || '';
  var savedFY   = localStorage.getItem('inv_fy') || '';
  if (savedCode) document.getElementById('inv-company-code').value = savedCode.toUpperCase();
  if (savedFY && sel.querySelector('option[value="'+savedFY+'"]')) sel.value = savedFY;
  updateInvNumPreview();
}

function updateInvNumPreview() {
  var code = (document.getElementById('inv-company-code').value || 'DHPE').toUpperCase().replace(/[^A-Z0-9]/g,'') || 'INV';
  var fy   = (document.getElementById('inv-fy-sel') && document.getElementById('inv-fy-sel').value) || '26-27';
  localStorage.setItem('inv_company_code', code);
  localStorage.setItem('inv_fy', fy);
  var el = document.getElementById('inv-num-preview');
  if (el) el.textContent = 'INV-001/' + code + '/' + fy + '/XXXXXX';
}

/* ── Render Invoice List ────────────────────────────────── */
function renderInvoices() {
  var q  = (document.getElementById('inv-search').value || '').trim();
  var st = document.getElementById('inv-status').value;
  var tp = document.getElementById('inv-type').value;
  var params = new URLSearchParams();
  if (q)  params.set('q', q);
  if (st) params.set('status', st);
  if (tp) params.set('type', tp);

  api('GET', '/invoices?' + params.toString())
    .then(function(data) {
      var tbody = document.getElementById('inv-body');
      if (!data || !data.length) { tbody.innerHTML = emptyRow(7); return; }

      tbody.innerHTML = data.map(function(r) {
        var typeLabel = r.invoiceType === 'B2C' ? 'Tax Invoice (B2C)' : 'Tax Invoice';
        var typeColor = r.invoiceType === 'B2C' ? '#7c3aed' : '#1d4ed8';
        var typeBg    = r.invoiceType === 'B2C' ? '#ede9fe' : '#dbeafe';

        var actionBtns =
          '<div style="display:flex;gap:2px;justify-content:center;">' +
            '<button class="inv-act-btn" title="Preview" onclick="previewInvoice('+r.id+')"><i class="bx bx-show"></i></button>' +
            '<button class="inv-act-btn" title="Share WhatsApp" onclick="shareWhatsApp(\''+r.invoiceNumber+'\','+r.totalAmount+')"><i class="bx bxl-whatsapp"></i></button>' +
            '<button class="inv-act-btn" title="Print" onclick="printInvoice('+r.id+')"><i class="bx bx-printer"></i></button>' +
            '<button class="inv-act-btn" title="Download PDF" onclick="downloadInvPDF('+r.id+',\''+r.invoiceNumber+'\')"><i class="bx bx-download"></i></button>' +
            (r.paymentStatus !== 'Paid' ? '<button class="inv-act-btn" title="Mark Paid" onclick="openMarkPaid('+r.id+',\''+r.invoiceNumber+'\')"><i class="bx bx-check-circle"></i></button>' : '') +
            '<button class="inv-act-btn" title="Edit" onclick="openGSTModal('+r.id+')"><i class="bx bx-edit-alt"></i></button>' +
            '<button class="inv-act-btn inv-act-del" title="Delete" onclick="deleteInvoice('+r.id+',\''+r.invoiceNumber+'\')"><i class="bx bx-trash"></i></button>' +
          '</div>';

        return '<tr class="inv-row">' +
          '<td class="acc-td" style="font-weight:700;color:var(--accent);font-size:12px;white-space:nowrap;">' + (r.invoiceNumber||'') + '</td>' +
          '<td class="acc-td"><span style="font-size:11px;font-weight:700;background:'+typeBg+';color:'+typeColor+';border-radius:6px;padding:3px 9px;">'+typeLabel+'</span></td>' +
          '<td class="acc-td"><div style="font-weight:600;font-size:13px;">' + (r.customerName||'') + '</div>' +
            (r.customerGstin ? '<div style="font-size:10px;color:var(--text-muted);margin-top:1px;">'+r.customerGstin+'</div>' : '') + '</td>' +
          '<td class="acc-td" style="white-space:nowrap;font-size:12px;">' + fmtD(r.invoiceDate) + '</td>' +
          '<td class="acc-td" style="font-weight:700;white-space:nowrap;">₹' + Number(r.totalAmount||0).toLocaleString('en-IN', {minimumFractionDigits:2}) + '</td>' +
          '<td class="acc-td">' + badge(r.status) + '</td>' +
          '<td class="acc-td" style="white-space:nowrap;">' + actionBtns + '</td>' +
        '</tr>';
      }).join('');

      document.getElementById('dash-inv').textContent = data.length;
    })
    .catch(function(err) {
      document.getElementById('inv-body').innerHTML =
        '<tr><td colspan="7" style="padding:40px;text-align:center;">' +
          '<div style="color:#ef4444;font-weight:600;margin-bottom:6px;"><i class="bx bx-error-circle"></i> Failed to load invoices</div>' +
          '<div style="font-size:12px;color:var(--text-muted);">Please restart the server so the Invoices table is created, then refresh.</div>' +
        '</td></tr>';
    });
}

/* ── Print Invoice ──────────────────────────────────────── */
function printInvoice(id) {
  var token = getToken();
  fetch('/api/invoices/' + id + '/pdf', { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r) { return r.blob(); })
    .then(function(blob) {
      var url = URL.createObjectURL(blob);
      var win = window.open(url);
      if (win) {
        win.addEventListener('load', function() { win.print(); });
      } else {
        toast('Allow popups to use Print', 'error');
      }
    })
    .catch(function() { toast('Print failed', 'error'); });
}

