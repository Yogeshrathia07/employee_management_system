      closeModal('inv-preview-modal');
      openGSTModal(id);
    };
    openModal('inv-preview-modal');
  }).catch(function() { toast('Failed to load invoice', 'error'); });
}

/* ── Mark as Paid ───────────────────────────────────────── */
function openMarkPaid(id, num) {
  document.getElementById('mark-paid-id').value  = id;
  document.getElementById('mark-paid-num').value = num;
  openModal('mark-paid-modal');
}
function confirmMarkPaid() {
  var id   = document.getElementById('mark-paid-id').value;
  var mode = document.getElementById('mark-paid-mode').value;
  api('PATCH', '/invoices/' + id + '/pay', { paymentMode: mode })
    .then(function() { closeModal('mark-paid-modal'); renderInvoices(); toast('Marked as Paid!', 'success'); })
    .catch(function() { toast('Failed to mark paid', 'error'); });
}

/* ── Delete Invoice ─────────────────────────────────────── */
function deleteInvoice(id, num) {
  if (!confirm('Delete invoice ' + num + '? This cannot be undone.')) return;
  api('DELETE', '/invoices/' + id)
    .then(function() { renderInvoices(); toast('Invoice deleted', 'success'); })
    .catch(function() { toast('Delete failed', 'error'); });
}

/* ── Invoice Reports ────────────────────────────────────── */
function renderInvReports() {
  api('GET', '/invoices').then(function(data) {
    if (!data) data = [];
    // Stat cards
    var total = data.reduce(function(s,r){return s+Number(r.totalAmount||0);},0);
    var paid  = data.filter(function(r){return r.status==='Paid';});
    var unpaid= data.filter(function(r){return r.status==='Overdue'||r.paymentStatus==='Unpaid';});
    var draft = data.filter(function(r){return r.status==='Draft';});
    var statsEl = document.getElementById('inv-report-stats');
    function statCard(label, val, color, bg) {
      return '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;">' +
        '<div style="display:flex;align-items:center;gap:12px;">' +
          '<div style="width:40px;height:40px;border-radius:10px;background:'+bg+';display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;color:'+color+';">₹</div>' +
          '<div><div style="font-size:18px;font-weight:800;color:var(--text-primary);">'+val+'</div><div style="font-size:11px;color:var(--text-muted);">'+label+'</div></div>' +
        '</div></div>';
    }
    statsEl.innerHTML =
      statCard('Total Invoiced', '₹'+total.toLocaleString('en-IN',{minimumFractionDigits:2}), '#1d4ed8', '#dbeafe') +
      statCard('Paid Revenue', '₹'+paid.reduce(function(s,r){return s+Number(r.totalAmount||0);},0).toLocaleString('en-IN',{minimumFractionDigits:2}), '#16a34a', '#dcfce7') +
      statCard('Pending / Overdue', unpaid.length + ' invoice'+(unpaid.length!==1?'s':''), '#dc2626', '#fee2e2') +
      statCard('Drafts', draft.length + ' invoice'+(draft.length!==1?'s':''), '#7c3aed', '#ede9fe');

    // Status breakdown
    var statMap = {};
    data.forEach(function(r){ statMap[r.status]=(statMap[r.status]||0)+1; });
    var statusEl = document.getElementById('inv-report-status');
    var maxV = Math.max.apply(null, Object.values(statMap).concat([1]));
    statusEl.innerHTML = Object.keys(statMap).map(function(k) {
      var sc = STATUS_COLORS[k]||{c:'#64748b',b:'#f1f5f9'};
      var pct = Math.round((statMap[k]/maxV)*100);
      return '<div style="margin-bottom:12px;">'+
        '<div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;"><span style="font-weight:600;">'+k+'</span><span style="color:var(--text-muted);">'+statMap[k]+'</span></div>'+
        '<div style="background:var(--bg-input);border-radius:4px;height:8px;"><div style="width:'+pct+'%;height:100%;background:'+sc.c+';border-radius:4px;transition:width .4s;"></div></div>'+
      '</div>';
    }).join('') || '<div style="color:var(--text-muted);font-size:13px;text-align:center;padding:24px;">No data yet</div>';

    // Top customers
    var custMap = {};
    data.forEach(function(r){ custMap[r.customerName||'Unknown']=(custMap[r.customerName||'Unknown']||0)+Number(r.totalAmount||0); });
    var sorted = Object.entries(custMap).sort(function(a,b){return b[1]-a[1];}).slice(0,5);
    var custEl = document.getElementById('inv-report-customers');
    var maxC = sorted.length ? sorted[0][1] : 1;
    custEl.innerHTML = sorted.map(function(entry) {
      var pct = Math.round((entry[1]/maxC)*100);
      return '<div style="margin-bottom:14px;">'+
        '<div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;"><span style="font-weight:600;">'+entry[0]+'</span><span style="color:var(--text-muted);">₹'+Number(entry[1]).toLocaleString('en-IN',{minimumFractionDigits:2})+'</span></div>'+
        '<div style="background:var(--bg-input);border-radius:4px;height:8px;"><div style="width:'+pct+'%;height:100%;background:#22c55e;border-radius:4px;transition:width .4s;"></div></div>'+
      '</div>';
    }).join('') || '<div style="color:var(--text-muted);font-size:13px;text-align:center;padding:24px;">No data yet</div>';
  }).catch(function(){});
}

/* ── WhatsApp Share ─────────────────────────────────────── */
function shareWhatsApp(num, amount) {
  var msg = 'Dear Customer,\n\nPlease find your invoice details below:\n\n' +
            'Invoice No: ' + num + '\nAmount: ₹' + Number(amount||0).toLocaleString('en-IN', {minimumFractionDigits:2}) + '\n\n' +
            'Kindly make the payment at the earliest. Thank you for your business!\n\n' +
            'Regards';
  window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
}

/* ── PDF Download (blob fetch with auth header) ─────────── */
function downloadInvPDF(id, num) {
  var token = getToken();
  fetch('/api/invoices/' + id + '/pdf', {
    headers: { 'Authorization': 'Bearer ' + token }
  }).then(function(res) {
    if (!res.ok) { toast('PDF generation failed', 'error'); return; }
    return res.blob();
  }).then(function(blob) {
    if (!blob) return;
    var url = URL.createObjectURL(blob);
    var a   = document.createElement('a');
    a.href     = url;
    a.download = 'Invoice-' + num + '.pdf';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }).catch(function() { toast('PDF download failed', 'error'); });
}

/* ══════════════════════════════════════════════════════════
   LEGACY doc modal (Proforma / Quotations)  ← unchanged
══════════════════════════════════════════════════════════ */
var editingDocId = null, editingDocType = null;
function addLineItemRow(container, item) {
  item = item || {name:'',qty:1,rate:0};
  var div = document.createElement('div');
  div.className = 'line-item-row';
  div.innerHTML = '<input type="text" class="form-control item-name" placeholder="Item description" value="'+escape(item.name||'')+'">'+
    '<input type="number" class="form-control item-qty" placeholder="Qty" value="'+(item.qty||1)+'" min="1" oninput="updateDocTotal()">'+
    '<input type="number" class="form-control item-rate" placeholder="Rate" value="'+(item.rate||0)+'" min="0" oninput="updateDocTotal()">'+
    '<div class="item-total">'+(item.qty&&item.rate?fmtAmt(item.qty*item.rate):'₹0')+'</div>'+
    '<button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove();updateDocTotal()"><i class="bx bx-x"></i></button>';
  div.querySelector('.item-rate').addEventListener('input', function(){ div.querySelector('.item-total').textContent=fmtAmt((parseFloat(div.querySelector('.item-qty').value)||0)*(parseFloat(div.querySelector('.item-rate').value)||0)); });
  div.querySelector('.item-qty').addEventListener('input', function(){ div.querySelector('.item-total').textContent=fmtAmt((parseFloat(div.querySelector('.item-qty').value)||0)*(parseFloat(div.querySelector('.item-rate').value)||0)); });
  container.appendChild(div);
}
function addLineItem() { addLineItemRow(document.getElementById('doc-items'), null); updateDocTotal(); }
function calcDocItems(container) {
  var rows = container.querySelectorAll('.line-item-row'); var total = 0;
  rows.forEach(function(row){ total += (parseFloat(row.querySelector('.item-qty').value)||0) * (parseFloat(row.querySelector('.item-rate').value)||0); });
  return total;
}
function updateDocTotal() {
  var t = calcDocItems(document.getElementById('doc-items'));
  document.getElementById('doc-total-display').textContent = fmtAmt(t);
}
function getDocItems(container) {
  return Array.from(container.querySelectorAll('.line-item-row')).map(function(row){
    return {name:unescape(row.querySelector('.item-name').value), qty:parseFloat(row.querySelector('.item-qty').value)||1, rate:parseFloat(row.querySelector('.item-rate').value)||0};
  });
}
function openDocModal(type) {
  editingDocType = type; editingDocId = null;
  var titles = {pro:'New Proforma Invoice', quo:'New Quotation'};
  document.getElementById('doc-type').value = type;
  document.getElementById('doc-modal-title').textContent = titles[type];
  document.getElementById('doc-party-label').textContent = 'Client Name';
  document.getElementById('doc-date2-label').textContent = 'Valid Till';
  document.getElementById('doc-items').innerHTML = '';
  document.getElementById('doc-status').innerHTML = '<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>';
  document.getElementById('doc-id').value    = genId(type==='pro'?'PRO':'QUO');
  document.getElementById('doc-party').value = '';
  document.getElementById('doc-date').value  = today();
  document.getElementById('doc-date2').value = '';
  document.getElementById('doc-status').value = 'Draft';
  document.getElementById('doc-notes').value = '';
  addLineItemRow(document.getElementById('doc-items'), null);
  updateDocTotal(); openModal('doc-modal');
}
function openDocEditModal(type, id) {
  editingDocType = type; editingDocId = id;
  var rec = load(type).find(function(x){return x.id===id;});
  if (!rec) return;
  var titles = {inv:'Edit Invoice', pro:'Edit Proforma Invoice', quo:'Edit Quotation'};
  document.getElementById('doc-type').value = type;
  document.getElementById('doc-modal-title').textContent = titles[type];
  document.getElementById('doc-party-label').textContent = 'Client Name';
  document.getElementById('doc-date2-label').textContent = type==='inv' ? 'Due Date' : 'Valid Till';
  document.getElementById('doc-items').innerHTML = '';
  var statMap = {inv:'<option>Draft</option><option>Sent</option><option>Paid</option><option>Overdue</option>', pro:'<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>', quo:'<option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option>'};
  document.getElementById('doc-status').innerHTML = statMap[type];
  document.getElementById('doc-id').value    = rec.id;
  document.getElementById('doc-party').value = rec.client;
  document.getElementById('doc-date').value  = rec.date;
  document.getElementById('doc-date2').value = rec.dueDate||rec.validTill||'';
  document.getElementById('doc-status').value = rec.status;
  document.getElementById('doc-notes').value = rec.notes||'';
  (rec.items||[]).forEach(function(it){ addLineItemRow(document.getElementById('doc-items'), it); });
  updateDocTotal(); openModal('doc-modal');
}
function saveDoc() {
  var type = document.getElementById('doc-type').value;
  var items = getDocItems(document.getElementById('doc-items'));
  var total = items.reduce(function(s,it){return s+it.qty*it.rate;},0);
  var d2Key = type==='inv' ? 'dueDate' : 'validTill';
  var rec = { id: document.getElementById('doc-id').value, client: document.getElementById('doc-party').value,
    date: document.getElementById('doc-date').value, status: document.getElementById('doc-status').value,
    notes: document.getElementById('doc-notes').value, items: items, amount: total };
  rec[d2Key] = document.getElementById('doc-date2').value;
  var arr = load(type);
  if (editingDocId) { var i=arr.findIndex(function(x){return x.id===editingDocId;}); if(i>=0)arr[i]=rec; }
  else arr.unshift(rec);
  save(type, arr);
  closeModal('doc-modal');
  if(type==='pro') renderProforma(); else if(type==='quo') renderQuotations();
  toast('Saved!','success');
}
function renderProforma() {
  var q  = (document.getElementById('pro-search').value || '').toLowerCase();
  var st = document.getElementById('pro-status').value;
  var data = load('pro').filter(function(r) {
    return (!q || (r.customerName||r.client||'').toLowerCase().includes(q) || (r.id||'').toLowerCase().includes(q))
        && (!st || r.status === st);
  });
  document.getElementById('pro-body').innerHTML = data.length ? data.map(function(r) {
    var proActBtns =
      '<div style="display:flex;gap:2px;justify-content:center;">' +
        '<button class="inv-act-btn" title="Preview"      onclick="previewProforma(\''+r.id+'\')"><i class="bx bx-show"></i></button>' +
        '<button class="inv-act-btn" title="Print"        onclick="printProforma(\''+r.id+'\')"><i class="bx bx-printer"></i></button>' +
        '<button class="inv-act-btn" title="Download PDF" onclick="downloadProformaPDF(\''+r.id+'\')"><i class="bx bx-download"></i></button>' +
        '<button class="inv-act-btn" title="Convert to Invoice" onclick="convertToInvoiceFromId(\''+r.id+'\')"><i class="bx bxs-receipt"></i></button>' +
        '<button class="inv-act-btn" title="Edit"         onclick="openProformaModal(\''+r.id+'\')"><i class="bx bx-edit-alt"></i></button>' +
        '<button class="inv-act-btn inv-act-del" title="Delete" onclick="deleteProforma(\''+r.id+'\')"><i class="bx bx-trash"></i></button>' +
      '</div>';
    return '<tr class="inv-row">' +
      '<td class="acc-td" style="font-weight:700;color:var(--accent);">' + (r.id||'—') + '</td>' +
      '<td class="acc-td">' + (r.customerName||r.client||'—') + '</td>' +
      '<td class="acc-td">' + fmtD(r.date) + '</td>' +
      '<td class="acc-td">' + fmtD(r.validityDate||r.validTill) + '</td>' +
      '<td class="acc-td" style="font-weight:600;">' + fmtAmt(r.totalAmount||r.amount||0) + '</td>' +
      '<td class="acc-td">' + badge(r.status) + '</td>' +
      '<td class="acc-td">' + proActBtns + '</td>' +
      '</tr>';
  }).join('') : emptyRow(7);
}

/* ── Proforma number generator ──────────────────────────── */
function nextProformaNumber() {
  var year = new Date().getFullYear();
  var key  = 'pro_seq_' + year;
  var seq  = parseInt(localStorage.getItem(key) || '0') + 1;
  localStorage.setItem(key, seq);
  return 'PRO-' + year + '-' + String(seq).padStart(4, '0');
}

/* ── Fill customer fields from vendor dropdown ──────────── */
function fillProFromVendor(jsonStr) {
  if (!jsonStr) return;
  try {
    var v = JSON.parse(jsonStr);
    document.getElementById('pro-c-name').value  = v.name    || '';
    document.getElementById('pro-c-gstin').value = v.gst     || '';
    document.getElementById('pro-c-addr').value  = v.address || '';
    document.getElementById('pro-c-state').value = v.state   || '';
    document.getElementById('pro-c-code').value  = v.stateCode || '';
    recalcProforma();
  } catch(e) {}
}

