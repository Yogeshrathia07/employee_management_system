var gstEditingId = null;
var gstItemCount = 0;

/* ── Populate vendor dropdown from localStorage vendors ─── */
function populateVendorDropdown(selectedName) {
  var sel = document.getElementById('gst-vendor-sel');
  if (!sel) return;
  var vendors = load('ven');
  sel.innerHTML = '<option value="">— Type manually or pick a vendor —</option>';
  vendors.forEach(function(v) {
    if (v.status === 'Inactive') return;
    var opt = document.createElement('option');
    opt.value = JSON.stringify(v);
    opt.textContent = v.name + (v.gst ? '  |  GST: ' + v.gst : '');
    if (selectedName && v.name === selectedName) opt.selected = true;
    sel.appendChild(opt);
  });
}

function populateCompanyDropdown(selectedName, autoFill) {
  var sel = document.getElementById('gst-company-sel');
  if (!sel) return;
  autoFill = autoFill !== false;
  api('GET', '/companies').then(function(companies) {
    sel.innerHTML = '<option value="">— Type manually or select a company —</option>';
    var activeCompanies = [];
    companies.forEach(function(c) {
      if (c.status === 'inactive') return;
      activeCompanies.push(c);
      var opt = document.createElement('option');
      opt.value = JSON.stringify(c);
      opt.textContent = c.name + (c.gstNo ? '  |  GST: ' + c.gstNo : '');
      if (selectedName && c.name === selectedName) opt.selected = true;
      sel.appendChild(opt);
    });
    if (selectedName && autoFill) {
      var match = activeCompanies.find(function(c) { return c.name === selectedName; });
      if (match) fillFromCompany(JSON.stringify(match));
    } else if (!selectedName && autoFill && activeCompanies.length) {
      sel.value = JSON.stringify(activeCompanies[0]);
      fillFromCompany(sel.value);
    }
  }).catch(function() {});
}

function fillFromCompany(jsonStr) {
  if (!jsonStr) return;
  var c;
  try { c = JSON.parse(jsonStr); } catch(e) { return; }
  document.getElementById('gst-s-name').value  = c.name    || '';
  document.getElementById('gst-s-gstin').value = (c.gstNo  || '').toUpperCase();
  document.getElementById('gst-s-addr').value  = c.address || '';
  setAccountStateValue('gst-s-state', 'gst-s-code', c.state, c.stateCode || accountStateCodeFromGstin(c.gstNo));
  document.getElementById('gst-s-pan').value   = (c.panNo  || '').toUpperCase();
  document.getElementById('gst-s-phone').value = c.phone   || '';
  document.getElementById('gst-s-email').value = c.email   || '';
  // Auto-fill bank details from company
  document.getElementById('gst-bank-name').value   = c.bankName    || '';
  document.getElementById('gst-bank-acname').value = c.bankAcName  || '';
  document.getElementById('gst-bank-ac').value     = c.bankAccount || '';
  document.getElementById('gst-bank-ifsc').value   = (c.bankIfsc   || '').toUpperCase();
  document.getElementById('gst-bank-branch').value = c.bankBranch  || '';
  recalcGST();
}

function populatePOVendorDropdown(selectedName) {
  var sel = document.getElementById('po-vendor');
  if (!sel) return;
  var vendors = load('ven').filter(function(v) { return v.status !== 'Inactive'; });
  sel.innerHTML = '<option value="">Select vendor</option>' + vendors.map(function(v) {
    var label = v.name + (v.gst ? ' | GST: ' + v.gst : '');
    return '<option value="' + escape(v.name || '') + '">' + escape(label) + '</option>';
  }).join('');
  if (selectedName) {
    var safeSelectedName = escape(selectedName);
    if (!Array.from(sel.options).some(function(opt) { return opt.value === safeSelectedName; })) {
      var opt = document.createElement('option');
      opt.value = safeSelectedName;
      opt.textContent = selectedName;
      sel.appendChild(opt);
    }
    sel.value = safeSelectedName;
  }
}

