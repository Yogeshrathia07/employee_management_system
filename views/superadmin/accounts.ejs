/* ── Add proforma item row ──────────────────────────────── */
function addProformaItem(it) {
  proItemCount++;
  var idx = proItemCount;
  it = it || { itemCode:'', name:'', hsnCode:'', quantity:1, unit:'', unitPrice:0, discount:0, taxRate:18 };
  var code = htmlEscape(it.itemCode || '');
  var name = htmlEscape(it.name || '');
  var hsn = htmlEscape(it.hsnCode || '');
  var unit = htmlEscape(it.unit || '');
  var row = document.createElement('tr');
  row.id = 'pro-row-' + idx;
  row.innerHTML =
    '<td class="gst-item-num">' + idx + '</td>' +
    '<td><input type="text"   class="pi-code"  value="' + code + '" placeholder="Code"></td>' +
    '<td><input type="text"   class="pi-name"  value="' + name + '" placeholder="Item description" oninput="recalcProforma()"></td>' +
    '<td><input type="text"   class="pi-hsn"   value="' + hsn + '" placeholder="HSN/SAC"></td>' +
    '<td><input type="number" class="pi-qty"   value="' + (it.quantity||1)  + '" min="0" step="0.01" oninput="recalcProforma()"></td>' +
    '<td><input type="text"   class="pi-unit"  value="' + unit + '" placeholder="Nos/Kg/Hr"></td>' +
    '<td><input type="number" class="pi-price" value="' + (it.unitPrice||0) + '" min="0" step="0.01" oninput="recalcProforma()"></td>' +
    '<td><input type="number" class="pi-disc"  value="' + (it.discount||0)  + '" min="0" max="100" step="0.01" oninput="recalcProforma()"></td>' +
    '<td><input type="number" class="pi-tax" value="' + (it.taxRate||18) + '" min="0" max="100" step="0.01" oninput="recalcProforma()" style="text-align:center;" onwheel="this.blur()"></td>' +
    '<td style="text-align:right;vertical-align:middle;font-weight:600;font-size:13px;white-space:nowrap;padding-right:12px;" id="pi-amt-' + idx + '">₹0.00</td>' +
    '<td style="text-align:center;vertical-align:middle;"><button type="button" class="btn btn-danger btn-sm" style="padding:3px 7px;display:inline-flex;align-items:center;justify-content:center;" onclick="removeProformaItem(\'pro-row-'+idx+'\')"><i class="bx bx-x"></i></button></td>';
  document.getElementById('pro-items-body').appendChild(row);
  recalcProforma();
}

function removeProformaItem(rowId) {
  var el = document.getElementById(rowId);
  if (el) el.remove();
  recalcProforma();
}

/* ── Recalculate proforma totals ────────────────────────── */
function recalcProforma() {
  var selCode = (document.getElementById('pro-s-code').value || '').trim();
  var cusCode = (document.getElementById('pro-c-code').value || '').trim();
  var useIGST = selCode && cusCode && selCode !== cusCode;

  document.getElementById('pro-tax-hint').textContent = useIGST
    ? 'IGST applied (inter-state).' : 'CGST + SGST applied (intra-state).';
  document.getElementById('pro-row-cgst').style.display = useIGST ? 'none' : '';
  document.getElementById('pro-row-sgst').style.display = useIGST ? 'none' : '';
  document.getElementById('pro-row-igst').style.display = useIGST ? '' : 'none';

  var rows = document.getElementById('pro-items-body').querySelectorAll('tr');
  var subtotal=0, totalCgst=0, totalSgst=0, totalIgst=0;

  rows.forEach(function(row, i) {
    var qty   = parseFloat(row.querySelector('.pi-qty').value)   || 0;
    var price = parseFloat(row.querySelector('.pi-price').value) || 0;
    var disc  = Math.min(100, Math.max(0, parseFloat(row.querySelector('.pi-disc').value) || 0));
    var tax   = Math.min(100, Math.max(0, parseFloat(row.querySelector('.pi-tax').value) || 0));
    row.querySelector('.pi-disc').value = disc;
    row.querySelector('.pi-tax').value = tax;
    var taxable = qty * price * (1 - disc / 100);
    var gstAmt  = taxable * tax / 100;
    subtotal += taxable;
    if (useIGST) { totalIgst += gstAmt; }
    else         { totalCgst += gstAmt/2; totalSgst += gstAmt/2; }
    var lineTotal = taxable + gstAmt;
    var amtEl = document.getElementById('pi-amt-' + (i+1));
    if (amtEl) amtEl.textContent = '₹' + lineTotal.toFixed(2);
  });

  var gross    = subtotal + totalCgst + totalSgst + totalIgst;
  var roundOff = parseFloat((Math.round(gross) - gross).toFixed(2));
  var total    = gross + roundOff;

  document.getElementById('pro-sub').textContent      = '₹' + subtotal.toFixed(2);
  document.getElementById('pro-cgst-val').textContent = '₹' + totalCgst.toFixed(2);
  document.getElementById('pro-sgst-val').textContent = '₹' + totalSgst.toFixed(2);
  document.getElementById('pro-igst-val').textContent = '₹' + totalIgst.toFixed(2);
  document.getElementById('pro-tax-total').textContent= '₹' + (totalCgst+totalSgst+totalIgst).toFixed(2);
  document.getElementById('pro-roundoff').textContent = '₹' + roundOff.toFixed(2);
  document.getElementById('pro-total-amt').textContent= '₹' + total.toFixed(2);
}

/* ── Collect proforma items ─────────────────────────────── */
function collectProformaItems() {
  var selCode = (document.getElementById('pro-s-code').value || '').trim();
  var cusCode = (document.getElementById('pro-c-code').value || '').trim();
  var useIGST = selCode && cusCode && selCode !== cusCode;

  var rows = document.getElementById('pro-items-body').querySelectorAll('tr');
  var items = [];
  rows.forEach(function(row) {
    var qty   = parseFloat(row.querySelector('.pi-qty').value)   || 0;
    var price = parseFloat(row.querySelector('.pi-price').value) || 0;
    var disc  = Math.min(100, Math.max(0, parseFloat(row.querySelector('.pi-disc').value) || 0));
    var tax   = Math.min(100, Math.max(0, parseFloat(row.querySelector('.pi-tax').value) || 0));
    var taxable = qty * price * (1 - disc / 100);
    var gstAmt  = taxable * tax / 100;
    items.push({
      itemCode: row.querySelector('.pi-code').value,
      name:     row.querySelector('.pi-name').value,
      hsnCode:  row.querySelector('.pi-hsn').value,
      quantity: qty, unit: row.querySelector('.pi-unit').value,
      unitPrice: price, discount: disc, taxRate: tax,
      taxableAmount: parseFloat(taxable.toFixed(2)),
      cgst: useIGST ? 0 : parseFloat((gstAmt/2).toFixed(2)),
      sgst: useIGST ? 0 : parseFloat((gstAmt/2).toFixed(2)),
      igst: useIGST ? parseFloat(gstAmt.toFixed(2)) : 0,
      itemTotal: parseFloat((taxable + gstAmt).toFixed(2)),
    });
  });
  return items;
}

/* ── Save proforma to localStorage ─────────────────────── */
function saveProforma(forceStatus) {
  syncAllAccountStateCodes();
  if (!document.getElementById('pro-c-name').value.trim()) return toast('Customer name is required', 'error');
  if (!document.getElementById('pro-date').value)          return toast('Date is required', 'error');

  var selCode = (document.getElementById('pro-s-code').value || '').trim();
  var cusCode = (document.getElementById('pro-c-code').value || '').trim();
  var useIGST = selCode && cusCode && selCode !== cusCode;
  var items   = collectProformaItems();

  var subtotal=0, totalCgst=0, totalSgst=0, totalIgst=0;
  items.forEach(function(it) {
    subtotal += it.taxableAmount;
    if (useIGST) totalIgst += it.igst;
    else { totalCgst += it.cgst; totalSgst += it.sgst; }
  });
  var gross    = subtotal + totalCgst + totalSgst + totalIgst;
  var roundOff = parseFloat((Math.round(gross) - gross).toFixed(2));

  var payTerms = document.getElementById('pro-pay-terms').value;
  var payTermsCustom = document.getElementById('pro-pay-terms-custom').value;

  var rec = {
    id:               proEditingId || nextProformaNumber(),
    date:             document.getElementById('pro-date').value,
    validityDate:     document.getElementById('pro-validity').value,
    placeOfSupply:    document.getElementById('pro-supply').value,
    status:           forceStatus || document.getElementById('pro-status-field').value,
    sellerName:       document.getElementById('pro-s-name').value,
    sellerGstin:      document.getElementById('pro-s-gstin').value.toUpperCase(),
    sellerAddress:    document.getElementById('pro-s-addr').value,
    sellerState:      document.getElementById('pro-s-state').value,
    sellerStateCode:  document.getElementById('pro-s-code').value,
    sellerPhone:      document.getElementById('pro-s-phone').value,
    sellerEmail:      document.getElementById('pro-s-email').value,
    sellerPan:        document.getElementById('pro-s-pan').value.toUpperCase(),
    customerName:     document.getElementById('pro-c-name').value,
    customerGstin:    document.getElementById('pro-c-gstin').value.toUpperCase(),
    customerAddress:  document.getElementById('pro-c-addr').value,
    customerState:    document.getElementById('pro-c-state').value,
    customerStateCode:document.getElementById('pro-c-code').value,
    customerPan:      document.getElementById('pro-c-pan').value.toUpperCase(),
    customerEmail:    document.getElementById('pro-c-email').value,
    billMonth:        monthFromInput(document.getElementById('pro-bill-month').value),
    billPeriodFrom:   document.getElementById('pro-bill-from').value,
    billPeriodTo:     document.getElementById('pro-bill-to').value,
    workOrder:        document.getElementById('pro-work-order').value,
    projectName:      document.getElementById('pro-project').value,
    workDetails:      document.getElementById('pro-work-details').value,
    bankName:         document.getElementById('pro-bank-name').value,
    bankAcName:       document.getElementById('pro-bank-acname').value,
    bankAccount:      document.getElementById('pro-bank-ac').value,
    bankIfsc:         document.getElementById('pro-bank-ifsc').value.toUpperCase(),
    bankBranch:       document.getElementById('pro-bank-branch').value,
    paymentTerms:     payTermsCustom || payTerms,
    paymentTermsCustom: payTermsCustom,
    deliveryTimeline: document.getElementById('pro-delivery').value,
    warranty:         document.getElementById('pro-warranty').value,
    notes:            document.getElementById('pro-notes').value,
    termsConditions:  document.getElementById('pro-terms').value,
    items:            items,
    subtotal:         parseFloat(subtotal.toFixed(2)),
    totalCgst:        parseFloat(totalCgst.toFixed(2)),
    totalSgst:        parseFloat(totalSgst.toFixed(2)),
    totalIgst:        parseFloat(totalIgst.toFixed(2)),
    totalTax:         parseFloat((totalCgst+totalSgst+totalIgst).toFixed(2)),
    roundOff:         roundOff,
    totalAmount:      parseFloat((gross + roundOff).toFixed(2)),
    showTaxInPdf:     !!(document.getElementById('pro-show-tax-pdf') && document.getElementById('pro-show-tax-pdf').checked),
  };

  var all = load('pro');
  if (proEditingId) {
    var idx = all.findIndex(function(r) { return r.id === proEditingId; });
    if (idx > -1) all[idx] = rec; else all.push(rec);
  } else {
    all.push(rec);
  }
  save('pro', all);
  closeModal('pro-inv-modal');
  renderProforma();
  toast('Proforma ' + (proEditingId ? 'updated' : 'saved') + '!', 'success');
  proEditingId = null;
}

