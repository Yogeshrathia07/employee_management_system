<!-- ═══════════════════════ MARK PAID MODAL ════════════════════════════════ -->
<div class="modal-overlay" id="mark-paid-modal">
  <div class="modal" style="max-width:400px;">
    <div class="modal-header"><span class="modal-title"><i class="bx bx-check-circle" style="color:#22c55e"></i> Mark as Paid</span><button class="modal-close" onclick="closeModal('mark-paid-modal')">×</button></div>
    <div class="modal-body">
      <input type="hidden" id="mark-paid-id">
