}

function exportReportExcel() {
  if (!repFiltered || !repFiltered.length) { toast('No data to export', 'error'); return; }
  if (typeof XLSX === 'undefined')          { toast('Excel library not loaded yet — try again in a moment', 'error'); return; }
  var sec = document.getElementById('rep-section').value;
  var cfg = REP_CONFIG[sec];

  var headers = cfg.columns.map(function(c){ return c.h; });
  var rows    = repFiltered.map(function(r){ return cfg.columns.map(function(c){ return c.v(r); }); });

  var ws = XLSX.utils.aoa_to_sheet([headers].concat(rows));

  // Style header row bold + auto column widths
  ws['!cols'] = headers.map(function(h, i) {
    var max = h.length;
    rows.forEach(function(row){ var v = String(row[i]||''); if (v.length > max) max = v.length; });
    return { wch: Math.min(max + 2, 42) };
  });

  // Freeze top row
  ws['!freeze'] = { xSplit: 0, ySplit: 1 };

  var wb   = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, cfg.label.substring(0,31));

  var today = new Date().toISOString().slice(0,10);
  var fname = cfg.label.replace(/\s+/g, '-') + '-' + today + '.xlsx';
  XLSX.writeFile(wb, fname);
  toast('Exported ' + repFiltered.length + ' records \u2192 ' + fname, 'success');
}

/* ── generic print helper ────────────────────────────────── */
function printAccountRecord(apiPath, title, fields) {
  api('GET', apiPath).then(function(r) {
    var rows = fields.map(function(f) {
      var val = r[f.key];
      if (val === null || val === undefined || val === '') return '';
      if (typeof val === 'number') val = f.money ? fmtAmt(val) : val;
      return '<tr><th>'+f.label+'</th><td>'+val+'</td></tr>';
    }).filter(Boolean).join('');
    var html = '<!DOCTYPE html><html><head><title>'+title+'</title>'+
      '<style>*{box-sizing:border-box}body{font-family:Arial,sans-serif;font-size:13px;padding:32px;color:#1a1a1a;margin:0}'+
      'h2{font-size:18px;margin:0 0 4px;color:#111}p.sub{margin:0 0 20px;font-size:12px;color:#666}'+
      'table{width:100%;border-collapse:collapse}th,td{padding:9px 14px;border:1px solid #d1d5db;text-align:left;vertical-align:top}'+
      'th{background:#f8fafc;width:36%;font-weight:600;color:#374151;white-space:nowrap}'+
      '.btn{margin-top:20px;padding:8px 22px;background:#1d4ed8;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:13px}'+
      '@media print{.btn{display:none}}</style></head>'+
      '<body><h2>'+title+'</h2><p class="sub">Generated on '+new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})+'</p>'+
      '<table>'+rows+'</table>'+
      '<button class="btn" onclick="window.print()">Print</button>'+
      '</body></html>';
    var w = window.open('', '_blank', 'width=680,height=640');
    if (w) { w.document.write(html); w.document.close(); }
  }).catch(function(e){ toast(e.message||'Error loading record','error'); });
}

