function populateVendorDropdown(selectedName) {
  var sel = document.getElementById('gst-vendor-sel');
  if (!sel) return;
  var customers = getKnownCustomers();
  var selectedClean = cleanAccountText(selectedName || '');
  if (!selectedClean && sel.value) {
    try { selectedClean = cleanAccountText(JSON.parse(sel.value).name || ''); } catch(e) {}
  }
  sel.innerHTML = '<option value="">— Type manually or pick an existing customer —</option>';
  customers.forEach(function(customer) {
    var opt = document.createElement('option');
    opt.value = JSON.stringify(customer);
    opt.textContent = customer.name + (customer.gst ? ' | GST: ' + customer.gst : '');
    if (selectedClean && cleanAccountText(customer.name) === selectedClean) opt.selected = true;
    sel.appendChild(opt);
  });
}

