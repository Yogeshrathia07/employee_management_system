        '<td style="padding:11px 12px;text-align:right;font-size:14px;font-weight:800;color:'+(m.hours?'var(--text-primary)':'var(--text-muted)')+';">'+(m.hours?m.hours+'<span style="font-size:11px;font-weight:400;">h</span>':'—')+'</td>'+
        '<td style="padding:11px 12px;text-align:right;font-size:13px;font-weight:700;color:#22c55e;">'+(m.approvedH?m.approvedH+'<span style="font-size:11px;font-weight:400;">h</span>':'—')+'</td>'+
