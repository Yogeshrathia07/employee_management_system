            (canEdit?'<button class="btn btn-ghost btn-sm" onclick="openEditTs('+ts.id+')"><i class="bx bx-edit"></i></button>':'') +
            (ts.status==='pending'?'<button class="btn btn-danger btn-sm" onclick="delTs('+ts.id+')"><i class="bx bx-trash"></i></button>':'') +
          '</div>' +
        '</div></div>';
    });
    html2 += '</div>';
    grid.innerHTML = html2;

  } else {
    // Year view — row-wise table (same as employee)
    var yr3 = ownNavDate.getFullYear();
    if (label) label.textContent = String(yr3);
    var yearSheets3 = allOwnTs.filter(function(ts){ return new Date(ts.weekStart).getFullYear()===yr3; });
    var totalYH = yearSheets3.reduce(function(s,t){return s+(t.totalHours||0);},0);
    var totalAH = yearSheets3.filter(function(t){return t.status==='approved';}).reduce(function(s,t){return s+(t.totalHours||0);},0);
    var mData = MO_F.map(function(name,mi){
      var ms=yearSheets3.filter(function(ts){return new Date(ts.weekStart).getMonth()===mi;});
      return {name:name,mi:mi,sheets:ms.length,hours:ms.reduce(function(s,t){return s+(t.totalHours||0);},0),approvedH:ms.filter(function(t){return t.status==='approved';}).reduce(function(s,t){return s+(t.totalHours||0);},0),pending:ms.filter(function(t){return t.status==='pending';}).length,rejected:ms.filter(function(t){return t.status==='rejected';}).length};
    });
    var now3=new Date();
    var html3='<div style="background:linear-gradient(135deg,var(--accent),#7c3aed);border-radius:var(--radius);padding:16px 20px;display:flex;align-items:center;gap:32px;flex-wrap:wrap;margin-bottom:16px;">'+
      '<div style="color:white;"><div style="font-size:26px;font-weight:800;line-height:1;">'+totalYH+'h</div><div style="font-size:11px;opacity:.75;margin-top:2px;">Total in '+yr3+'</div></div>'+
      '<div style="color:white;"><div style="font-size:26px;font-weight:800;line-height:1;">'+totalAH+'h</div><div style="font-size:11px;opacity:.75;margin-top:2px;">Approved</div></div>'+
      '<div style="color:white;"><div style="font-size:26px;font-weight:800;line-height:1;">'+yearSheets3.length+'</div><div style="font-size:11px;opacity:.75;margin-top:2px;">Timesheets</div></div>'+
      '</div>'+
      '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">'+
      '<table style="width:100%;border-collapse:collapse;table-layout:fixed;">'+
      '<colgroup><col style="width:110px"><col><col><col style="width:60px"><col style="width:70px"><col style="width:70px"><col style="width:80px"></colgroup>'+
      '<thead><tr style="background:var(--bg-input);border-bottom:1px solid var(--border);">'+
        '<th style="padding:10px 12px;text-align:left;font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;">Month</th>'+
        '<th style="padding:10px 12px;text-align:right;font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;">Hours</th>'+
        '<th style="padding:10px 12px;text-align:right;font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;">Approved</th>'+
