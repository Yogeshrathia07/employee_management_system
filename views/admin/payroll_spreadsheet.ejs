<%- include('../partials/head', {title: title || 'Payroll'}) %>
<link rel="stylesheet" href="/css/spreadsheet.css">

<div class="app-layout ss-page">
  <% if (pageRole === 'superadmin') { %>
    <%- include('../partials/sidebar-superadmin') %>
  <% } else { %>
    <%- include('../partials/sidebar-admin') %>
  <% } %>
  <div class="main-content">

    <header class="page-header print-hide">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title"><%= pageRole === 'superadmin' ? 'All Payroll' : 'Payroll' %></div>
          <div class="page-subtitle">Payroll database · consolidation · salary slips</div>
        </div>
      </div>
      <div class="header-actions"></div>
    </header>

    <div class="page-body">
      <div id="payroll-app">

        <!-- ═══ Tab Bar ═══ -->
        <div class="payroll-tab-bar print-hide">
          <button class="tab-btn active" data-tab="database"      onclick="payroll.goToTab('database')">
            <i class="bx bx-data"></i> Payroll Records
          </button>
          <button class="tab-btn"        data-tab="consolidation" onclick="payroll.goToTab('consolidation')">
            <i class="bx bx-table"></i> Summary
          </button>
          <button class="tab-btn"        data-tab="salary-slip"   onclick="payroll.goToTab('salary-slip')">
            <i class="bx bx-receipt"></i> Payslips
          </button>
        </div>

        <!-- ══════════════════════════════════════════
             TAB 1 — DATABASE
        ══════════════════════════════════════════ -->
        <div id="tab-database" class="tab-content active">

          <!-- Toolbar -->
          <div class="payroll-toolbar print-hide">
            <button class="payroll-btn btn-success" onclick="payroll._saveNow()">
              <i class="bx bx-save"></i> Save
            </button>
            <button class="payroll-btn btn-primary" onclick="payroll.openAddModal()">
              <i class="bx bx-user-plus"></i> Add Employee
            </button>
            <% if (pageRole === 'superadmin') { %>
              <select id="payroll-company-filter" class="filter-input" style="min-width:220px;" onchange="payroll.setCompany(this.value)">
                <option value="">Select company</option>
              </select>
            <% } %>
            <select id="generate-month" class="filter-input" style="min-width:130px;">
              <option value="1">January</option><option value="2">February</option><option value="3">March</option>
              <option value="4">April</option><option value="5">May</option><option value="6">June</option>
              <option value="7">July</option><option value="8">August</option><option value="9">September</option>
              <option value="10">October</option><option value="11">November</option><option value="12">December</option>
            </select>
            <input id="generate-year" class="filter-input" type="number" style="width:96px;" placeholder="Year">
            <button class="payroll-btn btn-primary" onclick="payroll.generateAll()">
              <i class="bx bxs-magic-wand"></i> Generate All
            </button>
            <span style="flex:1"></span>
            <span id="save-status" class="save-status status-saved">✓ Saved</span>
          </div>

          <!-- Filter bar -->
          <div class="db-filter-bar print-hide">
            <span class="db-filter-label">Filter:</span>
            <div class="db-month-pills" id="db-month-pills">
              <button class="db-pill active" data-month="" onclick="payroll.setDbMonth('')">All</button>
              <button class="db-pill" data-month="january"   onclick="payroll.setDbMonth('january')">Jan</button>
              <button class="db-pill" data-month="february"  onclick="payroll.setDbMonth('february')">Feb</button>
              <button class="db-pill" data-month="march"     onclick="payroll.setDbMonth('march')">Mar</button>
              <button class="db-pill" data-month="april"     onclick="payroll.setDbMonth('april')">Apr</button>
              <button class="db-pill" data-month="may"       onclick="payroll.setDbMonth('may')">May</button>
              <button class="db-pill" data-month="june"      onclick="payroll.setDbMonth('june')">Jun</button>
              <button class="db-pill" data-month="july"      onclick="payroll.setDbMonth('july')">Jul</button>
              <button class="db-pill" data-month="august"    onclick="payroll.setDbMonth('august')">Aug</button>
              <button class="db-pill" data-month="september" onclick="payroll.setDbMonth('september')">Sep</button>
              <button class="db-pill" data-month="october"   onclick="payroll.setDbMonth('october')">Oct</button>
              <button class="db-pill" data-month="november"  onclick="payroll.setDbMonth('november')">Nov</button>
              <button class="db-pill" data-month="december"  onclick="payroll.setDbMonth('december')">Dec</button>
            </div>
            <select id="db-year-filter" class="db-year-sel" onchange="payroll.setDbYear(this.value)">
              <option value="">All Years</option>
            </select>
            <div class="status-check-group" id="db-status-filter">
              <label class="status-check-item">
                <input type="checkbox" value="draft" onchange="payroll.setDbStatus()">
                <span>Draft</span>
              </label>
              <label class="status-check-item">
                <input type="checkbox" value="finalized" onchange="payroll.setDbStatus()">
                <span>Frozen</span>
              </label>
              <label class="status-check-item">
                <input type="checkbox" value="paid" onchange="payroll.setDbStatus()">
                <span>Paid</span>
              </label>
            </div>
            <button class="db-filter-clear" onclick="payroll.clearDbFilter()">✕ Clear</button>
            <span class="db-filter-count" id="db-filter-count"></span>
          </div>

          <!-- Scrollable database table -->
          <div class="db-wrapper">
            <table id="db-table">
              <colgroup>
                <col style="width:36px">   <!-- Sl -->
                <col style="width:42px">   <!-- Delete -->
                <col style="width:36px">   <!-- Edit -->
                <col style="width:130px">  <!-- Name -->
                <col style="width:110px">  <!-- Designation -->
                <col style="width:80px">   <!-- Month -->
                <col style="width:62px">   <!-- Year -->
                <col style="width:86px">   <!-- Status -->
                <col style="width:68px">   <!-- Total Days -->
                <col style="width:72px">   <!-- Allowed Leave -->
                <col style="width:72px">   <!-- Leave Taken -->
                <col style="width:72px">   <!-- Worked Days -->
                <col style="width:112px">  <!-- CTC -->
                <col style="width:78px">   <!-- Basic -->
                <col style="width:70px">   <!-- DA -->
                <col style="width:74px">   <!-- HRA -->
                <col style="width:92px">   <!-- Conveyance -->
                <col style="width:96px">   <!-- Conv Working -->
                <col style="width:96px">   <!-- Medical Exp -->
                <col style="width:82px">   <!-- Special -->
                <col style="width:76px">   <!-- Bonus -->
                <col style="width:68px">   <!-- TA -->
                <col style="width:96px">   <!-- Total Gross -->
                <col style="width:88px">   <!-- PF Contrib -->
                <col style="width:84px">   <!-- Prof Tax -->
                <col style="width:65px">   <!-- TDS -->
                <col style="width:92px">   <!-- Salary Adv -->
                <col style="width:110px">  <!-- Deduction (₹) -->
                <col style="width:100px">  <!-- Absent Ded (auto) -->
                <col style="width:96px">   <!-- Total Ded -->
                <col style="width:88px">   <!-- Net Payable -->
                <col style="width:75px">   <!-- Gender -->
                <col style="width:62px">   <!-- Prefix -->
                <col style="width:118px">  <!-- Auth Sign -->
                <col style="width:90px">   <!-- PF Applicable -->
                <col style="width:92px">   <!-- Med Bill Sub -->
                <col style="width:92px">   <!-- Med Bill Amt -->
                <col style="width:128px">  <!-- Company Name -->
              </colgroup>
              <thead>
                <tr>
                  <th rowspan="2" class="col-sl">Sl</th>
                  <th rowspan="2" class="col-del-hdr"><i class="bx bx-trash" style="font-size:14px;"></i></th>
                  <th rowspan="2" class="col-edit-hdr"><i class="bx bx-edit" style="font-size:14px;"></i></th>
                  <th colspan="10" style="background:#1e3a8a;">Employee Details &amp; Attendance</th>
                  <th colspan="10" class="h-gross">TOTAL GROSS SALARY</th>
                  <th colspan="6"  class="h-ded">TOTAL DEDUCTIONS</th>
                  <th rowspan="2" style="background:#4c1d95;color:#fff;min-width:72px;">NET<br>PAYABLE</th>
                  <th colspan="7"  class="h-extra">Additional Details</th>
                </tr>
                <tr>
                  <!-- Employee details -->
                  <th class="col-name">Name</th>
                  <th class="col-desig">Designation</th>
                  <th>Month</th>
                  <th>Year</th>
                  <th>Status</th>
                  <th>Total Days</th>
                  <th>Allowed Leave</th>
                  <th>Leave Taken</th>
                  <th style="background:#166534;color:#fff;">Worked Days</th>
                  <th>CTC</th>
                  <!-- Gross -->
                  <th class="h-gross">Basic</th>
                  <th class="h-gross">DA</th>
                  <th class="h-gross">HRA</th>
                  <th class="h-gross">Conveyance</th>
                  <th class="h-gross" style="background:#166534;">Conv. Working</th>
                  <th class="h-gross">Medical Exp.</th>
                  <th class="h-gross">Special</th>
                  <th class="h-gross">Bonus</th>
                  <th class="h-gross">TA</th>
                  <th class="h-gross" style="background:#14532d;">TOTAL GROSS</th>
                  <!-- Deductions -->
                  <th class="h-ded">PF Contrib.</th>
                  <th class="h-ded">Prof. Tax</th>
                  <th class="h-ded">TDS</th>
                  <th class="h-ded">Salary Adv.</th>
                  <th class="h-ded">Deduction (₹)</th>
                  <th class="h-ded">Absent Ded.</th>
                  <th class="h-ded" style="background:#7f1d1d;">TOTAL DED.</th>
                  <!-- Extra -->
                  <th class="h-extra">Gender</th>
                  <th class="h-extra">Prefix</th>
                  <th class="h-extra">Auth. Signatory</th>
                  <th class="h-extra">PF Applicable</th>
                  <th class="h-extra">Med. Bill Sub.</th>
                  <th class="h-extra">Med. Bill Amt</th>
                  <th class="h-extra">Company Name</th>
                </tr>
              </thead>
              <tbody id="db-tbody">
                <!-- Rows injected by JS -->
              </tbody>
            </table>
          </div>

        </div><!-- /tab-database -->

        <!-- ══════════════════════════════════════════
             TAB 2 — CONSOLIDATION
        ══════════════════════════════════════════ -->
        <div id="tab-consolidation" class="tab-content">

          <!-- Toolbar -->
          <div class="payroll-toolbar print-hide">
            <button class="payroll-btn btn-success" onclick="payroll.printConsolidation()">
              <i class="bx bx-printer"></i> Print
            </button>
            <div class="cons-filter-bar" style="border:none;padding:0;background:transparent;">
              <span style="font-size:12px;font-weight:600;color:#374151;">Filter by:</span>
              <select id="cons-filter-month" class="filter-input" onchange="payroll.applyConsFilter()">
                <option value="">All Months</option>
                <option>January</option><option>February</option><option>March</option>
                <option>April</option><option>May</option><option>June</option>
                <option>July</option><option>August</option><option>September</option>
                <option>October</option><option>November</option><option>December</option>
              </select>
              <select id="cons-filter-year" class="filter-input" onchange="payroll.applyConsFilter()">
                <option value="">All Years</option>
                <option>2023</option><option>2024</option><option>2025</option>
                <option>2026</option><option>2027</option><option>2028</option>
                <option>2029</option><option>2030</option>
              </select>
              <div class="status-check-group" id="cons-filter-status">
                <label class="status-check-item">
                  <input type="checkbox" value="draft" onchange="payroll.applyConsFilter()">
                  <span>Draft</span>
                </label>
                <label class="status-check-item">
                  <input type="checkbox" value="finalized" onchange="payroll.applyConsFilter()">
                  <span>Frozen</span>
                </label>
                <label class="status-check-item">
                  <input type="checkbox" value="paid" onchange="payroll.applyConsFilter()">
                  <span>Paid</span>
                </label>
              </div>
              <button class="payroll-btn" onclick="document.getElementById('cons-filter-month').value='';document.getElementById('cons-filter-year').value='';document.querySelectorAll('#cons-filter-status input[type=&quot;checkbox&quot;]').forEach(cb => cb.checked = false);payroll.applyConsFilter()">
                Clear
              </button>
            </div>
          </div>

          <!-- Consolidation content area -->
          <div class="cons-wrapper">
            <div class="cons-title" id="cons-header-title">
              Consolidated Salary Sheet
            </div>
            <div id="consolidation-body">
              <div style="text-align:center;color:#9ca3af;padding:40px;">
                Click the <strong>Consolidation</strong> tab to generate the summary.
              </div>
            </div>
          </div>

        </div><!-- /tab-consolidation -->

        <!-- ══════════════════════════════════════════
             TAB 3 — SALARY SLIP
        ══════════════════════════════════════════ -->
        <div id="tab-salary-slip" class="tab-content">

          <!-- Toolbar -->
          <div class="slip-toolbar print-hide">
            <button class="payroll-btn btn-primary" onclick="payroll.printSlip()">
              <i class="bx bx-printer"></i> Print
            </button>
            <div class="cons-filter-bar" style="border:none;padding:0;background:transparent;">
              <span style="font-size:12px;font-weight:600;color:#374151;">Filter:</span>
              <select id="slip-filter-month" class="filter-input" onchange="payroll._applySlipFilter()">
                <option value="">All Months</option>
                <option>January</option><option>February</option><option>March</option>
                <option>April</option><option>May</option><option>June</option>
                <option>July</option><option>August</option><option>September</option>
                <option>October</option><option>November</option><option>December</option>
              </select>
              <select id="slip-filter-year" class="filter-input" onchange="payroll._applySlipFilter()">
                <option value="">All Years</option>
                <option>2023</option><option>2024</option><option>2025</option>
                <option>2026</option><option>2027</option><option>2028</option>
                <option>2029</option><option>2030</option>
              </select>
              <div class="status-check-group" id="slip-filter-status">
                <label class="status-check-item">
                  <input type="checkbox" value="draft" onchange="payroll._applySlipFilter()">
                  <span>Draft</span>
                </label>
                <label class="status-check-item">
                  <input type="checkbox" value="finalized" onchange="payroll._applySlipFilter()">
                  <span>Frozen</span>
                </label>
                <label class="status-check-item">
                  <input type="checkbox" value="paid" onchange="payroll._applySlipFilter()">
                  <span>Paid</span>
                </label>
              </div>
              <button class="payroll-btn" onclick="document.getElementById('slip-filter-month').value='';document.getElementById('slip-filter-year').value='';document.querySelectorAll('#slip-filter-status input[type=&quot;checkbox&quot;]').forEach(cb => cb.checked = false);payroll._applySlipFilter()">
                Clear
              </button>
            </div>
          </div>

          <!-- Slip display -->
          <div class="slip-body-wrapper slip-layout">
            <div class="slip-list-panel">
              <div class="slip-list-head">
                <div class="slip-list-title">Employee Payroll List</div>
                <div id="slip-emp-meta" class="slip-emp-meta"></div>
                <div class="slip-list-search">
                  <i class="bx bx-search"></i>
                  <input id="slip-list-search" type="text" placeholder="Search employee..."
                         oninput="payroll.filterSlipList(this.value)">
                </div>
              </div>
              <div id="slip-emp-list-view" class="slip-emp-list-view"></div>
            </div>
            <div class="slip-preview-panel">
              <div id="slip-display">
                <div class="slip-empty-msg">Select an employee from the list to view their payslip.</div>
              </div>
            </div>
          </div>

        </div><!-- /tab-salary-slip -->

      </div><!-- #payroll-app -->
    </div><!-- .page-body -->
  </div><!-- .main-content -->
</div><!-- .app-layout -->

<!-- ══════════════════════════════════════════
     ADD EMPLOYEE MODAL  (timesheet-style)
══════════════════════════════════════════ -->
<div id="add-emp-modal" class="ae-overlay">
  <div class="ae-modal">

    <!-- Top header -->
    <div class="ae-top">
      <span class="ae-top-title">Payroll Entry</span>
      <button class="ae-top-close" onclick="payroll.closeAddModal()" title="Close"><i class="bx bx-x"></i></button>
    </div>

    <!-- Period bar -->
    <div class="ae-period">
      <div>
        <div class="ae-period-label">PAYROLL FOR</div>
        <div class="ae-period-val">
          <select id="ae-month" class="ae-period-sel" onchange="payroll._aeMonthYearChange()">
            <option value="">— Month —</option>
            <option>January</option><option>February</option><option>March</option>
            <option>April</option><option>May</option><option>June</option>
            <option>July</option><option>August</option><option>September</option>
            <option>October</option><option>November</option><option>December</option>
          </select>
          <input type="number" id="ae-year" class="ae-period-yr" placeholder="Year"
                 onchange="payroll._aeMonthYearChange()">
          <label class="ae-weekend-toggle" title="Count Saturday as a working day">
            <input type="checkbox" id="ae-include-sat" onchange="payroll._aeMonthYearChange()">
            <span>Include Saturday</span>
          </label>
          <label class="ae-weekend-toggle" title="Count Sunday as a working day">
            <input type="checkbox" id="ae-include-sun" onchange="payroll._aeMonthYearChange()">
            <span>Include Sunday</span>
          </label>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="ae-filter-bar">
          <i class="bx bx-search" style="color:#9ca3af;font-size:16px;"></i>
          <input type="text" id="ae-filter-input" class="ae-filter-input"
                 placeholder="Filter employees…"
                 oninput="payroll._aeFilterEmployees(this.value)">
        </div>
        <button class="ae-add-entry" onclick="payroll._aeAddEntry()">
          <i class="bx bx-plus"></i> Add Entry
        </button>
      </div>
    </div>

    <!-- Info banner (shown when empty) -->
    <div id="ae-banner" class="ae-banner">
      <i class="bx bx-info-circle"></i>
      <span>No entries yet. Click <strong>+ Add Entry</strong> to start adding employees to this payroll.</span>
    </div>

    <!-- Entry table -->
    <div class="ae-table-wrap">
      <table class="ae-table">
        <thead>
          <tr>
            <th class="ae-col-emp">EMPLOYEE</th>
            <th class="ae-col-desig">DESIGNATION</th>
            <th class="ae-col-num">TOTAL<br>DAYS</th>
            <th class="ae-col-num">LEAVE<br>TAKEN</th>
            <th class="ae-col-num" style="background:#166534;color:#fff;">WORKED<br>DAYS</th>
            <th class="ae-col-num">PF</th>
            <th class="ae-col-num">PROF.<br>TAX</th>
            <th class="ae-col-num">SAL.<br>ADV.</th>
            <th class="ae-col-num">TDS</th>
            <th class="ae-col-num">DEDUCTION<br>(₹)</th>
            <th class="ae-col-num">CTC</th>
            <th class="ae-col-del"></th>
          </tr>
        </thead>
        <tbody id="ae-tbody"></tbody>
        <tfoot>
          <tr class="ae-totals-row" id="ae-totals-row" style="display:none;">
            <td colspan="2" style="font-weight:700;padding-left:10px;">Weekly Totals</td>
            <td id="ae-tot-days"  class="ae-num-cell">—</td>
            <td id="ae-tot-leave" class="ae-num-cell">0</td>
            <td id="ae-tot-wd"    class="ae-num-cell">—</td>
            <td id="ae-tot-pf"    class="ae-num-cell">0</td>
            <td id="ae-tot-pt"    class="ae-num-cell">0</td>
            <td id="ae-tot-adv"   class="ae-num-cell">0</td>
            <td id="ae-tot-tds"   class="ae-num-cell">0</td>
            <td id="ae-tot-ded"   class="ae-num-cell">0</td>
            <td id="ae-tot-ctc"   class="ae-num-cell">0</td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Notes -->
    <div class="ae-notes">
      <div class="ae-notes-label">Notes</div>
      <textarea id="ae-notes-txt" class="ae-notes-input" placeholder="Any notes for this payroll batch…"></textarea>
    </div>

    <!-- Stats bar -->
    <div class="ae-statsbar">
      <span class="ae-stat-pill" id="ae-stat-emp">0 employees</span>
      <span class="ae-stat-sep">|</span>
      <span class="ae-stat-pill" id="ae-stat-rows">0 row(s)</span>
      <span style="flex:1"></span>
      <span class="ae-stat-total" id="ae-stat-ctc"><span class="ae-rupee">&#8377;</span>0 total CTC</span>
    </div>

    <!-- Footer -->
    <div class="ae-footer">
      <button class="ae-btn-cancel" onclick="payroll.closeAddModal()">Cancel</button>
      <button class="ae-btn-submit" onclick="payroll.submitAddEmployee()">Add to Payroll</button>
    </div>

  </div>
</div>

<script src="/js/api.js"></script>
<script src="/js/sidebar-fix.js"></script>
<script src="/js/spreadsheet.js"></script>
<script>
  window.PAYROLL_PAGE_ROLE = '<%= pageRole || "admin" %>';
  document.addEventListener('DOMContentLoaded', () => payroll.init());
</script>
