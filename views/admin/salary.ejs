  <div class="modal" style="max-width:580px">
    <div class="modal-header"><span class="modal-title" id="edit-title">Edit Salary</span><button class="modal-close" onclick="closeModal('edit-modal')">×</button></div>
    <div class="modal-body" style="max-height:72vh;overflow-y:auto;padding-right:4px;">

      <!-- Attendance Summary (read-only, from stored salary data) -->
      <div id="e-attendance-panel" style="display:none;margin-bottom:14px;border:1px solid var(--border);border-radius:10px;overflow:hidden;">
        <div style="background:var(--bg-input);padding:8px 14px;display:flex;align-items:center;justify-content:space-between;">
          <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);">Attendance Summary</span>
          <span id="e-att-period" style="font-size:11px;color:var(--text-muted);"></span>
        </div>
        <div style="padding:10px 14px;">
          <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:8px;">
            <div style="background:var(--bg-input);border-radius:8px;padding:8px 6px;text-align:center;">
              <div style="font-size:16px;font-weight:800;color:var(--text-primary);" id="e-att-caldays">—</div>
              <div style="font-size:10px;color:var(--text-muted);margin-top:1px;">Cal. Days</div>
            </div>
            <div style="background:#dcfce7;border-radius:8px;padding:8px 6px;text-align:center;">
              <div style="font-size:16px;font-weight:800;color:#16a34a;" id="e-att-present">—</div>
              <div style="font-size:10px;color:#15803d;margin-top:1px;">Present</div>
            </div>
            <div style="background:#fee2e2;border-radius:8px;padding:8px 6px;text-align:center;">
              <div style="font-size:16px;font-weight:800;color:#dc2626;" id="e-att-absent">—</div>
              <div style="font-size:10px;color:#b91c1c;margin-top:1px;">Absent</div>
            </div>
            <div style="background:#fef3c7;border-radius:8px;padding:8px 6px;text-align:center;">
              <div style="font-size:16px;font-weight:800;color:#d97706;" id="e-att-leaves">—</div>
              <div style="font-size:10px;color:#b45309;margin-top:1px;">Leaves</div>
            </div>
            <div style="background:var(--bg-input);border-radius:8px;padding:8px 6px;text-align:center;">
              <div style="font-size:16px;font-weight:800;color:var(--text-primary);" id="e-att-hours">—</div>
              <div style="font-size:10px;color:var(--text-muted);margin-top:1px;">Hrs Worked</div>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
            <div style="background:var(--bg-input);border-radius:8px;padding:7px 10px;">
              <div style="font-size:10px;color:var(--text-muted);">Working Days</div>
              <div style="font-size:13px;font-weight:700;" id="e-att-workdays">—</div>
            </div>
            <div style="background:var(--bg-input);border-radius:8px;padding:7px 10px;">
              <div style="font-size:10px;color:var(--text-muted);">Employee</div>
              <div style="font-size:13px;font-weight:700;" id="e-att-emp">—</div>
            </div>
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Currency</label>
          <select id="e-currency" class="form-control"></select>
        </div>
        <div class="form-group">
          <label class="form-label">CTC (Monthly)</label>
          <input type="number" id="e-ctc" class="form-control" readonly style="background:var(--bg-input);cursor:not-allowed;color:var(--text-muted);">
          <div style="font-size:11px;color:var(--text-muted);margin-top:3px;">Auto from components</div>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Payroll Working Days</label>
