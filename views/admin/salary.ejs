function openEdit(id) {
  const s = allSalaries.find(x => x.id === id);
  if (!s) return;
  editSalId = id;
  document.getElementById('edit-title').textContent = 'Edit — ' + (s.user?.name||'') + ' — ' + MONTHS[s.month-1] + ' ' + s.year;
  document.getElementById('e-leave').value   = s.leaveTaken || 0;
  document.getElementById('e-basic').value   = s.basicSalary || 0;
  document.getElementById('e-hra').value     = s.hra || 0;
  document.getElementById('e-conv').value    = s.conveyance || 0;
  document.getElementById('e-med').value     = s.medicalExpenses || 0;
  document.getElementById('e-special').value = s.specialAllowance || 0;
  document.getElementById('e-bonus').value   = s.bonus || 0;
  document.getElementById('e-ta').value      = s.ta || 0;
  calcEditCTC();
  document.getElementById('e-pf').value      = s.pfContribution || 0;
  document.getElementById('e-ptax').value    = s.professionTax || 0;
  document.getElementById('e-tds').value     = s.tds || 0;
  document.getElementById('e-advance').value = s.salaryAdvance || 0;
  document.getElementById('e-status').value  = s.status;
  document.getElementById('e-notes').value   = s.notes || '';
  var defCurr = (getUser()&&getUser().company&&getUser().company.currency)||'INR';
  document.getElementById('e-currency').value = s.currency || defCurr;

  // Attendance summary panel
  const calDays = new Date(s.year, s.month, 0).getDate();
  document.getElementById('e-attendance-panel').style.display = '';
  document.getElementById('e-att-period').textContent   = MONTHS[s.month-1] + ' ' + s.year;
  document.getElementById('e-att-caldays').textContent  = calDays;
  document.getElementById('e-att-present').textContent  = s.presentDays  ?? '—';
  document.getElementById('e-att-absent').textContent   = s.absentDays   ?? '—';
  document.getElementById('e-att-leaves').textContent   = s.leaveTaken   ?? '—';
  document.getElementById('e-att-hours').textContent    = (s.actualHours  ?? '—') + (s.actualHours != null ? ' hrs' : '');
  document.getElementById('e-att-workdays').textContent = (s.totalWorkDays ?? '—') + (s.totalWorkDays != null ? ' days' : '');
  document.getElementById('e-att-emp').textContent      = s.user?.name || '—';
  document.getElementById('e-workdays').value           = s.totalWorkDays || 0;
  document.getElementById('e-workdays').max             = calDays || '';
  document.getElementById('e-expected-hours').value     = s.expectedHours || 0;
  document.getElementById('e-present-days').value       = s.presentDays || 0;
  document.getElementById('e-actual-hours').value       = s.actualHours || 0;
  syncEditWorkdaySummary();

  openModal('edit-modal');
}

