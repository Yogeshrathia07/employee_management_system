function fmt(n) { return fmtCurrency(n); }

function calcGenCTC() {
  const ids = ['g-basic','g-hra','g-conv','g-med','g-special','g-bonus','g-ta'];
  const total = ids.reduce((s,id) => s + (parseFloat(document.getElementById(id).value)||0), 0);
  document.getElementById('g-ctc').value = total;
}
function calcEditCTC() {
  const ids = ['e-basic','e-hra','e-conv','e-med','e-special','e-bonus','e-ta'];
  const total = ids.reduce((s,id) => s + (parseFloat(document.getElementById(id).value)||0), 0);
  document.getElementById('e-ctc').value = total;
}

function syncGenWorkdaySummary() {
  const calDays = parseFloat(document.getElementById('g-att-caldays').textContent) || 0;
  const workdayInput = document.getElementById('g-workdays');
  let workdays = parseFloat(workdayInput.value) || 0;
  if (calDays && workdays > calDays) {
    workdays = calDays;
    workdayInput.value = calDays;
  }
  const present = parseFloat(document.getElementById('g-present-days').value) || 0;
  const leaves = parseFloat(document.getElementById('g-leave').value) || 0;
  const actualHours = parseFloat(document.getElementById('g-actual-hours').value) || 0;
  const expectedHoursInput = document.getElementById('g-expected-hours');
  const absent = Math.max(0, workdays - present - leaves);
  document.getElementById('g-att-workdays').textContent = (workdays || 0) + ' days';
  document.getElementById('g-att-absent').textContent = absent;
  if (expectedHoursInput && document.activeElement !== expectedHoursInput) {
    expectedHoursInput.value = workdays > 0 ? (workdays * 8) : 0;
  }
  document.getElementById('g-att-hours').textContent = (actualHours || 0) + ' hrs';
}

function syncEditWorkdaySummary() {
  const calDays = parseFloat(document.getElementById('e-att-caldays').textContent) || 0;
  const workdayInput = document.getElementById('e-workdays');
  let workdays = parseFloat(workdayInput.value) || 0;
  if (calDays && workdays > calDays) {
    workdays = calDays;
    workdayInput.value = calDays;
  }
  const present = parseFloat(document.getElementById('e-present-days').value) || 0;
  const leaves = parseFloat(document.getElementById('e-leave').value) || 0;
  const actualHours = parseFloat(document.getElementById('e-actual-hours').value) || 0;
  const expectedHoursInput = document.getElementById('e-expected-hours');
  const absent = Math.max(0, workdays - present - leaves);
  document.getElementById('e-att-workdays').textContent = (workdays || 0) + ' days';
  document.getElementById('e-att-absent').textContent = absent;
  if (expectedHoursInput && document.activeElement !== expectedHoursInput) {
    expectedHoursInput.value = workdays > 0 ? (workdays * 8) : 0;
  }
  document.getElementById('e-att-hours').textContent = (actualHours || 0) + (actualHours != null ? ' hrs' : '');
}

// Load employees for single generate
async function loadUsers() {
  try {
    const companyId = getPayrollSelectedCompanyId();
    const users = await api('GET', '/users');
    allUsers = users.filter(u => {
      if (u.role !== 'employee' && u.role !== 'manager') return false;
      if (!companyId) return true;
      return String(u.companyId || '') === String(companyId);
    });
    const sel = document.getElementById('g-user');
    sel.innerHTML = '<option value="">Select employee...</option>' + allUsers.map(u =>
      `<option value="${u.id}">${u.name} (${u.role})</option>`
    ).join('');
  } catch(e) {}
}

// Called when employee OR month/year changes — pre-fill salary structure + fetch live leave/hours
let _previewTimer = null;
function onEmployeeOrPeriodChange() {
  const uid   = document.getElementById('g-user').value;
  const month = document.getElementById('g-month').value;
  const year  = document.getElementById('g-year').value;

  // Always pre-fill salary structure from cached user object immediately
  const user = allUsers.find(u => String(u.id) === String(uid));
  if (user) {
    document.getElementById('g-basic').value   = user.basicSalary       || 0;
    document.getElementById('g-hra').value     = user.hra               || 0;
    document.getElementById('g-conv').value    = user.conveyance        || 0;
    document.getElementById('g-med').value     = user.medicalExpenses   || 0;
    document.getElementById('g-special').value = user.specialAllowance  || 0;
    document.getElementById('g-bonus').value   = user.bonus             || 0;
    document.getElementById('g-ta').value      = user.ta                || 0;
    // Pre-fill currency from employee's stored currency
    var defCurr = (getUser()&&getUser().company&&getUser().company.currency)||'INR';
    document.getElementById('g-currency').value = user.currency || defCurr;
    calcGenCTC();
  }

  // Fetch live leave taken + hours if all three are set
  if (!uid || !month || !year) {
    document.getElementById('g-attendance-panel').style.display = 'none';
    return;
  }
  clearTimeout(_previewTimer);
  _previewTimer = setTimeout(async () => {
    const loading = document.getElementById('g-leave-loading');
    loading.style.display = '';
    try {
      const preview = await api('GET', `/salary/preview?userId=${uid}&month=${month}&year=${year}`);
      document.getElementById('g-leave').value = preview.leaveTaken || 0;
      document.getElementById('g-present-days').value = preview.presentDays || 0;
      document.getElementById('g-actual-hours').value = preview.actualHours || 0;
      // Update salary structure with fresh server data
      document.getElementById('g-basic').value   = preview.basicSalary       || document.getElementById('g-basic').value;
      document.getElementById('g-hra').value     = preview.hra               || document.getElementById('g-hra').value;
      document.getElementById('g-conv').value    = preview.conveyance        || document.getElementById('g-conv').value;
      document.getElementById('g-med').value     = preview.medicalExpenses   || document.getElementById('g-med').value;
      document.getElementById('g-special').value = preview.specialAllowance  || document.getElementById('g-special').value;
      document.getElementById('g-bonus').value   = preview.bonus             || document.getElementById('g-bonus').value;
      document.getElementById('g-ta').value      = preview.ta                || document.getElementById('g-ta').value;
      calcGenCTC();

      // ── Attendance Summary Panel ──────────────────────────────────────
      const panel = document.getElementById('g-attendance-panel');
      panel.style.display = '';
      document.getElementById('g-att-period').textContent = MONTHS[Number(month) - 1] + ' ' + year;
      document.getElementById('g-att-caldays').textContent  = preview.calDays       || '—';
      document.getElementById('g-att-present').textContent  = preview.presentDays   ?? '—';
      document.getElementById('g-att-absent').textContent   = preview.absentDays    ?? '—';
      document.getElementById('g-att-leaves').textContent   = preview.leaveTaken    ?? '—';
      document.getElementById('g-att-holidays').textContent = preview.holidayDays   ?? '—';
      document.getElementById('g-workdays').value           = preview.totalWorkDays ?? 0;
      document.getElementById('g-workdays').max             = preview.calDays ?? '';
      document.getElementById('g-att-workdays').textContent = (preview.totalWorkDays ?? '—') + ' days';
      document.getElementById('g-expected-hours').value     = preview.expectedHours ?? ((preview.totalWorkDays || 0) * 8);
      document.getElementById('g-att-hours').textContent    = (preview.actualHours   ?? '—') + ' hrs';
      syncGenWorkdaySummary();

      const noData = !preview.presentDays && !preview.leaveTaken && !preview.actualHours;
      document.getElementById('g-att-nodata').style.display = noData ? '' : 'none';
    } catch(e) {
      hint.textContent   = 'Could not fetch leave data';
      hint.style.display = '';
      hint.style.color   = 'var(--danger)';
      document.getElementById('g-attendance-panel').style.display = 'none';
    } finally {
      loading.style.display = 'none';
    }
  }, 400); // debounce 400ms
}

async function loadSalaries() {
  try {
    let params = [];
    const month  = document.getElementById('f-month').value;
    const year   = document.getElementById('f-year').value;
    const status = document.getElementById('f-status').value;
    if (month) params.push('month=' + month);
    if (year)  params.push('year=' + year);
    const cid = getSelectedCompanyId();
    if (cid) params.push('companyId=' + cid);

    let salaries = await api('GET', '/salary' + (params.length ? '?' + params.join('&') : ''));
    allSalaries = salaries;

    document.getElementById('s-total').textContent     = allSalaries.length;
    document.getElementById('s-draft').textContent     = allSalaries.filter(s => s.status === 'draft').length;
    document.getElementById('s-finalized').textContent = allSalaries.filter(s => s.status === 'finalized').length;
    document.getElementById('s-paid').textContent      = allSalaries.filter(s => s.status === 'paid').length;

    filterSalaries();
  } catch(e) { toast(e.message, 'error'); }
}

function filterSalaries() {
  const status = document.getElementById('f-status').value;
  const search = (document.getElementById('f-search').value || '').toLowerCase().trim();
  let salaries = allSalaries;
  if (status) salaries = salaries.filter(s => s.status === status);
  if (search) salaries = salaries.filter(s => (s.user?.name || '').toLowerCase().includes(search));
  renderSalaries(salaries);
}

function renderSalaries(salaries) {
  const grid = document.getElementById('salary-grid');
  if (!salaries.length) {
    grid.innerHTML = '<div style="grid-column:1/-1;"><div class="empty-state"><div class="empty-icon"><i class="bx bxs-wallet"></i></div><p>No salary records found</p></div></div>';
    return;
  }

  grid.innerHTML = salaries.map(s => {
    const sc = s.status==='paid'?'#22c55e':s.status==='finalized'?'#3b82f6':'#f59e0b';
    const sb = s.status==='paid'?'#dcfce7':s.status==='finalized'?'#dbeafe':'#fef3c7';
    const calDays = new Date(s.year, s.month, 0).getDate();
    return `<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;display:flex;flex-direction:column;gap:10px;transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.boxShadow=''">
      <!-- Header: name + status -->
      <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
        <div style="min-width:0;">
          <div style="font-weight:700;font-size:14px;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${s.user?.name||'—'}</div>
          <div style="font-size:11px;color:var(--text-muted);text-transform:capitalize;">${s.user?.department||s.user?.role||''} · ${MONTHS[s.month-1]} ${s.year} · ${calDays} days</div>
        </div>
        <span style="font-size:11px;font-weight:700;background:${sb};color:${sc};border-radius:20px;padding:3px 10px;flex-shrink:0;text-transform:capitalize;">${s.status}</span>
      </div>
      <!-- Net pay highlight -->
      <div style="background:linear-gradient(135deg,var(--accent),#7c3aed);border-radius:10px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;">
        <span style="font-size:11px;color:rgba(255,255,255,0.75);">Net Pay</span>
        <span style="font-size:20px;font-weight:800;color:white;">${fmt(s.netSalary)}</span>
      </div>
      <!-- Actions -->
      <div style="display:flex;flex-wrap:wrap;gap:6px;">
        <button class="btn btn-ghost btn-sm" onclick="viewPayslip(${s.id})" style="flex:1;min-width:0;justify-content:center;"><i class="bx bx-show"></i> View</button>
        ${s.status==='finalized'?`<button class="btn btn-success btn-sm" onclick="pay(${s.id})" style="flex:1;min-width:0;justify-content:center;"><i class="bx bxs-wallet"></i> Pay</button>`:''}
        <button class="btn btn-ghost btn-sm" onclick="downloadPayslip(${s.id})" title="Download"><i class="bx bx-download"></i></button>
        ${s.status!=='paid'?`<button class="btn btn-ghost btn-sm" onclick="openEdit(${s.id})" title="Edit"><i class="bx bx-edit"></i></button>`:''}
        ${s.status!=='paid'?`<button class="btn btn-danger btn-sm" onclick="delSal(${s.id})" title="Delete"><i class="bx bx-trash"></i></button>`:''}
      </div>
    </div>`;
  }).join('');
}

async function bulkGenerate() {
  const month     = document.getElementById('b-month').value;
  const year      = document.getElementById('b-year').value;
  const companyId = getPayrollSelectedCompanyId();
  if (!month || !year) return toast('Select month and year', 'error');
  if (payrollCompanySelectionRequired() && !companyId) return toast('Select a company first', 'error');
  const btn = document.getElementById('bulk-btn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner" style="width:16px;height:16px"></span> Generating...';
  try {
    const res = await api('POST', '/salary/generate-bulk', { month, year, companyId });
    toast(res.message, 'success');
    closeModal('bulk-modal');
    loadSalaries();
  } catch(e) { toast(e.message, 'error'); }
  finally { btn.disabled = false; btn.innerHTML = '<i class="bx bxs-magic-wand"></i> Generate'; }
}

