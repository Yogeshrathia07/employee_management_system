<%- include('../partials/head', {title: 'Payroll — Admin'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-admin') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title">Payroll</div>
          <div class="page-subtitle">Generate & manage employee salary records</div>
        </div>
      </div>
      <div class="header-actions"></div>
    </header>
    <div class="page-body admin-employees-page">
      <div class="employee-directory-shell">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:20px;">
        <span id="company-filter-container" style="display:none;"></span>
      </div>

      <!-- Stats -->
      <div class="stats-grid" style="grid-template-columns:repeat(4,1fr);">
        <div class="stat-card"><div class="stat-icon" style="background:#f3f4f6;color:#111"><i class="bx bxs-group"></i></div><div><div class="stat-value" id="s-total">0</div><div class="stat-label">Total Records</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:#f3f4f6;color:#111"><i class="bx bxs-edit"></i></div><div><div class="stat-value" id="s-draft">0</div><div class="stat-label">Drafts</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:#f3f4f6;color:#111"><i class="bx bxs-check-circle"></i></div><div><div class="stat-value" id="s-finalized">0</div><div class="stat-label">Finalized</div></div></div>
        <div class="stat-card"><div class="stat-icon" style="background:#f3f4f6;color:#111"><i class="bx bxs-wallet"></i></div><div><div class="stat-value" id="s-paid">0</div><div class="stat-label">Paid</div></div></div>
      </div>

      <!-- Filters -->
      <div class="admin-toolbar" style="margin-bottom:20px;">
        <select id="f-month" class="form-control" style="width:140px" onchange="loadSalaries()">
          <option value="">All Months</option>
        </select>
        <input type="number" id="f-year" class="form-control" style="width:100px" placeholder="Year" onchange="loadSalaries()">
        <select id="f-status" class="form-control" style="width:130px" onchange="loadSalaries()">
          <option value="">All Status</option>
          <option value="draft">Draft</option>
          <option value="finalized">Finalized</option>
          <option value="paid">Paid</option>
        </select>
        <button class="btn btn-ghost" onclick="exportCSV()"><i class="bx bx-download"></i> Export CSV</button>
        <button class="btn btn-ghost" onclick="openModal('gen-modal')"><i class="bx bx-plus"></i> Single Generate</button>
        <button class="btn btn-primary" onclick="openModal('bulk-modal')"><i class="bx bxs-magic-wand"></i> Generate All</button>
      </div>

      <div id="salary-grid" class="salary-card-grid">
        <div style="grid-column:1/-1;display:flex;justify-content:center;padding:40px;"><span class="spinner"></span></div>
      </div>
      </div>
    </div>
  </div>
</div>

<!-- Bulk Generate Modal -->
<div class="modal-overlay" id="bulk-modal">
  <div class="modal" style="max-width:440px">
    <div class="modal-header"><span class="modal-title">Generate Salaries for All Employees</span><button class="modal-close" onclick="closeModal('bulk-modal')">×</button></div>
    <div class="modal-body">
      <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">Auto-fetches approved leave & timesheet data for every active employee. Uses each employee's salary structure from their profile.</p>
      <div class="form-group" id="b-company-wrap" style="display:none;">
        <label class="form-label">Company</label>
        <select id="b-company" class="form-control" onchange="syncPayrollCompanySelection(this.value)">
          <option value="">Select company...</option>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Month</label><select id="b-month" class="form-control"></select></div>
        <div class="form-group"><label class="form-label">Year</label><input type="number" id="b-year" class="form-control"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('bulk-modal')">Cancel</button>
      <button class="btn btn-primary" id="bulk-btn" onclick="bulkGenerate()"><i class="bx bxs-magic-wand"></i> Generate</button>
    </div>
  </div>
</div>

<!-- Single Generate Modal -->
<div class="modal-overlay" id="gen-modal">
  <div class="modal" style="max-width:580px">
    <div class="modal-header"><span class="modal-title">Generate Salary — Single Employee</span><button class="modal-close" onclick="closeModal('gen-modal')">×</button></div>
    <div class="modal-body" style="max-height:72vh;overflow-y:auto;padding-right:4px;">
      <div class="form-group" id="g-company-wrap" style="display:none;">
        <label class="form-label">Company</label>
        <select id="g-company" class="form-control" onchange="syncPayrollCompanySelection(this.value); loadUsers();">
          <option value="">Select company...</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Employee</label>
        <select id="g-user" class="form-control" onchange="onEmployeeOrPeriodChange()"><option value="">Select employee...</option></select>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Month</label><select id="g-month" class="form-control" onchange="onEmployeeOrPeriodChange()"></select></div>
        <div class="form-group"><label class="form-label">Year</label><input type="number" id="g-year" class="form-control" oninput="onEmployeeOrPeriodChange()"></div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">CTC (Monthly, Rs.)</label>
          <input type="number" id="g-ctc" class="form-control" readonly style="background:var(--bg-input);cursor:not-allowed;color:var(--text-muted);" value="0">
          <div style="font-size:11px;color:var(--text-muted);margin-top:3px;">Auto from components</div>
        </div>
        <div class="form-group">
          <label class="form-label" style="display:flex;align-items:center;gap:6px;">
            Leave Taken (days)
            <span id="g-leave-loading" style="display:none;font-size:11px;color:var(--text-muted);">fetching…</span>
          </label>
          <input type="number" id="g-leave" class="form-control" min="0" value="0">
          <div id="g-leave-hint" style="font-size:11px;color:var(--text-muted);margin-top:3px;display:none;"></div>
        </div>
      </div>

      <div class="section-divider-label">Earnings Components</div>
      <div class="form-row" style="grid-template-columns:1fr 1fr 1fr">
        <div class="form-group"><label class="form-label">Basic Salary</label><input type="number" id="g-basic" class="form-control" min="0" value="0" oninput="calcGenCTC()"></div>
        <div class="form-group"><label class="form-label">HRA</label><input type="number" id="g-hra" class="form-control" min="0" value="0" oninput="calcGenCTC()"></div>
        <div class="form-group"><label class="form-label">Conveyance</label><input type="number" id="g-conv" class="form-control" min="0" value="0" oninput="calcGenCTC()"></div>
      </div>
      <div class="form-row" style="grid-template-columns:1fr 1fr 1fr">
        <div class="form-group"><label class="form-label">Medical Expenses</label><input type="number" id="g-med" class="form-control" min="0" value="0" oninput="calcGenCTC()"></div>
        <div class="form-group"><label class="form-label">Special Allowance</label><input type="number" id="g-special" class="form-control" min="0" value="0" oninput="calcGenCTC()"></div>
        <div class="form-group"><label class="form-label">Bonus</label><input type="number" id="g-bonus" class="form-control" min="0" value="0" oninput="calcGenCTC()"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Travel Allowance (TA)</label><input type="number" id="g-ta" class="form-control" min="0" value="0" oninput="calcGenCTC()"></div>
        <div class="form-group"></div>
      </div>

      <div class="section-divider-label">Deductions</div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">PF Contribution</label><input type="number" id="g-pf" class="form-control" min="0" value="0"></div>
        <div class="form-group"><label class="form-label">Profession Tax</label><input type="number" id="g-ptax" class="form-control" min="0" value="0"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">TDS</label><input type="number" id="g-tds" class="form-control" min="0" value="0"></div>
        <div class="form-group"><label class="form-label">Salary Advance</label><input type="number" id="g-advance" class="form-control" min="0" value="0"></div>
      </div>
      <div class="form-group"><label class="form-label">Notes</label><textarea id="g-notes" class="form-control" rows="2"></textarea></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('gen-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="genSingle()">Generate</button>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal" style="max-width:580px">
    <div class="modal-header"><span class="modal-title" id="edit-title">Edit Salary</span><button class="modal-close" onclick="closeModal('edit-modal')">×</button></div>
    <div class="modal-body" style="max-height:72vh;overflow-y:auto;padding-right:4px;">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">CTC (Monthly)</label>
          <input type="number" id="e-ctc" class="form-control" readonly style="background:var(--bg-input);cursor:not-allowed;color:var(--text-muted);">
          <div style="font-size:11px;color:var(--text-muted);margin-top:3px;">Auto from components</div>
        </div>
        <div class="form-group"><label class="form-label">Leave Taken (days)</label><input type="number" id="e-leave" class="form-control"></div>
      </div>

      <div class="section-divider-label">Earnings Components</div>
      <div class="form-row" style="grid-template-columns:1fr 1fr 1fr">
        <div class="form-group"><label class="form-label">Basic Salary</label><input type="number" id="e-basic" class="form-control" oninput="calcEditCTC()"></div>
        <div class="form-group"><label class="form-label">HRA</label><input type="number" id="e-hra" class="form-control" oninput="calcEditCTC()"></div>
        <div class="form-group"><label class="form-label">Conveyance</label><input type="number" id="e-conv" class="form-control" oninput="calcEditCTC()"></div>
      </div>
      <div class="form-row" style="grid-template-columns:1fr 1fr 1fr">
        <div class="form-group"><label class="form-label">Medical Expenses</label><input type="number" id="e-med" class="form-control" oninput="calcEditCTC()"></div>
        <div class="form-group"><label class="form-label">Special Allowance</label><input type="number" id="e-special" class="form-control" oninput="calcEditCTC()"></div>
        <div class="form-group"><label class="form-label">Bonus</label><input type="number" id="e-bonus" class="form-control" oninput="calcEditCTC()"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Travel Allowance (TA)</label><input type="number" id="e-ta" class="form-control" oninput="calcEditCTC()"></div>
        <div class="form-group"></div>
      </div>

      <div class="section-divider-label">Deductions</div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">PF Contribution</label><input type="number" id="e-pf" class="form-control"></div>
        <div class="form-group"><label class="form-label">Profession Tax</label><input type="number" id="e-ptax" class="form-control"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">TDS</label><input type="number" id="e-tds" class="form-control"></div>
        <div class="form-group"><label class="form-label">Salary Advance</label><input type="number" id="e-advance" class="form-control"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Status</label>
          <select id="e-status" class="form-control"><option value="draft">Draft</option><option value="finalized">Finalized</option></select>
        </div>
        <div class="form-group"><label class="form-label">Notes</label><input type="text" id="e-notes" class="form-control"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('edit-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="updateSalary()">Update</button>
    </div>
  </div>
</div>

<style>
.section-divider-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  margin: 14px 0 8px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--border);
}
</style>

<script src="/js/api.js"></script>
<script src="/js/sidebar-fix.js"></script>
<script src="/js/admin-company-filter.js"></script>
<script>
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
let allSalaries = [], allUsers = [];
let editSalId = null;

function isSuperPayrollView() { return getUser()?.role === 'superadmin'; }

function syncPayrollCompanySelection(companyId) {
  if (!isSuperPayrollView()) return;
  const value = companyId || '';
  ['company-filter','b-company','g-company'].forEach(id => {
    const el = document.getElementById(id);
    if (el && String(el.value || '') !== String(value)) el.value = value;
  });
}

function getPayrollSelectedCompanyId() {
  if (!isSuperPayrollView()) return '';
  const bulkModal   = document.getElementById('bulk-modal');
  const singleModal = document.getElementById('gen-modal');
  if (bulkModal   && bulkModal.classList.contains('show'))   return document.getElementById('b-company')?.value || '';
  if (singleModal && singleModal.classList.contains('show')) return document.getElementById('g-company')?.value || '';
  return getSelectedCompanyId();
}

function setupPayrollCompanySelectors() {
  if (!isSuperPayrollView()) return;
  const options = '<option value="">Select company...</option>' + (_allCompanies || []).map(c => `<option value="${c.id}">${c.name}</option>`).join('');
  ['b-company-wrap','g-company-wrap'].forEach(wid => {
    const wrap = document.getElementById(wid);
    const sel  = document.getElementById(wid.replace('-wrap', ''));
    if (wrap && sel) { wrap.style.display = ''; sel.innerHTML = options; }
  });
  syncPayrollCompanySelection(getSelectedCompanyId());
}

// Populate month selects
['f-month','g-month','b-month'].forEach(id => {
  const el = document.getElementById(id);
  const isFilter = id === 'f-month';
  el.innerHTML = (isFilter ? '<option value="">All Months</option>' : '') +
    MONTHS.map((m, i) => `<option value="${i+1}" ${!isFilter && i+1===new Date().getMonth()+1?'selected':''}>${m}</option>`).join('');
});
document.getElementById('g-year').value = new Date().getFullYear();
document.getElementById('b-year').value = new Date().getFullYear();

function fmt(n) { return fmtCurrency(n); }

function calcGenCTC() {
  const ids = ['g-basic','g-hra','g-conv','g-med','g-special','g-bonus','g-ta'];
  const total = ids.reduce((s,id) => s + (parseFloat(document.getElementById(id).value)||0), 0);
  document.getElementById('g-ctc').value = total;
}
function calcEditCTC() {
  const ids = ['e-basic','e-hra','e-conv','e-med','e-special','e-bonus','e-ta'];
  const total = ids.reduce((s,id) => s + (parseFloat(document.getElementById(id).value)||0), 0);
  document.getElementById('e-ctc').value = total;
}

// Load employees for single generate
async function loadUsers() {
  try {
    const companyId = getPayrollSelectedCompanyId();
    const users = await api('GET', '/users');
    allUsers = users.filter(u => {
      if (u.role !== 'employee' && u.role !== 'manager') return false;
      if (!companyId) return true;
      return String(u.companyId || '') === String(companyId);
    });
    const sel = document.getElementById('g-user');
    sel.innerHTML = '<option value="">Select employee...</option>' + allUsers.map(u =>
      `<option value="${u.id}">${u.name} (${u.role})</option>`
    ).join('');
  } catch(e) {}
}

// Called when employee OR month/year changes — pre-fill salary structure + fetch live leave/hours
let _previewTimer = null;
function onEmployeeOrPeriodChange() {
  const uid   = document.getElementById('g-user').value;
  const month = document.getElementById('g-month').value;
  const year  = document.getElementById('g-year').value;

  // Always pre-fill salary structure from cached user object immediately
  const user = allUsers.find(u => String(u.id) === String(uid));
  if (user) {
    document.getElementById('g-basic').value   = user.basicSalary       || 0;
    document.getElementById('g-hra').value     = user.hra               || 0;
    document.getElementById('g-conv').value    = user.conveyance        || 0;
    document.getElementById('g-med').value     = user.medicalExpenses   || 0;
    document.getElementById('g-special').value = user.specialAllowance  || 0;
    document.getElementById('g-bonus').value   = user.bonus             || 0;
    document.getElementById('g-ta').value      = user.ta                || 0;
    calcGenCTC();
  }

  // Fetch live leave taken + hours if all three are set
  if (!uid || !month || !year) return;
  clearTimeout(_previewTimer);
  _previewTimer = setTimeout(async () => {
    const loading = document.getElementById('g-leave-loading');
    const hint    = document.getElementById('g-leave-hint');
    loading.style.display = '';
    hint.style.display    = 'none';
    try {
      const preview = await api('GET', `/salary/preview?userId=${uid}&month=${month}&year=${year}`);
      document.getElementById('g-leave').value = preview.leaveTaken || 0;
      if (preview.leaveTaken > 0) {
        hint.textContent    = `${preview.leaveTaken} approved leave day(s) found for this period`;
        hint.style.display  = '';
        hint.style.color    = '#f59e0b';
      } else {
        hint.textContent    = 'No approved leaves found for this period';
        hint.style.display  = '';
        hint.style.color    = 'var(--text-muted)';
      }
      // Update salary structure with fresh server data
      document.getElementById('g-basic').value   = preview.basicSalary       || document.getElementById('g-basic').value;
      document.getElementById('g-hra').value     = preview.hra               || document.getElementById('g-hra').value;
      document.getElementById('g-conv').value    = preview.conveyance        || document.getElementById('g-conv').value;
      document.getElementById('g-med').value     = preview.medicalExpenses   || document.getElementById('g-med').value;
      document.getElementById('g-special').value = preview.specialAllowance  || document.getElementById('g-special').value;
      document.getElementById('g-bonus').value   = preview.bonus             || document.getElementById('g-bonus').value;
      document.getElementById('g-ta').value      = preview.ta                || document.getElementById('g-ta').value;
      calcGenCTC();
    } catch(e) {
      hint.textContent   = 'Could not fetch leave data';
      hint.style.display = '';
      hint.style.color   = 'var(--danger)';
    } finally {
      loading.style.display = 'none';
    }
  }, 400); // debounce 400ms
}

async function loadSalaries() {
  try {
    let params = [];
    const month  = document.getElementById('f-month').value;
    const year   = document.getElementById('f-year').value;
    const status = document.getElementById('f-status').value;
    if (month) params.push('month=' + month);
    if (year)  params.push('year=' + year);
    const cid = getSelectedCompanyId();
    if (cid) params.push('companyId=' + cid);

    let salaries = await api('GET', '/salary' + (params.length ? '?' + params.join('&') : ''));
    allSalaries = salaries;
    if (status) salaries = salaries.filter(s => s.status === status);

    document.getElementById('s-total').textContent     = allSalaries.length;
    document.getElementById('s-draft').textContent     = allSalaries.filter(s => s.status === 'draft').length;
    document.getElementById('s-finalized').textContent = allSalaries.filter(s => s.status === 'finalized').length;
    document.getElementById('s-paid').textContent      = allSalaries.filter(s => s.status === 'paid').length;

    const grid = document.getElementById('salary-grid');
    if (!salaries.length) {
      grid.innerHTML = '<div style="grid-column:1/-1;"><div class="empty-state"><div class="empty-icon"><i class="bx bxs-wallet"></i></div><p>No salary records found</p></div></div>';
      return;
    }

    grid.innerHTML = salaries.map(s => {
      const sc = s.status==='paid'?'#22c55e':s.status==='finalized'?'#3b82f6':'#f59e0b';
      const sb = s.status==='paid'?'#dcfce7':s.status==='finalized'?'#dbeafe':'#fef3c7';
      const calDays = new Date(s.year, s.month, 0).getDate();
      const worked  = Math.max(0, calDays - (s.leaveTaken || 0));
      return `<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;display:flex;flex-direction:column;gap:12px;transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='var(--shadow-lg)'" onmouseout="this.style.boxShadow=''">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
          <div style="min-width:0;">
            <div style="font-weight:700;font-size:14px;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${s.user?.name||'—'}</div>
            <div style="font-size:11px;color:var(--text-muted);margin-top:2px;text-transform:capitalize;">${s.user?.department||s.user?.role||''}</div>
          </div>
          <span style="font-size:11px;font-weight:700;background:${sb};color:${sc};border-radius:20px;padding:3px 10px;flex-shrink:0;text-transform:capitalize;">${s.status}</span>
        </div>
        <div style="text-align:center;background:linear-gradient(135deg,var(--accent),#7c3aed);border-radius:12px;padding:16px;">
          <div style="font-size:11px;color:rgba(255,255,255,0.7);margin-bottom:4px;">${MONTHS[s.month-1]} ${s.year} · Net Pay</div>
          <div style="font-size:28px;font-weight:900;color:white;">${fmt(s.netSalary)}</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          <div style="background:var(--bg-input);border-radius:8px;padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);">CTC</div>
            <div style="font-size:13px;font-weight:700;">${fmt(s.baseSalary)}</div>
          </div>
          <div style="background:var(--bg-input);border-radius:8px;padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);">Gross</div>
            <div style="font-size:13px;font-weight:700;">${fmt(s.grossSalary)}</div>
          </div>
          <div style="background:var(--bg-input);border-radius:8px;padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);">Deductions</div>
            <div style="font-size:13px;font-weight:700;color:var(--danger);">-${fmt(s.deductions)}</div>
          </div>
          <div style="background:var(--bg-input);border-radius:8px;padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);">Days</div>
            <div style="font-size:13px;font-weight:700;">${worked}/${calDays}d</div>
          </div>
        </div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <button class="btn btn-ghost btn-sm" onclick="viewPayslip(${s.id})" style="flex:1;justify-content:center;"><i class="bx bx-show"></i> View</button>
          <button class="btn btn-ghost btn-sm" onclick="downloadPayslip(${s.id})"><i class="bx bx-download"></i></button>
          ${s.status!=='paid'?`<button class="btn btn-ghost btn-sm" onclick="openEdit(${s.id})"><i class="bx bx-edit"></i></button>`:''}
          ${s.status==='finalized'?`<button class="btn btn-success btn-sm" onclick="pay(${s.id})"><i class="bx bxs-wallet"></i> Pay</button>`:''}
          ${s.status!=='paid'?`<button class="btn btn-danger btn-sm" onclick="delSal(${s.id})"><i class="bx bx-trash"></i></button>`:''}
        </div>
      </div>`;
    }).join('');
  } catch(e) { toast(e.message, 'error'); }
}

async function bulkGenerate() {
  const month     = document.getElementById('b-month').value;
  const year      = document.getElementById('b-year').value;
  const companyId = getPayrollSelectedCompanyId();
  if (!month || !year) return toast('Select month and year', 'error');
  if (getUser()?.role === 'superadmin' && !companyId) return toast('Select a company first', 'error');
  const btn = document.getElementById('bulk-btn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner" style="width:16px;height:16px"></span> Generating...';
  try {
    const res = await api('POST', '/salary/generate-bulk', { month, year, companyId });
    toast(res.message, 'success');
    closeModal('bulk-modal');
    loadSalaries();
  } catch(e) { toast(e.message, 'error'); }
  finally { btn.disabled = false; btn.innerHTML = '<i class="bx bxs-magic-wand"></i> Generate'; }
}

async function genSingle() {
  const companyId = getPayrollSelectedCompanyId();
  if (getUser()?.role === 'superadmin' && !companyId) return toast('Select a company first', 'error');
  const body = {
    userId:          document.getElementById('g-user').value,
    month:           document.getElementById('g-month').value,
    year:            document.getElementById('g-year').value,
    companyId,
    leaveTaken:      parseFloat(document.getElementById('g-leave').value)  || 0,
    basicSalary:     parseFloat(document.getElementById('g-basic').value)  || 0,
    hra:             parseFloat(document.getElementById('g-hra').value)    || 0,
    conveyance:      parseFloat(document.getElementById('g-conv').value)   || 0,
    medicalExpenses: parseFloat(document.getElementById('g-med').value)    || 0,
    specialAllowance:parseFloat(document.getElementById('g-special').value)|| 0,
    bonus:           parseFloat(document.getElementById('g-bonus').value)  || 0,
    ta:              parseFloat(document.getElementById('g-ta').value)     || 0,
    pfContribution:  parseFloat(document.getElementById('g-pf').value)     || 0,
    professionTax:   parseFloat(document.getElementById('g-ptax').value)   || 0,
    tds:             parseFloat(document.getElementById('g-tds').value)    || 0,
    salaryAdvance:   parseFloat(document.getElementById('g-advance').value)|| 0,
    notes:           document.getElementById('g-notes').value,
  };
  if (!body.userId) return toast('Select an employee', 'error');
  try {
    await api('POST', '/salary', body);
    toast('Salary generated!', 'success');
    closeModal('gen-modal');
    loadSalaries();
  } catch(e) { toast(e.message, 'error'); }
}

function openEdit(id) {
  const s = allSalaries.find(x => x.id === id);
  if (!s) return;
  editSalId = id;
  document.getElementById('edit-title').textContent = 'Edit — ' + (s.user?.name||'') + ' — ' + MONTHS[s.month-1] + ' ' + s.year;
  document.getElementById('e-leave').value   = s.leaveTaken || 0;
  document.getElementById('e-basic').value   = s.basicSalary || 0;
  document.getElementById('e-hra').value     = s.hra || 0;
  document.getElementById('e-conv').value    = s.conveyance || 0;
  document.getElementById('e-med').value     = s.medicalExpenses || 0;
  document.getElementById('e-special').value = s.specialAllowance || 0;
  document.getElementById('e-bonus').value   = s.bonus || 0;
  document.getElementById('e-ta').value      = s.ta || 0;
  calcEditCTC();
  document.getElementById('e-pf').value      = s.pfContribution || 0;
  document.getElementById('e-ptax').value    = s.professionTax || 0;
  document.getElementById('e-tds').value     = s.tds || 0;
  document.getElementById('e-advance').value = s.salaryAdvance || 0;
  document.getElementById('e-status').value  = s.status;
  document.getElementById('e-notes').value   = s.notes || '';
  openModal('edit-modal');
}

async function updateSalary() {
  const body = {
    leaveTaken:      parseFloat(document.getElementById('e-leave').value)   || 0,
    basicSalary:     parseFloat(document.getElementById('e-basic').value)   || 0,
    hra:             parseFloat(document.getElementById('e-hra').value)     || 0,
    conveyance:      parseFloat(document.getElementById('e-conv').value)    || 0,
    medicalExpenses: parseFloat(document.getElementById('e-med').value)     || 0,
    specialAllowance:parseFloat(document.getElementById('e-special').value) || 0,
    bonus:           parseFloat(document.getElementById('e-bonus').value)   || 0,
    ta:              parseFloat(document.getElementById('e-ta').value)      || 0,
    pfContribution:  parseFloat(document.getElementById('e-pf').value)      || 0,
    professionTax:   parseFloat(document.getElementById('e-ptax').value)    || 0,
    tds:             parseFloat(document.getElementById('e-tds').value)     || 0,
    salaryAdvance:   parseFloat(document.getElementById('e-advance').value) || 0,
    status:          document.getElementById('e-status').value,
    notes:           document.getElementById('e-notes').value,
  };
  try {
    await api('PUT', '/salary/' + editSalId, body);
    toast('Updated', 'success');
    closeModal('edit-modal');
    loadSalaries();
  } catch(e) { toast(e.message, 'error'); }
}

async function pay(id) {
  if (!confirm('Mark this salary as paid? This cannot be undone.')) return;
  try { await api('PATCH', '/salary/' + id + '/pay'); toast('Salary marked as paid!', 'success'); loadSalaries(); }
  catch(e) { toast(e.message, 'error'); }
}

async function delSal(id) {
  if (!confirm('Delete this salary record?')) return;
  try { await api('DELETE', '/salary/' + id); toast('Deleted', 'success'); loadSalaries(); }
  catch(e) { toast(e.message, 'error'); }
}

function viewPayslip(id) {
  window.open('/api/salary/' + id + '/payslip?token=' + getToken() + '&mode=view', '_blank');
}
function downloadPayslip(id) {
  window.open('/api/salary/' + id + '/payslip?token=' + getToken() + '&mode=download', '_blank');
}
function exportCSV() {
  const token = getToken();
  const month = document.getElementById('f-month').value;
  const year  = document.getElementById('f-year').value;
  let url = '/api/salary/export/csv?token=' + token;
  if (month) url += '&month=' + month;
  if (year)  url += '&year='  + year;
  window.open(url, '_blank');
}

function reloadPageData() { setupPayrollCompanySelectors(); loadSalaries(); loadUsers(); }
initCompanyFilter().then(function() { setupPayrollCompanySelectors(); loadUsers(); loadSalaries(); });
</script>
</body></html>
