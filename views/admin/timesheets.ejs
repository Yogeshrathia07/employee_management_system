<%- include('../partials/head', {title: 'All Timesheets'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-admin') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title">All Timesheets</div>
          <div class="page-subtitle">Review and manage all timesheet submissions</div>
        </div>
      </div>
      <div class="header-actions"></div>
    </header>
    <div class="page-body admin-employees-page">
      <div class="employee-directory-shell">

        <!-- Toolbar -->
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:18px;">
          <span id="company-filter-container"></span>
          <select id="filter-status" class="form-control" style="width:130px" onchange="applyFilters()">
            <option value="">All Status</option>
            <option value="pending">Pending</option>
            <option value="approved">Approved</option>
            <option value="rejected">Rejected</option>
          </select>
          <select id="filter-month" class="form-control" style="width:120px" onchange="applyFilters()">
            <option value="">All Months</option>
            <option value="0">January</option><option value="1">February</option><option value="2">March</option>
            <option value="3">April</option><option value="4">May</option><option value="5">June</option>
            <option value="6">July</option><option value="7">August</option><option value="8">September</option>
            <option value="9">October</option><option value="10">November</option><option value="11">December</option>
          </select>
          <select id="filter-year" class="form-control" style="width:100px" onchange="applyFilters()">
            <option value="">All Years</option>
          </select>
          <div style="margin-left:auto;display:flex;gap:8px;">
            <button class="btn btn-ghost btn-sm" onclick="exportFiltered()" title="Export current filtered view to CSV">
              <i class="bx bxs-file-export"></i> Export CSV
            </button>
          </div>
        </div>

        <!-- Stats -->
        <div id="ts-stats" style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;"></div>

        <!-- Table -->
        <div id="ts-grid" style="overflow-x:auto;max-width:100%;">
          <div style="display:flex;justify-content:center;padding:40px;"><span class="spinner"></span></div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- ── View Details Modal ── -->
<div class="modal-overlay" id="view-modal">
  <div class="modal" style="width:min(96vw,840px);max-width:min(96vw,840px);max-height:90vh;display:flex;flex-direction:column;">
    <div class="modal-header">
      <span class="modal-title" id="view-modal-title">Timesheet Details</span>
      <button class="modal-close" onclick="closeModal('view-modal')">×</button>
    </div>
    <div class="modal-body" id="view-modal-body" style="overflow:auto;"></div>
    <div class="modal-footer" id="view-modal-footer" style="padding:12px 20px;"></div>
  </div>
</div>

<!-- ── Reject Modal ── -->
<div class="modal-overlay" id="reject-modal">
  <div class="modal" style="max-width:420px">
    <div class="modal-header"><span class="modal-title">Reject Timesheet</span><button class="modal-close" onclick="closeModal('reject-modal')">×</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">Reason for Rejection</label><textarea id="reject-reason" class="form-control" rows="3" placeholder="Optional reason..."></textarea></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('reject-modal')">Cancel</button>
      <button class="btn btn-danger" onclick="confirmReject()">Reject</button>
    </div>
  </div>
</div>

<script src="/js/api.js"></script>
<script src="/js/sidebar-fix.js"></script>
<script src="/js/admin-company-filter.js"></script>
<script>
var allTs = [], rejectId = null, filteredTs = [];
var MO_FULL_TS = ['January','February','March','April','May','June','July','August','September','October','November','December'];

var DN = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

/* ── helpers ── */
function getMondayOfTS(date) {
  var d = new Date(date), day = d.getDay();
  d.setDate(d.getDate() - day + (day===0?-6:1)); d.setHours(0,0,0,0); return d;
}
function getDayHours(t) {
  var h = [0,0,0,0,0,0,0];
  (t.entries||[]).forEach(function(e) {
    var d = new Date(e.date+'T00:00:00'), di = d.getDay()-1; if (di<0) di=6;
    if (di>=0&&di<7) h[di] += Number(e.hours||0);
  });
  return h;
}
function getDayEntries(t, di) {
  return (t.entries||[]).filter(function(e) {
    var d = new Date(e.date+'T00:00:00'), x = d.getDay()-1; if (x<0) x=6; return x===di;
  });
}
function getDayProjects(t, di) {
  return [...new Set(getDayEntries(t,di).map(function(e){ return e.project||''; }).filter(Boolean))].join(', ');
}
function statusChip(s) {
  var c = s==='approved'?'#22c55e':s==='rejected'?'#ef4444':'#f59e0b';
  var b = s==='approved'?'#dcfce7':s==='rejected'?'#fee2e2':'#fef3c7';
  return '<span style="font-size:11px;font-weight:700;background:'+b+';color:'+c+';border-radius:20px;padding:2px 10px;text-transform:capitalize;white-space:nowrap;">'+s+'</span>';
}
function fmtShortD(d) { return new Date(d).toLocaleDateString('en-US',{day:'2-digit',month:'short',year:'numeric'}); }

/* ── Filters ── */
function populateTsYearFilter() {
  var years = [...new Set(allTs.map(function(t){ return new Date(t.weekStart).getFullYear(); }))].sort(function(a,b){return b-a;});
  var sel = document.getElementById('filter-year');
  var cur = sel.value;
  sel.innerHTML = '<option value="">All Years</option>' + years.map(function(y){ return '<option value="'+y+'"'+(String(y)===cur?' selected':'')+'>'+y+'</option>'; }).join('');
}

function applyFilters() {
  var fStatus = document.getElementById('filter-status').value;
  var fMonth  = document.getElementById('filter-month').value;
  var fYear   = document.getElementById('filter-year').value;
  filteredTs = allTs.filter(function(t){
    if (fStatus && t.status !== fStatus) return false;
    if (fMonth !== '' || fYear !== '') {
      var d = new Date(t.weekStart);
      if (fMonth !== '' && d.getMonth() !== Number(fMonth)) return false;
      if (fYear  !== '' && d.getFullYear() !== Number(fYear))  return false;
    }
    return true;
  });
  renderTs(filteredTs);
}

/* ── Render table ── */
function renderTs(ts) {
  var grid = document.getElementById('ts-grid');
  if (!ts.length) {
    grid.innerHTML = '<div class="empty-state"><div class="empty-icon"><i class="bx bxs-time-five"></i></div><p>No timesheets found</p></div>';
    return;
  }

  var thead = '<thead><tr style="background:#f0f4ff;">' +
    '<th style="padding:8px 12px;text-align:left;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;">Employee</th>' +
    DN.map(function(d){ return '<th style="padding:8px 4px;text-align:center;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;width:40px;">'+d+'</th>'; }).join('') +
    '<th style="padding:8px 8px;text-align:center;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;width:50px;">Total</th>' +
    '<th style="padding:8px 8px;text-align:left;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;width:80px;">Status</th>' +
    '<th style="padding:8px 8px;text-align:left;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;width:110px;">Actions</th>' +
  '</tr></thead>';

  var tableRows = ts.map(function(t) {
    var dh = getDayHours(t);
    var weekMon = getMondayOfTS(t.weekStart), weekSun = new Date(weekMon);
    weekSun.setDate(weekSun.getDate()+6);
    var weekLabel = weekMon.toLocaleDateString('en-US',{month:'short',day:'numeric'}) + '–' + weekSun.toLocaleDateString('en-US',{month:'short',day:'numeric'});

    var dayCells = dh.map(function(h, di) {
      var proj = getDayProjects(t, di);
      var cs = h>0 ? 'font-weight:700;color:var(--accent);' : 'color:var(--border);';
      return '<td style="padding:6px 3px;text-align:center;font-size:12px;'+cs+'border-bottom:1px solid #edf0f7;" title="'+(proj||'No entries')+'">' +
        (h>0 ? h.toFixed(1)+'<span style="font-size:9px;font-weight:400;">h</span>' : '—') +
      '</td>';
    }).join('');

    return '<tr style="background:var(--bg-card);" onmouseover="this.style.background=\'var(--bg-input)\'" onmouseout="this.style.background=\'var(--bg-card)\'">' +
      '<td style="padding:8px 12px;border-bottom:1px solid #edf0f7;max-width:180px;">' +
        '<div style="display:flex;align-items:center;gap:8px;">' +
          userAvatar(t.user, 26) +
          '<div style="min-width:0;">' +
            '<div style="font-weight:600;font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+(t.user&&t.user.name||'—')+'</div>' +
            '<div style="font-size:10px;color:var(--text-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+weekLabel+'</div>' +
          '</div>' +
        '</div>' +
      '</td>' +
      dayCells +
      '<td style="padding:6px 8px;text-align:center;font-size:13px;font-weight:800;color:var(--text-primary);border-bottom:1px solid #edf0f7;">'+t.totalHours+'h</td>' +
      '<td style="padding:6px 8px;border-bottom:1px solid #edf0f7;">'+statusChip(t.status)+'</td>' +
      '<td style="padding:6px 8px;border-bottom:1px solid #edf0f7;">' +
        '<div style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">' +
          '<button class="btn btn-ghost btn-sm" onclick="openViewTs('+t.id+')" style="padding:3px 6px;" title="View"><i class="bx bx-show"></i></button>' +
          (t.status==='pending' ?
            '<button class="btn btn-success btn-sm" onclick="actTs('+t.id+',\'approve\')" style="padding:3px 6px;" title="Approve"><i class="bx bx-check"></i></button>' +
            '<button class="btn btn-danger btn-sm" onclick="openReject('+t.id+')" style="padding:3px 6px;" title="Reject"><i class="bx bx-x"></i></button>'
          : (t.approver ? '<span style="font-size:10px;color:var(--text-muted);">✓ '+t.approver.name+'</span>' : '')) +
        '</div>' +
        (t.rejectionReason ? '<div style="font-size:10px;color:#ef4444;margin-top:2px;">'+t.rejectionReason.slice(0,30)+'…</div>' : '') +
      '</td>' +
    '</tr>';
  }).join('');

  grid.innerHTML = '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;">' +
    '<table style="width:100%;border-collapse:collapse;table-layout:fixed;">' + thead + '<tbody>' + tableRows + '</tbody></table>' +
  '</div>';
}

/* ── Load ── */
async function reloadPageData() { await loadTs(); }
async function loadTs() {
  try {
    var url = '/timesheets';
    var cid = getSelectedCompanyId(); if (cid) url += '?companyId='+cid;
    allTs = await api('GET', url);
    populateTsYearFilter();

    // Stats bar (always from full allTs)
    var pending  = allTs.filter(function(t){ return t.status==='pending'; }).length;
    var approved = allTs.filter(function(t){ return t.status==='approved'; }).length;
    var rejected = allTs.filter(function(t){ return t.status==='rejected'; }).length;
    var totalH   = allTs.reduce(function(s,t){ return s+(t.totalHours||0); }, 0);
    document.getElementById('ts-stats').innerHTML =
      stat(totalH+'h', 'Total Hours', 'var(--accent)') +
      stat(pending,    'Pending',     '#f59e0b') +
      stat(approved,   'Approved',    '#22c55e') +
      stat(rejected,   'Rejected',    '#ef4444');

    applyFilters();
  } catch(e) { toast(e.message,'error'); }
}

function stat(val, label, color) {
  return '<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:10px 18px;display:flex;align-items:center;gap:10px;">' +
    '<span style="font-size:20px;font-weight:800;color:'+color+';">'+val+'</span>' +
    '<span style="font-size:11px;color:var(--text-muted);">'+label+'</span>' +
  '</div>';
}

/* ── View Details Modal ── */
function openViewTs(id) {
  var t = allTs.find(function(x){ return x.id===id; });
  if (!t) return;

  var weekMon = getMondayOfTS(t.weekStart), weekSun = new Date(weekMon);
  weekSun.setDate(weekSun.getDate()+6);
  var weekLabel = weekMon.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) + ' – ' +
                  weekSun.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
  var sc = t.status==='approved'?'#22c55e':t.status==='rejected'?'#ef4444':'#f59e0b';
  var sb = t.status==='approved'?'#dcfce7':t.status==='rejected'?'#fee2e2':'#fef3c7';

  // Header
  var header = '<div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;padding-bottom:16px;border-bottom:1px solid var(--border);margin-bottom:16px;">' +
    userAvatar(t.user, 44) +
    '<div style="flex:1;">' +
      '<div style="font-weight:800;font-size:16px;color:var(--text-primary);">'+(t.user&&t.user.name||'—')+'</div>' +
      '<div style="font-size:12px;color:var(--text-muted);margin-top:2px;text-transform:capitalize;">'+(t.user&&t.user.role||'')+(t.user&&t.user.department?' · '+t.user.department:'')+'</div>' +
      '<div style="font-size:12px;color:var(--text-muted);margin-top:2px;"><i class="bx bx-calendar"></i> '+weekLabel+'</div>' +
    '</div>' +
    '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;">' +
      '<span style="font-size:11px;font-weight:700;background:'+sb+';color:'+sc+';border-radius:20px;padding:3px 12px;text-transform:capitalize;">'+t.status+'</span>' +
      '<span style="font-size:15px;font-weight:800;color:var(--accent);">'+t.totalHours+'h total</span>' +
      (t.approver ? '<span style="font-size:11px;color:var(--text-muted);"><i class="bx bx-check-circle" style="color:#22c55e;"></i> '+t.approver.name+'</span>' : '') +
    '</div>' +
  '</div>';

  // Per-day entries table
  var entries = [...(t.entries||[])].sort(function(a,b){ return a.date>b.date?1:-1; });
  var entryRows = entries.length ? entries.map(function(e) {
    var d = new Date(e.date+'T00:00:00');
    var di = d.getDay()-1; if (di<0) di=6;
    return '<tr style="border-bottom:1px solid #edf0f7;">' +
      '<td style="padding:9px 12px;white-space:nowrap;">' +
        '<span style="font-weight:600;font-size:13px;color:var(--text-primary);">'+DN[di]+'</span>' +
        '<span style="font-size:11px;color:var(--text-muted);margin-left:6px;">'+d.toLocaleDateString('en-US',{day:'2-digit',month:'short'})+'</span>' +
      '</td>' +
      '<td style="padding:9px 12px;font-size:12px;color:var(--accent);font-weight:700;">'+(e.project||'—')+'</td>' +
      '<td style="padding:9px 12px;font-size:11px;"><span style="background:var(--bg-input);border-radius:6px;padding:2px 8px;text-transform:capitalize;color:var(--text-secondary);">'+(e.billingType||'—')+'</span></td>' +
      '<td style="padding:9px 12px;font-size:12px;color:var(--text-secondary);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+(e.description||'—')+'</td>' +
      '<td style="padding:9px 12px;text-align:center;font-weight:800;font-size:14px;color:var(--text-primary);">'+Number(e.hours||0).toFixed(1)+'<span style="font-size:11px;font-weight:400;">h</span></td>' +
    '</tr>';
  }).join('') : '<tr><td colspan="5" style="padding:24px;text-align:center;color:var(--text-muted);">No entries</td></tr>';

  var table = '<div style="overflow:auto;border:1px solid var(--border);border-radius:12px;margin-bottom:14px;">' +
    '<table style="width:100%;border-collapse:collapse;min-width:560px;">' +
    '<thead><tr style="background:#f0f4ff;">' +
      '<th style="padding:9px 12px;text-align:left;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;">Day</th>' +
      '<th style="padding:9px 12px;text-align:left;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;">Project</th>' +
      '<th style="padding:9px 12px;text-align:left;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;">Billing</th>' +
      '<th style="padding:9px 12px;text-align:left;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;">Description</th>' +
      '<th style="padding:9px 12px;text-align:center;font-size:11px;font-weight:700;color:#5871a4;border-bottom:2px solid #dde6fb;">Hours</th>' +
    '</tr></thead>' +
    '<tbody>'+entryRows+'</tbody>' +
    '</table></div>';

  var notesHtml = t.notes ? '<div style="background:var(--bg-input);border-radius:10px;padding:10px 14px;font-size:12px;color:var(--text-secondary);margin-bottom:10px;"><strong>Notes:</strong> '+t.notes+'</div>' : '';
  var rejHtml   = t.rejectionReason ? '<div style="background:#fee2e2;border:1px solid #fecaca;border-radius:10px;padding:10px 14px;font-size:12px;color:#991b1b;"><i class="bx bx-x-circle"></i> <strong>Rejection reason:</strong> '+t.rejectionReason+'</div>' : '';

  document.getElementById('view-modal-title').textContent = (t.user&&t.user.name||'Employee') + "'s Timesheet";
  document.getElementById('view-modal-body').innerHTML = header + table + notesHtml + rejHtml;

  var footerHtml = '<button class="btn btn-ghost" onclick="closeModal(\'view-modal\')">Close</button>';
  if (t.status==='pending') {
    footerHtml = '<button class="btn btn-ghost" onclick="closeModal(\'view-modal\')">Close</button>' +
      '<div style="display:flex;gap:8px;">' +
        '<button class="btn btn-success" onclick="actTs('+t.id+',\'approve\');closeModal(\'view-modal\')"><i class="bx bx-check"></i> Approve</button>' +
        '<button class="btn btn-danger" onclick="closeModal(\'view-modal\');openReject('+t.id+')"><i class="bx bx-x"></i> Reject</button>' +
      '</div>';
  }
  document.getElementById('view-modal-footer').innerHTML = footerHtml;
  openModal('view-modal');
}

/* ── Actions ── */
async function actTs(id, action) {
  try { await api('PATCH','/timesheets/'+id+'/action',{action}); toast('Timesheet '+action+'d','success'); loadTs(); }
  catch(e){ toast(e.message,'error'); }
}
function openReject(id) { rejectId=id; document.getElementById('reject-reason').value=''; openModal('reject-modal'); }
async function confirmReject() {
  try {
    await api('PATCH','/timesheets/'+rejectId+'/action',{action:'reject',rejectionReason:document.getElementById('reject-reason').value});
    toast('Rejected','success'); closeModal('reject-modal'); loadTs();
  } catch(e){ toast(e.message,'error'); }
}

/* ── Excel Export (exports current filtered view) ── */
function exportFiltered() {
  var data = filteredTs;
  if (!data.length) return toast('No timesheets to export', 'error');

  var fMonth = document.getElementById('filter-month').value;
  var fYear  = document.getElementById('filter-year').value;
  var fStatus= document.getElementById('filter-status').value;
  var label  = 'timesheets';
  if (fYear)   label += '_' + fYear;
  if (fMonth !== '') label += '_' + MO_FULL_TS[Number(fMonth)];
  if (fStatus) label += '_' + fStatus;
  label += '_' + new Date().toISOString().slice(0,10);

  function csvCell(v) { var s = String(v||''); return s.includes(',') || s.includes('"') || s.includes('\n') ? '"' + s.replace(/"/g,'""') + '"' : s; }
  var rows = [['Employee','Email','Role','Department','Week Start','Week End','Mon','Tue','Wed','Thu','Fri','Sat','Sun','Total Hours','Status','Approver','Projects','Notes','Submitted On']];
  data.forEach(function(t) {
    var dh = getDayHours(t);
    var projects = [...new Set((t.entries||[]).map(function(e){ return e.project||''; }).filter(Boolean))].join(', ');
    rows.push([
      (t.user&&t.user.name)||'',
      (t.user&&t.user.email)||'',
      (t.user&&t.user.role)||'',
      (t.user&&t.user.department)||'',
      t.weekStart||'', t.weekEnd||'',
      dh[0],dh[1],dh[2],dh[3],dh[4],dh[5],dh[6],
      t.totalHours||0,
      t.status||'',
      t.approver?t.approver.name:'',
      projects,
      (t.notes||'').replace(/\n/g,' '),
      t.createdAt?fmtShortD(t.createdAt):''
    ]);
  });

  var csv = '\uFEFF' + rows.map(function(r){ return r.map(csvCell).join(','); }).join('\r\n');
  var blob = new Blob([csv], {type:'text/csv;charset=utf-8'});
  var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = label + '.csv';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  toast('Exported ' + data.length + ' timesheet(s)', 'success');
}

initCompanyFilter().then(reloadPageData);
</script>
</body></html>
