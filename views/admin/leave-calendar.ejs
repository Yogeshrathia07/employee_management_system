<%- include('../partials/head', {title: 'Leave Calendar'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-admin') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title">Company Leave Calendar</div>
          <div class="page-subtitle">Visual overview of all company leaves</div>
        </div>
      </div>
      <div class="header-actions">
      </div>
    </header>
    <div class="page-body">

      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px;">
        <!-- Legend -->
        <div style="display:flex;gap:14px;flex-wrap:wrap;align-items:center;">
          <div style="display:flex;align-items:center;gap:6px;font-size:13px;"><span style="width:10px;height:10px;border-radius:50%;background:#f59e0b;display:inline-block;"></span> Pending</div>
          <div style="display:flex;align-items:center;gap:6px;font-size:13px;"><span style="width:10px;height:10px;border-radius:50%;background:#22c55e;display:inline-block;"></span> Approved</div>
          <div style="display:flex;align-items:center;gap:6px;font-size:13px;"><span style="width:10px;height:10px;border-radius:50%;background:#ef4444;display:inline-block;"></span> Rejected</div>
          <div style="display:flex;align-items:center;gap:6px;font-size:13px;"><span style="width:10px;height:10px;border-radius:50%;background:#8b5cf6;display:inline-block;"></span> Holiday</div>
        </div>
        <div style="display:flex;gap:8px;">
          <a href="/admin/leaves" class="btn btn-primary btn-sm"><i class="bx bx-list-ul"></i> Manage Leaves</a>
          <button class="btn btn-primary btn-sm" onclick="openAddLeaveModal(null)"><i class="bx bx-plus"></i> Add Holiday / Leave</button>
        </div>
      </div>

      <div style="font-size:12px;color:var(--text-muted);margin-bottom:10px;"><i class="bx bx-info-circle"></i> Click on any date to add a holiday. Click the status boxes to view full details.</div>

      <div class="card" style="padding:0;overflow:hidden;">
        <div id="leave-calendar" style="padding:16px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- ── Day Detail Popup ─────────────────────────────────────────── -->
<div id="day-popup" style="display:none;position:fixed;z-index:9999;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);backdrop-filter:blur(3px);align-items:center;justify-content:center;">
  <div style="background:var(--bg-card);border-radius:var(--radius);box-shadow:var(--shadow-lg);width:100%;max-width:520px;margin:16px;overflow:hidden;max-height:85vh;display:flex;flex-direction:column;">
    <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
      <div>
        <div style="font-weight:700;font-size:16px;color:var(--text-primary);" id="day-popup-title">Leaves</div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:2px;" id="day-popup-sub"></div>
      </div>
      <button onclick="closeDayPopup()" style="width:32px;height:32px;border-radius:50%;border:1px solid var(--border);background:#fff;cursor:pointer;font-size:20px;color:var(--text-muted);display:flex;align-items:center;justify-content:center;flex-shrink:0;">×</button>
    </div>
    <div id="day-popup-body" style="padding:16px 20px;overflow-y:auto;"></div>
    <div style="padding:12px 20px;border-top:1px solid var(--border);flex-shrink:0;display:flex;justify-content:flex-end;gap:8px;" id="day-popup-footer"></div>
  </div>
</div>

<!-- ── Add Holiday / Leave Modal ───────────────────────────────── -->
<div class="modal-overlay" id="add-leave-modal">
  <div class="modal" style="max-width:460px;">
    <div class="modal-header">
      <span class="modal-title"><i class="bx bxs-calendar-plus" style="color:var(--accent);margin-right:6px;"></i> Add Holiday / Company Leave</span>
      <button class="modal-close" onclick="closeModal('add-leave-modal')">×</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Holiday / Leave Title <span style="color:var(--danger);">*</span></label>
        <input type="text" id="al-title" class="form-control" placeholder="e.g. Diwali, Republic Day, Team Outing…">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Start Date <span style="color:var(--danger);">*</span></label>
          <input type="date" id="al-start" class="form-control">
        </div>
        <div class="form-group">
          <label class="form-label">End Date <span style="color:var(--danger);">*</span></label>
          <input type="date" id="al-end" class="form-control">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Type</label>
        <select id="al-type" class="form-control">
          <option value="holiday">Public Holiday</option>
          <option value="festival">Festival</option>
          <option value="company_event">Company Event</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Note <span style="color:var(--text-muted);font-weight:400;">(optional)</span></label>
        <textarea id="al-note" class="form-control" rows="2" placeholder="Additional details…"></textarea>
      </div>
      <div style="background:var(--accent-light);border-radius:var(--radius-sm);padding:10px 14px;font-size:12px;color:var(--accent);display:flex;gap:8px;align-items:flex-start;">
        <i class="bx bx-info-circle" style="font-size:15px;flex-shrink:0;margin-top:1px;"></i>
        <span>This will be added as an approved company leave visible to all users on the calendar.</span>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('add-leave-modal')">Cancel</button>
      <button class="btn btn-primary" id="al-submit-btn" onclick="submitAddLeave()"><i class="bx bxs-calendar-plus"></i> Add to Calendar</button>
    </div>
  </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
<script src="/js/api.js"></script>
<script src="/js/sidebar-fix.js"></script>

<style>
/* ── Status boxes inside calendar cells ── */
.day-status-wrap {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 2px 3px 4px;
  cursor: pointer;
}
.day-status-pill {
  display: flex;
  align-items: center;
  gap: 4px;
  border-radius: 4px;
  padding: 2px 6px;
  font-size: 10px;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.15s;
  white-space: nowrap;
  width: fit-content;
}
.day-status-pill:hover { opacity: 0.8; }
.day-status-pill.pending  { background:#fef3c7; color:#92400e; }
.day-status-pill.approved { background:#dcfce7; color:#166534; }
.day-status-pill.rejected { background:#fee2e2; color:#991b1b; }
.day-status-pill.holiday  { background:#ede9fe; color:#5b21b6; }
.day-status-pill .dot {
  width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
}
.day-status-pill.pending  .dot { background: #f59e0b; }
.day-status-pill.approved .dot { background: #22c55e; }
.day-status-pill.rejected .dot { background: #ef4444; }
.day-status-pill.holiday  .dot { background: #8b5cf6; }

/* Detail card in popup */
.leave-detail-card {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 14px;
  margin-bottom: 10px;
  background: var(--bg-card);
  transition: box-shadow 0.15s;
}
.leave-detail-card:hover { box-shadow: var(--shadow); }
.leave-detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 12px;
}
.leave-detail-box {
  background: var(--bg-input);
  border-radius: 8px;
  padding: 9px 11px;
}
.leave-detail-box .lbl { font-size: 10px; color: var(--text-muted); }
.leave-detail-box .val { font-size: 13px; font-weight: 700; margin-top: 2px; }
</style>

<script>
let allLeaves = [];
let calInstance = null;

/* ── Helpers ── */
function localDateStr(date) {
  return date.getFullYear() + '-' +
    String(date.getMonth()+1).padStart(2,'0') + '-' +
    String(date.getDate()).padStart(2,'0');
}
function leaveIncludes(l, dateStr) {
  // Slice to YYYY-MM-DD regardless of whether value has time/timezone suffix
  return dateStr >= l.startDate.slice(0, 10) && dateStr <= l.endDate.slice(0, 10);
}
function statusColor(s){ return s==='approved'?'#22c55e':s==='rejected'?'#ef4444':s==='holiday'?'#8b5cf6':'#f59e0b'; }
function statusBg(s)   { return s==='approved'?'#dcfce7':s==='rejected'?'#fee2e2':s==='holiday'?'#ede9fe':'#fef3c7'; }
function isHolidayType(l){ return ['holiday','festival','company_event'].includes(l.type); }

/* ── Popups ── */
function closeDayPopup() { document.getElementById('day-popup').style.display='none'; }
document.getElementById('day-popup').addEventListener('click', function(e){ if(e.target===this) closeDayPopup(); });

function showDayLeaves(dateStr, leaves) {
  const label = new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
  document.getElementById('day-popup-title').textContent = label;
  document.getElementById('day-popup-sub').textContent   = leaves.length + ' leave record' + (leaves.length!==1?'s':'') + ' on this date';

  const pending  = leaves.filter(l=>l.status==='pending');
  const approved = leaves.filter(l=>l.status==='approved');
  const rejected = leaves.filter(l=>l.status==='rejected');

  function group(title, dotColor, items) {
    if (!items.length) return '';
    return `<div style="margin-bottom:14px;">
      <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;display:flex;align-items:center;gap:6px;">
        <span style="width:8px;height:8px;border-radius:50%;background:${dotColor};display:inline-block;"></span>${title} (${items.length})
      </div>
      ${items.map(l => leaveCard(l)).join('')}
    </div>`;
  }

  document.getElementById('day-popup-body').innerHTML =
    group('Pending',  '#f59e0b', pending) +
    group('Approved', '#22c55e', approved) +
    group('Rejected', '#ef4444', rejected);

  document.getElementById('day-popup-footer').innerHTML =
    `<a href="/admin/leaves" class="btn btn-ghost btn-sm"><i class="bx bx-list-ul"></i> Manage Leaves</a>
     <button class="btn btn-primary btn-sm" onclick="closeDayPopup();openAddLeaveModal('${dateStr}')"><i class="bx bx-plus"></i> Add Holiday</button>`;

  document.getElementById('day-popup').style.display = 'flex';
}

function leaveCard(l) {
  const sc = statusColor(l.status);
  const sb = statusBg(l.status);
  const isHoliday = isHolidayType(l);
  const name = isHoliday ? (l.reason || l.type) : (l.user?.name || '—');
  const initials = name.split(' ').map(x=>x[0]).join('').substring(0,2).toUpperCase();
  const avatarBg = isHoliday ? 'linear-gradient(135deg,#8b5cf6,#6d28d9)' : 'linear-gradient(135deg,var(--accent),#7c3aed)';

  return `<div class="leave-detail-card">
    <div style="display:flex;align-items:center;gap:12px;">
      <div style="width:40px;height:40px;border-radius:50%;background:${avatarBg};display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:white;flex-shrink:0;">
        ${isHoliday ? '<i class="bx bxs-calendar-star" style="font-size:17px;"></i>' : initials}
      </div>
      <div style="flex:1;min-width:0;">
        <div style="font-weight:700;font-size:14px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${name}</div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:capitalize;margin-top:2px;">${l.type.replace(/_/g,' ')}${!isHoliday?' · '+l.days+' day'+(l.days!==1?'s':''):''}</div>
      </div>
      <span style="font-size:11px;font-weight:700;background:${sb};color:${sc};border-radius:20px;padding:3px 10px;flex-shrink:0;text-transform:capitalize;">${l.status}</span>
    </div>
    <div class="leave-detail-grid">
      <div class="leave-detail-box"><div class="lbl">From</div><div class="val">${l.startDate.split('T')[0]}</div></div>
      <div class="leave-detail-box"><div class="lbl">To</div><div class="val">${l.endDate.split('T')[0]}</div></div>
      ${!isHoliday ? `<div class="leave-detail-box"><div class="lbl">Employee</div><div class="val">${l.user?.name||'—'}</div></div>
      <div class="leave-detail-box"><div class="lbl">Days</div><div class="val">${l.days}</div></div>` : ''}
      ${l.reason ? `<div class="leave-detail-box" style="grid-column:1/-1;"><div class="lbl">${isHoliday?'Title / Note':'Reason'}</div><div class="val" style="font-weight:500;font-size:12px;">${l.reason}</div></div>` : ''}
    </div>
  </div>`;
}

/* ── Add Holiday Modal ── */
function openAddLeaveModal(dateStr) {
  document.getElementById('al-title').value = '';
  document.getElementById('al-type').value  = 'holiday';
  document.getElementById('al-note').value  = '';
  const today = dateStr || localDateStr(new Date());
  document.getElementById('al-start').value = today;
  document.getElementById('al-end').value   = today;
  openModal('add-leave-modal');
}

async function submitAddLeave() {
  const title = document.getElementById('al-title').value.trim();
  const start = document.getElementById('al-start').value;
  const end   = document.getElementById('al-end').value;
  const type  = document.getElementById('al-type').value;
  const note  = document.getElementById('al-note').value.trim();

  if (!title) return toast('Enter a holiday title', 'error');
  if (!start || !end) return toast('Select start and end dates', 'error');
  if (end < start) return toast('End date must be on or after start date', 'error');

  // Calculate days
  const ms   = new Date(end) - new Date(start);
  const days = Math.round(ms / 86400000) + 1;

  const btn = document.getElementById('al-submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner" style="width:14px;height:14px;"></span> Adding…';

  try {
    const leave = await api('POST', '/leaves', {
      type, startDate: start, endDate: end, days,
      reason: title + (note ? ' — ' + note : '')
    });
    // Auto-approve company holidays
    await api('PATCH', '/leaves/' + leave.id + '/action', { action: 'approve' });
    toast('Holiday added to calendar!', 'success');
    closeModal('add-leave-modal');
    await reloadCalendar();
  } catch(e) {
    toast(e.message || 'Failed to add leave', 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bx bxs-calendar-plus"></i> Add to Calendar';
  }
}

/* ── Calendar ── */
async function reloadCalendar() {
  try { allLeaves = await api('GET', '/leaves'); } catch(e) {}
  if (calInstance) { calInstance.destroy(); calInstance = null; }
  initCalendar();
}

function injectDayBadges(info) {
  // Use FullCalendar's dateStr directly (always YYYY-MM-DD, no timezone shift)
  const dateStr  = info.dateStr || localDateStr(info.date);
  const day      = allLeaves.filter(l => leaveIncludes(l, dateStr));
  if (!day.length) return;

  const holidays = day.filter(l => isHolidayType(l));
  const pending  = day.filter(l => l.status==='pending' && !isHolidayType(l));
  const approved = day.filter(l => l.status==='approved' && !isHolidayType(l));
  const rejected = day.filter(l => l.status==='rejected' && !isHolidayType(l));

  const wrap = document.createElement('div');
  wrap.className = 'day-status-wrap';
  wrap.onclick = function(e) { e.stopPropagation(); showDayLeaves(dateStr, day); };

  if (holidays.length)  wrap.innerHTML += `<div class="day-status-pill holiday"><span class="dot"></span>${holidays.length} holiday${holidays.length!==1?'s':''}</div>`;
  if (pending.length)   wrap.innerHTML += `<div class="day-status-pill pending"><span class="dot"></span>${pending.length} pending</div>`;
  if (approved.length)  wrap.innerHTML += `<div class="day-status-pill approved"><span class="dot"></span>${approved.length} approved</div>`;
  if (rejected.length)  wrap.innerHTML += `<div class="day-status-pill rejected"><span class="dot"></span>${rejected.length} rejected</div>`;

  const frame = info.el.querySelector('.fc-daygrid-day-events') || info.el.querySelector('.fc-daygrid-day-frame') || info.el;
  frame.appendChild(wrap);
}

function initCalendar() {
  const el = document.getElementById('leave-calendar');
  el.innerHTML = '';
  calInstance = new FullCalendar.Calendar(el, {
    initialView: 'dayGridMonth',
    headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,dayGridWeek,listMonth' },
    events: [],          // no event bars — we use dayCellDidMount instead
    eventDisplay: 'none',
    dayCellDidMount: injectDayBadges,
    dateClick: function(info) {
      // Ignore clicks that originated from a status pill or its wrapper
      if (info.jsEvent.target.closest('.day-status-wrap, .day-status-pill')) return;
      openAddLeaveModal(info.dateStr);
    },
    height: 'auto',
  });
  calInstance.render();

  // Calendar styles
  const s = document.createElement('style');
  s.textContent = `
    .fc{color:var(--text-primary);}
    .fc-theme-standard td,.fc-theme-standard th{border-color:var(--border);}
    .fc-col-header-cell,.fc-daygrid-day{background:var(--bg-card);}
    .fc-today-button,.fc-button{background:var(--accent)!important;border-color:var(--accent)!important;}
    .fc-day-today{background:rgba(91,106,191,.1)!important;}
    .fc-toolbar-title{color:var(--text-primary);font-weight:700;}
    .fc-daygrid-day:hover{background:rgba(91,106,191,.04)!important;cursor:pointer;}
    .fc-daygrid-day-frame{min-height:90px;}
    .fc-daygrid-day-number{font-weight:600;color:var(--text-secondary);}
    .fc-day-today .fc-daygrid-day-number{color:var(--accent);font-weight:800;}
  `;
  document.head.appendChild(s);
}

/* ── Init ── */
document.addEventListener('DOMContentLoaded', async () => {
  try { allLeaves = await api('GET', '/leaves'); } catch(e) {}
  initCalendar();
});
</script>
</body></html>
