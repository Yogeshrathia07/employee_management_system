<%- include('../partials/head', {title: 'Assign Tasks'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-admin') %>
  <div class="main-content">
    <header class="page-header">
      <div class="flex items-center gap-3">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
        <div>
          <div class="page-title"><i class="bx bx-task"></i> Tasks — Assign to Managers</div>
          <div class="page-subtitle">Create and assign tasks to managers</div>
        </div>
      </div>
      <div class="header-actions">
        <button class="btn btn-primary" onclick="openCreate()"><i class="bx bx-plus"></i> New Task</button>
      </div>
    </header>

    <div class="page-body admin-employees-page employee-shared-page">
      <div class="employee-directory-shell">

        <!-- Toolbar -->
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:18px;">
          <span id="company-filter-container"></span>
          <select id="filter-manager" class="form-control" style="width:180px;" onchange="renderTasks()">
            <option value="">All Managers</option>
          </select>
          <div class="toggle-group mb-0">
            <button class="toggle-btn active" onclick="setStatusFilter('',this)">All</button>
            <button class="toggle-btn" onclick="setStatusFilter('todo',this)">To Do</button>
            <button class="toggle-btn" onclick="setStatusFilter('in_progress',this)">In Progress</button>
            <button class="toggle-btn" onclick="setStatusFilter('done',this)">Done</button>
          </div>
          <span id="task-count" style="font-size:13px;color:var(--text-muted);"></span>
        </div>

        <!-- Table -->
        <div class="card">
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Task / Project</th>
                  <th>Assigned Manager</th>
                  <th>Priority</th>
                  <th>Due Date</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="tasks-tbody">
                <tr><td colspan="6" style="text-align:center;padding:60px;"><span class="spinner"></span></td></tr>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Create / Edit Task Modal -->
<div class="modal-overlay" id="task-modal">
  <div class="modal" style="max-width:540px;">
    <div class="modal-header">
      <span class="modal-title" id="task-modal-title">New Task</span>
      <button class="modal-close" onclick="closeModal('task-modal')">×</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="task-id">
      <div class="form-group">
        <label class="form-label">Assign to Manager <span style="color:var(--danger)">*</span></label>
        <select id="task-assignee" class="form-control">
          <option value="">— Select Manager —</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Project Name</label>
        <input type="text" id="task-project" class="form-control" placeholder="e.g. Website Redesign">
      </div>
      <div class="form-group">
        <label class="form-label">Task Title <span style="color:var(--danger)">*</span></label>
        <input type="text" id="task-title" class="form-control" placeholder="e.g. Complete API integration">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="form-group">
          <label class="form-label">Priority</label>
          <select id="task-priority" class="form-control">
            <option value="low">Low</option>
            <option value="medium" selected>Medium</option>
            <option value="high">High</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Due Date</label>
          <input type="date" id="task-due" class="form-control">
        </div>
      </div>
      <div class="form-group mb-0">
        <label class="form-label">Description</label>
        <textarea id="task-desc" class="form-control" rows="3" placeholder="Task details..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('task-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveTask()"><i class="bx bx-check"></i> Save</button>
    </div>
  </div>
</div>

<!-- View Task Modal -->
<div class="modal-overlay" id="view-modal">
  <div class="modal" style="max-width:520px;">
    <div class="modal-header">
      <span class="modal-title">Task Details</span>
      <button class="modal-close" onclick="closeModal('view-modal')">×</button>
    </div>
    <div class="modal-body" id="view-modal-body"></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('view-modal')">Close</button></div>
  </div>
</div>

<!-- Delete Confirm -->
<div class="modal-overlay" id="del-modal">
  <div class="modal" style="max-width:400px;">
    <div class="modal-header"><span class="modal-title">Delete Task</span><button class="modal-close" onclick="closeModal('del-modal')">×</button></div>
    <div class="modal-body"><p style="font-size:14px;color:var(--text-secondary);">Are you sure you want to delete this task? This cannot be undone.</p></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('del-modal')">Cancel</button>
      <button class="btn btn-danger" onclick="confirmDelete()"><i class="bx bx-trash"></i> Delete</button>
    </div>
  </div>
</div>

<script src="/js/api.js"></script>
<script src="/js/sidebar-fix.js"></script>
<script src="/js/admin-company-filter.js"></script>
<script>
var allTasks = [], allManagers = [], deleteId = null, activeStatus = '';

var PRIORITY_COLOR = { high:'#ef4444', medium:'#f59e0b', low:'#22c55e' };
var PRIORITY_BG    = { high:'#fee2e2', medium:'#fef3c7', low:'#dcfce7' };
var STATUS_LABEL   = { todo:'To Do', in_progress:'In Progress', done:'Done' };
var STATUS_COLOR   = { todo:'#6366f1', in_progress:'#f59e0b', done:'#22c55e' };
var STATUS_BG      = { todo:'rgba(99,102,241,0.1)', in_progress:'#fef3c7', done:'#dcfce7' };

function escH(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function setStatusFilter(f, btn) {
  activeStatus = f;
  document.querySelectorAll('.toggle-group .toggle-btn').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  renderTasks();
}

function renderTasks() {
  var managerF = document.getElementById('filter-manager').value;
  var data = allTasks.filter(function(t) {
    if (activeStatus && t.status !== activeStatus) return false;
    if (managerF && String(t.assignedTo) !== String(managerF)) return false;
    return true;
  });

  var countEl = document.getElementById('task-count');
  if (countEl) countEl.textContent = data.length + ' task' + (data.length !== 1 ? 's' : '');

  var tbody = document.getElementById('tasks-tbody');
  if (!data.length) {
    tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><div class="empty-icon"><i class="bx bx-task"></i></div><h3>No tasks found</h3><p>Assign a task using the button above</p></div></td></tr>';
    return;
  }

  tbody.innerHTML = data.map(function(t) {
    var mgr  = t.assignee;
    var pc   = PRIORITY_COLOR[t.priority]||'#64748b';
    var pb   = PRIORITY_BG[t.priority]||'#f1f5f9';
    var sc   = STATUS_COLOR[t.status]||'#64748b';
    var sb   = STATUS_BG[t.status]||'#f1f5f9';
    var sl   = STATUS_LABEL[t.status]||t.status;
    var due  = t.dueDate ? new Date(t.dueDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '—';
    var overdue = t.dueDate && t.status !== 'done' && new Date(t.dueDate) < new Date();
    return '<tr>' +
      '<td>' +
        '<div style="font-weight:700;font-size:13px;color:var(--text-primary);">' + escH(t.title) + '</div>' +
        (t.projectName ? '<div style="font-size:11px;color:var(--accent);margin-top:2px;"><i class="bx bxs-briefcase" style="font-size:10px;"></i> ' + escH(t.projectName) + '</div>' : '') +
      '</td>' +
      '<td>' +
        '<div style="font-weight:600;font-size:13px;">' + (mgr ? escH(mgr.name) : '—') + '</div>' +
        (mgr && mgr.department ? '<div style="font-size:11px;color:var(--text-muted);">' + escH(mgr.department) + '</div>' : '') +
      '</td>' +
      '<td><span style="font-size:12px;font-weight:700;background:'+pb+';color:'+pc+';border-radius:12px;padding:3px 10px;text-transform:capitalize;">' + (t.priority||'medium') + '</span></td>' +
      '<td style="font-size:12px;' + (overdue?'color:#ef4444;font-weight:700;':'color:var(--text-muted);') + '">' + due + (overdue?' ⚠':'') + '</td>' +
      '<td><span style="font-size:12px;font-weight:700;background:'+sb+';color:'+sc+';border-radius:12px;padding:3px 10px;">' + sl + '</span></td>' +
      '<td>' +
        '<div style="display:flex;gap:5px;">' +
          '<button class="btn btn-ghost btn-sm" onclick="viewTask('+t.id+')" title="View"><i class="bx bx-show"></i></button>' +
          '<button class="btn btn-ghost btn-sm" onclick="openEdit('+t.id+')" title="Edit"><i class="bx bx-edit"></i></button>' +
          '<button class="btn btn-danger btn-sm" onclick="openDelete('+t.id+')" title="Delete"><i class="bx bx-trash"></i></button>' +
        '</div>' +
      '</td>' +
    '</tr>';
  }).join('');
}

/* ── Load managers for filter + modal ── */
async function loadManagers() {
  try {
    var url = '/users?role=manager';
    var cid = getSelectedCompanyId();
    if (cid) url += '&companyId=' + cid;
    var users = await api('GET', url);
    allManagers = (users||[]).filter(function(u){ return u.role === 'manager'; });

    var filterSel  = document.getElementById('filter-manager');
    var assignSel  = document.getElementById('task-assignee');
    var opts = '<option value="">— Select Manager —</option>' +
      allManagers.map(function(m){
        return '<option value="'+m.id+'">'+escH(m.name)+(m.department?' ('+escH(m.department)+')':'')+'</option>';
      }).join('');
    filterSel.innerHTML = '<option value="">All Managers</option>' +
      allManagers.map(function(m){
        return '<option value="'+m.id+'">'+escH(m.name)+'</option>';
      }).join('');
    assignSel.innerHTML = opts;
  } catch(e) {}
}

/* ── Load tasks ── */
async function reloadPageData() {
  try {
    var url = '/tasks';
    var cid = getSelectedCompanyId();
    if (cid) url += '?companyId=' + cid;
    // fetch tasks assigned TO managers only
    allTasks = (await api('GET', url))||[];
    // filter: only show tasks where assignee is a manager role
    var mgrIds = allManagers.map(function(m){ return m.id; });
    allTasks = allTasks.filter(function(t){ return mgrIds.indexOf(t.assignedTo) !== -1; });
    renderTasks();
  } catch(e) { toast(e.message, 'error'); }
}

/* ── Create ── */
function openCreate() {
  document.getElementById('task-id').value      = '';
  document.getElementById('task-modal-title').textContent = 'Assign New Task to Manager';
  document.getElementById('task-assignee').value = '';
  document.getElementById('task-project').value  = '';
  document.getElementById('task-title').value    = '';
  document.getElementById('task-priority').value = 'medium';
  document.getElementById('task-due').value      = '';
  document.getElementById('task-desc').value     = '';
  openModal('task-modal');
}

/* ── Edit ── */
function openEdit(id) {
  var t = allTasks.find(function(x){ return x.id === id; });
  if (!t) return;
  document.getElementById('task-id').value       = t.id;
  document.getElementById('task-modal-title').textContent = 'Edit Task';
  document.getElementById('task-assignee').value = t.assignedTo;
  document.getElementById('task-project').value  = t.projectName || '';
  document.getElementById('task-title').value    = t.title;
  document.getElementById('task-priority').value = t.priority;
  document.getElementById('task-due').value      = t.dueDate || '';
  document.getElementById('task-desc').value     = t.description || '';
  openModal('task-modal');
}

/* ── Save ── */
async function saveTask() {
  var id       = document.getElementById('task-id').value;
  var assignee = document.getElementById('task-assignee').value;
  var title    = document.getElementById('task-title').value.trim();
  if (!title)   return toast('Task title is required', 'error');
  if (!assignee) return toast('Please select a manager', 'error');
  var body = {
    title,
    projectName: document.getElementById('task-project').value.trim(),
    description: document.getElementById('task-desc').value,
    assignedTo:  Number(assignee),
    priority:    document.getElementById('task-priority').value,
    dueDate:     document.getElementById('task-due').value || null,
  };
  try {
    if (id) { await api('PUT', '/tasks/' + id, body); toast('Task updated', 'success'); }
    else    { await api('POST', '/tasks', body);       toast('Task assigned to manager', 'success'); }
    closeModal('task-modal');
    await reloadPageData();
  } catch(e) { toast(e.message, 'error'); }
}

/* ── View ── */
function viewTask(id) {
  var t = allTasks.find(function(x){ return x.id === id; });
  if (!t) return;
  var mgr = t.assignee;
  var due = t.dueDate ? new Date(t.dueDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '—';
  var sc  = STATUS_COLOR[t.status]||'#64748b';
  var sb  = STATUS_BG[t.status]||'#f1f5f9';
  document.getElementById('view-modal-body').innerHTML =
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Manager</div><div class="detail-value">'+(mgr?escH(mgr.name):'—')+'</div></div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Project</div><div class="detail-value">'+(t.projectName?escH(t.projectName):'—')+'</div></div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Priority</div><div class="detail-value" style="text-transform:capitalize;">'+(t.priority||'medium')+'</div></div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Due Date</div><div class="detail-value">'+due+'</div></div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Status</div><div class="detail-value"><span style="font-size:12px;font-weight:700;background:'+sb+';color:'+sc+';border-radius:10px;padding:2px 9px;">'+(STATUS_LABEL[t.status]||t.status)+'</span></div></div>' +
      '<div style="background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Assigned By</div><div class="detail-value">'+(t.assigner?escH(t.assigner.name):'—')+'</div></div>' +
    '</div>' +
    '<div style="margin-top:12px;background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Task Title</div><div class="detail-value" style="font-size:15px;font-weight:700;">'+escH(t.title)+'</div></div>' +
    (t.description ? '<div style="margin-top:12px;background:var(--bg-input);border-radius:12px;padding:12px;"><div class="detail-label">Description</div><div class="detail-value">'+escH(t.description)+'</div></div>' : '');
  openModal('view-modal');
}

/* ── Delete ── */
function openDelete(id) { deleteId = id; openModal('del-modal'); }
async function confirmDelete() {
  try {
    await api('DELETE', '/tasks/' + deleteId);
    toast('Task deleted', 'success');
    closeModal('del-modal');
    await reloadPageData();
  } catch(e) { toast(e.message, 'error'); }
}

initCompanyFilter().then(async function() {
  await loadManagers();
  await reloadPageData();
});
</script>
</body></html>
